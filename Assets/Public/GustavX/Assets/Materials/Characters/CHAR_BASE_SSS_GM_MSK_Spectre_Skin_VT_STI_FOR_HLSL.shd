void CalculateMatEmissiveColor(in float2 in_0,
	out float3 out_0)
{
	// Texture2DNode {
	float4 Local0 = Texture2DParameter_MSKglowmap.Sample(_DefaultWrapSampler, in_0);
	// [Local0] Get needed components
	float Local1 = Local0.x;
	float Local2 = Local0.y;
	float Local3 = Local0.z;
	// } Texture2DNode
	float Local4 = (Local2 * FloatParameter_GlowColorBlend2);
	float Local5 = (Local1 - Local4);
	float Local6 = (FloatParameter_GlowColorBlend3 * Local3);
	float Local7 = (Local5 - Local6);
	float Local8 = clamp(Local7, 0.0f, 1.0f);
	float Local9 = (Local8 * FloatParameter_GlowMultiplier1);
	float3 Local10 = (Vector3Parameter_GlowColor1 * Local9);
	float Local11 = (Local2 - Local6);
	float Local12 = clamp(Local11, 0.0f, 1.0f);
	float Local13 = (Local12 * FloatParameter_GlowMultiplier2);
	float3 Local14 = (Vector3Parameter_GlowColor2 * Local13);
	float3 Local15 = max(Local10, Local14);
	float Local16 = (Local3 * FloatParameter_GlowMultiplier3);
	float3 Local17 = (Vector3Parameter_GlowColor3 * Local16);
	float3 Local18 = max(Local15, Local17);
	out_0 = Local18;
}

void CalculateMatNormal(in float2 in_0,
	out float3 out_0)
{
	// VirtualTextureNode {
	float4 Local0;
	float4 Local1 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache1, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 1, Local0);
	// [Local1] Convert normalmaps to tangent space vectors
	Local1.xyzw = Local1.wzyx;
	Local1.xyz = ((Local1.xyz * 2.0f) - 1.0f);
	Local1.z = -(Local1.z);
	Local1.xyz = normalize(Local1.xyz);
	// } VirtualTextureNode
	float3 Local2 = Local1.xyz;
	// Texture2DNode {
	float4 Local3 = Texture2DParameter_DetailNormalMask.Sample(_DefaultWrapSampler, in_0);
	// [Local3] Get needed components
	float Local4 = Local3.x;
	// } Texture2DNode
	// UVNode {
	// } UVNode
	float2 Local5 = (in_0 * FloatParameter_DetailNormalTiling);
	// Texture2DNode {
	float4 Local6 = Texture2DParameter_DetailNormalMap.Sample(_DefaultWrapSampler, Local5);
	// [Local6] Convert normalmaps to tangent space vectors
	Local6.xyzw = Local6.wzyx;
	Local6.xyz = ((Local6.xyz * 2.0f) - 1.0f);
	Local6.z = -(Local6.z);
	Local6.xyz = normalize(Local6.xyz);
	// [Local6] Get needed components
	float3 Local7 = Local6.xyz;
	// } Texture2DNode
	float3 Local8 = (FloatParameter_DetailNormalStrength * Local7);
	float3 Local9 = (Local4 * Local8);
	float3 Local10 = (float3(1.0f, 0.0f, 1.0f) * Local9);
	float3 Local11 = (Local2 + Local10);
	// NormalizeNode {
	float3 Local12 = normalize(Local11);
	// } NormalizeNode
	out_0 = Local12;
}

