PixelOutput main(in PixelInput In)
{
	PixelOutput Out;

	float3 matEmissiveColor;
	CalculateMatEmissiveColor(In.TexCoords0, matEmissiveColor);
	float3 matNormal;
	CalculateMatNormal(In.TexCoords0, matNormal);
	float3x3 NBT_WS = float3x3(In.WorldTangent, In.WorldNormal, In.WorldBinormal);

	matNormal = normalize(mul(matNormal, NBT_WS));

	float3 matBaseColor;
	// Normalize Local Normal
	float3 localNormalNormalized = normalize(In.LocalNormal);

	CalculateMatBaseColor(In.TexCoords0, localNormalNormalized, In.LocalPosition.xyz, matBaseColor);
	float matMetalMask;
	CalculateMatMetalMask(In.TexCoords0, matMetalMask);
	float matReflectance;
	CalculateMatReflectance(matReflectance);
	float matOcclusion;
	CalculateMatOcclusion(In.TexCoords0, matOcclusion);
	float matRoughness;
	CalculateMatRoughness(In.TexCoords0, localNormalNormalized, In.LocalPosition.xyz, matRoughness);
	float matSubsurfaceMask;
	CalculateMatSubsurfaceMask(In.TexCoords0, matSubsurfaceMask);
	matSubsurfaceMask = saturate(matSubsurfaceMask);
	float matThickness;
	CalculateMatThickness(In.TexCoords0, matThickness);
	matThickness = saturate(matThickness);
	float3 FinalColor = float3(0.0f, 0.0f, 0.0f);

	float shadow = 1.0f;
	BSDFData bsdfData;
	FillBSDFDataFromMaterial(matBaseColor, matOcclusion, matReflectance, 0.0f, matNormal, matRoughness, float3(1.0f, 0.0f, 0.0f), matMetalMask, DiffusionProfileIndex, 3, 0, matSubsurfaceMask, matThickness, true, float3(0.0f, 0.0f, 1.0f), 1.0f, float3(1.0f, 1.0f, 1.0f), 0.0f, 0.4f, bsdfData);

	// Exposure
	float svExposure = LoadExposure();

	// Normalized world space view vector
	float3 worldViewNormalized = normalize(In.WorldView);

	// Evaluate Image Based Lighting Fallback
	float3 iblDiffuseRefl;
	float3 iblSpecularRefl;
	EvaluateDistantIBL(bsdfData, worldViewNormalized, iblDiffuseRefl, iblSpecularRefl);
	float3 ibl = (iblDiffuseRefl + iblSpecularRefl);

	ibl = (ibl * matOcclusion);

	FinalColor = (FinalColor + (ibl * svExposure));

	// Evaluate Lighting
	float3 sunL;
	float3 extinction;
	float3 inscatter;
	sunL = g_SunLightColor;
	extinction = float3(1.0f, 1.0f, 1.0f);
	inscatter = float3(0.0f, 0.0f, 0.0f);
	[branch]
	if ((g_ScatteringIntensity > 0.0f))
	{
		EvaluateAtmosphericLighting(TrilinearWrapSampler, g_CameraWorldPos.xyz, In.WorldPosition.xyz, bsdfData.NormalWS, g_ScatteringSunDirection, sunL, extinction, inscatter);
		inscatter = (inscatter * (g_ScatteringIntensity * 10.0f));
		if ((g_CastMoonLight == 0.0f))
		{
			sunL = ((sunL * g_ScatteringSunColor) * g_ScatteringSunIntensity);
		}
		else
		{
			sunL = g_SunLightColor;
		}
	}

	[branch]
	if ((g_CloudsShadowFactor > 0.0f))
	{
		float cloudsShadow;
		cloudsShadow = GetCoverage(TrilinearWrapSampler, In.WorldPosition.xyz, Atmos_PrevCoverage, float3(0.0f, 0.0f, 0.0f), g_PrevCloudsHeight, g_PrevCloudsCoverageParams, g_PrevSunDirection, Atmos_TargCoverage, float3(0.0f, 0.0f, 0.0f), g_TargCloudsHeight, g_TargCloudsCoverageParams, g_TargSunDirection, g_LerpValue);

		cloudsShadow = SmoothThreshold(cloudsShadow, 0.05f, 0.5f);
		cloudsShadow = (1.0f - saturate((cloudsShadow * g_CloudsShadowFactor)));
		shadow = (shadow * cloudsShadow);
	}

	[branch]
	if ((g_LocalCoverageScalar > 0.0f))
	{
		float localShadow;
		localShadow = GetCoverage(TrilinearWrapSampler, In.WorldPosition.xyz, PrevLocalCoverageMap, g_PrevLocalCoverageOffset, g_PrevLocalCoverageHeight, g_PrevLocalCoverageParams, g_PrevSunDirection, TargLocalCoverageMap, g_TargLocalCoverageOffset, g_TargLocalCoverageHeight, g_TargLocalCoverageParams, g_TargSunDirection, g_LerpValue);

		localShadow = (1.0f - saturate((localShadow * g_LocalCoverageScalar)));
		shadow = (shadow * localShadow);
	}

	float3 probeDiffuseRefl;
	float3 probeSpecularRefl;
	float3 diffuseRefl;
	float3 specularRefl;
	float3 dpdx;
	float3 dpdy;
	dpdx = ddx(In.WorldPosition.xyz);
	dpdy = ddy(In.WorldPosition.xyz);
	EvaluateLighting(bsdfData, In.WorldPosition.xyz, worldViewNormalized, shadow, 0.0f, sunL, false, 0, svExposure, float2(0.0f, 0.0f), dpdx, dpdy, probeDiffuseRefl, probeSpecularRefl, diffuseRefl, specularRefl);
	float3 directLighting = (diffuseRefl + specularRefl);

	float3 indirectLighting = (probeDiffuseRefl + probeSpecularRefl);

	directLighting = (directLighting * lerp(1.0f, matOcclusion, g_ForwardAODirectLightInfluence));

	indirectLighting = (indirectLighting * matOcclusion);

	FinalColor = (FinalColor + directLighting);
	FinalColor = (FinalColor + indirectLighting);

	FinalColor = ((FinalColor * extinction) + (inscatter * svExposure));

	FinalColor = (FinalColor + (matEmissiveColor * !g_LightprobeCapture));

	// UV position
	float2 Local0 = (In.ProjectedPosition.xy * float2(g_RTInvWidth, g_RTInvHeight));

	float svFogDepth = In.DepthNormalized;
	// Fog
	float4 svFog = SampleFog(Local0, svFogDepth);

	FinalColor = (FinalColor * svFog.www);
	FinalColor = (FinalColor + svFog.xyz);

	Out.Color0 = float4(FinalColor, _FadeOpacity);
	Out.Color0 = max(Out.Color0, 0.0f);

	return Out;
}
