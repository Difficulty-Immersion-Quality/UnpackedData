	float2 Local15 = (((step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).x * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).zy) + (step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).z * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).xy)) + (step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).y * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).xz));
	float3 Local16 = step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local14 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f))));
	// Texture2DNode {
