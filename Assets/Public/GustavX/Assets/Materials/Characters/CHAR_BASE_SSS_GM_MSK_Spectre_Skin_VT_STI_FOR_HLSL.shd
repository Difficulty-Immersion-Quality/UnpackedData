void CalculateMatThickness(in float2 in_0,
	out float out_0)
{
	// VirtualTextureNode {
	float4 Local0;
	float4 Local1 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, Local0);
