	float4 Local3 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, Local0);
	float Local4 = Local3.z;
	// } VirtualTextureNode
	float3 Local5 = Local1.xyz;
	// Texture2DNode {
	float4 Local6 = Texture2DParameter_MSKcloth.Sample(_DefaultWrapSampler, in_0);
	// [Local6] Get needed components
	float3 Local7 = Local6.xyz;
	// } Texture2DNode
	float3 Local8 = (((Vector3Parameter_Color_01 * Local7.x) + (Vector3Parameter_Color_02 * Local7.y)) + (Vector3Parameter_Color_03 * Local7.z));
	float3 Local9 = (Local8 * Local5);
	// DotNode {
