	float3 WorldTangent : TEXCOORD3;
	float3 LocalNormal : TEXCOORD4;
	float3 LocalPosition : TEXCOORD5;
	float3 WorldView : TEXCOORD6;
	float4 WorldPosition : TEXCOORD7;
	float Depth : TEXCOORD8;
	float DepthNormalized : TEXCOORD9;
};

struct PixelOutput
{
	float4 Color0 : SV_Target0;
};

