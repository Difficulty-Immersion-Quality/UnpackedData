	// VirtualTextureNode {
	float4 Local0 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, VTFeedback);
	float Local1 = Local0.z;
	// } VirtualTextureNode
	out_0 = Local1;
}

void CalculateMatRoughness(in float2 in_0,
	in float3 in_1,
	in float3 in_2,
	out float out_0,
	out float4 VTFeedback)
{
	// Texture2DNode {
	float4 Local0 = Texture2DParameter_2765e27052ce6f45eddfd0451042b54c.Sample(_DefaultWrapSampler, in_0);
	// [Local0] Get needed components
	float Local1 = Local0.z;
	// } Texture2DNode
	// LocalNormal {
	// } LocalNormal
	// LocalPosition {
	// } LocalPosition
	float2 Local2 = (((step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).x * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).zy) + (step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).z * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).xy)) + (step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).y * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).xz));
	float3 Local3 = step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local1 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f))));
	// Texture2DNode {
	float4 Local4 = Texture2DParameter_2765e27052ce6f45eddfd0451042b54c.Sample(_DefaultWrapSampler, Local2);
	// [Local4] Get needed components
	float3 Local5 = Local4.xyz;
	float Local6 = Local4.z;
	// } Texture2DNode
	float2 Local7 = Local5.yx;
	// VirtualTextureNode {
	float4 Local8 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache1, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 1, VTFeedback);
	// [Local8] Convert normalmaps to tangent space vectors
	Local8.xyzw = Local8.wzyx;
	Local8.xyz = ((Local8.xyz * 2.0f) - 1.0f);
	Local8.z = -(Local8.z);
	Local8.xyz = normalize(Local8.xyz);
	float4 Local9 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, VTFeedback);
	float Local10 = Local9.z;
