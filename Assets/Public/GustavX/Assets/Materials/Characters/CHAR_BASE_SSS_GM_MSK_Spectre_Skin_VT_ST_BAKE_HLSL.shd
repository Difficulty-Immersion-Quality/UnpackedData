[Vertex shader]
#include "Shaders/HLSL/Preamble.shdh"
#include "Shaders/HLSL/Global/DS_Globals.shdh"
#include "Shaders/HLSL/CommonHelpers.shdh"

struct VertexInput
{
	float2 UnpackedUVs : TEXCOORD4;
	float2 TexCoords0 : TEXCOORD0;
	float4 LocalQTangent : NORMAL0;
	float3 Position : POSITION0;
};

struct VertexOutput
{
	float4 ProjectedPosition : SV_Position0;
	float2 TexCoords0 : TEXCOORD0;
	float3 LocalNormal : TEXCOORD1;
	float3 LocalPosition : TEXCOORD2;
};

VertexOutput main(in VertexInput In)
{
	VertexOutput Out;

	// UVs as projected position {
	// Flip UV.y coordinate so mesh won't be flipped
	// Use extra UV set for unpacked with Houdini UV islands
	float2 uv_coordinates = In.UnpackedUVs;
	uv_coordinates = float2(uv_coordinates.x, (1.0f - uv_coordinates.y));

	uv_coordinates = mad(uv_coordinates, float2(2.0f, 2.0f), float2(-1.0f, -1.0f));
	float4 uv_projected = float4(uv_coordinates, 0.0f, 1.0f);
	float4 projectedPosition = uv_projected;
	// } UVs as projected position

	// Pass projected position to pixel shader
	Out.ProjectedPosition = projectedPosition;

	Out.TexCoords0 = In.TexCoords0;
	// Compute localTangentFrame tangent frame
	float3x3 localTangentFrame = GetTangentFrame(In.LocalQTangent);

	float3 localNormal = localTangentFrame[2];

	// Pass Local Normal to PS
	Out.LocalNormal = localNormal;

	// Pass local position to pixel shader
	Out.LocalPosition = In.Position;


	return Out;
}


[Fragment shader]
#include "Shaders/HLSL/Preamble.shdh"
#include "Shaders/HLSL/Global/DS_Globals.shdh"
#include "Shaders/HLSL/CommonHelpers.shdh"
#include "Shaders/HLSL/VirtualTexturing.shdh"
#include "Shaders/HLSL/PBR.shdh"

struct PixelInput
{
	float4 ProjectedPosition : SV_Position0;
	float2 TexCoords0 : TEXCOORD0;
	float3 LocalNormal : TEXCOORD1;
	float3 LocalPosition : TEXCOORD2;
};

struct PixelOutput
{
	float4 Color0 : SV_Target0;
	float4 Color1 : SV_Target1;
	float4 Color2 : SV_Target2;
	float4 Color3 : SV_Target3;
};

VK_DESCRIPTOR(DS_Shader, 0) cbuffer CB_EngineParams : register(b0)
{
	float4 VirtualTexture_CB_Texture[2];
	uint VirtualTexture_TilesetDataIndex;
	uint PADDING0_VirtualTexture_TilesetDataIndex;
	uint PADDING1_VirtualTexture_TilesetDataIndex;
	uint PADDING2_VirtualTexture_TilesetDataIndex;
};
VK_DESCRIPTOR(DS_Shader, 1) cbuffer CB_MaterialConstants : register(b1)
{
	float3 Vector3Parameter_Color_01;
	float FloatParameter_DetailNormalStrength;
	float3 Vector3Parameter_Color_02;
	float FloatParameter_DetailNormalTiling;
	float3 Vector3Parameter_Color_03;
	float FloatParameter_Blood_AO_Sharpness;
	float3 Vector3Parameter_Blood_Color;
	float FloatParameter_Blood;
	float3 Vector3Parameter_GlowColor1;
	float FloatParameter_Reflectance;
	float3 Vector3Parameter_GlowColor2;
	float FloatParameter_GlowColorBlend2;
	float3 Vector3Parameter_GlowColor3;
	float FloatParameter_GlowColorBlend3;
	float FloatParameter_GlowMultiplier1;
	float FloatParameter_GlowMultiplier2;
	float FloatParameter_GlowMultiplier3;
	float PADDING_FloatParameter_GlowMultiplier3;
};
VK_DESCRIPTOR(DS_Shader, 2) SamplerState _DefaultBorderSampler;
VK_DESCRIPTOR(DS_Shader, 3) Texture2D VirtualTexture_Pagetable;
VK_DESCRIPTOR(DS_Shader, 4) Texture2DArray VirtualTexture_Cache1;
VK_DESCRIPTOR(DS_Shader, 5) Texture2D Texture2DParameter_DetailNormalMask;
VK_DESCRIPTOR(DS_Shader, 6) Texture2D Texture2DParameter_DetailNormalMap;
VK_DESCRIPTOR(DS_Shader, 7) Texture2DArray VirtualTexture_Cache0;
VK_DESCRIPTOR(DS_Shader, 8) Texture2DArray VirtualTexture_Cache2;
VK_DESCRIPTOR(DS_Shader, 9) Texture2D Texture2DParameter_MSKcloth;
VK_DESCRIPTOR(DS_Shader, 10) Texture2D Texture2DParameter_2765e27052ce6f45eddfd0451042b54c;
VK_DESCRIPTOR(DS_Shader, 11) Texture2D Texture2DParameter_MSKglowmap;
void CalculateMatNormal(in float2 in_0,
	out float3 out_0,
	out float4 VTFeedback)
{
	// VirtualTextureNode {
	float4 Local0 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache1, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 1, VTFeedback);
	// [Local0] Convert normalmaps to tangent space vectors
	Local0.xyzw = Local0.wzyx;
	Local0.xyz = ((Local0.xyz * 2.0f) - 1.0f);
	Local0.z = -(Local0.z);
	Local0.xyz = normalize(Local0.xyz);
	// } VirtualTextureNode
	float3 Local1 = Local0.xyz;
	// Texture2DNode {
	float4 Local2 = Texture2DParameter_DetailNormalMask.Sample(_DefaultWrapSampler, in_0);
	// [Local2] Get needed components
	float Local3 = Local2.x;
	// } Texture2DNode
	// UVNode {
	// } UVNode
	float2 Local4 = (in_0 * FloatParameter_DetailNormalTiling);
	// Texture2DNode {
	float4 Local5 = Texture2DParameter_DetailNormalMap.Sample(_DefaultWrapSampler, Local4);
	// [Local5] Convert normalmaps to tangent space vectors
	Local5.xyzw = Local5.wzyx;
	Local5.xyz = ((Local5.xyz * 2.0f) - 1.0f);
	Local5.z = -(Local5.z);
	Local5.xyz = normalize(Local5.xyz);
	// [Local5] Get needed components
	float3 Local6 = Local5.xyz;
	// } Texture2DNode
	float3 Local7 = (FloatParameter_DetailNormalStrength * Local6);
	float3 Local8 = (Local3 * Local7);
	float3 Local9 = (float3(1.0f, 0.0f, 1.0f) * Local8);
	float3 Local10 = (Local1 + Local9);
	// NormalizeNode {
	float3 Local11 = normalize(Local10);
	// } NormalizeNode
	out_0 = Local11;
}

void CalculateMatBaseColor(in float2 in_0,
	in float3 in_1,
	in float3 in_2,
	out float3 out_0,
	out float4 VTFeedback)
{
	// VirtualTextureNode {
	float4 Local0 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache0, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 0, VTFeedback);
	float4 Local1 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache1, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 1, VTFeedback);
	// [Local1] Convert normalmaps to tangent space vectors
	Local1.xyzw = Local1.wzyx;
	Local1.xyz = ((Local1.xyz * 2.0f) - 1.0f);
	Local1.z = -(Local1.z);
	Local1.xyz = normalize(Local1.xyz);
	float4 Local2 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, VTFeedback);
	float Local3 = Local2.z;
	// } VirtualTextureNode
	float3 Local4 = Local0.xyz;
	// Texture2DNode {
	float4 Local5 = Texture2DParameter_MSKcloth.Sample(_DefaultWrapSampler, in_0);
	// [Local5] Get needed components
	float3 Local6 = Local5.xyz;
	// } Texture2DNode
	float3 Local7 = (((Vector3Parameter_Color_01 * Local6.x) + (Vector3Parameter_Color_02 * Local6.y)) + (Vector3Parameter_Color_03 * Local6.z));
	float3 Local8 = (Local7 * Local4);
	// DotNode {
	float Local9 = dot(Local6, float3(1.0f, 1.0f, 1.0f));
	// } DotNode
	float Local10 = clamp(Local9, 0.0f, 1.0f);
	float3 Local11 = lerp(Local4, Local8, float3(Local10, Local10, Local10));
	// Texture2DNode {
	float4 Local12 = Texture2DParameter_2765e27052ce6f45eddfd0451042b54c.Sample(_DefaultWrapSampler, in_0);
	// [Local12] Get needed components
	float Local13 = Local12.z;
	// } Texture2DNode
	// LocalNormal {
	// } LocalNormal
	// LocalPosition {
	// } LocalPosition
	float2 Local14 = (((step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).x * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).zy) + (step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).z * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).xy)) + (step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f)))).y * (float3(1.0f, -1.0f, 1.0f) * ((float3(0.0f, 0.0f, 0.0f) + in_2) * 2.8f)).xz));
	float3 Local15 = step(float3(0.5f, 0.5f, 0.5f), (pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)) / dot(pow(abs(((float3(0.0f, 0.5f, 1.0f) * ((2.0f * (Local13 + -0.5f)) * 0.3f)) + in_1)), float3(160.0f, 160.0f, 160.0f)), float3(1.0f, 1.0f, 1.0f))));
	// Texture2DNode {
	float4 Local16 = Texture2DParameter_2765e27052ce6f45eddfd0451042b54c.Sample(_DefaultWrapSampler, Local14);
	// [Local16] Get needed components
	float3 Local17 = Local16.xyz;
	float Local18 = Local16.z;
	// } Texture2DNode
	float2 Local19 = Local17.yx;
	float Local20 = Local1.z;
	float Local21 = clamp(Local20, 0.0f, 1.0f);
	float Local22 = pow(Local3, FloatParameter_Blood_AO_Sharpness);
	float Local23 = (1.0f - Local22);
	float Local24 = (Local21 + Local23);
	float Local25 = clamp(Local24, 0.0f, 1.0f);
	float Local26 = (1.0f - Local25);
	float Local27 = (Local18 - 0.7f);
	float Local28 = max(1E-05f, Local27);
	float Local29 = (Local26 + Local28);
	float Local30 = step(Local29, FloatParameter_Blood);
	float2 Local31 = (Local19 * Local30);
	float Local32 = Local31.y;
	float3 Local33 = lerp(Local11, Vector3Parameter_Blood_Color, float3(Local32, Local32, Local32));
	out_0 = Local33;
}

void CalculateMatMetalMask(in float2 in_0,
	out float out_0,
	out float4 VTFeedback)
