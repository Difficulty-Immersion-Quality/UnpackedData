void CalculateMatSubsurfaceMask(in float2 in_0,
	out float out_0,
	out float4 VTFeedback)
{
	// VirtualTextureNode {
	float4 Local0 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, VTFeedback);
	// } VirtualTextureNode
	float Local1 = Local0.w;
	float Local2 = floor(Local1);
	float Local3 = (1.0f - Local2);
	out_0 = Local3;
}

void CalculateMatThickness(in float2 in_0,
	out float out_0,
	out float4 VTFeedback)
{
	// VirtualTextureNode {
	float4 Local0 = SampleVirtualTexture(in_0, VirtualTexture_Pagetable, VirtualTexture_Cache2, _DefaultBorderSampler, VirtualTexture_TilesetDataIndex, VirtualTexture_CB_Texture, 2, VTFeedback);
	// } VirtualTextureNode
	float Local1 = Local0.w;
	out_0 = Local1;
}

void CalculateMatEmissiveColor(in float2 in_0,
	out float3 out_0)
{
	// Texture2DNode {
	float4 Local0 = Texture2DParameter_MSKglowmap.Sample(_DefaultWrapSampler, in_0);
	// [Local0] Get needed components
	float Local1 = Local0.x;
	float Local2 = Local0.y;
	float Local3 = Local0.z;
	// } Texture2DNode
	float Local4 = (Local2 * FloatParameter_GlowColorBlend2);
	float Local5 = (Local1 - Local4);
	float Local6 = (FloatParameter_GlowColorBlend3 * Local3);
	float Local7 = (Local5 - Local6);
	float Local8 = clamp(Local7, 0.0f, 1.0f);
	float Local9 = (Local8 * FloatParameter_GlowMultiplier1);
	float3 Local10 = (Vector3Parameter_GlowColor1 * Local9);
	float Local11 = (Local2 - Local6);
	float Local12 = clamp(Local11, 0.0f, 1.0f);
	float Local13 = (Local12 * FloatParameter_GlowMultiplier2);
	float3 Local14 = (Vector3Parameter_GlowColor2 * Local13);
	float3 Local15 = max(Local10, Local14);
	float Local16 = (Local3 * FloatParameter_GlowMultiplier3);
	float3 Local17 = (Vector3Parameter_GlowColor3 * Local16);
	float3 Local18 = max(Local15, Local17);
	out_0 = Local18;
}

PixelOutput main(in PixelInput In)
{
	PixelOutput Out;

	float4 VTFeedback = float4(1.0f, 1.0f, 1.0f, 1.0f);

	float3 matNormal;
	CalculateMatNormal(In.TexCoords0, matNormal, VTFeedback);
	float3 matBaseColor;
	// Normalize Local Normal
	float3 localNormalNormalized = normalize(In.LocalNormal);

	CalculateMatBaseColor(In.TexCoords0, localNormalNormalized, In.LocalPosition.xyz, matBaseColor, VTFeedback);
	float4 svMatBaseColor;
	svMatBaseColor = float4(matBaseColor, 1.0f);
	float matMetalMask;
	CalculateMatMetalMask(In.TexCoords0, matMetalMask, VTFeedback);
	float matReflectance;
	CalculateMatReflectance(matReflectance);
	float matOcclusion;
	CalculateMatOcclusion(In.TexCoords0, matOcclusion, VTFeedback);
	float matRoughness;
	CalculateMatRoughness(In.TexCoords0, localNormalNormalized, In.LocalPosition.xyz, matRoughness, VTFeedback);
	float matSubsurfaceMask;
	CalculateMatSubsurfaceMask(In.TexCoords0, matSubsurfaceMask, VTFeedback);
	matSubsurfaceMask = saturate(matSubsurfaceMask);
	float matThickness;
	CalculateMatThickness(In.TexCoords0, matThickness, VTFeedback);
	matThickness = saturate(matThickness);
	float3 matEmissiveColor;
	CalculateMatEmissiveColor(In.TexCoords0, matEmissiveColor);
	float4 physicalValue;
	physicalValue = float4(matMetalMask, matRoughness, matOcclusion, matReflectance);
	float4 outNormal;
	outNormal = float4(matNormal, 0.0f);
	outNormal.z = -(outNormal.z);
	outNormal = mad(outNormal, float4(0.5f, 0.5f, 0.5f, 0.5f), float4(0.5f, 0.5f, 0.5f, 0.0f));
	outNormal = float4(outNormal.w, outNormal.z, outNormal.y, outNormal.x);
	Out.Color0 = outNormal;
	// Baked base color output
	Out.Color1 = pow(svMatBaseColor, float4(0.4545454f, 0.4545454f, 0.4545454f, 1.0f));
	Out.Color2 = physicalValue;
	Out.Color3 = float4(matEmissiveColor, matThickness);

	return Out;
}
