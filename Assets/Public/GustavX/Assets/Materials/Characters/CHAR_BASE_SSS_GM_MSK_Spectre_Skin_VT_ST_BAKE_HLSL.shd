	float Local13 = pow(Local10, FloatParameter_Blood_AO_Sharpness);
	float Local14 = (1.0f - Local13);
	float Local15 = (Local12 + Local14);
	float Local16 = clamp(Local15, 0.0f, 1.0f);
	float Local17 = (1.0f - Local16);
	float Local18 = (Local6 - 0.7f);
	float Local19 = max(1E-05f, Local18);
