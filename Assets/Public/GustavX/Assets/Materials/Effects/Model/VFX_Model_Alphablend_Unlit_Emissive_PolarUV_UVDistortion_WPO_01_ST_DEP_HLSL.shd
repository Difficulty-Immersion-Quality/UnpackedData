	float2 Vector2Parameter_MaskScrollingSpeed;
	float2 Vector2Parameter_FadeInMiddle_SmoothStep;
	float2 Vector2Parameter_Opacity_BordersMask_SmoothStep;
	float FloatParameter_PolarUVExp;
