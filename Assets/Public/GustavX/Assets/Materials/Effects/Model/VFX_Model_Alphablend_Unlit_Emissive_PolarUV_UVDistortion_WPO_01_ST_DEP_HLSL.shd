	float FloatParameter_OpacityPower_UseDynParam;
	float FloatParameter_Opacity_BordersMask_Switch;
	float FloatParameter_AlphaClip;
	float FloatParameter_Opacity;
	float FloatParameter_DepthDifferenceBlendDistance;
	float PADDING0_FloatParameter_DepthDifferenceBlendDistance;
	float PADDING1_FloatParameter_DepthDifferenceBlendDistance;
	float PADDING2_FloatParameter_DepthDifferenceBlendDistance;
};
VK_DESCRIPTOR(DS_Shader, 2) Texture2D Texture2DParameter_DistortionTexture;
VK_DESCRIPTOR(DS_Shader, 3) Texture2D Texture2DParameter_MainTexture;
void CalculateMatWorldPositionOffset(in float2 in_0,
	in float4 in_1,
	in float3 in_2,
	out float3 out_0)
{
	// UVNode {
	// } UVNode
	float2 Local0 = (in_0 * Vector2Parameter_UV_Stretch);
	float2 Local1 = (Local0 + Vector2Parameter_UV_Center);
	float2 Local2 = (float2(-1.0f, -1.0f) + (((Local1 - 0.0f) * (1.0f - -1.0f)) / max(abs((1.0f - 0.0f)), 1E-05f)));
	float2 Local3 = Local2;
	float Local4 = length(Local3);
	float Local5 = (1.0f - Local4);
	float Local6 = pow(Local5, FloatParameter_PolarUVExp);
	float Local7 = (1.0f - Local6);
	float Local8 = Local2.y;
	float Local9 = Local2.x;
	float Local10 = atan2(Local8, Local9);
	float Local11 = (0.0f + (((Local10 - -3.14159f) * (1.0f - 0.0f)) / max(abs((3.14159f - -3.14159f)), 1E-05f)));
	float2 Local12 = float2(Local7, Local11);
	float2 Local13 = Local12.yx;
	float2 Local14 = lerp(Local12, Local13, float2(FloatParameter_ToggleInvertUV, FloatParameter_ToggleInvertUV));
	float2 Local15 = float2(Local4, Local11);
	float2 Local16 = (Local15 * Vector2Parameter_DistortionTiling);
	float2 Local17 = (g_CurrentTime * Vector2Parameter_DistortionScrollingSpeed);
	float2 Local18 = frac(Local17);
	// DynamicParameterNode {
	// } DynamicParameterNode
	float2 Local19 = (Vector2Parameter_DistortionScrollingSpeed * in_1.x);
	float2 Local20 = lerp(Local18, Local19, float2(in_1.y, in_1.y));
	float2 Local21 = (Local16 + Local20);
	// Texture2DNode {
	float4 Local22 = Texture2DParameter_DistortionTexture.SampleLevel(_DefaultWrapSampler, Local21, 0.0f);
	// [Local22] Get needed components
	float Local23 = Local22.x;
	// } Texture2DNode
	float Local24 = (Local23 * FloatParameter_DistortionIntensity);
	float2 Local25 = (Local14 + float2(Local24, Local24));
	float2 Local26 = (Local25 * Vector2Parameter_Tiling);
	float2 Local27 = (g_CurrentTime * Vector2Parameter_ScrollingSpeed);
	float2 Local28 = frac(Local27);
	// DynamicParameterNode {
	// } DynamicParameterNode
	float2 Local29 = (Vector2Parameter_ScrollingSpeed * in_1.x);
	float2 Local30 = lerp(Local28, Local29, float2(in_1.y, in_1.y));
	float2 Local31 = (Local26 + Local30);
	// Texture2DNode {
	float4 Local32 = Texture2DParameter_MainTexture.SampleLevel(_DefaultWrapSampler, Local31, 0.0f);
	// [Local32] Get needed components
	float3 Local33 = Local32.xyz;
	float Local34 = Local32.x;
	// } Texture2DNode
	float3 Local35 = lerp(float3(Local34, Local34, Local34), Local33, float3(FloatParameter__Use_RGBFromMainTexture, FloatParameter__Use_RGBFromMainTexture, FloatParameter__Use_RGBFromMainTexture));
	float3 Local36 = (Local35 * FloatParameter_WPO_Multiply);
	// WorldNormalNode {
	// } WorldNormalNode
	float3 Local37 = (Local36 * in_2);
	out_0 = Local37;
}

VertexOutput main(in VertexInput In)
{
	VertexOutput Out;

	float3 matWorldPositionOffset;
	float4 transformedQTangent = In.LocalQTangent;
	[branch]
	if ((TransformedVerticesOffset > 0))
	{
		// Skinned QTangent
		transformedQTangent = GetSkinnedQTangent(In.VertexID, TransformedVerticesOffset);
	}
	// Compute transformedTangentFrame tangent frame
	float3x3 transformedTangentFrame = GetTangentFrame(transformedQTangent);

	float3 transformedNormal = transformedTangentFrame[2];

	// World space Normal
	float3 worldNormal = mul((float3x3)(WorldOffsetMatrix), transformedNormal);

	// Normalize World Normal
	float3 worldNormalNormalized = normalize(worldNormal);

	CalculateMatWorldPositionOffset(In.TexCoords0, DynamicParameter, worldNormalNormalized, matWorldPositionOffset);
	float3 localPositionStatic = In.Position;
	[branch]
	if ((TransformedVerticesOffset > 0))
	{
		// Skinned vertex
		localPositionStatic = GetSkinnedPosition(In.VertexID, TransformedVerticesOffset);
	}
	// World space offset
	float3 worldOffset = mul(WorldOffsetMatrix, float4(localPositionStatic, 1.0f)).xyz;

	worldOffset = (worldOffset + matWorldPositionOffset);

	// Projected position
	float4 projectedPosition = mul(g_OffsetViewProjectionMat, float4(worldOffset, 1.0f));

	// Pass projected position to pixel shader
	Out.ProjectedPosition = projectedPosition;

	Out.VertexColor = In.VertexColor;
	Out.TexCoords0 = In.TexCoords0;
	// View space position
	float3 viewPosition = mul((float3x3)(g_ViewMat), worldOffset);

	// Depth
	float depth = viewPosition.z;

	// Pass depth to pixel shader
	Out.Depth = depth;


	return Out;
}


[Fragment shader]
#include "Shaders/HLSL/Preamble.shdh"
#include "Shaders/HLSL/Global/DS_Globals.shdh"
