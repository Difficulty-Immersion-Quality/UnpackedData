<ls:StateMachine xmlns:ls="clr-namespace:ls;assembly=Code"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ls:StateMachine.States>
        <ls:State Name="SystemUIs" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayFriendsList"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="MainMenu.LoadGame" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayFriendsList"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="Paused.LoadGame" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayFriendsList"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="Paused.SaveGame" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayFriendsList"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="Options" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayFriendsList"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="GameSettings" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayFriendsList"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="Lobby" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenCrossplayProfile">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayProfile" MetaData="ReducedView"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="CharacterAssign" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenCrossplayProfile">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayProfile" MetaData="ReducedView"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <!-- STATE: CrossplayFriendsList-->
        <ls:State Name = "CrossplayFriendsList" DisableStatesBelow = "False" HideStatesBelow = "False" IsModal="True" Layout="Player" Owner="Player">
            <ls:State.Widgets>
                <ls:StateWidget Filename="CrossplayFriendsList_c.xaml" Layer="PauseOverlay"/>
            </ls:State.Widgets>

            <ls:State.Events>
                <ls:StateEvent Name = "CloseWidget">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "CloseFriendsList">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenReport">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ReportPanel"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenCrossplayProfile">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CrossplayProfile"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenMessageBox">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CommonMessageBox"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenSystemMessageBox">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="SystemMessageBox"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

            </ls:State.Events>
        </ls:State>

        <!-- STATE: CrossplayProfile-->
        <ls:State Name = "CrossplayProfile" DisableStatesBelow = "False" HideStatesBelow = "False" IsModal="True" Layout="Player" Owner="Player">
            <ls:State.Widgets>
                <ls:StateWidget Filename="CrossplayProfile_c.xaml" Layer="PauseOverlay"/>
            </ls:State.Widgets>

            <ls:State.Events>
                <ls:StateEvent Name = "CloseWidget">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenCrossplayProfile">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "CloseCrossplayProfile">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

            </ls:State.Events>
        </ls:State>
    </ls:StateMachine.States>
</ls:StateMachine>