                                                </ControlTemplate.Resources>

                                                <Grid HorizontalAlignment="Center">
                                                    <b:Interaction.Triggers>
                                                        <b:PropertyChangedTrigger Binding="{Binding Value, RelativeSource={RelativeSource TemplatedParent}}">
