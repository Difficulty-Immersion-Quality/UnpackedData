                                                            <ls:LSThumb Style="{StaticResource OptionSliderThumbStyle}" />
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <ls:LSRepeatButton x:Name="PART_TrackAfter" Style="{StaticResource Style.Slider.RepeatButton}" Command="Slider.IncreaseLarge"/>
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                    <TextBlock x:Name="PART_ValueLabel" Style="{StaticResource DefaultSliderValueStyle}" Foreground="{StaticResource LS_accent100TxtColor}" FontSize="{StaticResource ScaledMediumFontSize}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </ControlTemplate.Resources>

                                        <Slider x:Name="element" 
                                                Template="{StaticResource OptionsSliderTemplate}" 
                                                Value="{Binding Value}" 
                                                Minimum="{Binding Min}" 
                                                Maximum="{Binding Max}" 
                                                IsSnapToTickEnabled="True" 
                                                SmallChange="{Binding Step}" 
                                                LargeChange="{Binding Step, Converter={StaticResource MultiplierConverter}, ConverterParameter=3}" 
                                                TickFrequency="{Binding Step}" 
                                                IsEnabled="{Binding DataContext.IsHost, ElementName=DMSettings}"
                                                Width="868">
                                            <b:Interaction.Triggers>
                                                <b:EventTrigger EventName="ValueChanged">
                                                    <b:InvokeCommandAction Command="{Binding DataContext.ValueChanged, ElementName=DMSettings}" CommandParameter="{Binding .}"/>
                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>
                                        </Slider>

                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EditableInGame}" Value="False">
                                                <Setter TargetName="element" Property="IsEnabled" Value="False"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding DataContext.IsMainMenu, ElementName=DMSettings}" Value="True">
                                                <Setter TargetName="element" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Metadata, ElementName=DMSettings}" Value="Lobby">
                                                <Setter TargetName="element" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>

                                            <!-- 16:10+ ratio-->
                                            <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="True">
                                                <Setter TargetName="element" Property="Width" Value="{StaticResource LetterBoxRatioSettingWidth}"/>
                                            </DataTrigger>

                                            <!-- 4:3+ ratio -->
                                            <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                                <Setter TargetName="element" Property="Width" Value="{StaticResource FullscreenRatioSettingWidth}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ControlTemplate.Resources>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="900"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*" MinWidth="600"/>
                                    </Grid.ColumnDefinitions>

                                    <ListBox x:Name="Options" 
                                             Grid.Column="1" 
                                             VerticalAlignment="Center" 
                                             HorizontalAlignment="Center" 
                                             HorizontalContentAlignment="Center"
                                             AlternationCount="{Binding CustomSettings.Count}" 
                                             ItemsSource="{Binding CustomSettings}" 
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                                             SelectionMode="Single">
                                        <ListBox.Template>
                                            <ControlTemplate>
                                                <ScrollViewer x:Name="ScrollViewer"
                                                              HorizontalAlignment="Center" 
                                                              HorizontalContentAlignment="Center"
                                                              Padding="16,0" 
                                                              Height="1500" 
                                                              Width="Auto" 
                                                              Template="{StaticResource ScrollViewerTemplate}" 
                                                              Background="Transparent">
                                                    <ScrollViewer.Resources>
                                                        <Style x:Key="ScrollBarStyle" TargetType="ScrollBar" BasedOn="{StaticResource DecorativeGoldScrollBar}"/>
                                                        <GridLength x:Key="Top">0</GridLength>
                                                        <GridLength x:Key="Bottom">0</GridLength>
                                                    </ScrollViewer.Resources>
                                                    <ItemsPresenter HorizontalAlignment="Center"/>
                                                </ScrollViewer>

                                                <ControlTemplate.Triggers>
                                                    <!-- 16:10+ ratio-->
                                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="True">
                                                        <Setter TargetName="ScrollViewer" Property="MaxWidth" Value="1500"/>
                                                    </DataTrigger>

                                                    <!-- 4:3+ ratio -->
                                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                                        <Setter TargetName="ScrollViewer" Property="MaxWidth" Value="1300"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ListBox.Template>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid x:Name="Container" MaxWidth="1800" HorizontalAlignment="Center">

                                                    <ls:AttachedProperties.AutomationId>
                                                        <MultiBinding StringFormat="{}{0}_{1}">
                                                            <Binding Path="ListItemType"/>
                                                            <Binding Path="Text"/>
                                                        </MultiBinding>
                                                    </ls:AttachedProperties.AutomationId>

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition x:Name="col0" Width="*"/>
                                                        <ColumnDefinition x:Name="col1" Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image x:Name="highlight" Grid.Column="0" Grid.ColumnSpan="2" Stretch="Fill" Height="116" Source="{StaticResource ItemBG}"/>
                                                    <TextBlock x:Name="label" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="60,0,0,0" TextWrapping="Wrap" MaxWidth="1100" ls:TextBlockFormatter.SourceText="{Binding Text}" FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_accent75TxtColor}"/>
                                                    <Control x:Name="content" Grid.Column="1" VerticalAlignment="Center"  HorizontalAlignment="Right" Template="{StaticResource ComboBoxTemplate}" Margin="20,0,60,0"/>

                                                    <b:Interaction.Triggers>
                                                        <b:EventTrigger EventName="MouseEnter">
                                                            <ls:LSPlaySound Sound="UI_HUD_Options_OptionHover"/>
                                                        </b:EventTrigger>
                                                    </b:Interaction.Triggers>
                                                </Grid>

                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding ListItemType}" Value="TickBox">
                                                        <Setter Property="Template" Value="{StaticResource TickBoxTemplate}" TargetName="content"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ListItemType}" Value="Slider">
                                                        <Setter Property="Template" Value="{StaticResource SliderTemplate}" TargetName="content"/>
                                                    </DataTrigger>

                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualConverter}">
                                                                <Binding Path="Value"/>
                                                                <Binding Path="DefaultValue"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                                                    </DataTrigger>

                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding EditableInGame}" Value="False"/>
                                                            <Condition Binding="{Binding DataContext.IsMainMenu , ElementName=DMSettings}" Value="False"/>
                                                            <Condition Binding="{Binding Metadata, ElementName=DMSettings}" Value=""/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_baseTxtColor}"/>
                                                    </MultiDataTrigger>

                                                    <!-- 16:10+ ratio-->
                                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="True">
                                                        <Setter TargetName="Container" Property="Width" Value="1400"/>
                                                    </DataTrigger>

                                                    <!-- 4:3+ ratio -->
                                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                                        <Setter TargetName="Container" Property="Width" Value="1200"/>
                                                    </DataTrigger>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                                                        <Setter TargetName="highlight" Property="Source" Value="{StaticResource ItemBGHL}"/>
                                                    </Trigger>

                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding EditableInGame}" Value="False"/>
                                                            <Condition Binding="{Binding DataContext.IsMainMenu , ElementName=DMSettings}" Value="False"/>
                                                            <Condition Binding="{Binding Metadata, ElementName=DMSettings}" Value=""/>
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_tint60}"/>
                                                    </MultiDataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>

                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="IsSelected" Value="True"/>
                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                    </Trigger>

                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>

                                    <StackPanel x:Name="SelectedItemDescription" Grid.Column="2" Margin="80, 40,80,0" Orientation="Vertical" DataContext="{Binding SelectedItem, ElementName=Options}">
                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Text}" TextAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource LS_tint100}" FontSize="{StaticResource ScaledLargeFontSize}"/>

                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Description}" TextAlignment="Left" TextWrapping="Wrap" Margin="0,20"/>

                                        <ListBox ItemsSource="{Binding Options}" Visibility="{Binding Options, Converter={StaticResource NullToCollapsedConverter}}" HorizontalAlignment="Left">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>

                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type ls:VMEnumData}">
                                                    <DataTemplate.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                                        </Style>

                                                        <ImageSource x:Key="SelectedOptionIcon">pack://application:,,,/Core;component/Assets/CharacterPanel/ico_bullet_d.png</ImageSource>
                                                    </DataTemplate.Resources>

                                                    <StackPanel Orientation="Vertical" Margin="0,0,0,20" MaxWidth="800">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image x:Name="SelectedIcon" Source="{StaticResource SelectedOptionIcon}" Stretch="None" Visibility="Collapsed" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                                            <TextBlock x:Name="Title" ls:TextBlockFormatter.SourceText="{Binding Name}" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledIntermediateFontSize}"/>
                                                        </StackPanel>

                                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Description}" Foreground="{StaticResource LS_baseTxtColor}" FontSize="{StaticResource ScaledDefaultFontSize}"/>
                                                    </StackPanel>

                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualConverter}">
                                                                    <Binding Path=""/>
                                                                    <Binding Path="DataContext.SelectedItem" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter TargetName="SelectedIcon" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <TextBlock x:Name="WarningOption" ls:TextBlockFormatter.SourceText="{Binding Source='h3c46af69gfe72g49f1gb524g8bf318295dc3', Converter={StaticResource TranslatedStringConverter}}" Visibility="Collapsed" TextWrapping="Wrap" Foreground="{StaticResource LS_accent100TxtColor}"/>
                                    </StackPanel>

                                    <TextBlock x:Name="DescriptionText" Grid.Column="2" Margin="80, 40,80,0" TextAlignment="Left" TextWrapping="Wrap" ls:TextBlockFormatter.SourceText="{Binding Source='he48cb8b7g6277g420bg95d5g16add9116a76', Converter={StaticResource TranslatedStringConverter}}" Visibility="Collapsed" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledIntermediateFontSize}"/>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem.EditableInGame, ElementName=Options}" Value="False">
                                        <Setter TargetName="WarningOption" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=Options, Converter={StaticResource NullToBoolTrueConverter}}" Value="True">
                                        <Setter TargetName="DescriptionText" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                        <Setter TargetName="SelectedItemDescription" Property="Margin" Value="0,40,0,0"/>
                                        <Setter TargetName="DescriptionText" Property="Margin" Value="0,40,0,0"/>
                                        <Setter TargetName="SelectedItemDescription" Property="MaxWidth" Value="600"/>
                                        <Setter TargetName="DescriptionText" Property="MaxWidth" Value="600"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="CustomSettingsFadeIn">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CustomSettingsHolder" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.3" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="CustomSettingsFadeOut"/>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <BeginStoryboard x:Name="CustomSettingsFadeOut">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CustomSettingsHolder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <BeginStoryboard x:Name="PresetListPanToRight">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="0,0,0,-100" Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="CustomSettingsFadeIn"/>
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>

                <!-- Taller screen ratio (16:10 and plus) -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasBeenInitialized}" Value="True"/>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding CanOnlyChangeCustomMode}" Value="False"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="True"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="False"/>
                    </MultiDataTrigger.Conditions>

                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PresetListPanToLeftTallScreen">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="{StaticResource LetterboxMarginCustom}"  Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="PresetListPanToRight"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeft"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftWideScreen"/>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <!-- For 4:3 screen ratios and squarer -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasBeenInitialized}" Value="True"/>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding CanOnlyChangeCustomMode}" Value="False"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True"/>
                    </MultiDataTrigger.Conditions>

                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PresetListPanToLeft">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="{StaticResource FullscreenMarginCustom}"  Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="PresetListPanToRight"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftTallScreen"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftWideScreen"/>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>
                
                <!-- Wide screen counterparts -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasBeenInitialized}" Value="True"/>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding CanOnlyChangeCustomMode}" Value="False"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PresetListPanToLeftWideScreen">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="{StaticResource WidescreenMarginCustom}" Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="PresetListPanToRight"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeft"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftTallScreen"/>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Presets.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="False">
                    <Setter TargetName="ConfirmBtn" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CancelBtn" Property="Margin" Value="-32,0"/>
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding IsMainMenu}" Value="False"/>
                    </MultiDataTrigger.Conditions>

                    <Setter TargetName="TitleText" Property="Tag" Value="{Binding Source='h3745e72dg245ag4502g8774g8965baf256eb', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ConfirmBtn" Property="Content" Value="{Binding Source='h5ec59419gbcbag4572gbf24g259ad7f261f2', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ConfirmBtn" Property="Command" Value="{Binding UpdateCustomDifficultyCommand, Mode=OneTime}"/>

                    <Setter TargetName="DefaultCustom" Property="Content" Value="{Binding Source='hf8f0bd69gdbfeg4657gbb07gfda9602d4a08', Converter={StaticResource TranslatedStringConverter}}"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding CanOnlyChangeCustomMode}" Value="True"/>
                        <Condition Binding="{Binding IsMainMenu}" Value="False"/>
                    </MultiDataTrigger.Conditions>

                    <Setter TargetName="CancelBtn" Property="Command" Value="{Binding CustomEvent, Mode=OneTime}"/>
                    <Setter TargetName="CancelBtn" Property="CommandParameter" Value="CloseWidget"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsHost}" Value="False"/>
                        <Condition Binding="{Binding IsMainMenu}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ChangeDifficultyNotice" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ConfirmBtn" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="DefaultCustom" Property="Visibility" Value="Collapsed"/>
                </MultiDataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>