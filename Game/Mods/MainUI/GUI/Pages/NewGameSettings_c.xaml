<ls:UIWidget x:Name="DMSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             ls:UIWidget.ContextName="DMSettings"
             FocusLeft="UILeft" FocusRight="UIRight"
             FocusDown="UIDown" FocusUp="UIUp"
             ls:MoveFocus.FocusMovementMode="Closest"
             KeyboardNavigation.DirectionalNavigation="Continue"
             CanCacheFocusSurroundingElements="False"
             d:DataContext="{d:DesignInstance {x:Type ls:DCDMSettings}, IsDesignTimeCreatable=True}"
             d:DesignHeight="2160" d:DesignWidth="3840"
             ls:AttachedProperties.AutomationId ="{Binding (ls.UICanvas.CanvasLayout), RelativeSource={RelativeSource Mode=Self}, StringFormat='{}NewGameSettings_c_{0}'}">
    
    <ls:UIWidget.Template>
        <ControlTemplate>
            <ControlTemplate.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceDictionary Source="/Core;component/Library/OptionTemplates_c.xaml"/>
                    </ResourceDictionary.MergedDictionaries>

                    <BitmapImage x:Key="FadeHeaderImage" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/fade_header.png"/>
                    <BitmapImage x:Key="FadeFooterImage" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/fade_footer.png"/>
                    <BitmapImage x:Key="TitleBarImage" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/titlebar.png"/>
                    <BitmapImage x:Key="Selector" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/c_selector.png" />
                    <BitmapImage x:Key="BackgroundBanner" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/column_bg.png" />
                    <BitmapImage x:Key="Arrow" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/c_selectionArrow.png" />
                    <BitmapImage x:Key="BackgroundFade" UriSource="pack://application:,,,/Core;component/Assets/Shared/background_fade.png"/>

                    <Thickness x:Key="WidescreenMarginCustom">-2840,0,0,-100</Thickness>
                    <Thickness x:Key="LetterboxMarginCustom">-2460,0,0,-100</Thickness>
                    <Thickness x:Key="FullscreenMarginCustom">-2000,0,0,-100</Thickness>

                    <DataTemplate x:Key="RulesetDataTemplate">
                        <Grid x:Name="base" ls:MoveFocus.Focusable="True" Focusable="True">
                            <b:Interaction.Triggers>
                                <b:DataTrigger Binding="{Binding IsFocused, ElementName=base}" Value="True">
                                    <ls:LSPlaySound Sound="UI_Shared_Hover" />
                                    <b:ChangePropertyAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" PropertyName="SelectedItem" Value="{Binding .}"/>
                                </b:DataTrigger>
                            </b:Interaction.Triggers>

                            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" ClipToBounds="True" Margin="0,80,0,0">
                                <Image x:Name="DifficultyImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform/>
                                    </Image.RenderTransform>
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource IconIdToSourceConverter}">
                                            <Binding Source="Assets/DMSettings/"/>
                                            <Binding Path="AssetName"/>
                                            <Binding Source="_bg_d"/>
                                        </MultiBinding>
                                    </Image.Source>
                                    <Image.Effect>
                                        <ls:SaturationEffect Saturation="0"/>
                                    </Image.Effect>
                                </Image>

                                <Image x:Name="DifficultyImageHover" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform/>
                                    </Image.RenderTransform>
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource IconIdToSourceConverter}">
                                            <Binding Source="Assets/DMSettings/"/>
                                            <Binding Path="AssetName"/>
                                            <Binding Source="_bg_h"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                            </Grid>

                            <Image Source="{StaticResource BackgroundBanner}" Stretch="None" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                            <Image x:Name="SelectorImage" Source="{StaticResource Selector}" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Hidden"/>

                            <TextBlock x:Name="Title" Text="{Binding Title.Str}" 
                                           Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledTitleFontSize}" FontWeight="DemiBold"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Top" 
                                           Margin="0,1360,0,0"/>

                            <TextBlock x:Name="Description" Text="{Binding Description.Str}" 
                                           Foreground="{StaticResource LS_baseTxtColor}" FontSize="{StaticResource ScaledSmallishFontSize}" FontStyle="Italic" FontWeight="DemiBold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Top" TextAlignment="Center" 
                                           TextWrapping="Wrap" 
                                           Margin="0,1464,0,0" 
                                           MaxWidth="720"/>

                            <Image x:Name="LeftArrow" Source="{StaticResource Arrow}" Stretch="None" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,796,0,0" RenderTransformOrigin="0.5, 0.5" Visibility="Hidden">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="-1"/>
                                </Image.RenderTransform>
                            </Image>
                            <Image x:Name="RightArrow" Source="{StaticResource Arrow}" Stretch="None" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,796,0,0" Visibility="Hidden"/>
                        </Grid>

                        <DataTemplate.Triggers>
                            <!-- Any difficulty animation (in selection) -->
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Mode=TemplatedParent}}" Value="True">
                                <Setter TargetName="SelectorImage" Property="Source" Value="pack://application:,,,/Core;component/Assets/DMSettings/selector_active.png"/>
                                <Setter TargetName="SelectorImage" Property="Margin" Value="0,36,0,0"/>
                                <Setter TargetName="SelectorImage" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="LeftArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Title" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                                <Setter TargetName="Description" Property="Foreground" Value="{StaticResource LS_accent75TxtColor}"/>

                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="ImageHover" Storyboard="{StaticResource NewGameCard.ImageHover}"/>
                                    <StopStoryboard BeginStoryboardName="ImageDefault"/>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard x:Name="ImageDefault" Storyboard="{StaticResource NewGameCard.ImageDefault}"/>
                                    <StopStoryboard BeginStoryboardName="ImageHover"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="0">
                                <Setter TargetName="LeftArrow" Property="Visibility" Value="Hidden"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="4">
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Hidden"/>
                            </DataTrigger>


                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsHonour}" Value="True"/>
                                    <Condition Binding="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="0"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Hidden"/>
                            </MultiDataTrigger>

                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="NoArrow">
                                <Setter TargetName="LeftArrow" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="base" Property="Focusable" Value="False"/>
                                <Setter TargetName="base" Property="ls:MoveFocus.Focusable" Value="False"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="ImageHoverCustom" Storyboard="{StaticResource NewGameCard.ImageHover}"/>
                                </DataTrigger.EnterActions>
                            </DataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding DataContext.IsInCustomMode, ElementName=DMSettings}" Value="True"/>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Mode=TemplatedParent}}" Value="False"/>
                                </MultiDataTrigger.Conditions>

                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="DifficultyFadeOut">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                    <StopStoryboard BeginStoryboardName="DifficultyFadeIn"/>
                                </MultiDataTrigger.EnterActions>

                                <MultiDataTrigger.ExitActions>
                                    <BeginStoryboard x:Name="DifficultyFadeIn">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                    <StopStoryboard BeginStoryboardName="DifficultyFadeOut"/>
                                </MultiDataTrigger.ExitActions>
                            </MultiDataTrigger>

                            <DataTrigger Binding="{Binding DataContext.IsInCustomMode, ElementName=DMSettings}" Value="True">
                                <Setter TargetName="LeftArrow" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="base" Property="Focusable" Value="False"/>
                                <Setter TargetName="base" Property="ls:MoveFocus.Focusable" Value="False"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ResourceDictionary>
            </ControlTemplate.Resources>

            <Grid Background="{StaticResource LS_PopUpBackgroundColor}">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <ls:LSPlaySound Sound="UI_HUD_NewGameSettings_Open"/>
                        <ls:SetMoveFocusAction TargetName="DMSettings" FocusElement="{Binding ElementName=PresetList}"/>
                    </b:EventTrigger>

                    <b:DataTrigger Binding="{Binding IsOriginallyInCustomMode}" Value="True">
                        <b:ChangePropertyAction TargetName="PresetList" PropertyName="SelectedIndex" Value="3"/>
                        <b:ChangePropertyAction TargetName="carouselClipper" PropertyName="Margin" Value="{StaticResource WidescreenMarginCustom}"/>
                        <b:ChangePropertyAction TargetName="CustomSettingsHolder" PropertyName="Opacity" Value="1"/>
                    </b:DataTrigger>

                    <b:DataTrigger Binding="{Binding IsOriginallyInCustomMode}" Value="True">
                        <b:Interaction.Behaviors>
                            <b:ConditionBehavior>
                                <b:ConditionalExpression>
                                    <b:ComparisonCondition LeftOperand="{Binding Data.AspectRatio}" Operator="GreaterThanOrEqual" RightOperand="0.625"/>
                                </b:ConditionalExpression>
                            </b:ConditionBehavior>
                        </b:Interaction.Behaviors>
                        <b:ChangePropertyAction TargetName="carouselClipper" PropertyName="Margin" Value="{StaticResource LetterboxMarginCustom}"/>
                    </b:DataTrigger>


                    <b:DataTrigger Binding="{Binding IsOriginallyInCustomMode}" Value="True">
                        <b:Interaction.Behaviors>
                            <b:ConditionBehavior>
                                <b:ConditionalExpression>
                                    <b:ComparisonCondition LeftOperand="{Binding Data.AspectRatio}" Operator="GreaterThanOrEqual" RightOperand="0.75"/>
                                </b:ConditionalExpression>
                            </b:ConditionBehavior>
                        </b:Interaction.Behaviors>
                        <b:ChangePropertyAction TargetName="carouselClipper" PropertyName="Margin" Value="{StaticResource FullscreenMarginCustom}"/>
                    </b:DataTrigger>

                    <b:DataTrigger Binding="{Binding IsInCustomMode}" Value="False">
                        <ls:SetMoveFocusAction TargetName="DMSettings" FocusElement="{Binding ElementName=PresetList}"/>
                    </b:DataTrigger>
                </b:Interaction.Triggers>

                <ls:LSNineSliceImage x:Name="CurrentGameBackground" ImageSource="{StaticResource BackgroundFade}" Slices="0" IconWidth="3740" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Collapsed"/>
                <Image Source="{StaticResource FadeHeaderImage}" VerticalAlignment="Top" HorizontalAlignment="Center" Stretch="None"/>
                <Image Source="{StaticResource FadeFooterImage}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Stretch="None"/>

                <TextBlock x:Name="TitleText" Text="{Binding Source='h57a5735eg7213g4c3cg914cgbd1b5af276cc', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="{StaticResource ScaledHugeFontSize}" Foreground="{StaticResource LS_extraspecialTxtColor}" Margin="0,40,0,0"/>

                <Image Source="{StaticResource TitleBarImage}" VerticalAlignment="Top" HorizontalAlignment="Center" Stretch="None" Margin="0,148,0,0"/>

                <Grid x:Name="carouselClipper" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,-100" Width="3840">
                    <Grid.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="0" Color="Transparent"/>
                                <GradientStop Offset="0.05" Color="White"/>
                                <GradientStop Offset="0.95" Color="White"/>
                                <GradientStop Offset="1" Color="Transparent"/>
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Grid.OpacityMask>
                    <ListBox x:Name="PresetList" ItemsSource="{Binding Presets}" Margin="0,220,0,0" SelectedIndex="1" AlternationCount="{Binding Presets.Count}" ItemTemplate="{StaticResource RulesetDataTemplate}" Width="8000">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsPanelTemplate.Resources>
                                    <System:Double x:Key="IndexSizeModifier">-996</System:Double>
                                    <System:Double x:Key="LeftMarginSize">1420</System:Double>
                                </ItemsPanelTemplate.Resources>
                                <StackPanel x:Name="itemsPanel" IsItemsHost="True" Orientation="Horizontal" Background="Transparent" >
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform x:Name="itemsPanelTransform" X="0" Y="0"/>
                                    </StackPanel.RenderTransform>

                                    <b:Interaction.Triggers>

                                        <!-- Set initial sideways offset to animate from -->
                                        <b:EventTrigger EventName="Loaded">
                                            <b:ChangePropertyAction TargetName="itemsPanelTransform" PropertyName="X">
                                                <b:ChangePropertyAction.Value>
                                                    <MultiBinding Converter="{StaticResource AddMultipleConverter}">
                                                        <Binding ElementName="PresetList" Path="SelectedIndex" Converter="{StaticResource MultiplierConverter}" ConverterParameter="{StaticResource IndexSizeModifier}"/>
                                                        <Binding Source="{StaticResource LeftMarginSize}"/>
                                                    </MultiBinding>
                                                </b:ChangePropertyAction.Value>
                                            </b:ChangePropertyAction>

                                            <b:ControlStoryboardAction ControlStoryboardOption="Play">
                                                <b:ControlStoryboardAction.Storyboard>
                                                    <Storyboard TargetName="itemsPanelTransform" TargetProperty="X" FillBehavior="Stop">
                                                        <DoubleAnimation Duration="0:0:0">
                                                            <DoubleAnimation.To>
                                                                <MultiBinding Converter="{StaticResource AddMultipleConverter}">
                                                                    <Binding ElementName="PresetList" Path="SelectedIndex" Converter="{StaticResource MultiplierConverter}" ConverterParameter="{StaticResource IndexSizeModifier}"/>
                                                                    <Binding Source="{StaticResource LeftMarginSize}"/>
                                                                </MultiBinding>
                                                            </DoubleAnimation.To>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </b:ControlStoryboardAction.Storyboard>
                                            </b:ControlStoryboardAction>
                                        </b:EventTrigger>

                                        <!-- Animate sideways to selected item -->
                                        <b:PropertyChangedTrigger Binding="{Binding Path=SelectedValue, ElementName=PresetList}">
                                            <ls:LSPlaySound Sound="{Binding SelectedItem.AssetName, ElementName=PresetList, StringFormat='UI_HUD_MainMenu_{0}_Selected'}"/>

                                            <b:ControlStoryboardAction ControlStoryboardOption="Play">
                                                <b:ControlStoryboardAction.Storyboard>
                                                    <Storyboard FillBehavior="Stop" TargetName="itemsPanelTransform" TargetProperty="X">
                                                        <DoubleAnimation Duration="0:0:0.2" AccelerationRatio="0.25" DecelerationRatio="0.25">
                                                            <DoubleAnimation.To>
                                                                <MultiBinding Converter="{StaticResource AddMultipleConverter}">
                                                                    <Binding ElementName="PresetList" Path="SelectedIndex" Converter="{StaticResource MultiplierConverter}" ConverterParameter="{StaticResource IndexSizeModifier}"/>
                                                                    <Binding Source="{StaticResource LeftMarginSize}"/>
                                                                </MultiBinding>
                                                            </DoubleAnimation.To>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </b:ControlStoryboardAction.Storyboard>
                                            </b:ControlStoryboardAction>

                                            <b:ChangePropertyAction TargetName="itemsPanelTransform" PropertyName="X">
                                                <b:ChangePropertyAction.Value>
                                                    <MultiBinding Converter="{StaticResource AddMultipleConverter}">
                                                        <Binding ElementName="PresetList" Path="SelectedIndex" Converter="{StaticResource MultiplierConverter}" ConverterParameter="{StaticResource IndexSizeModifier}"/>
                                                        <Binding Source="{StaticResource LeftMarginSize}"/>
                                                    </MultiBinding>
                                                </b:ChangePropertyAction.Value>
                                            </b:ChangePropertyAction>
                                        </b:PropertyChangedTrigger>

                                    </b:Interaction.Triggers>

                                </StackPanel>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </Grid>

                <Control x:Name="CustomSettingsHolder" VerticalAlignment="Center" Opacity="0" ls:MoveFocus.IsMoveFocusScope="True"/>

                <TextBlock x:Name="ChangeDifficultyNotice" Text="{Binding Source='h63e32c4agf6d6g42dagb8f6g6ae105cb4f52', Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,160" Visibility="Collapsed"/>

                <StackPanel x:Name="ButtonPrompts" Style="{StaticResource ButtonHint.Container.Center}">
                    <ls:LSButton x:Name="CancelButton" 
                                 BoundEvent="UICancel" 
                                 Command="{Binding CustomEvent, Mode=OneTime}" 
                                 CommandParameter="CloseWidget" 
                                 Tag="{Binding Source='hfe928c0dgb014g4eb2g8c52g6ed43b026e20', Converter={StaticResource TranslatedStringConverter}}" 
                                 ContentTemplate="{StaticResource ControllerButtonHint}" 
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, ConverterParameter=UICancel, Converter={StaticResource FindInputEventConverter}}"/>
                    
                    <ls:LSButton x:Name="StartGameButton" 
                                 BoundEvent="UIAccept" 
                                 ContentTemplate="{StaticResource ControllerButtonHint}" 
                                 Command="{Binding StartNewGame, Mode=OneTime}" 
                                 CommandParameter="{Binding SelectedItem, ElementName=PresetList}" 
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, ConverterParameter=UIAccept, Converter={StaticResource FindInputEventConverter}}" 
                                 Tag="{Binding Source='hff3fbf0fgf6c5g427fga4dfgbb238c01cb4c', Converter={StaticResource TranslatedStringConverter}}" 
                                 OverwriteClickSound="UI_HUD_NewGameSettings_StartGame_Click"/>

                    <ls:LSButton x:Name="RestoreToDefaultButton" 
                                 BoundEvent="UIDelete" 
                                 Command="{Binding ResetToDefaultCommand, Mode=OneTime}" 
                                 Tag="{Binding Source='h0dcd297egde63g4e44g820dg07c21a2346d3', Converter={StaticResource TranslatedStringConverter}}" 
                                 ContentTemplate="{StaticResource ControllerButtonHint}" 
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, ConverterParameter=UIDelete, Converter={StaticResource FindInputEventConverter}}" 
                                 Visibility="Collapsed"/>

                    <ls:LSButton x:Name="MoreInfoButton" 
                                 BoundEvent="UIDelete" 
                                 Command="{Binding CustomEvent, Mode=OneTime}"
                                 CommandParameter="OpenMoreInfo"
                                 Tag="{Binding Source='h46c00fa7gbb38g480fg9a0fgb4232bec8658', Converter={StaticResource TranslatedStringConverter}}" 
                                 ContentTemplate="{StaticResource ControllerButtonHint}" 
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, ConverterParameter=UIDelete, Converter={StaticResource FindInputEventConverter}}" 
                                 Visibility="Collapsed"/>
                </StackPanel>

                <!-- Player slots -->
                <Control x:Name="PlayerSlots" Style="{StaticResource MinimalPlayerSlotsMenuStyle}"/>
            </Grid>

            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding IsMainMenu}" Value="False">
                    <Setter TargetName="CurrentGameBackground" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="PresetList" Property="SelectedValue" Value="{Binding CurrentPreset, Mode=OneTime}"/>
                    <Setter TargetName="TitleText" Property="Text" Value="{Binding Source='h37dad4aagf5cag4c29g90c2g88e3b50cbc9e', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="Command" Value="{Binding UpdateDifficultyCommand, Mode=OneTime}"/>
                    <Setter TargetName="StartGameButton" Property="Tag" Value="{Binding Source='h5ec59419gbcbag4572gbf24g259ad7f261f2', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="OverwriteClickSound" Value="UI_Shared_Apply"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Presets.Count}" Value="1">
                    <Setter TargetName="TitleText" Property="Text" Value="{Binding Source='h46616d84g0ebag4586g9230gca30c54e7596', Converter={StaticResource TranslatedStringConverter}}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding SelectedItem.IsHonour, ElementName=PresetList}" Value="True">
                    <Setter TargetName="MoreInfoButton" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding SelectedItem.IsCustom, ElementName=PresetList}" Value="True">
                    <Setter TargetName="StartGameButton" Property="Tag" Value="{Binding Source='h839dd40ag30f3g49e0g9135g411c9fcc81ba', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="Command" Value="{Binding ChangeDisplayCustomSettingsCommand, Mode=OneTime}"/>
                    <Setter TargetName="StartGameButton" Property="CommandParameter" Value="{StaticResource TrueValue}"/>
                    <Setter TargetName="StartGameButton" Property="OverwriteClickSound" Value="UI_Shared_Apply"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsInCustomMode}" Value="True">
                    <Setter TargetName="CurrentGameBackground" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="TitleText" Property="Text" Value="{Binding Source='h6f947303gef88g4640g8e4cg1ec35b5da79e', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="Tag" Value="{Binding Source='hff3fbf0fgf6c5g427fga4dfgbb238c01cb4c', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="Command" Value="{Binding StartNewCustomGame}"/>
                    <Setter TargetName="StartGameButton" Property="IsEnabled" Value="True"/>
                    <Setter TargetName="StartGameButton" Property="OverwriteClickSound" Value="UI_HUD_NewGameSettings_StartGame_Click"/>
                    <Setter TargetName="CancelButton" Property="Command" Value="{Binding ChangeDisplayCustomSettingsCommand, Mode=OneTime}"/>
                    <Setter TargetName="CancelButton" Property="CommandParameter" Value="{StaticResource FalseValue}"/>
                    <Setter TargetName="RestoreToDefaultButton" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="CustomSettingsHolder" Property="Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <ControlTemplate.Resources>
                                    <ImageSource x:Key="ItemBG">pack://application:,,,/Core;component/Assets/Options/li_bg.png</ImageSource>
                                    <ImageSource x:Key="ItemBGHL">pack://application:,,,/Core;component/Assets/Options/li_bg_active.png</ImageSource>

                                    <ControlTemplate x:Key="ComboBoxTemplate">
                                        <ls:LSComboBox x:Name="comboBox" 
                                                       ItemsSource="{Binding Options, Mode=OneWay}" 
                                                       SelectedItem="{Binding SelectedValue, Mode=TwoWay}" 
                                                       Foreground="{StaticResource LS_specialTxtColor}" 
                                                       Style="{StaticResource OptionsComboBoxStyle}" 
                                                       Text="{Binding SelectedValue.Name, Mode=OneWay}" 
                                                       SoundID="UI_Shared_Hover" 
                                                       IsEnabled="{Binding DataContext.IsHost, ElementName=DMSettings}"
                                                       ActionNextEvent="UIRight" 
                                                       ActionPrevEvent="UILeft">
                                            <b:Interaction.Triggers>
                                                <b:PropertyChangedTrigger Binding="{Binding SelectedValue}">
                                                    <b:InvokeCommandAction Command="{Binding DataContext.ValueChanged, ElementName=DMSettings, Mode=OneTime}" CommandParameter="{Binding .}"/>
                                                </b:PropertyChangedTrigger>
                                            </b:Interaction.Triggers>
                                        </ls:LSComboBox>

                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EditableInGame}" Value="False">
                                                <Setter TargetName="comboBox" Property="IsEnabled" Value="False"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding DataContext.IsMainMenu, ElementName=DMSettings}" Value="True">
                                                <Setter TargetName="comboBox" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Metadata, ElementName=DMSettings}" Value="Lobby">
                                                <Setter TargetName="comboBox" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>

                                    <ControlTemplate x:Key="TickBoxTemplate">
                                        <ls:LSTickBox x:Name="tickBox" 
                                                      Style="{StaticResource TickBoxStyle}" 
                                                      IsChecked="{Binding Value}" 
                                                      SoundID="UI_Shared_Hover" 
                                                      IsEnabled="{Binding DataContext.IsHost, ElementName=DMSettings}"
                                                      ActionNextEvent="UIRight"
                                                      ActionPrevEvent="UILeft">
                                            <b:PropertyChangedTrigger Binding="{Binding Value}">
                                                <b:InvokeCommandAction Command="{Binding DataContext.ValueChanged, ElementName=DMSettings, Mode=OneTime}" CommandParameter="{Binding .}"/>
                                            </b:PropertyChangedTrigger>
                                        </ls:LSTickBox>

                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EditableInGame}" Value="False">
                                                <Setter TargetName="tickBox" Property="IsEnabled" Value="False"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding DataContext.IsMainMenu, ElementName=DMSettings}" Value="True">
                                                <Setter TargetName="tickBox" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Metadata, ElementName=DMSettings}" Value="Lobby">
                                                <Setter TargetName="tickBox" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>

                                    <ControlTemplate x:Key="SliderTemplate">
                                        <ls:LSSlider x:Name="element" 
                                                     Style="{StaticResource OptionsSliderStyle}"
                                                     Template="{StaticResource OptionsSliderTemplate}"
                                                     Value="{Binding Value}" 
                                                     Minimum="{Binding Min}" 
                                                     Maximum="{Binding Max}" 
                                                     IsSnapToTickEnabled="True" 
                                                     SmallChange="{Binding Step}" 
                                                     LargeChange="{Binding Step, Converter={StaticResource MultiplierConverter}, ConverterParameter=3}" 
                                                     TickFrequency="{Binding Step}" 
                                                     IsEnabled="{Binding DataContext.IsHost, ElementName=DMSettings}">
                                            <b:Interaction.Triggers>
                                                <b:EventTrigger EventName="ValueChanged">
                                                    <b:InvokeCommandAction Command="{Binding DataContext.ValueChanged, ElementName=DMSettings, Mode=OneTime}" CommandParameter="{Binding .}"/>
                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>
                                        </ls:LSSlider>

                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EditableInGame}" Value="False">
                                                <Setter TargetName="element" Property="IsEnabled" Value="False"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding DataContext.IsMainMenu, ElementName=DMSettings}" Value="True">
                                                <Setter TargetName="element" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Metadata, ElementName=DMSettings}" Value="Lobby">
                                                <Setter TargetName="element" Property="IsEnabled" Value="True"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ControlTemplate.Resources>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="900"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*" MinWidth="600"/>
                                    </Grid.ColumnDefinitions>

                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Loaded">
                                            <ls:SetMoveFocusAction TargetName="DMSettings" FocusElement="{Binding ElementName=Options}"/>
                                        </b:EventTrigger>

                                        <b:EventTrigger EventName="LocalFocusChanged">
                                            <ls:LSPlaySound Sound="UI_Shared_Hover" />
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>

                                    <ItemsControl x:Name="Options" 
                                                  Grid.Column="1" 
                                                  VerticalAlignment="Top" 
                                                  HorizontalAlignment="Center" 
                                                  AlternationCount="{Binding CustomSettings.Count}" 
                                                  ItemsSource="{Binding CustomSettings}" 
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.ScrollUnit="Pixel"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  Height="1680">
                                        <ItemsControl.Template>
                                            <ControlTemplate>
                                                <ls:LSScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible" Template="{StaticResource StretchingScrollViewerTemplate}">
                                                    <ItemsPresenter/>
                                                </ls:LSScrollViewer>
                                            </ControlTemplate>
                                        </ItemsControl.Template>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel Orientation="Vertical" VerticalAlignment="Top"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid x:Name="Container" Margin="0,0,0,12" MaxWidth="1800">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition x:Name="col0" Width="*"/>
                                                        <ColumnDefinition x:Name="col1" Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Image x:Name="Box" Grid.Column="0" Grid.ColumnSpan="2" Source="{StaticResource ListButtonBg}" Stretch="Fill" Height="{Binding ActualHeight, ElementName=label, Converter={StaticResource AddConverter}, ConverterParameter=28}"/>
                                                    <TextBlock x:Name="label" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="60,0,0,0" TextWrapping="Wrap" MaxWidth="1100" ls:TextBlockFormatter.SourceText="{Binding Text}" FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_accent75TxtColor}"/>
                                                    <Control x:Name="content" Grid.Column="1" IsEnabled="False" VerticalAlignment="Center"  HorizontalAlignment="Right" Template="{StaticResource ComboBoxTemplate}" Margin="20,0,60,0"/>
                                                    <Control x:Name="Frame" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Hidden" Style="{StaticResource FocusableBorderStyle}" Width="{Binding ActualWidth, ElementName=Box}" Height="{Binding ActualHeight, ElementName=Box}"/>
                                                </Grid>

                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding ListItemType}" Value="TickBox">
                                                        <Setter Property="Template" Value="{StaticResource TickBoxTemplate}" TargetName="content"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ListItemType}" Value="Slider">
                                                        <Setter Property="Template" Value="{StaticResource SliderTemplate}" TargetName="content"/>
                                                    </DataTrigger>

                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding EditableInGame}" Value="False"/>
                                                            <Condition Binding="{Binding DataContext.IsMainMenu, ElementName=DMSettings}" Value="False"/>
                                                            <Condition Binding="{Binding Metadata, ElementName=DMSettings}" Value=""/>
                                                        </MultiDataTrigger.Conditions>

                                                        <Setter TargetName="label" Property="Opacity" Value="{StaticResource DisabledOpacity}"/>
                                                        <Setter TargetName="content" Property="Opacity" Value="{StaticResource DisabledOpacity}"/>
                                                    </MultiDataTrigger>

                                                    <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                                        <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                                                    </DataTrigger>
                                                    
                                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="True">
                                                        <Setter TargetName="Container" Property="Width" Value="1400"/>
                                                    </DataTrigger>

                                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                                        <Setter TargetName="Container" Property="Width" Value="1200"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding (ls:MoveFocus.IsFocused), RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                                        <Setter TargetName="Box" Property="Source" Value="{StaticResource ListButtonBg_h}"/>
                                                        <Setter TargetName="content" Property="IsEnabled" Value="True"/>
                                                        <Setter TargetName="Frame" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                                                    </DataTrigger>

                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding EditableInGame}" Value="False"/>
                                                            <Condition Binding="{Binding DataContext.IsMainMenu, ElementName=DMSettings}" Value="False"/>
                                                            <Condition Binding="{Binding Metadata, ElementName=DMSettings}" Value=""/>
                                                            <Condition Binding="{Binding (ls:MoveFocus.IsFocused), RelativeSource={RelativeSource Mode=Self}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="content" Property="IsEnabled" Value="False"/>
                                                    </MultiDataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Focusable" Value="True"/>
                                                <Setter Property="ls:MoveFocus.Focusable" Value="True"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>

                                    <StackPanel x:Name="SelectedItemDescription" Grid.Column="2" Margin="80,0,80,0" Orientation="Vertical" DataContext="{Binding FocusedElement.DataContext, ElementName=DMSettings}">
                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Text}" TextAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource LS_tint100}" FontSize="{StaticResource ScaledLargeFontSize}"/>

                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Description}" TextAlignment="Left" TextWrapping="Wrap" Margin="0,20"/>

                                        <ListBox ItemsSource="{Binding Options}" Visibility="{Binding Options, Converter={StaticResource NullToCollapsedConverter}}" HorizontalAlignment="Left">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>

                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type ls:VMEnumData}">
                                                    <DataTemplate.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                                        </Style>

                                                        <ImageSource x:Key="SelectedOptionIcon">pack://application:,,,/Core;component/Assets/CharacterPanel/ico_bullet_d.png</ImageSource>
                                                    </DataTemplate.Resources>

                                                    <StackPanel x:Name="ItemPanel" Orientation="Vertical" Margin="0,0,0,20" MaxWidth="800" HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image x:Name="SelectedIcon" Source="{StaticResource SelectedOptionIcon}" Stretch="None" Visibility="Collapsed" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                                            <TextBlock x:Name="Title" ls:TextBlockFormatter.SourceText="{Binding Name}" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledIntermediateFontSize}"/>
                                                        </StackPanel>

                                                        <TextBlock ls:TextBlockFormatter.SourceText="{Binding Description}" Foreground="{StaticResource LS_baseTxtColor}" FontSize="{StaticResource ScaledDefaultFontSize}"/>
                                                    </StackPanel>

                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualConverter}">
                                                                    <Binding Path=""/>
                                                                    <Binding Path="DataContext.SelectedItem" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter TargetName="SelectedIcon" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                                                        </DataTrigger>

                                                        <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                                            <Setter TargetName="ItemPanel" Property="MaxWidth" Value="600"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <TextBlock x:Name="DescriptionText" ls:TextBlockFormatter.SourceText="{Binding Source='h3c46af69gfe72g49f1gb524g8bf318295dc3', Converter={StaticResource TranslatedStringConverter}}" Visibility="{Binding EditableInGame, Converter={StaticResource BoolToCollapsedConverter}}" TextWrapping="Wrap" Foreground="{StaticResource LS_accent100TxtColor}"/>
                                    </StackPanel>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <DataTrigger  Binding="{Binding DataContext.Data.AspectRatio, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}} , Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True">
                                        <Setter TargetName="SelectedItemDescription" Property="Margin" Value="0,40,0,0"/>
                                        <Setter TargetName="DescriptionText" Property="Margin" Value="0,40,0,0"/>
                                        <Setter TargetName="SelectedItemDescription" Property="MaxWidth" Value="600"/>
                                        <Setter TargetName="DescriptionText" Property="MaxWidth" Value="600"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="CustomSettingsFadeIn">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CustomSettingsHolder" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.3" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="CustomSettingsFadeOut"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard x:Name="CustomSettingsFadeOut">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CustomSettingsHolder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <BeginStoryboard x:Name="PresetListPanToRight">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="0,0,0,-100" Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="CustomSettingsFadeIn"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <!-- Taller screen ratio (16:10 and plus) -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="True"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="False"/>
                    </MultiDataTrigger.Conditions>

                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PresetListPanToLeftTallScreen">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="{StaticResource LetterboxMarginCustom}"  Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="PresetListPanToRight"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeft"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftWideScreen"/>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <!-- For 4:3 screen ratios and squarer -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.74}" Value="True"/>
                    </MultiDataTrigger.Conditions>

                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PresetListPanToLeft">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="{StaticResource FullscreenMarginCustom}"  Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="PresetListPanToRight"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftTallScreen"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftWideScreen"/>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <!-- Wide screen counterparts -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.62}" Value="False"/>
                    </MultiDataTrigger.Conditions>

                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PresetListPanToLeftWideScreen">
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetName="carouselClipper" Storyboard.TargetProperty="Margin" To="{StaticResource WidescreenMarginCustom}" Duration="0:0:0.5">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                        <StopStoryboard BeginStoryboardName="PresetListPanToRight"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeft"/>
                        <StopStoryboard BeginStoryboardName="PresetListPanToLeftTallScreen"/>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Presets.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="False">
                    <Setter TargetName="StartGameButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding IsMainMenu}" Value="False"/>
                    </MultiDataTrigger.Conditions>

                    <Setter TargetName="TitleText" Property="Text" Value="{Binding Source='h3745e72dg245ag4502g8774g8965baf256eb', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="Tag" Value="{Binding Source='h5ec59419gbcbag4572gbf24g259ad7f261f2', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="StartGameButton" Property="Command" Value="{Binding UpdateCustomDifficultyCommand, Mode=OneTime}"/>
                    <Setter TargetName="StartGameButton" Property="OverwriteClickSound" Value="UI_Shared_Apply"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding IsOriginallyInCustomMode}" Value="True"/>
                        <Condition Binding="{Binding IsMainMenu}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="CancelButton" Property="Command" Value="{Binding CustomEvent, Mode=OneTime}"/>
                    <Setter TargetName="CancelButton" Property="CommandParameter" Value="CloseWidget"/>

                    <Setter TargetName="RestoreToDefaultButton" Property="Tag" Value="{Binding Source='hf8f0bd69gdbfeg4657gbb07gfda9602d4a08', Converter={StaticResource TranslatedStringConverter}}"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsHost}" Value="False"/>
                        <Condition Binding="{Binding IsMainMenu}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ChangeDifficultyNotice" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="StartGameButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="RestoreToDefaultButton" Property="Visibility" Value="Collapsed"/>
                </MultiDataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>