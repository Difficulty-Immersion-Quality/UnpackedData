<ls:UIWidget x:Name="OverheadInfo_c"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Template="{StaticResource Hud.Root}"
             ls:UIWidget.ContextName="Overheads" d:DataContext="{d:DesignInstance {x:Type ls:DCOverheads}, IsDesignTimeCreatable=True}"
             d:DesignWidth="3840" d:DesignHeight="2160"
             ls:AttachedProperties.AutomationId ="{Binding (ls.UICanvas.CanvasLayout), RelativeSource={RelativeSource Mode=Self}, StringFormat='{}OverheadInfo_c_{0}'}">

    <ls:UIWidget.ContentTemplate>
        <DataTemplate>
            <DataTemplate.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceDictionary Source="/Core;component/Library/OverheadPassives.xaml"/>
                    </ResourceDictionary.MergedDictionaries>

                    <!-- Constants -->
                    <System:Double x:Key="TextOutlineThickness">4</System:Double>

                    <!-- passive rolls -->
                    <System:Double x:Key="Overhead.PassiveRolls.IconWidth">92</System:Double>
                    <System:Double x:Key="Overhead.PassiveRolls.IconWidthOffset">-52</System:Double>
                    <System:Double x:Key="Overhead.PassiveRolls.IconHeight">104</System:Double>
                    <Style x:Key="Overhead.PassiveRolls.Text" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="{Binding DataContext.CurrentPlayer.UIOptions.OverheadFontSizeModifier, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource AddConverter}, ConverterParameter={StaticResource MediumFontSize}}"/>
                        <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}" />
                        <Setter Property="Margin" Value="24 0 0 0" />
                        <Setter Property="noesis:Text.Stroke" Value="{StaticResource Dialogue.Stroke}"/>
                        <Setter Property="noesis:Text.StrokeThickness" Value="3"/>
                    </Style>

                    <Style x:Key="HealthTextBlockStyle" TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="noesis:Text.Stroke" Value="{StaticResource Dialogue.Stroke}"/>
                        <Setter Property="noesis:Text.StrokeThickness" Value="2"/>
                        <Setter Property="FontSize" Value="{DynamicResource MediumFontSize}"/>
                        <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                    </Style>

                    <Style x:Key="CollapsableTextBlock" TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Storyboard x:Key="FadeOutSubtitles">
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InnerDialogSubtitle" Storyboard.TargetProperty="Opacity">
                            <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>

                    <Storyboard x:Key="FadeInSubtitles">
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InnerDialogSubtitle" Storyboard.TargetProperty="Opacity">
                            <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </ResourceDictionary>
            </DataTemplate.Resources>
            <Grid>
                <Grid
                    x:Name="InnerDialogSubtitle"
                    Margin="0,0,0,420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Opacity="0">
                    <Rectangle Grid.ColumnSpan="2">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#00000000" />
                                <GradientStop Offset="0.15" Color="#6F000000" />
                                <GradientStop Offset="0.85" Color="#6F000000" />
                                <GradientStop Offset="1" Color="#00000000" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#00000000" />
                                <GradientStop Offset="0.05" Color="#FF000000" />
                                <GradientStop Offset="0.95" Color="#FF000000" />
                                <GradientStop Offset="1" Color="#00000000" />
                            </LinearGradientBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <TextBlock
                        VerticalAlignment="Bottom"
                        Margin="20,0"
                        noesis:Text.StrokeThickness="{DynamicResource TextOutlineThickness}"
                        FontSize="{Binding DataContext.CurrentPlayer.UIOptions.OverheadFontSizeModifier, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource AddConverter}, ConverterParameter={StaticResource BigFontSize}}"
                        TextAlignment="Center"
                        MaxWidth="1600"
                        TextWrapping="Wrap"
                        Foreground="{StaticResource LS_accent100TxtColor}"
                        Effect="{StaticResource HUD.DropShadow}">
                        <TextBlock.Inlines>
                            <Run x:Name="speakerName">
                                <Run.Text>
                                    <Binding
                                        Mode="OneWay"
                                        Path="CurrentSpeaker"
                                        StringFormat="{}{0}: " />
                                </Run.Text>
                            </Run><Span ls:TextBlockFormatter.SourceText="{Binding CurrentSubtitle}" />
                        </TextBlock.Inlines>
                        <noesis:Text.Stroke>
                            <SolidColorBrush Opacity="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=TextBlock}, Path=Foreground.Opacity}" Color="{DynamicResource TextOutlineColor}" />
                        </noesis:Text.Stroke>
                    </TextBlock>

                </Grid>
                <!-- show all the overheads for this player (to support split-screen) -->
                <ItemsControl x:Name="OverheadRoot" ItemsSource="{Binding CurrentPlayer.Overheads}" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas ClipToBounds="{Binding Data.IsCameraSplit}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <!-- position "over head" -->
                            <Setter Property="Canvas.Left" Value="{Binding Position.X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Position.Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type ls:LocalPlayerEntityOverheads}">
                            <Canvas x:Name="OverheadCanvas" Height="4">
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform X="{Binding ElementName=ContentRoot, Path=ActualWidth,Converter={StaticResource MultiplierConverter}, ConverterParameter=-0.5}" Y="0"/>
                                    </TransformGroup>
                                </Canvas.RenderTransform>
                                <StackPanel Width="2048" Canvas.Bottom="0" Canvas.Left="-1024" VerticalAlignment="Bottom" DataContext="{Binding EntityOverheads}">
                                    <ItemsControl ItemsSource="{Binding Dialogues}" ItemTemplate="{StaticResource TextTemplate}" ItemsPanel="{StaticResource StackedOverheadsPanel}" MaxWidth="1000"/>
                                    <ItemsControl ItemsSource="{Binding Messages}" ItemTemplate="{StaticResource TextTemplate}" ItemsPanel="{StaticResource StackedOverheadsPanel}"/>

                                    <!--Targeting overhead when aiming that entity-->
                                    <DockPanel HorizontalAlignment="Center" Visibility="{Binding Target.IsTargeted, Converter={StaticResource BoolToVisibleConverter}}">
                                        <!--Set size to 0 if needs to be collapsed so no empty space over the head if no targeting-->

                                        <!--<TextBlock ls:TextBlockFormatter.SourceText="{Binding Target}"/>-->
                                        <Image DockPanel.Dock="Left" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Source" Value="{x:Null}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Acid">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionAcid.png"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Cold">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionCold.png"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Fire">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionFire.png"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Force">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionForce.png"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Lightning">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionLightening.png"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Necrotic">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionNecrotic.png"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Target.AttackType}" Value="Target">
                                                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_actionTarget.png"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <Grid Height="100">
                                            <Image HorizontalAlignment="Center" Stretch="None" Grid.Row="0" Margin="-16,0,0,0">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="{x:Null}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Target.BuffType}" Value="-1">
                                                                <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_debuffed.png"/>
                                                                <Setter Property="VerticalAlignment" Value="Bottom"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Target.BuffType}" Value="1">
                                                                <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Overhead/ico_buffed.png"/>
                                                                <Setter Property="VerticalAlignment" Value="Top"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock ls:TextBlockFormatter.SourceText="{Binding Target.Text}"
                                                   FontSize="{StaticResource BigFontSize}" FontWeight="Bold"
                                                   HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                   noesis:Text.StrokeThickness="{StaticResource TextOutlineThickness}">
                                            <noesis:Text.Stroke>
                                                <SolidColorBrush Color="{DynamicResource TextOutlineColor}" Opacity="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=TextBlock}, Path=Foreground.Opacity}"/>
                                            </noesis:Text.Stroke>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource LS_PrimaryColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Target.BuffType}" Value="-1">
                                                                <Setter Property="Foreground" Value="{DynamicResource LS_DebuffedTextColor}"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Target.BuffType}" Value="1">
                                                                <Setter Property="Foreground" Value="{DynamicResource LS_BuffedTextColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DockPanel>

                                    <!-- Passive rolls -->
                                    <ItemsControl x:Name="PassiveRolls" ItemsSource="{Binding PassiveRolls}" ItemTemplate="{StaticResource Overhead.PassiveRoll}" ItemsPanel="{StaticResource StackedOverheadsPanel}">
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.TargetObject.Combat,
                                                                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}},
                                                                            Converter={StaticResource NullToBoolFalseConverter}}" Value="True"/>
                                                            <Condition Binding="{Binding Type}" Value="SavingThrow"/>
                                                            <Condition Binding="{Binding Successful}" Value="False"/>
                                                            <Condition Binding="{Binding IsSkillCheck}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>

                                    <!-- Death Saving Thow -->
                                    <ContentControl Template="{StaticResource Overhead.DeathSavingThrow}" DataContext="{Binding DeathSavingThrow}" HorizontalAlignment="Center">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="Visibility" Value="Collapsed" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DeathSavingThrowInfo.Active}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TimeRemaining, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>

                                    <!-- TargetInfo (hidden for now for experimentation - GUS-215662) -->
                                    <!--<ContentControl Template="{StaticResource TargetInfo}" DataContext="{Binding TargetObject}" HorizontalAlignment="Center" Visibility="{Binding ., Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}"/>-->
                                </StackPanel>
                            </Canvas>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding PlayerId, RelativeSource={RelativeSource AncestorType=ls:UIWidget}}" Value="1">
                                    <Setter TargetName="OverheadCanvas" Property="RenderTransform">
                                        <Setter.Value>
                                            <TransformGroup>
                                                <TranslateTransform X="0" Y="0"/>
                                            </TransformGroup>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding PlayerId, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="1">
                    <Setter TargetName="OverheadRoot" Property="Visibility" Value="Visible" />
                </DataTrigger>

                <DataTrigger Binding="{Binding Data.IsCameraSplit}" Value="True">
                    <Setter TargetName="OverheadRoot" Property="Visibility" Value="Visible" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentSpeaker}" Value="">
                    <Setter TargetName="speakerName" Property="Text" Value="" />
                </DataTrigger>
                <DataTrigger Value="False">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualConverter}">
                            <Binding Path="CurrentSubtitle" />
                            <Binding Source="" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <DataTrigger.EnterActions>
                        <StopStoryboard BeginStoryboardName="FadeOutSubtitlesStoryBoard" />
                        <BeginStoryboard x:Name="FadeInSubtitlesStoryBoard" Storyboard="{StaticResource FadeInSubtitles}" />
                    </DataTrigger.EnterActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentSubtitleDuration, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.3}" Value="False">
                    <DataTrigger.EnterActions>
                        <StopStoryboard BeginStoryboardName="FadeInSubtitlesStoryBoard" />
                        <BeginStoryboard x:Name="FadeOutSubtitlesStoryBoard" Storyboard="{StaticResource FadeOutSubtitles}" />
                    </DataTrigger.EnterActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentPlayer.UIData.Notification.Type}" Value="CombatStarted">
                    <Setter TargetName="InnerDialogSubtitle" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </ls:UIWidget.ContentTemplate>
</ls:UIWidget>