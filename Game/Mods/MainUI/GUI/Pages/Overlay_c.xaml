                        <Condition Binding="{Binding Data.LocalPlayers[0].SelectedCharacter.InTurnBasedMode}" Value="True"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].SelectedCharacter.InTurnBasedMode}" Value="True"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].SelectedCharacter.IsOwnerActiveInSplitscreenFullscreenTurn}" Value="True"/>
                        <Condition Binding="{Binding Layout}" Value="Common" />
