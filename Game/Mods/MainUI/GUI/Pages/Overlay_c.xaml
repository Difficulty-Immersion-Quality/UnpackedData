                    <Setter TargetName="ForceSplitScreenIndicator" Property="HorizontalAlignment" Value="Left"/>
                    <Setter TargetName="ForceSplitScreenIndicator" Property="Opacity" Value="1"/>
                    <Setter TargetName="ToggleSplitScreen" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ForceSplitScreenContent" Property="Opacity" Value="0"/>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Margin" Value="30,0,0,56"/>
                    <Setter TargetName="ForceSplitScreenIndicator" Property="Margin" Value="0,0,0,0"/>
                    <Setter TargetName="ButtonPromptHolder" Property="Margin" Value="26,0,0,150"/>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="HorizontalAlignment" Value="Left"/>
                    <Setter TargetName="ToggleSplitScreenMergedTextRight" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ToggleSplitScreenMergedButton" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>

                <!-- Rearrange Force Split Screen indicator for player 2 in combat with Full Screen Shared Initiative OFF-->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsFullScreenSharedInitiativeEnabled}" Value="False"/>
