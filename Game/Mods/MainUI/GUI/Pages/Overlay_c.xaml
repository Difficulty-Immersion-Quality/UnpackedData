                        <Condition Binding="{Binding Data.LocalPlayers[0].SelectedCharacter.IsOwnerActiveInSplitscreenFullscreenTurn}" Value="False"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].SelectedCharacter.IsOwnerActiveInSplitscreenFullscreenTurn}" Value="False"/>
                        <Condition Binding="{Binding Layout}" Value="Common" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Margin" Value="0,0,30,56"/>
                    <Setter TargetName="ButtonPromptHolder" Property="Margin" Value="0,0,26,150"/>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="HorizontalAlignment" Value="Right"/>
                    <Setter TargetName="ToggleSplitScreenMergedTextLeft" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ToggleSplitScreenMergedButton" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ForceSplitScreenIndicator" Property="Opacity" Value="1"/>
