                    <Setter TargetName="OpenActionRadials" Property="IsEnabled" Value="False" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPlayer.UIData.CharacterCreationMode}" Value="Creation">
                    <Setter TargetName="ButtonPromptHolder" Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPlayer.UIData.ActiveState}" Value="ProofOfHonour">
                    <Setter TargetName="ButtonPromptHolder" Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPlayer.UIData.ActiveState}" Value="Book">
                    <Setter TargetName="ButtonPromptHolder" Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPlayer.UIData.ActiveState}" Value="MessageBox">
                    <Setter TargetName="ButtonPromptHolder" Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.IsOwnerActiveInSplitscreenFullscreenTurn}" Value="True"/>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.IsCasting}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ActionCancelButton" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.IsOwnerActiveInSplitscreenFullscreenTurn}" Value="True"/>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.Moving}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ActionCancelButton" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasInputEnabled, ElementName=Overlay}" Value="True"/>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.IsCasting}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ActionCancelButton" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>

                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualConverter}">
                            <Binding Path="CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.CurrentSpellTask.Name.Str"/>
                            <Binding Path="CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.MainMeleeAttack.Spell.Name"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter TargetName="ActionCancelButton"  Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualConverter}">
                            <Binding Path="CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.CurrentSpellTask.Name.Str"/>
                            <Binding Path="CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.MainRangedAttack.Spell.Name"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter TargetName="ActionCancelButton"  Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <!-- Hide world text for secondary player while the camera is merged -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Layout}" Value="Common"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="2"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="WorldTextContainer" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Layout}" Value="Common">
                    <Setter TargetName="OpenActionRadials" Property="Visibility" Value="Visible" />
                    <Setter TargetName="OpenActionRadialsSplitAlt" Property="Visibility" Value="Collapsed" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPlayer.UIData.WorldContextMenu.Visible}" Value="True">
                    <Setter TargetName="ExamineTarget" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="OpenContextMenu" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="OpenActionRadials" Property="Opacity" Value="0"/>
                    <Setter TargetName="OpenActionRadials" Property="Height" Value="0"/>
                    <Setter TargetName="ActionCancelButton" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="SelectButtonPrompt" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <!-- Hide Button Prompts in split screen when player has full UI and other player activates their UI -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.UIData.ActiveState}" Value="PlayerPortraitsActive"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="1"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].UIData.ActiveState}" Value="PlayerPortraitsActive"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="2"/>
                        <Condition Binding="{Binding Data.LocalPlayers[0].UIData.ActiveState}" Value="PlayerPortraitsActive"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.UIData.ActiveState}" Value="ShortcutMenu"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="1"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].UIData.ActiveState}" Value="ShortcutMenu"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="2"/>
                        <Condition Binding="{Binding Data.LocalPlayers[0].UIData.ActiveState}" Value="ShortcutMenu"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <!-- Block actions when in merged split screen combat and it's not your turn-->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsFullScreenSharedInitiativeEnabled}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.IsCurrentTurn}" Value="False"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Layout}" Value="Common" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="OpenActionRadialsSplitAlt" Property="IsEnabled" Value="False" />
                    <Setter TargetName="OpenActionRadialsEnd" Property="IsEnabled" Value="False" />
                    <Setter TargetName="OpenActionRadials" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ButtonPromptHolder" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ButtonPromptHolder" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="JumpAction" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ToggleGroupHideBinding" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ExamineSurfaceCommand" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ToggleLightSource" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ExamineCommand" Property="IsEnabled" Value="False" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsFullScreenSharedInitiativeEnabled}" Value="True"/>
                        <Condition Binding="{Binding CurrentPlayer.SelectedCharacter.IsOwnerActiveInSplitscreenFullscreenTurn}" Value="False"/>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding Data.LocalPlayers.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True"/>
                        <Condition Binding="{Binding Layout}" Value="Common" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="OpenActionRadialsSplitAlt" Property="IsEnabled" Value="False" />
                    <Setter TargetName="OpenActionRadialsEnd" Property="IsEnabled" Value="False" />
                    <Setter TargetName="OpenActionRadials" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ButtonPromptHolder" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ButtonPromptHolder" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="JumpAction" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ToggleGroupHideBinding" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ExamineSurfaceCommand" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ToggleLightSource" Property="IsEnabled" Value="False" />
                    <Setter TargetName="ExamineCommand" Property="IsEnabled" Value="False" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="2"/>
                        <Condition Binding="{Binding Data.LocalPlayers[0].UIData.ActiveState}" Value="Paused"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="False"/>
                        <Condition Binding="{Binding CurrentPlayer.PlayerId}" Value="1"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].UIData.ActiveState}" Value="Paused"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ButtonPromptHolder" Property="Opacity" Value="0" />
                    <Setter TargetName="ToggleSplitScreenMerged" Property="Opacity" Value="0" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="True"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].UIData.ActiveState}" Value="ContainerInventory"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ForceSplitScreenContent" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="True"/>
                        <Condition Binding="{Binding Data.LocalPlayers[0].UIData.ActiveState}" Value="ContainerInventory"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ForceSplitScreenContent" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="True"/>
                        <Condition Binding="{Binding Data.LocalPlayers[1].UIData.ActiveState}" Value="Trade"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ForceSplitScreenContent" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Data.IsCameraSplit}" Value="True"/>
                        <Condition Binding="{Binding Data.LocalPlayers[0].UIData.ActiveState}" Value="Trade"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ForceSplitScreenContent" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>

            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>
