<ls:UIWidget x:Name="PinnedTooltips"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:b="http://schemas.microsoft.com/xaml/behaviors" 
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
			 mc:Ignorable="d"
             UpdatePinnedTooltipList = "True"
             d:DesignHeight="2160" d:DesignWidth="3840"
			 d:DataContext="{d:DesignInstance {x:Type ls:Widget}, IsDesignTimeCreatable=True}">
    
    <ls:UIWidget.Template>
        <ControlTemplate>
            <Grid x:Name="Root">
                <!-- Pinned tooltips stuff -->
                <ls:LSElementPanel x:Name="PinnedTooltipsPanel" PlayerId="{Binding CurrentPlayer.PlayerId}" ElementList="{Binding PinnedTooltipList, ElementName=PinnedTooltips }" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClickCommand="{Binding RemovePinnedTooltipCommand, ElementName=PinnedTooltips}" Visibility="{Binding PinnedTooltipList.Count, ElementName=PinnedTooltips, Converter={StaticResource CountToVisibilityConverter}}" Background="{StaticResource LS_PopUpBackgroundColor}" IsHitTestVisible="{Binding CurrentPlayer.UIData.IsClearingPinnedTooltips, Converter={StaticResource InvertBoolConverter}}">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseLeftButtonUp">
                            <b:InvokeCommandAction Command="{Binding RequestClearPinnedTooltipsCommand, ElementName=PinnedTooltips}"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </ls:LSElementPanel>

                <ls:LSInputBinding x:Name="RequestClearInputBinding" BoundEvent="ToggleInGameMenu" Command="{Binding RequestClearPinnedTooltipsCommand, ElementName=PinnedTooltips}" IsEnabled="{Binding PinnedTooltips.Count,ElementName=PinnedTooltips, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}">
                </ls:LSInputBinding>
            </Grid>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>
