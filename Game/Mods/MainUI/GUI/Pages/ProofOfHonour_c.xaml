<ls:UIWidget x:Name="ProofOfHonour_c"
             ls:UIWidget.ContextName="ProofOfHonour"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" ls:TooltipExtender.Owner="{Binding CurrentPlayer.SelectedCharacter}"
             d:DesignHeight="2160" d:DesignWidth="3840"
             Template="{StaticResource Hud.Root}"
             d:DataContext="{d:DesignInstance Type=ls:DCProofOfHonour}">
    <ls:UIWidget.ContentTemplate>
        <DataTemplate>
            <DataTemplate.Resources>
                <ImageSource x:Key="honorGradient">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/c_honorScreen_gradient.png</ImageSource>
                <ImageSource x:Key="titleDecoration">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/c_honor_titleDecoration.png</ImageSource>
                <ImageSource x:Key="paneBackground">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/c_honorScreen_pane.png</ImageSource>
                <ImageSource x:Key="memoriamDecor">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/c_honor_bodyDecoration.png</ImageSource>
                <ImageSource x:Key="footerDecor">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/c_honor_footerDecoration.png</ImageSource>
                <ImageSource x:Key="campaignDurationIcon">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/ico_c_campaignDuration.png</ImageSource>
                <ImageSource x:Key="campaignEndIcon">pack://application:,,,/Core;component/Assets/ProofOfHonour_c/ico_c_campaignEnd.png</ImageSource>

                <ImageSource x:Key="PortraitFrame">pack://application:,,,/Core;component/Assets/ProofOfHonour/characterFrame_d.png</ImageSource>
                <ImageSource x:Key="PortraitFrameHighlight">pack://application:,,,/Core;component/Assets/ProofOfHonour/characterFrame_h.png</ImageSource>
                <ImageSource x:Key="PortraitFrameRemote">pack://application:,,,/Core;component/Assets/ProofOfHonour/characterFrame_coop_d.png</ImageSource>
                <ImageSource x:Key="PortraitFrameHighlightRemote">pack://application:,,,/Core;component/Assets/ProofOfHonour/characterFrame_coop_h.png</ImageSource>

                <DataTemplate x:Key="PortraitCore" DataType="{x:Type ls:Character}">
                    <ls:LSEntityObject x:Name="CharacterCore" EntityRef="{Binding EntityHandle}" Background="Transparent" Height="220" Opacity="1" Margin="-3,-4">
                        <Rectangle Width="130" Height="190" VerticalAlignment="Center" HorizontalAlignment="Center" Fill="{Binding Icon}" Margin="0,0,0,-10"/>

                        <!-- Collapsed: normal frame state -->
                        <Image x:Name="Frame" Source="{StaticResource PortraitFrame}" Stretch="None" RenderTransformOrigin="0.5 0.5">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="1" Color="{StaticResource tint00}"/>
                            </Image.Effect>
                        </Image>
                        <Image x:Name="FrameHighlight" Source="{StaticResource PortraitFrameHighlight}" Stretch="None" Visibility="Hidden" RenderTransformOrigin="0.5 0.5"/>

                        <Image x:Name="AvatarCrown" Style="{StaticResource AvatarCrownImageStyle}" IsHitTestVisible="False" VerticalAlignment="Top" Margin="0,-30,0,0" Width="90" Stretch="Uniform"/>
                    </ls:LSEntityObject>

                    <DataTemplate.Triggers>
                        <!-- Remote frame -->
                        <DataTrigger Value="False">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource EqualConverter}">
                                    <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=ls:UIWidget}" Path="DataContext.CurrentPlayer.UserId"/>
                                    <Binding Path="PlayerCharacterProperties.OwnerUserID"/>
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter TargetName="Frame" Property="Source" Value="{StaticResource PortraitFrameRemote}"/>
                            <Setter TargetName="FrameHighlight" Property="Source" Value="{StaticResource PortraitFrameHighlightRemote}"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </DataTemplate.Resources>
            <Grid Background="Transparent" d:DataContext="{d:DesignInstance {x:Type ls:DCProofOfHonour}, IsDesignTimeCreatable=True}">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <ls:LSPlaySound Sound="UI_HUD_HonourEndGame"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,100">
                    <TextBlock Text="{Binding Source='he3027a35g04e7g4966g9ae0g3a3b2cb70cc1', Converter={StaticResource TranslatedStringConverter}}"
                           FontSize="{StaticResource ScaledMassiveFontSize}" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center"/>
                    <Image Source="{StaticResource titleDecoration}" Stretch="None"/>
                </StackPanel>
                <Image Source="{StaticResource honorGradient}" Stretch="UniformToFill"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <ItemsControl ItemsSource="{Binding Data.Players}" Template="{StaticResource MinimalItemsControlTemplate}" Panel.ZIndex="10" HorizontalAlignment="Center">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ItemsControl x:Name="PartyLineItemControl" ItemsSource="{Binding PartyGroups}">
                                    <ItemsControl.Template>
                                        <ControlTemplate>
                                            <ItemsPresenter/>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type ls:VMCharacterGroup}">
                                            <ItemsControl x:Name="PortraitHolder" Margin="0,0,0,20" ItemsSource="{Binding Characters}" Background="Transparent" BorderBrush="Transparent"
                                                          ItemTemplate="{StaticResource PortraitCore}">
                                                <ItemsControl.Template>
                                                    <ControlTemplate>
                                                        <ItemsPresenter/>
                                                    </ControlTemplate>
                                                </ItemsControl.Template>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel IsItemsHost="True" Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Image Source="{StaticResource paneBackground}" Stretch="None" Margin="0,-100,0,130"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.RowSpan="2" Grid.Column="0" VerticalAlignment="Center" DataContext="{Binding Data.PartyCharacters[0].Stats.ClassList[0]}"
                               Style="{StaticResource ClassIconStyle}" Stretch="Uniform" Width="200"/>
                        <TextBlock Grid.RowSpan="2" Grid.Column="1" Text="{Binding Data.PartyCharacters[0].Name, StringFormat={}{0}\,}" VerticalAlignment="Center" Margin="30,0" Foreground="{StaticResource LS_tint100}"/>

                        <StackPanel Grid.RowSpan="2" Grid.Column="2" Orientation="Vertical" Margin="-20,0,0,0" >
                            <Border x:Name="LevelsBorder" Height="116" Width="20"/>
                            <ItemsControl x:Name="ClassLevels" Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Data.PartyCharacters[0].Stats.ClassList}" AlternationCount="{Binding Data.PartyCharacters[0].Stats.ClassList.Count}"
                                          Height="180">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True" MaxWidth="1000"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="ls:VMClass">
                                        <StackPanel x:Name="class" Orientation="Horizontal">
                                            <StackPanel.Tag>
                                                <MultiBinding Converter="{StaticResource EqualConverter}">
                                                    <Binding Path="(ItemsControl.AlternationIndex)" RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type ContentPresenter}}" Converter="{StaticResource AddConverter}" ConverterParameter="1"/>
                                                    <Binding Path="AlternationCount" RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}"/>
                                                </MultiBinding>
                                            </StackPanel.Tag>

                                            <TextBlock x:Name="classInfo" Foreground="{StaticResource LS_tint100}">
                                            <Run>
                                               <Run.Text>
                                                   <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                                    <Binding Source="hd678d4eeg181fg499dg9e81g2146ab24e03a"/>
                                                    <Binding Path="DataContext.Level.Value" RelativeSource="{RelativeSource Mode=Self}"/>
                                                    <Binding Path="DataContext.ClassDisplayName" RelativeSource="{RelativeSource Mode=Self}"/>
                                                </MultiBinding>
                                               </Run.Text> 
                                            </Run><Run x:Name="classSeparator" Text=", "/>
                                            </TextBlock>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Tag, ElementName=class}" Value="True">
                                                <Setter TargetName="classSeparator" Property="Text" Value=""/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Image Source="{StaticResource memoriamDecor}" Stretch="None"/>
                        <TextBlock Text="{Binding Source='hda26f31cg9c53g43cdg99bdgef87a9e93d1f', Converter={StaticResource TranslatedStringConverter}}"
                                   Foreground="{StaticResource LS_accent25TxtColor}" HorizontalAlignment="Center" Margin="20,0,20,0"/>
                        <Image Source="{StaticResource memoriamDecor}" Stretch="None" RenderTransformOrigin="0.5, 0.5">
                            <Image.RenderTransform>
                                <ScaleTransform ScaleX="-1"/>
                            </Image.RenderTransform>
                        </Image>
                    </StackPanel>

                    <TextBlock Text="{Binding Source='h436aeeb2g69c5g43dcg914cg2344fb4741f6', Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Center"
                               Foreground="{StaticResource LS_accent75TxtColor}" Margin="0, 10" TextWrapping="Wrap" MaxWidth="1000" TextAlignment="Center"/>

                    <Grid HorizontalAlignment="Center" Margin="0,60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="410"/>
                            <ColumnDefinition Width="410"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.Column="0" Grid.Row="0" Source="{StaticResource campaignDurationIcon}" Stretch="None" HorizontalAlignment="Center"/>
                        <Image Grid.Column="1" Grid.Row="0" Source="{StaticResource campaignEndIcon}" Stretch="None" HorizontalAlignment="Center"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding Source='h2c6b2736g52b1g4321gb0a2g4b7bb84522bc', Converter={StaticResource TranslatedStringConverter}}"
                                   HorizontalAlignment="Center" Foreground="{StaticResource LS_accent25TxtColor}"/>
                        <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Source='h14260990gf4a6g49bag911fgdee30c5baf9e', Converter={StaticResource TranslatedStringConverter}}"
                                   HorizontalAlignment="Center" Foreground="{StaticResource LS_accent25TxtColor}"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Text="{Binding CampaignDuration}" HorizontalAlignment="Center" Foreground="{StaticResource LS_accent75TxtColor}"/>
                        <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding CampaignEndTime}" HorizontalAlignment="Center" Foreground="{StaticResource LS_accent75TxtColor}"/>
                    </Grid>

                    <Image Source="{StaticResource footerDecor}" Stretch="None"/>
                    <ls:LSButton x:Name="menuButton" Tag="{Binding Source='hb8f17a12gded0g4ed7g8897gfa821f15093c', Converter={StaticResource TranslatedStringConverter}}"
                                 Command="{Binding ReturnToMainMenuCommand}" ContentTemplate="{StaticResource ControllerButtonHint}" Margin="6,0,0,65" BoundEvent="UIAccept"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}">
                        <ls:LSButton.Resources>
                            <ImageBrush x:Key="IconNormal" ImageSource="pack://application:,,,/Core;component/Assets/Buttons/ico_btn_cross_d.png" Stretch="Fill"/>
                            <ImageBrush x:Key="IconPressed" ImageSource="pack://application:,,,/Core;component/Assets/Buttons/ico_btn_cross_d.png" Stretch="Fill"/>
                            <ImageBrush x:Key="IconHighlight" ImageSource="pack://application:,,,/Core;component/Assets/Buttons/ico_btn_cross_h.png" Stretch="Fill"/>
                            <ImageBrush x:Key="IconDisabled" ImageSource="pack://application:,,,/Core;component/Assets/Buttons/ico_btn_cross_d.png" Stretch="Fill"/>
                        </ls:LSButton.Resources>
                    </ls:LSButton>
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding ElementName=ClassLevels, Path=ItemsSource.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=3}" Value="True">
                    <Setter TargetName="LevelsBorder" Property="Height" Value="196"/>
                    <Setter TargetName="ClassLevels" Property="Height" Value="260"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </ls:UIWidget.ContentTemplate>
</ls:UIWidget>
