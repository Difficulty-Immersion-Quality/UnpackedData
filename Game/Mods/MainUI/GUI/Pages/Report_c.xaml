<ls:UIWidget
    x:Name="Report_c"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ls="clr-namespace:ls;assembly=Code"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d"
    ls:UIWidget.UseCustomDC="True"
    ls:UIWidget.ContextName="ReportContext"
    d:DataContext="{d:DesignInstance {x:Type ls:DCReport}, IsDesignTimeCreatable=True}"
    ls:TooltipExtender.Owner="{Binding CurrentPlayer.SelectedCharacter}"
    FocusDown="UIDown" FocusLeft="UILeft" FocusRight="UIRight" FocusUp="UIUp">

    <ls:UIWidget.Resources>
        <BitmapImage x:Key="ReportBackground" UriSource="pack://application:,,,/Core;component/Assets/Report_c/c_mods_overlay_BG.png" />
        <BitmapImage x:Key="ReportIcon" UriSource="pack://application:,,,/Core;component/Assets/Report/ico_report_00.png"/>
        <BitmapImage x:Key="ReportTextInputBg" UriSource="pack://application:,,,/Core;component/Assets/Report_c/c_inp_report_textBox.png" />
        <BitmapImage x:Key="ReportInfoBg" UriSource="pack://application:,,,/Core;component/Assets/Report/modoverlay_li_03.png"/>

        <DataTemplate x:Key="UserPreviewTemplate" DataType="{x:Type ls:VMCrossplayUser}">
            <StackPanel x:Name="userPreviewRoot" HorizontalAlignment="Center" Orientation="Horizontal">
                <Grid x:Name="userAvatar" VerticalAlignment="Center">
                    <Image x:Name="avatarFrame" Source="{StaticResource accountFrameDefault}" Stretch="None"/>
                    <Image x:Name="defaultIcon" Width="{StaticResource avatarIconSize}" Height="{StaticResource avatarIconSize}" Stretch="Fill" Source="{StaticResource accountUnknownPortrait}"/>
                </Grid>

                <TextBlock x:Name="userName" Margin="36,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_selectedTextPad}" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>
    </ls:UIWidget.Resources>

    <ls:UIWidget.Template>
        <ControlTemplate>
            <Grid x:Name="ReportRoot" Background="{StaticResource LS_PanelBackground}">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <ls:SetMoveFocusAction TargetName="Report_c"/>
                    </b:EventTrigger>

                    <b:EventTrigger EventName="FocusChanged">
                        <ls:LSPlaySound Sound="UI_Shared_Hover"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <StackPanel x:Name="Title" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,48,0,-48">
                    <Image x:Name="ReportIcon" Source="{StaticResource ReportIcon}" Stretch="None" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock x:Name="ReportTitle" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_tint100}" VerticalAlignment="Center"/>
                </StackPanel>

                <ls:LSNineSliceImage x:Name="ReportContent" 
                                     ImageSource="{StaticResource ReportBackground}"
                                     Slices="160"
                                     Padding="240,120"
                                     Width="2340"
                                     Height="2000"
                                     Margin="0,-20,0,20"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                    <AdornerDecorator>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="ReportSubTitle" Grid.Row="0" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_tint100}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,40"/>

                            <Grid x:Name="ReportedElementPreview" Grid.Row="1" Margin="0,0,0,50">
                                <Image x:Name="ReportedElementPreviewBg" Source="{StaticResource ReportInfoBg}" Stretch="Fill" VerticalAlignment="Center" Height="160"/>
                                <ContentPresenter x:Name="ReportedElementPreviewData" Content="{Binding Report.Data}" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Report content -->
                            <StackPanel x:Name="ReportReasons" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,4">
                                <TextBlock x:Name="ReportReasonsDescription" Text="{Binding Source='h6b9d3026g3c2eg4d9bgb944g29d427b5b47c',Converter={StaticResource TranslatedStringConverter}}" FontSize="{StaticResource ScaledMediumFontSize}" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,56" MaxWidth="1400" Foreground="{StaticResource LS_accent75TxtColor}"/>

                                <ItemsControl x:Name="ReasonsList" ItemsSource="{Binding Report.Reasons}" AlternationCount="{Binding Report.Reasons.Count}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="ls:VMReportReason">
                                            <RadioButton x:Name="ReasonEntry" Style="{StaticResource FocusableRadioButtonStyleBold}" ls:MoveFocus.FocusMovementMode="MainAxis" GroupName="Reasons" Margin="0,0,0,12">

                                                <b:Interaction.Triggers>
                                                    <b:EventTrigger EventName="Checked">
                                                        <b:ChangePropertyAction TargetObject="{Binding DataContext, ElementName=Report_c}" PropertyName="ReportReason" Value="{Binding ReasonEnum}"/>
                                                    </b:EventTrigger>
                                                    <b:EventTrigger EventName="Loaded">
                                                        <b:Interaction.Behaviors>
                                                            <b:ConditionBehavior>
                                                                <b:ConditionalExpression>
                                                                    <b:ComparisonCondition LeftOperand="{Binding ReasonEnum}" Operator="Equal" RightOperand="{Binding DataContext.ReportReason, ElementName=Report_c}"/>
                                                                </b:ConditionalExpression>
                                                            </b:ConditionBehavior>
                                                        </b:Interaction.Behaviors>
                                                        <b:ChangePropertyAction PropertyName="IsChecked" Value="True"/>
                                                    </b:EventTrigger>
                                                </b:Interaction.Triggers>

                                                <Grid Background="Transparent" VerticalAlignment="Center" Width="916" Height="164">
                                                    <TextBlock Text="{Binding ReasonText}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="120,0,0,0" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_accent75TxtColor}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </RadioButton>

                                            <DataTemplate.Triggers>

                                                <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource Self}, Converter={StaticResource ModuloConverter}, ConverterParameter='2'}" Value="0">
                                                    <Setter TargetName="ReasonEntry" Property="Margin" Value="0,0,24,12"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <ls:LSNineSliceImage x:Name="ReportSummary" 
                                                 Grid.Row="3" 
                                                 Visibility="Collapsed"
                                                 ImageSource="{StaticResource ReportTextInputBg}"
                                                 Slices="16"
                                                 Padding="24"
                                                 ls:MoveFocus.Focusable="True" Focusable="True"
                                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Grid>
                                    <ls:LSTextBox x:Name="Summary" Text="{Binding ReportSummary, Mode=TwoWay}" TextImmediateSourceUpdate="True"
                                                  Foreground="{StaticResource LS_accent75TxtColor}" CaretBrush="{StaticResource LS_accent75TxtColor}" SelectionBrush="{StaticResource LS_accent100TxtColor}"
                                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,0,30,0"
                                                  MaxLength="10000"
                                                  AcceptsReturn="True" AcceptsTab="True" 
                                                  TextAlignment="Left" TextWrapping="Wrap" 
                                                  VerticalScrollBarVisibility="Auto">
                                        <ls:LSTextBox.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource GoldScrollBar}">
                                                <Setter Property="Margin" Value="60,0,-60,0"/>
                                            </Style>
                                        </ls:LSTextBox.Resources>
                                    </ls:LSTextBox>

                                    <TextBlock x:Name="SummaryHint" Text="{Binding Source='h779dd8a8g3f0cg436bga132g605632f9df43', Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent25TxtColor}" VerticalAlignment="Top" TextAlignment="Left" TextWrapping="Wrap" IsHitTestVisible="False" Margin="4,4,0,0" FontStyle="Italic" Visibility="Collapsed"/>
                                </Grid>
                            </ls:LSNineSliceImage>

                            <TextBlock x:Name="DelayDisclaimer" Grid.Row="4" Visibility="Collapsed" Text="{Binding Source='hcb763a08g5271g45d6gbcdcga4048a5959e4',Converter={StaticResource TranslatedStringConverter}}" FontSize="{StaticResource ScaledMediumFontSize}" VerticalAlignment="Top" TextAlignment="Center" TextWrapping="Wrap" Margin="0,150,0,20" MaxWidth="1400" Foreground="{StaticResource LS_accent75TxtColor}"/>

                            <ls:LSCheckBox x:Name="BlockUser" Grid.Row="5" Visibility="Collapsed" Style="{StaticResource DefaultSimpleCheckBoxStyle}" 
                                           Margin="0,22" Height="140"
                                           IsChecked="True"
                                           Content="{Binding Source='h4dfe51efg0143g42bfgb58ag4ef694576c04',Converter={StaticResource TranslatedStringConverter}}"/>
                            
                            <!-- Reporting content -->
                            <Control x:Name="SendingReportSpinner" Grid.Row="2" Grid.RowSpan="4" Visibility="Collapsed" Template="{StaticResource BusyElement}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Report result content -->
                            <Grid x:Name="ReportResults" Grid.Row="2" Grid.RowSpan="4" Visibility="Collapsed" Width="1600" Margin="150,200,-150,-200">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image x:Name="ResultIcon" Source="{StaticResource IconHourglassActive}" VerticalAlignment="Top" Stretch="None" Margin="0,50,22,0" Visibility="Collapsed"/>

                                <StackPanel x:Name="ResultsRoot" Grid.Column="1">
                                    <TextBlock x:Name="ResultsTitle" Text="{Binding Source='h96d547b9g1566g4110g9901g39345fd626a4',Converter={StaticResource TranslatedStringConverter}}" FontSize="{StaticResource ScaledHugeFontSize}" Foreground="{StaticResource LS_tint100}" TextWrapping="Wrap" Margin="0,0,0,48"/>
                                    <TextBlock x:Name="ResultsDescription" ls:TextBlockFormatter.SourceText="{Binding Source='h884379b3g5a24g4345gacc4g6ec12f7be140',Converter={StaticResource TranslatedStringConverter}}" FontSize="{StaticResource ScaledDefaultFontSize}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </AdornerDecorator>
                </ls:LSNineSliceImage>

                <!-- Buttons -->
                <StackPanel x:Name="ButtonsHolder" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,-44,0,44" Height="120">
                    <ls:LSButton x:Name="SelectReasonButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 Margin="5,0" VerticalAlignment="Center"
                                 BoundEvent="UIAccept"
                                 Tag="{Binding Source='h04f38549g65b8g4b72g834eg87ee8863fdc5',Converter={StaticResource TranslatedStringConverter}}"
                                 Visibility="Collapsed">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LSButtonPressed">
                                <b:ChangePropertyAction TargetObject="{Binding FocusedElement, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ls:UIWidget}}" PropertyName="IsChecked" Value="True"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>

                    <ls:LSButton x:Name="EditSummaryButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 Margin="5,0" VerticalAlignment="Center"
                                 BoundEvent="UIAccept"
                                 Tag="{Binding Source='hbe10cd88g9f76g4626g8e4dgb2ebb22f0dc7',Converter={StaticResource TranslatedStringConverter}}"
                                 Visibility="Collapsed">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LSButtonPressed">
                                <ls:SetMoveFocusAction TargetObject="{Binding Path=., RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}}" Reset="True"/>
                                <noesis:SetFocusAction TargetName="Summary"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>

                    <ls:LSButton x:Name="ChangeBlockButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 Margin="5,0" VerticalAlignment="Center"
                                 Tag="{Binding Source='hbe10cd88g9f76g4626g8e4dgb2ebb22f0dc7',Converter={StaticResource TranslatedStringConverter}}"
                                 Visibility="Collapsed"/>

                    <ls:LSButton x:Name="SubmitButton"
                                 HoldTime="{StaticResource HoldTimeShortcuts}"
                                 Style="{StaticResource ControllerDelayedHoldButtonStyle}"
                                 Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxY'}"
                                 Margin="5,0" VerticalAlignment="Center"
                                 BoundEvent="UIMessageBoxY"
                                 Command="{Binding SendReportCommand}"
                                 Tag="{Binding Source='h9b5c798eg6258g4fe6g9086g404216364550',Converter={StaticResource TranslatedStringConverter}}"
                                 Visibility="Collapsed">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="HoldFinishedEvent">
                                <b:Interaction.Behaviors>
                                    <b:ConditionBehavior>
                                        <b:ConditionalExpression>
                                            <b:ComparisonCondition LeftOperand="{Binding Report.Type}" Operator="Equal" RightOperand="User"/>
                                            <b:ComparisonCondition LeftOperand="{Binding IsChecked, ElementName=BlockUser}" Operator="Equal" RightOperand="True"/>
                                        </b:ConditionalExpression>
                                    </b:ConditionBehavior>
                                </b:Interaction.Behaviors>
                                <b:InvokeCommandAction Command="{Binding DataContext.BlockUserCommand, ElementName=Report_c}" CommandParameter="{Binding DataContext.Data.CrossplayCurrentFriend, ElementName=Report_c}"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>

                    <ls:LSButton x:Name="CloseButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                                 Margin="5,0" VerticalAlignment="Center"
                                 BoundEvent="UICancel"
                                 Command="{Binding CustomEvent}" CommandParameter="CloseWidget"
                                 Tag="{Binding Source='hd17fc873gbda6g4283gb940gd9317b144143',Converter={StaticResource TranslatedStringConverter}}"/>
                </StackPanel>
            </Grid>

            <ControlTemplate.Triggers>
                <!-- States -->
                <DataTrigger Binding="{Binding ReportState}" Value="FillingReport">
                    <Setter TargetName="CloseButton" Property="Tag" Value="{Binding Source='h9d3b37a6gf7e3g40a8g87d3g21b1d1732512', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="SubmitButton" Property="Visibility" Value="Visible"/>

                    <Setter TargetName="ReportReasons" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ReportSummary" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="DelayDisclaimer" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ReportState}" Value="Reporting">
                    <Setter TargetName="SendingReportSpinner" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="CloseButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ReportState}" Value="ReportedSuccess">
                    <Setter TargetName="ReportResults" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ReportState}" Value="ReportedFailedAndStored">
                    <Setter TargetName="ReportResults" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ResultIcon" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ResultsTitle" Property="Text" Value="{Binding Source='h4e5ed996ga99eg4894gb9c5g833e0be0d5d9',Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ResultsDescription" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source='h2a0dbff4g005fg40e8gb4bfg6f0f4e0f06d7',Converter={StaticResource TranslatedStringConverter}}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ReportState}" Value="ReportedFailed">
                    <Setter TargetName="ReportResults" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ResultIcon" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ResultsTitle" Property="Text" Value="{Binding Source='h4e5ed996ga99eg4894gb9c5g833e0be0d5d9',Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ResultsDescription" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source='h21912982gc102g4322gb70bg8b89f762c8e7',Converter={StaticResource TranslatedStringConverter}}"/>
                </DataTrigger>

                <!-- Report type dependencies -->
                <DataTrigger Binding="{Binding Report.Type}" Value="Mod">
                    <Setter TargetName="ReportTitle" Property="Text" Value="{Binding Source='hac0ceac1g3ff8g40e0gb0a0g8083d0278f77', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ReportSubTitle" Property="Text" Value="{Binding Source='hcf1bc87fg3191g4329g99bag7f0dd2086627', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ReportReasonsDescription" Property="Text" Value="{Binding Source='h6b9d3026g3c2eg4d9bgb944g29d427b5b47c', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ReportedElementPreviewData" Property="ContentTemplate" Value="{StaticResource ModPreviewTemplate}"/>
                    <Setter TargetName="ReportedElementPreviewData" Property="Tag" Value="Focused"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Report.Type}" Value="User">
                    <Setter TargetName="ReportTitle" Property="Text" Value="{Binding Source='hcb37985dgb52ag4471g933cg3b963418cb30', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ReportSubTitle" Property="Text" Value="{Binding Source='he41ebeaeg8a70g4cfcgadfbg588ec194365a', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ReportReasonsDescription" Property="Text" Value="{Binding Source='h49226414gfd93g4234g8748ga56214c87ec0', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="ReportedElementPreviewData" Property="ContentTemplate" Value="{StaticResource UserPreviewTemplate}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Report.Type}" Value="User"/>
                        <Condition Binding="{Binding ReportState}" Value="FillingReport"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="BlockUser" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="DelayDisclaimer" Property="Margin" Value="0,0,0,22"/>
                </MultiDataTrigger>

                <!-- Disable the submit button until a valid summary and reason are provided -->
                <DataTrigger Binding="{Binding ReportSummary}" Value="">
                    <Setter TargetName="SubmitButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ReportReason}" Value="255">
                    <Setter TargetName="SubmitButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>

                <!-- Others -->
                <Trigger SourceName="ReportSummary" Property="ls:MoveFocus.IsFocused" Value="True">
                    <Setter TargetName="ReportSummary" Property="ImageSource" Value="pack://application:,,,/Core;component/Assets/Report_c/c_inp_report_textBox_selected.png" />
                </Trigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding (ls:MoveFocus.IsFocused), ElementName=ReportSummary}" Value="False"/>
                        <Condition Binding="{Binding (ls:MoveFocus.IsFocused), ElementName=BlockUser}" Value="False"/>
                        <Condition Binding="{Binding IsFocused, ElementName=Summary}" Value="False"/>
                        <Condition Binding="{Binding ReportState}" Value="FillingReport"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SelectReasonButton" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding (ls:MoveFocus.IsFocused), ElementName=ReportSummary}" Value="True"/>
                        <Condition Binding="{Binding ReportState}" Value="FillingReport"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="EditSummaryButton" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding (ls:MoveFocus.IsFocused), ElementName=BlockUser}" Value="True"/>
                        <Condition Binding="{Binding ReportState}" Value="FillingReport"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ChangeBlockButton" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="BlockUser" Property="BoundEvent" Value="UIAccept"/>
                </MultiDataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=Summary}" Value="False"/>
                        <Condition Binding="{Binding ReportSummary}" Value=""/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SummaryHint" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>

                <Trigger Property="IsKeyboardFocused" SourceName="Summary" Value="True">
                    <Setter TargetName="Summary" Property="Background" Value="Transparent"/>
                    <Setter TargetName="Summary" Property="Foreground" Value="{StaticResource LS_extraspecialTxtColor}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>

</ls:UIWidget>

