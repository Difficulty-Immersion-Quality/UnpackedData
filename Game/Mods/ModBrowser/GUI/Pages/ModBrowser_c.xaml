<ls:UIWidget x:Name="ModBrowser_c"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             mc:Ignorable="d"
             ls:UIWidget.ContextName="ModBrowserDownload"
             Template="{StaticResource ModBrowserBackgroundTemplate_c}"
             d:DesignWidth="3840" d:DesignHeight="2160"
             d:DataContext="{d:DesignInstance Type=ls:DCModBrowser, IsDesignTimeCreatable=True}"
             FocusDown="UIDown" FocusLeft="UILeft" FocusRight="UIRight" FocusUp="UIUp"
             Tag="{StaticResource FalseValue}">
    <!-- Tag will store whether to show sort and filter options -->
    <ls:UIWidget.ContentTemplate>
        <DataTemplate>
            <DataTemplate.Resources>
                <Thickness x:Key="SidebarHideMargin">-1350,-80,1350,0</Thickness>
                <Thickness x:Key="SidebarShowMargin">-1250,-80,1250,0</Thickness>

                <Thickness x:Key="SidebarHideMarginLowerARs">-175,-80,0,0</Thickness>
                <Thickness x:Key="SidebarShowMarginLowerARs">-75,-80,0,0</Thickness>
            </DataTemplate.Resources>

            <!-- Tag will store the focused element when the details view is opened, so we can go back to it after closing the details view -->
            <Grid x:Name="root" VerticalAlignment="Stretch" Tag="{x:Null}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <b:Interaction.Triggers>
                    <b:DataTrigger Binding="{Binding Path=IsUpdatingModList}" Value="False">
                        <ls:SetMoveFocusAction TargetName="ModBrowser_c" DeferFocusAction="True"/>
                    </b:DataTrigger>

                    <b:DataTrigger Binding="{Binding Path=InDetailsView}" Value="True">
                         <!-- Save current focused element -->
                        <b:ChangePropertyAction TargetName="root" PropertyName="Tag" Value="{Binding FocusedElement, ElementName=ModBrowser_c}"/>
                    </b:DataTrigger>
                    <b:DataTrigger Binding="{Binding Path=InDetailsView}" Value="False">
                        <!-- Restore focused element -->
                        <ls:SetMoveFocusAction TargetName="ModBrowser_c" FocusElement="{Binding Tag, ElementName=root}" DeferFocusAction="True"/>
                        <b:ChangePropertyAction TargetName="root" PropertyName="Tag" Value="{x:Null}"/>
                    </b:DataTrigger>

                    <b:EventTrigger EventName="MoveFocusRight">
                        <ls:LSPlaySound Sound="UI_Shared_Hover" />
                    </b:EventTrigger>

                    <b:EventTrigger EventName="MoveFocusLeft">
                        <ls:LSPlaySound Sound="UI_Shared_Hover" />
                    </b:EventTrigger>

                    <b:EventTrigger EventName="MoveFocusUp">
                        <ls:LSPlaySound Sound="UI_Shared_Hover" />
                    </b:EventTrigger>

                    <b:EventTrigger EventName="MoveFocusDown">
                        <ls:LSPlaySound Sound="UI_Shared_Hover" />
                    </b:EventTrigger>

                    <b:EventTrigger EventName="Loaded">
                        <b:Interaction.Behaviors>
                            <b:ConditionBehavior>
                                <b:ConditionalExpression>
                                    <b:ComparisonCondition LeftOperand="{Binding ShowModManagerSplash}" Operator="Equal" RightOperand="True"/>
                                </b:ConditionalExpression>
                            </b:ConditionBehavior>
                        </b:Interaction.Behaviors>

                        <b:InvokeCommandAction Command="{Binding CustomEvent}" CommandParameter="ShowSplashScreen"/>
                        <b:ChangePropertyAction TargetObject="{Binding DataContext, ElementName=ModBrowser_c}" PropertyName="IsShowingSplash" Value="True"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <TextBlock x:Name="UGCDisabled" Grid.Row="0" Text="{Binding Source='hc8b6cc7dgda8bg49fcg84f9gcbea92d18277', Converter={StaticResource TranslatedStringConverter}}"
                           HorizontalAlignment="Center" Margin="0,-20,0,20" FontSize="{StaticResource LargeFontSize}" FontWeight="DemiBold"
                           Visibility="{Binding Data.IsUGCDisabled, Converter={StaticResource BoolToVisibleConverter}}"/>

                <StackPanel x:Name="ActiveFiltersContainer" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" MinHeight="72" Margin="0,-12,0,0">
                    <TextBlock Text="{Binding Source=h9c5d2c2ag37efg40b8g9351g37eda20081c2, Converter={StaticResource TranslatedStringConverter}}" Margin="10,0" VerticalAlignment="Center" Foreground="{StaticResource LS_accent100TxtColor}"/>

                    <ItemsControl x:Name="ActiveFilters" ItemsSource="{Binding ActiveFilters}" MaxWidth="2000">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ls:LSNineSliceImage ImageSource="{StaticResource ModBrowserTagsBg_d}" Slices="34" Padding="34,0" Height="72">
                                    <TextBlock Text="{Binding .}" VerticalAlignment="Center" FontSize="{StaticResource ScaledMediumFontSize}" Foreground="{StaticResource LS_accent100TxtColor}"/>
                                </ls:LSNineSliceImage>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TextBlock x:Name="ConnectionWarning" Grid.Row="2" Text="{Binding Source='h41be27a3gda6cg4992gb00eg5317b117fac7', Converter={StaticResource TranslatedStringConverter}}"
                           HorizontalAlignment="Center" Margin="0,600" FontSize="{StaticResource LargeFontSize}" FontWeight="DemiBold" Visibility="Collapsed"/>

                <TextBlock x:Name="NoResultsWarning" Grid.Row="2" Text="{Binding Source='hb2a05d67gd8f5g49ceg8d5bg7ad0f05635e3', Converter={StaticResource TranslatedStringConverter}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource LS_tint100}" Visibility="Collapsed"/>

                <Control x:Name="ModListUpdateSpinner" Template="{StaticResource SearchingModsTemplate}" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsUpdatingModList, Converter={StaticResource BoolToVisibleConverter}}"/>

                <Control x:Name="ModListPermissionsSpinner" Grid.Row="2" Template="{StaticResource BusyElement}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed"/>

                <Grid x:Name="ModListRoot" Grid.Row="2" HorizontalAlignment="Center" IsEnabled="{Binding Tag, ElementName=ModBrowser_c, Converter={StaticResource InvertBoolConverter}}" Visibility="{Binding IsUpdatingModList, Converter={StaticResource BoolToCollapsedConverter}}">
                    <Grid.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="0" Color="Transparent"/>
                                <GradientStop Offset="0.025" Color="White"/>
                                <GradientStop Offset="0.965" Color="White"/>
                                <GradientStop Offset="1" Color="Transparent"/>
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Grid.OpacityMask>

                    <ListBox x:Name="ModList" ItemContainerStyle="{StaticResource SingleModStyle}" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel" ItemsSource="{Binding DownloadableMods}"
                             AlternationCount="{Binding DownloadableMods.Count}" Width="2720" Height="{Binding ActualHeight, ElementName=ModListRoot}" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ls:LSGrid Columns="4" ContainerData="{Binding .}" CellWidth="680" CellHeight="580" AutoIndex="True" ExtendedRows="False" SnapsToDevicePixels="True"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Template>
                            <ControlTemplate>
                                <ls:LSScrollViewer x:Name="PART_ScrollViewer" Template="{StaticResource ScrollViewerTemplate}" ls:ScrollViewerHelper.VerticalScrollOffsetMargin="300">
                                    <ls:LSScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource GoldScrollBar}">
                                            <Setter Property="Margin" Value="0,40"/>
                                        </Style>
                                    </ls:LSScrollViewer.Resources>

                                    <ItemsPresenter Margin="0,0,0,0"/>
                                </ls:LSScrollViewer>
                            </ControlTemplate>
                        </ListBox.Template>
                        <b:Interaction.Triggers>
                            <b:PropertyChangedTrigger Binding="{Binding FocusedElement, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}">
                                <b:ChangePropertyAction PropertyName="SelectedItem" Value="{Binding FocusedElement.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                            </b:PropertyChangedTrigger>
                        </b:Interaction.Triggers>
                        <b:Interaction.Behaviors>
                            <ls:ResetScrollOnItemsChangedBehavior/>
                        </b:Interaction.Behaviors>
                    </ListBox>
                </Grid>

                <Control x:Name="PageSelectionControl"  Grid.Row="3" Template="{StaticResource PageSelectionTemplate}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" IsEnabled="{Binding IsEnabled, ElementName=ModListRoot}"/>

                <StackPanel x:Name="BottomButtonsPanel" Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Style="{StaticResource ButtonHint.Container.Center}">
                    <ls:LSButton x:Name="toggleFiltersButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UISort'}"
                                 Tag="{Binding Source=h9c23d217ga85cg4605g8904g0d1410b5290f, Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UISort">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LSButtonPressed">
                                <b:Interaction.Behaviors>
                                    <b:ConditionBehavior>
                                        <b:ConditionalExpression>
                                            <b:ComparisonCondition LeftOperand="{Binding Tag, ElementName=ModBrowser_c}" Operator="Equal" RightOperand="{StaticResource TrueValue}"/>
                                        </b:ConditionalExpression>
                                    </b:ConditionBehavior>
                                </b:Interaction.Behaviors>
                                <b:InvokeCommandAction Command="{Binding UpdateSearchCommand}"/>
                            </b:EventTrigger>

                            <b:EventTrigger EventName="LSButtonPressed">
                                <b:ChangePropertyAction TargetName="ModBrowser_c" PropertyName="Tag" Value="{Binding Tag, ElementName=ModBrowser_c, Converter={StaticResource InvertBoolConverter}}"/>
                                <ls:SetMoveFocusAction TargetName="ModBrowser_c" DeferFocusAction="True"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>

                    <ls:LSButton x:Name="detailsButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 Tag="{Binding Source='h6dd87748g1061g4e27gade4g9d6709511bfd',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIAccept"
                                 Command="{Binding ToggleDetailsCommand}"
                                 CommandParameter="{Binding FocusedElement.DataContext, ElementName=ModBrowser_c}"/>

                    <ls:LSButton x:Name="subscribeButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIDelete'}"
                                 Tag="{Binding Source='h0c9f422cga55cg4d2agb342ga095b82caa58',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIDelete"
                                 Command="{Binding DownloadModCommand}"
                                 CommandParameter="{Binding FocusedElement.DataContext, ElementName=ModBrowser_c}"/>

                    <ls:LSButton x:Name="clearFiltersButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxX'}"
                                 Tag="{Binding Source=h6da1a7c1g1ab0g4b44ga6e0g6f89f91a88a2, Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIMessageBoxX">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LSButtonPressed">
                                <b:InvokeCommandAction Command="{Binding ClearFiltersCommand}"/>
                                <b:ChangePropertyAction TargetObject="{Binding DataContext, ElementName=ModBrowser_c}" PropertyName="SearchText" Value=""/>
                                <b:InvokeCommandAction Command="{Binding UpdateSearchCommand}"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>

                    <ls:LSButton x:Name="closeButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                                 BoundEvent="UICancel" Tag="{Binding Source='h6fefa28bg2149g4cacga071gd95b236b2d0b',Converter={StaticResource TranslatedStringConverter}}"
                                 Command="{Binding CustomEvent}" SoundID="UI_Shared_Cancel" CommandParameter="CloseWidget"/>
                </StackPanel>

                <Grid x:Name="SideBar" Grid.Row="1" Grid.RowSpan="4" HorizontalAlignment="Center" Opacity="0" Margin="{StaticResource SidebarHideMargin}" IsEnabled="{Binding Tag, ElementName=ModBrowser_c}">
                    <Grid.Resources>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Template" Value="{StaticResource SideSearchPanelTreeViewItemTemplate}"/>
                        </Style>
                    </Grid.Resources>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="SideBarBackground" Background="{StaticResource LS_PanelBackground}" Width="1500">
                        <Grid.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Offset="0" Color="Transparent"/>
                                    <GradientStop Offset="0.025" Color="White"/>
                                    <GradientStop Offset="0.60" Color="White"/>
                                    <GradientStop Offset="1" Color="Transparent"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Grid.OpacityMask>
                    </Grid>

                    <StackPanel x:Name="FiltersRoot" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="800" Margin="94,0,23,0">
                        <TextBlock Text="{Binding Source=h3e17d4c9gffe7g45ecg9160gd56d7c5a6511, Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Center" Margin="0,32,0,0" FontSize="{StaticResource ScaledLargeFontSize}" Foreground="{StaticResource LS_tint100}"/>

                        <Grid x:Name="SearchBarContainer" Margin="20,0,20,20" ls:MoveFocus.Focusable="True" Focusable="True">
                            <Image x:Name="SearchBarBg" Source="{StaticResource c_ModBrowserSearchBox_d}" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <ls:LSTextBox x:Name="SearchText" Text="{Binding SearchText, Mode=TwoWay}" TextImmediateSourceUpdate="True"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                          FontSize="{StaticResource ScaledSmallFontSize}"
                                          MaxWidth="{Binding ActualWidth, ElementName=SearchBarBg, Converter={StaticResource AddConverter}, ConverterParameter='-25'}"
                                          MaxLength="1000">
                                <ls:LSTextBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource GoldScrollBar}">
                                        <Setter Property="Margin" Value="60,0,-60,0"/>
                                    </Style>
                                </ls:LSTextBox.Resources>
                            </ls:LSTextBox>

                            <StackPanel x:Name="SearchBarHint" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="100,0,0,0" IsHitTestVisible="False" Visibility="Hidden">
                                <Image x:Name="SearchBarHintIcon" Source="{StaticResource ModBrowserSearchBoxHintIcon}" Stretch="None" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SearchBarHintText" Text="{Binding Source=he3c5c91cg4be9g44e8gb2a5ge24777cd9b42, Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" FontSize="{StaticResource ScaledSmallFontSize}" FontStyle="Italic"/>
                            </StackPanel>

                            <Control x:Name="SearchTextFocusedMarker" Visibility="Collapsed" Style="{StaticResource FocusableBorderCarouselStyle}" Margin="-20" Width="{Binding ActualWidth, ElementName=SearchBarBg}" Height="{Binding ActualHeight, ElementName=SearchBarBg}"/>
                        </Grid>

                        <ListBox x:Name="SortOptions" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortType, Mode=TwoWay}" Margin="0,-14,0,0">
                            <ListBox.Resources>
                                <BitmapImage x:Key="CarouselArrow_d" UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_carousel_arrow_d.png"/>

                                <Style x:Key="IconCarouselRepeatButtonStyle" TargetType="ls:LSRepeatButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <Image x:Name="arrow" Source="{StaticResource CarouselArrow_d}" Stretch="None"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="arrow" Property="Opacity" Value="0.2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <ControlTemplate x:Key="CarouselButtonTemplate" TargetType="ContentControl">
                                    <Grid MinHeight="125">
                                        <Rectangle x:Name="focusedFill" Fill="{StaticResource focusedFillGradiant}" Visibility="Hidden" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                        <Control x:Name="Frame" Visibility="Hidden" Style="{StaticResource FocusableBorderCarouselStyle}" />
                                        <ContentPresenter x:Name="content" IsEnabled="False"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger SourceName="base" Property="ls:MoveFocus.IsFocused" Value="True">
                                            <Setter TargetName="content" Property="IsEnabled" Value="True"/>
                                            <Setter TargetName="Frame" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="focusedFill" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ListBox.Resources>
                            <ListBox.Template>
                                <ControlTemplate>
                                    <ContentControl x:Name="base" ls:MoveFocus.Focusable="True" Focusable="True" Template="{StaticResource CarouselButtonTemplate}" HorizontalAlignment="Stretch">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger SourceName="leftBtn" EventName="Click">
                                                <ls:SelectNextListBoxItem Reversed="True" TargetObject="{Binding RelativeSource={RelativeSource TemplatedParent}}" ForceSelect="True"/>
                                            </b:EventTrigger>
                                            <b:EventTrigger SourceName="rightBtn" EventName="Click">
                                                <ls:SelectNextListBoxItem TargetObject="{Binding RelativeSource={RelativeSource TemplatedParent}}" ForceSelect="True"/>
                                            </b:EventTrigger>
                                            <b:PropertyChangedTrigger Binding="{Binding SelectedValue, RelativeSource={RelativeSource TemplatedParent}}">
                                                <ls:LSPlaySound Sound="UI_Controller_DefaultSlider_Step"/>
                                            </b:PropertyChangedTrigger>
                                        </b:Interaction.Triggers>

                                        <Grid Height="180">
                                            <TextBlock Text="{Binding Source=hce314911gcae3g4345gbc5ag201bc976a594, Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Center" VerticalAlignment="Top" FontWeight="Bold" Margin="0,10,0,0" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_accent100TxtColor}"/>

                                            <ls:LSRepeatButton x:Name="leftBtn" BoundEvent="UILeft" Style="{StaticResource IconCarouselRepeatButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="40,0,0,0" >
                                                <ls:LSRepeatButton.RenderTransform>
                                                    <ScaleTransform ScaleX="-1" CenterX="32"/>
                                                </ls:LSRepeatButton.RenderTransform>
                                            </ls:LSRepeatButton>

                                            <ls:LSRepeatButton x:Name="rightBtn" BoundEvent="UIRight" Style="{StaticResource IconCarouselRepeatButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0" />

                                            <Grid x:Name="SliderBase" HorizontalAlignment="Center" VerticalAlignment="Center" Width="488" Height="46" Margin="0,-10,0,-10" >
                                                <ItemsPresenter x:Name="AppearanceCarouselSlider" Width="488" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>

                                            <TextBlock x:Name="cTxt" Text="{Binding SortType, Converter={StaticResource EnumTranslatedStringConverter}, ConverterParameter='h7e5f30e8g1fd8g4f3bg837dg3f275d25f638'}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16" FontSize="{StaticResource ScaledMediumFontSize}" Foreground="{StaticResource LS_accent75TxtColor}"/>
                                        </Grid>
                                    </ContentControl>
                                </ControlTemplate>
                            </ListBox.Template>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Rectangle VerticalAlignment="center" x:Name="dashLine" Height="8" Fill="{StaticResource LS_accent00TxtColor}" Opacity="0.6" Margin="1,0">
                                                    <Rectangle.Width>
                                                        <MultiBinding Converter="{StaticResource DivideMultiConverter}" ConverterParameter="Round" >
                                                            <Binding Path="ActualWidth" ElementName="AppearanceCarouselSlider" Converter="{StaticResource AddConverter}" ConverterParameter="-122"/>
                                                            <Binding Path="ItemsSource.Count" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" Converter="{StaticResource AddConverter}" ConverterParameter="-1"/>
                                                        </MultiBinding>
                                                    </Rectangle.Width>
                                                </Rectangle>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="dashLine" Property="Width" Value="100" />
                                                        <Setter TargetName="dashLine" Property="Fill" Value="{StaticResource LS_accent75TxtColor}" />
                                                        <Setter TargetName="dashLine" Property="Opacity" Value="1" />
                                                    </Trigger>

                                                    <DataTrigger Binding="{Binding (ls:MoveFocus.IsFocused), ElementName=base}" Value="True">
                                                        <Setter TargetName="dashLine" Property="Height" Value="12" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"  />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <ls:LSScrollViewer MaxHeight="1410" Margin="0,15,0,0">
                            <ls:LSScrollViewer.OpacityMask>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Offset="0" Color="White"/>
                                        <GradientStop Offset="0.95" Color="White"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </ls:LSScrollViewer.OpacityMask>

                            <ls:LSScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource GoldScrollBar}">
                                    <Setter Property="Margin" Value="0,0,0,50"/>
                                </Style>
                            </ls:LSScrollViewer.Resources>

                            <StackPanel>
                                <Grid x:Name="TopSpace" Margin="0,21,0,0"/>

                                <TreeView x:Name="Filters" Template="{StaticResource MinimalTreeViewTemplate}">
                                    <TreeViewItem IsExpanded="True">
                                        <TreeViewItem>
                                            <TreeViewItem.Header>
                                                <ls:LSToggleButton x:Name="ExplicitContentButton" Content="{Binding Source=h044356fcgc4a6g44bfgaa75gc26eb46ae649, Converter={StaticResource TranslatedStringConverter}}" IsChecked="{Binding ShowExplicitContentEnabled, Mode=TwoWay}" Style="{StaticResource FilterToggleButtonStyle}"/>
                                            </TreeViewItem.Header>
                                        </TreeViewItem>
                                        <TreeViewItem>
                                            <TreeViewItem.Header>
                                                <ls:LSToggleButton x:Name="ExternalDependenciesButton" Content="{Binding Source=h1b37a6fcg1771g407fg9187gb0ac1a152876, Converter={StaticResource TranslatedStringConverter}}" IsChecked="{Binding ShowExternalDependenciesEnabled, Mode=TwoWay}" Style="{StaticResource FilterToggleButtonStyle}"/>
                                            </TreeViewItem.Header>
                                        </TreeViewItem>
                                    </TreeViewItem>
                                </TreeView>

                                <TreeView x:Name="Categories" Template="{StaticResource MinimalTreeViewTemplate}" ItemsSource="{Binding Categories}">
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Tags}" DataType="{x:Type ls:VMModCategory}">
                                            <TreeViewItem>
                                                <TreeViewItem.Header>
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource FilterTitleStyle}"/>
                                                </TreeViewItem.Header>
                                            </TreeViewItem>
                                        </HierarchicalDataTemplate>

                                        <HierarchicalDataTemplate DataType="{x:Type ls:VMModCategoryTag}">
                                            <TreeViewItem>
                                                <TreeViewItem.Header>
                                                    <ls:LSToggleButton x:Name="TagButton" Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource FilterToggleButtonStyle}"/>
                                                </TreeViewItem.Header>
                                            </TreeViewItem>
                                        </HierarchicalDataTemplate>
                                    </TreeView.Resources>
                                </TreeView>

                                <Grid x:Name="BottomSpace" Margin="0,0,0,50"/>
                            </StackPanel>
                        </ls:LSScrollViewer>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Style="{StaticResource ButtonHint.Container.Center}" Margin="-250,0,250,56">
                        <ls:LSButton x:Name="toggleActionbeButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                     Tag="{Binding Source='h73880dc7ga260g4f04gab87ga0afe4b0794e',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIAccept"
                                     Visibility="Collapsed">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="LSButtonPressed">
                                    <b:ChangePropertyAction TargetObject="{Binding FocusedElement, ElementName=ModBrowser_c}" PropertyName="IsChecked" Value="{Binding FocusedElement.IsChecked, ElementName=ModBrowser_c, Converter={StaticResource InvertBoolConverter}}"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSButton>

                        <ls:LSButton x:Name="editSearchButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                     Tag="{Binding Source='h989c3331g06e5g45fcg980fg2ce3f17f63cb',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIAccept"
                                     Visibility="Collapsed">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="LSButtonPressed">
                                    <ls:SetMoveFocusAction TargetName="ModBrowser_c" Reset="True"/>
                                    <noesis:SetFocusAction TargetName="SearchText"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSButton>

                        <ls:LSButton x:Name="applyFiltersButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxY'}"
                                     Tag="{Binding Source=h325897c1gf60eg4867g8418g309a0252ab82, Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIMessageBoxY"
                                     Command="{Binding UpdateSearchCommand}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="LSButtonPressed">
                                    <b:ChangePropertyAction TargetName="ModBrowser_c" PropertyName="Tag" Value="{Binding Tag, ElementName=ModBrowser_c, Converter={StaticResource InvertBoolConverter}}"/>
                                    <ls:SetMoveFocusAction TargetName="ModBrowser_c" DeferFocusAction="True"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSButton>

                        <ls:LSInputBinding x:Name="closeFiltersButton" BoundEvent="UICancel">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="LSInputBindingPressed">
                                    <b:InvokeCommandAction Command="{Binding UpdateSearchCommand}"/>
                                    <b:ChangePropertyAction TargetName="ModBrowser_c" PropertyName="Tag" Value="{Binding Tag, ElementName=ModBrowser_c, Converter={StaticResource InvertBoolConverter}}"/>
                                    <ls:SetMoveFocusAction TargetName="ModBrowser_c" DeferFocusAction="True"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSInputBinding>
                    </StackPanel>
                </Grid>

                <Control x:Name="ModDetailsControl" Grid.Row="0" Grid.RowSpan="4" VerticalAlignment="Top" Template="{StaticResource ModDetailsTemplate}" Visibility="Collapsed"/>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding FocusedElement.DataContext.InstallState, ElementName=ModBrowser_c}" Value="Downloaded">
                    <Setter TargetName="subscribeButton" Property="Tag" Value="{Binding Source='h0ebc30c6g8cc7g4c36gb15dg93cdf03da23e',Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FocusedElement.DataContext.InstallState, ElementName=ModBrowser_c}" Value="Subscribed">
                    <Setter TargetName="subscribeButton" Property="Tag" Value="{Binding Source='hf3bbce24gd050g434bg9600g167a0c64da09',Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FocusedElement.DataContext.InstallState, ElementName=ModBrowser_c}" Value="Downloading">
                    <Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding FocusedElement.DataContext.InstallState, ElementName=ModBrowser_c}" Value="Uninstalled"/>
                        <Condition Binding="{Binding Data.ModAccountState}" Value="ModioConnected"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="subscribeButton" Property="Tag" Value="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282',Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="subscribeButton" Property="Command" Value="{Binding SubscribeModCommand}"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding FocusedElement, ElementName=ModBrowser_c, Converter={StaticResource TypeConverter}}" Value="ls.LSToggleButton">
                    <Setter TargetName="toggleActionbeButton" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <Trigger SourceName="SearchBarContainer" Property="ls:MoveFocus.IsFocused" Value="True">
                    <Setter TargetName="SearchTextFocusedMarker" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="SearchBarBg" Property="Source" Value="{StaticResource c_ModBrowserSearchBox_h}"/>
                    <Setter TargetName="editSearchButton" Property="Visibility" Value="Visible"/>
                </Trigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchText}" Value="False"/>
                        <Condition Binding="{Binding SearchText}" Value=""/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SearchBarHint" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=SearchText}" Value="True">
                    <Setter TargetName="SearchText" Property="Foreground" Value="{StaticResource LS_extraspecialTxtColor}"/>
                    <Setter TargetName="SearchBarBg" Property="Source" Value="{StaticResource c_ModBrowserSearchBox_h}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding ActiveFilters.Count}" Value="0">
                    <Setter TargetName="ActiveFiltersContainer" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="clearFiltersButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsUpdatingModList}" Value="False"/>
                        <Condition Binding="{Binding DownloadableMods.Count}" Value="0"/>
                        <Condition Binding="{Binding Data.IsUGCDisabled}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="NoResultsWarning" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Tag, ElementName=ModBrowser_c}" Value="{StaticResource TrueValue}">
                    <!--I know this could be a Trigger, but for some reason it doesn't work-->
                    <Setter TargetName="toggleFiltersButton" Property="Tag" Value="{Binding Source=hfb661d4fgb80fg4035ga529gb17d3c333d12, Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="detailsButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="subscribeButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="closeButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding FocusedElement.DataContext, ElementName=ModBrowser_c, FallbackValue={x:Null}}" Value="{x:Null}">
                    <Setter TargetName="subscribeButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="detailsButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>

                <!-- If AR is greater than 0.5625 ratio (this is an AR lower than 16/9), attach the side bar to the screen side instead so it doesn't get cut -->
                <DataTrigger Binding="{Binding Data.AspectRatio, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0.5625}" Value="True">
                    <Setter TargetName="SideBar" Property="HorizontalAlignment" Value="Left"/>
                    <Setter TargetName="SideBar" Property="Margin" Value="{StaticResource SidebarHideMarginLowerARs}"/>
                </DataTrigger>

                <!-- Animation for >= 16/9 ARs -->
                <MultiDataTrigger>
                    <!--I know this could be a MultiTrigger, but for some reason it doesn't work-->
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, ElementName=ModBrowser_c}" Value="{StaticResource TrueValue}"/>
                        <Condition Binding="{Binding HorizontalAlignment, ElementName=SideBar}" Value="Center"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SideBar" Property="Opacity" Value="1"/>
                    <Setter TargetName="SideBar" Property="Margin" Value="{StaticResource SidebarShowMargin}"/>
                    <MultiDataTrigger.EnterActions>
                        <StopStoryboard BeginStoryboardName="HideFilterPanel"/>
                        <BeginStoryboard Name="ShowFilterPanel">
                            <Storyboard FillBehavior="Stop">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="(UIElement.Opacity)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
                                </DoubleAnimationUsingKeyFrames>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="Margin">
                                    <SplineThicknessKeyFrame KeyTime="0:0:0" Value="{StaticResource SidebarHideMargin}" />
                                    <SplineThicknessKeyFrame KeyTime="0:0:0.1" Value="{StaticResource SidebarShowMargin}" />
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ShowFilterPanel"/>
                        <BeginStoryboard Name="HideFilterPanel">
                            <Storyboard FillBehavior="Stop">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="(UIElement.Opacity)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0"/>
                                </DoubleAnimationUsingKeyFrames>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="Margin">
                                    <SplineThicknessKeyFrame KeyTime="0:0:0" Value="{StaticResource SidebarShowMargin}" />
                                    <SplineThicknessKeyFrame KeyTime="0:0:0.1" Value="{StaticResource SidebarHideMargin}" />
                                </ThicknessAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>

                <!-- Animation for < 16/9 ARs -->
                <MultiDataTrigger>
                    <!--I know this could be a MultiTrigger, but for some reason it doesn't work-->
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, ElementName=ModBrowser_c}" Value="{StaticResource TrueValue}"/>
                        <Condition Binding="{Binding HorizontalAlignment, ElementName=SideBar}" Value="Left"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SideBar" Property="Opacity" Value="1"/>
                    <Setter TargetName="SideBar" Property="Margin" Value="{StaticResource SidebarShowMarginLowerARs}"/>
                    <MultiDataTrigger.EnterActions>
                        <StopStoryboard BeginStoryboardName="HideFilterPanelLowerARs"/>
                        <BeginStoryboard Name="ShowFilterPanelLowerARss">
                            <Storyboard FillBehavior="Stop">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="(UIElement.Opacity)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
                                </DoubleAnimationUsingKeyFrames>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="Margin">
                                    <SplineThicknessKeyFrame KeyTime="0:0:0" Value="{StaticResource SidebarHideMarginLowerARs}" />
                                    <SplineThicknessKeyFrame KeyTime="0:0:0.1" Value="{StaticResource SidebarShowMarginLowerARs}" />
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ShowFilterPanelLowerARs"/>
                        <BeginStoryboard Name="HideFilterPanelLowerARs">
                            <Storyboard FillBehavior="Stop">
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="(UIElement.Opacity)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0"/>
                                </DoubleAnimationUsingKeyFrames>
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="Margin">
                                    <SplineThicknessKeyFrame KeyTime="0:0:0" Value="{StaticResource SidebarShowMarginLowerARs}" />
                                    <SplineThicknessKeyFrame KeyTime="0:0:0.1" Value="{StaticResource SidebarHideMarginLowerARs}" />
                                </ThicknessAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SideBar" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding Data.IsUGCDisabled}" Value="True">
                    <Setter TargetName="toggleFiltersButton" Property="IsEnabled" Value="False"/>
                    <Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
                    <Setter TargetName="detailsButton" Property="IsEnabled" Value="False"/>
			    </DataTrigger>
                <DataTrigger Binding="{Binding InDetailsView}" Value="True">
                    <Setter TargetName="ModDetailsControl" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ActiveFiltersContainer" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ModListRoot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PageSelectionControl" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="BottomButtonsPanel" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ConnectionWarning" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ModListUpdateSpinner" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SideBar" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWaitingOnPermissionsChanged}" Value="True">
                    <Setter TargetName="UGCDisabled" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="NoResultsWarning" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ModListRoot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ModListPermissionsSpinner" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="toggleFiltersButton" Property="IsEnabled" Value="False"/>
                    <Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
                    <Setter TargetName="detailsButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWaitingOnPermissionsRequest}" Value="True">
                    <Setter TargetName="UGCDisabled" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="NoResultsWarning" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ModListRoot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ModListPermissionsSpinner" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="toggleFiltersButton" Property="IsEnabled" Value="False"/>
                    <Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
                    <Setter TargetName="detailsButton" Property="IsEnabled" Value="False"/>
                </DataTrigger>
				<DataTrigger Binding="{Binding IsModBrowserDisabled}" Value="True">
					<Setter TargetName="ModListRoot" Property="Visibility" Value="Collapsed"/>
					<Setter TargetName="ModListPermissionsSpinner" Property="Visibility" Value="Collapsed"/>
					<Setter TargetName="ConnectionWarning" Property="Visibility" Value="Visible"/>
					<Setter TargetName="PageSelectionControl" Property="Visibility" Value="Collapsed"/>
					<Setter TargetName="toggleFiltersButton" Property="Visibility" Value="Collapsed"/>
					<Setter TargetName="subscribeButton" Property="IsEnabled" Value="False"/>
					<Setter TargetName="detailsButton" Property="IsEnabled" Value="False"/>
				</DataTrigger>
			</DataTemplate.Triggers>
        </DataTemplate>
    </ls:UIWidget.ContentTemplate>
</ls:UIWidget>