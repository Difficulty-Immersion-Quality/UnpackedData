<ls:StateMachine xmlns:ls="clr-namespace:ls;assembly=Code"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ls:StateMachine.States>
        <ls:State Name="SystemUIs" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModVerificationWindow"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name = "MainMenu.LoadGame" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModVerificationWindow"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name = "Paused.LoadGame" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModVerificationWindow"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="Paused.SaveGame" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModVerificationWindow"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="Options" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModVerificationWindow"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name="GameSettings" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModVerificationWindow"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <ls:State Name = "MainMenu" ModType="Extend">
            <ls:State.Events>
                <ls:StateEvent Name="OpenModBrowser">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModBrowser"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenAccountManagement">
                    <ls:StateEvent.Actions>
                        <ls:PushState Name="AccountManagement"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <!--STATE: ModBrowser-->
        <ls:State Name = "ModBrowser" Layout = "Common" Owner = "All" DisableStatesBelow = "False" IsModal="True" HideStatesBelow = "True">
            <ls:State.Widgets>
                <ls:StateWidget Filename="/MainUI;component/Pages/ModDownloadingWidget.xaml" Layer="PauseOverlay"/>
            </ls:State.Widgets>
            <ls:State.InitialSubstates>
                <ls:InitialSubstate Name="ModBrowserDownload"/>
            </ls:State.InitialSubstates>
            <ls:State.Events>
                <ls:StateEvent Name = "OpenModBrowserDownload">
                    <ls:StateEvent.Actions>
                        <ls:SetSubstate Name="ModBrowserDownload"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "OpenModBrowserInstalled">
                    <ls:StateEvent.Actions>
                        <ls:SetSubstate Name="ModBrowserInstalled"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "ShowSplashScreen">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="ModBrowserSplashScreen"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "OpenSignUp">
                    <ls:StateEvent.Actions>
                        <ls:PushState Name="SignUp"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "OpenAccountManagement">
                    <ls:StateEvent.Actions>
                        <ls:PushState Name="AccountManagement"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "CloseWidget">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "CloseAll">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <!--STATE: ModBrowser Download-->
        <ls:State Name = "ModBrowserDownload" Layout = "Common" Owner = "All">
            <ls:State.Widgets>
                <ls:StateWidget Filename="ModBrowser_c.xaml" Layer="Pause" SoundLayer="EscapeMenu"/>
            </ls:State.Widgets>
        </ls:State>

        <!--STATE: ModBrowser Installed-->
        <ls:State Name = "ModBrowserInstalled" Layout = "Common" Owner = "All">
            <ls:State.Widgets>
                <ls:StateWidget Filename="ModBrowserInstalled_c.xaml" Layer="Pause" SoundLayer="EscapeMenu"/>
            </ls:State.Widgets>
        </ls:State>

        <!-- STATE ModBrowser SplashScreen-->
		<ls:State Name ="ModBrowserSplashScreen" HideStatesBelow = "False" IsModal = "True" Layout = "Common" Owner = "Player" IsModdable = "False">
            <ls:State.Widgets>
                <ls:StateWidget Filename="ModBrowserSplashScreen_c.xaml" Layer="MessageBox"/>
            </ls:State.Widgets>
            <ls:State.Events>
                <ls:StateEvent Name = "CloseWidget">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <!--STATE: AccountManagement-->
        <ls:State Name = "AccountManagement" DisableStatesBelow = "True" Layout = "Common" Owner = "DefaultPlayer">
            <ls:State.Widgets>
                <ls:StateWidget Filename="AccountManagement_c.xaml" Layer="Pause"/>
            </ls:State.Widgets>
            <ls:State.Events>
                <ls:StateEvent Name = "CloseWidget">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "CloseAccountManagement">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "OpenMessageBox">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="MessageBox"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "OpenModioSignIn">
                    <ls:StateEvent.Actions>
                        <ls:PushState Name="ModioSignIn"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <!--STATE: Modio Sign In-->
        <ls:State Name = "ModioSignIn" DisableStatesBelow = "True" Layout = "Common" Owner = "DefaultPlayer">
            <ls:State.Widgets>
                <ls:StateWidget Filename="ModioSignIn_c.xaml" Layer="Pause"/>
            </ls:State.Widgets>
            <ls:State.Events>
                <ls:StateEvent Name = "CloseWidget">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
                <ls:StateEvent Name = "OpenMessageBox">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="MessageBox"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>

        <!-- STATE: Mod Verification Window -->
        <ls:State Name = "ModVerificationWindow" DisableStatesBelow = "False" HideStatesBelow = "False" IsModal="True" Layout="Player" Owner="Player">
            <ls:State.Widgets>
                <ls:StateWidget Filename="/MainUI;component/Pages/ModDownloadingWidget.xaml" Layer="MessageBox"/>
                <ls:StateWidget Filename="ModVerification_c.xaml" Layer="PauseOverlay"/>
            </ls:State.Widgets>

            <ls:State.Events>
                <ls:StateEvent Name = "CloseModVerificationWindow">
                    <ls:StateEvent.Actions>
                        <ls:RemoveState/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenMessageBox">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="CommonMessageBox"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>

                <ls:StateEvent Name = "OpenSystemMessageBox">
                    <ls:StateEvent.Actions>
                        <ls:AddSubstate Name="SystemMessageBox"/>
                    </ls:StateEvent.Actions>
                </ls:StateEvent>
            </ls:State.Events>
        </ls:State>
    </ls:StateMachine.States>
</ls:StateMachine>