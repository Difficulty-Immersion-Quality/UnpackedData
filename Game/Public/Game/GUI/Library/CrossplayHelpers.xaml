    <Style x:Key="CrossplayBreadcrumbsStyle" TargetType="ls:LSButton" BasedOn="{StaticResource {x:Type ls:LSButton}}">
        <Setter Property="Visibility" Value="{Binding (ls:AttachedProperties.Number), RelativeSource={RelativeSource Mode=Self}, Converter={StaticResource CountToVisibilityConverter}}"/>
        <Setter Property="Command" Value="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
        <Setter Property="CommandParameter" Value="OpenFriendsRequest"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ls:LSButton">
                    <Grid>
                        <Image x:Name="bg" Source="{DynamicResource SmallRoundButtonDefault}" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txt" Text="{Binding (ls:AttachedProperties.Number), RelativeSource={RelativeSource Mode=TemplatedParent}}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource ScaledSmallFontSize}" FontWeight="Bold" Foreground="{StaticResource LS_accent100TxtColor}" Margin="8,0" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Source" Value="{DynamicResource SmallRoundButtonHighlight}" />
                            <Setter TargetName="txt" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Source" Value="{DynamicResource SmallRoundButtonHighlight}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.Data.CrossplayFriendRequests.Count, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, FallbackValue=0}" Value="0">
                <Setter Property="CommandParameter" Value="OpenFriendsList"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

