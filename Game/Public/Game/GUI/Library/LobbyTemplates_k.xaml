<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    xmlns:ls="clr-namespace:ls;assembly=Code"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
					mc:Ignorable="d">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="OptionTemplates_Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <BitmapImage x:Key="LobbyHeaderBackground" UriSource="pack://application:,,,/Core;component/Assets/Lobby/nav_bg_lobby.png"/>
    <BitmapImage x:Key="LobbyDivider" UriSource="pack://application:,,,/Core;component/Assets/Lobby/divider_lobby.png"/>
    <BitmapImage x:Key="FooterDecor" UriSource="pack://application:,,,/Core;component/Assets/Lobby/footer_lobby_big.png"/>
    <BitmapImage x:Key="FooterCenterDecorImage" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/footer_centerDecors.png"/>
    <BitmapImage x:Key="FooterSideDecorImage" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/footer_sideDecors.png"/>
    <BitmapImage x:Key="FooterFade" UriSource="pack://application:,,,/Core;component/Assets/DMSettings/fade_footer.png" />

    <BitmapImage x:Key="NavButtonDefault" UriSource="pack://application:,,,/Core;component/Assets/Buttons/btn_hudNav_d.png"/>
    <BitmapImage x:Key="NavButtonHighlight" UriSource="pack://application:,,,/Core;component/Assets/Buttons/btn_hudNav_h.png"/>
    <BitmapImage x:Key="NavButtonPressed" UriSource="pack://application:,,,/Core;component/Assets/Buttons/btn_hudNav_p.png"/>
    <BitmapImage x:Key="NavButtonDisabled" UriSource="pack://application:,,,/Core;component/Assets/Buttons/btn_hudNav_disabled.png"/>

    <BitmapImage x:Key="ScrubberIconDefault" UriSource="pack://application:,,,/Core;component/Assets/Options/ico_scrubber_d.png"/>
    <BitmapImage x:Key="ScrubberIconHighlight" UriSource="pack://application:,,,/Core;component/Assets/Options/ico_scrubber_h.png"/>

    <BitmapImage x:Key="SmallRoundButtonDefault" UriSource="pack://application:,,,/Core;component/Assets/Buttons/btn_small_round_d.png"/>
    <BitmapImage x:Key="SmallRoundButtonHighlight" UriSource="pack://application:,,,/Core;component/Assets/Buttons/btn_small_round_h.png"/>

    <ControlTemplate x:Key="ComboBoxTemplate">
        <ls:LSComboBox x:Name="comboBox" ItemsSource="{Binding ComboItems, Mode=OneWay}" SelectedItem="{Binding SelectedItem}" Foreground="{StaticResource LS_specialTxtColor}" Style="{StaticResource ComboBoxStyle}"
                       Text="{Binding SelectedItem.Name, Mode=OneWay}" IsEnabled="{Binding Enabled, Mode=OneWay}" SoundID="UI_HUD_Options_ComboBox"
                       d:DataContext="{d:DesignInstance {x:Type ls:VMComboBoxSetting}, IsDesignTimeCreatable=True}">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <b:InvokeCommandAction Command="{Binding DataContext.ValueChanged, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </ls:LSComboBox>
    </ControlTemplate>

    <ControlTemplate x:Key="TickBoxTemplate">
        <ls:LSToggleButton Style="{StaticResource TickBox}" IsChecked="{Binding Value}" IsEnabled="{Binding Enabled}" SoundID="UI_HUD_Options_ToggleButton" Margin="8,0"
                           Command="{Binding DataContext.ValueChanged, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}"/>
    </ControlTemplate>

    <DataTemplate x:Key="LobbyOptionTemplate">
        <DataTemplate.Resources>
            <ImageSource x:Key="ItemBG">pack://application:,,,/Core;component/Assets/Options/li_bg.png</ImageSource>
            <ImageSource x:Key="ItemBGHL">pack://application:,,,/Core;component/Assets/Options/li_bg_active.png</ImageSource>
        </DataTemplate.Resources>
        <Grid x:Name="Container" Margin="0,4,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="col0"/>
                <ColumnDefinition x:Name="col1" Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="highlight" Grid.Column="0" Grid.ColumnSpan="2" Stretch="Fill" Source="{StaticResource ItemBG}" Margin="0,16,0,-16"/>
            <TextBlock x:Name="label" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="60,0,0,0" TextWrapping="Wrap" Text="{Binding Text}" FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_accent75TxtColor}"/>
            <Control x:Name="content" Grid.Column="1" VerticalAlignment="Center"  HorizontalAlignment="Left" Template="{StaticResource ComboBoxTemplate}" />

            <b:Interaction.Triggers>
                <b:EventTrigger EventName="MouseEnter">
                    <ls:LSPlaySound Sound="UI_HUD_Options_OptionHover"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding ListItemType}" Value="TickBox">
                <Setter Property="Template" Value="{StaticResource TickBoxTemplate}" TargetName="content"/>
            </DataTrigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="highlight" Property="Source" Value="{StaticResource ItemBGHL}"/>
                <Setter TargetName="label" Property="Foreground" Value="{StaticResource LS_tint100}"/>
            </Trigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="LobbyOptionStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="ContentTemplate" Value="{StaticResource LobbyOptionTemplate}" />
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="IsSelected" Value="False"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="MaxHeight" Value="112"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding ListItemType}" Value="Button">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate DataType="{x:Type ls:VMListButton}">
                            <ls:LSButton Margin="0,8,0,8" Style="{StaticResource BrownButtonStyle}" Content="{Binding Text}" Command="{Binding ButtonCommand.ActionCommand}"/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding ListItemType}" Value="String">
                <Setter Property="ContentTemplate">
                    <Setter.Value>
                        <DataTemplate DataType="{x:Type ls:VMListItem}">
                            <DataTemplate.Resources>
                                <ImageSource x:Key="SideDecorations">pack://application:,,,/Core;component/Assets/Options/decors_header.png</ImageSource>
                            </DataTemplate.Resources>

                            <StackPanel Margin="0,40,0,0" Orientation="Horizontal">
                                <Image Source="{StaticResource SideDecorations}" Stretch="None" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Text}" FontWeight="Bold" Foreground="{StaticResource LS_tint100}" Margin="16,0"/>
                                <Image Source="{StaticResource SideDecorations}" Stretch="None" VerticalAlignment="Center">
                                    <Image.RenderTransform>
                                        <ScaleTransform ScaleX="-1" CenterX="42"/>
                                    </Image.RenderTransform>
                                </Image>
                            </StackPanel>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="IsSelected" Value="True"/>
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Background" Value="Transparent" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Background" Value="Transparent" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="LobbySectionTitle">
        <ControlTemplate.Resources>
            <BitmapImage x:Key="TitleOrnament" UriSource="pack://application:,,,/Core;component/Assets/Options/decors_header.png"/>
        </ControlTemplate.Resources>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Image Source="{StaticResource TitleOrnament}"/>
            <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       FontSize="{StaticResource ScaledLargeFontSize}"
                       Foreground="{StaticResource LS_baseTxtColor}" Margin="30,0"/>
            <Image Source="{StaticResource TitleOrnament}" RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform ScaleX="-1"/>
                </Image.RenderTransform>
            </Image>
        </StackPanel>
    </ControlTemplate>
</ResourceDictionary>