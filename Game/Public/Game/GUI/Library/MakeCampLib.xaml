<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"

                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    xmlns:ls="clr-namespace:ls;assembly=Code"
					mc:Ignorable="d">

    <Storyboard x:Key="RingFillingAnim" Duration="0:0:1">
        <PointAnimationUsingKeyFrames Storyboard.TargetProperty="Stroke.StartPoint" Storyboard.TargetName="RingPath">
            <DiscretePointKeyFrame KeyTime="0:0:0" Value="{Binding DataContext.RingStartFillBeginPoint, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
            <SplinePointKeyFrame KeySpline="0.333,0 0.667,1" KeyTime="0:0:1" Value="{Binding DataContext.RingStartFillEndPoint, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
        </PointAnimationUsingKeyFrames>
        <PointAnimationUsingKeyFrames Storyboard.TargetProperty="Stroke.EndPoint" Storyboard.TargetName="RingPath">
            <DiscretePointKeyFrame KeyTime="0:0:0" Value="{Binding DataContext.RingEndFillStartPoint, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
            <LinearPointKeyFrame KeyTime="0:0:1" Value="{Binding DataContext.RingEndFillEndPoint, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
        </PointAnimationUsingKeyFrames>
    </Storyboard>

    <Style x:Key="ItemIconStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="ContentTemplate" Value="{DynamicResource ItemIcon}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="ls:LSListBoxItem.MouseRightClickEnabled" Value="False"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="ls:MoveFocus.Focusable" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource Style.FocusVisualStyle}"/>
        <Setter Property="ls:LSListBoxItem.SelectOnMouseUp" Value="True"/>
        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                    <Condition Binding="{Binding Tag, ElementName=root}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter Property="Opacity" Value="0.7"/>
                    <Setter Property="IsEnabled" Value="False"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="SoundEventsTemplate" TargetType="Control">
        <Grid>
            <b:Interaction.Triggers>
                <!-- RTPC Set to % of Bar filled -->
                <b:PropertyChangedTrigger Binding="{Binding SelectedSuppliesAmount}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding PreviousSupplyPercentage}" Operator="NotEqual" RightOperand="{Binding NewSupplyPercentage}"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <b:InvokeCommandAction Command="{Binding SoundSetRTPC}">
                        <b:InvokeCommandAction.CommandParameter>
                            <MultiBinding Converter="{StaticResource PassThroughConverter}">
                                <Binding Source="RTPC_UI_HUD_MakeCamp_CurrentSupplyCount"/>
                                <Binding Path="NewSupplyPercentage"/>
                            </MultiBinding>
                        </b:InvokeCommandAction.CommandParameter>
                    </b:InvokeCommandAction>
                    <ls:LSPlaySound Sound="UI_HUD_MakeCamp_ItemSelect_FillLayer"/>
                </b:PropertyChangedTrigger>

                <!-- Switch Set to Decrease-->
                <b:PropertyChangedTrigger Binding="{Binding SelectedSuppliesAmount}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding NewSupplyPercentage}" Operator="LessThan" RightOperand="{Binding PreviousSupplyPercentage}"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <b:InvokeCommandAction Command="{Binding SoundSetSwitch}">
                        <b:InvokeCommandAction.CommandParameter>
                            <MultiBinding Converter="{StaticResource PassThroughConverter}">
                                <Binding Source="UI_HUD_MakeCamp_CurrentSupply"/>
                                <Binding Source="Decrease"/>
                            </MultiBinding>
                        </b:InvokeCommandAction.CommandParameter>
                    </b:InvokeCommandAction>
                </b:PropertyChangedTrigger>

                <!-- Switch Set to Increase-->
                <b:PropertyChangedTrigger Binding="{Binding SelectedSuppliesAmount}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding NewSupplyPercentage}" Operator="GreaterThan" RightOperand="{Binding PreviousSupplyPercentage}"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <b:InvokeCommandAction Command="{Binding SoundSetSwitch}">
                        <b:InvokeCommandAction.CommandParameter>
                            <MultiBinding Converter="{StaticResource PassThroughConverter}">
                                <Binding Source="UI_HUD_MakeCamp_CurrentSupply"/>
                                <Binding Source="Increase"/>
                            </MultiBinding>
                        </b:InvokeCommandAction.CommandParameter>
                    </b:InvokeCommandAction>
                </b:PropertyChangedTrigger>

                <!-- Switch stop Complete Loop-->
                <b:PropertyChangedTrigger Binding="{Binding SelectedSuppliesAmount}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding PreviousSupplyPercentage}" Operator="GreaterThanOrEqual" RightOperand="1"/>
                                <b:ComparisonCondition LeftOperand="{Binding NewSupplyPercentage}" Operator="LessThan" RightOperand="1"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <ls:LSPlaySound Sound="UI_HUD_CampSuppliesFill_Completed_Stop"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>
        </Grid>
    </ControlTemplate>
</ResourceDictionary>