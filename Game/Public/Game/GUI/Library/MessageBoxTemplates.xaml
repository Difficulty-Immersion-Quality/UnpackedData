<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:ls="clr-namespace:ls;assembly=Code"
					mc:Ignorable="d">

    <DataTemplate x:Key="MessageBoxButton" DataType="{x:Type ls:GameCommand}">
        <ContentControl>
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Template" Value="{DynamicResource MsgSecondaryButton}" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding ActionCommandParameter}" Value="" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource MsgPrimaryButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding ActionCommandParameter}" Value="{x:Null}" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource MsgSubmitInputButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding BoundEvent}" Value="UIAccept" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource MsgPrimaryButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.CheckBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding BoundEvent}" Value="UIAccept" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource MsgSubmitCheckBoxButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding BoundEvent}" Value="UIPaste" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource MsgPasteToInputButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>

                        <!-- Game Over Buttons -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding BoundEvent}" Value="UICancel" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource GameOverMainMenuButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding BoundEvent}" Value="UIDelete" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource GameOverBackButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding DataContext.InputBoxProperty, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="False" />
                                <Condition Binding="{Binding DataContext.IsGameOver, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True" />
                                <Condition Binding="{Binding BoundEvent}" Value="UIAccept" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Template" Value="{DynamicResource GameOverLoadGameButton}" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </DataTemplate>

    <ControlTemplate x:Key="MessageBoxTemplate">
        <StackPanel>
            <!-- body text -->
            <ls:LSScrollViewer x:Name="MessageScroller" MaxHeight="1000" HorizontalAlignment="Center" VerticalScrollBarVisibility="Auto" BoundScrollUpEvent="UIScrollUp" BoundScrollDownEvent="UIScrollDown" Visibility="{Binding TextProperty, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter='EmptyString'}">
                <TextBlock x:Name="Message" ls:TextBlockFormatter.SourceText="{Binding TextProperty}" FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_accent100TxtColor}" TextWrapping="Wrap" TextAlignment="Center" Margin="20,0"/>
            </ls:LSScrollViewer>

            <!-- input box -->
            <Grid HorizontalAlignment="Center" Visibility="{Binding InputBoxProperty, Converter={StaticResource BoolToVisibleConverter}}">
                <Image Stretch="None">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Messagebox/inputField_d.png"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Messagebox/inputField_h.png"/>
                                </Trigger>

                                <DataTrigger Binding="{Binding Path=IsMouseOver, ElementName=Input}" Value="True">
                                    <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/Messagebox/inputField_h.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <ls:LSTextBox x:Name="Input" Text="{Binding InputTextProperty}" MaxWidth="900"  Mask="Filename" TextImmediateSourceUpdate="True" MaxLength="{Binding InputBoxMaxLengthProperty}" Margin="80,20,80,14" Style="{StaticResource DefaultInputBox}" UseLayoutRounding="True" PlayerId="{Binding PlayerId}" ProfanityFilter="True">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="Loaded">
                            <b:Interaction.Behaviors>
                                <b:ConditionBehavior>
                                    <b:ConditionalExpression>
                                        <b:ComparisonCondition LeftOperand="{Binding IsVisible, ElementName=Input}" Operator="Equal" RightOperand="True" />
                                    </b:ConditionalExpression>
                                </b:ConditionBehavior>
                            </b:Interaction.Behaviors>
                            <noesis:SetFocusAction/>
                        </b:EventTrigger>

                        <b:EventTrigger EventName="GotKeyboardFocus">
                            <b:Interaction.Behaviors>
                                <b:ConditionBehavior>
                                    <b:ConditionalExpression>
                                        <b:ComparisonCondition LeftOperand="{Binding DataContext.Data.UIInputMethod, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Operator="Equal" RightOperand="Controller"/>
                                        <b:ComparisonCondition LeftOperand="IsReadOnly" Operator="NotEqual" RightOperand="True" />
                                    </b:ConditionalExpression>
                                </b:ConditionBehavior>
                            </b:Interaction.Behaviors>
                            <noesis:SelectAllAction/>
                        </b:EventTrigger>

                    </b:Interaction.Triggers>
                </ls:LSTextBox>
            </Grid>

            <!-- check box -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 20" Visibility="{Binding CheckBoxProperty, Converter={StaticResource BoolToVisibleConverter}}">
                <ls:LSToggleButton x:Name="CheckBox" ls:Input.Event="UILeft" Style="{StaticResource TickBox}" IsChecked="{Binding CheckBoxValueProperty, Mode=TwoWay}" Focusable="False" SoundID="UI_Shared_Hover" BoundEvent="UIRight">
                    <b:Interaction.Triggers>
                        <ls:GameInputTrigger BoundEvent = "{Binding Path=(ls:Input.Event),ElementName=CheckBox}" FiredOn="ButtonUpAndDown" IsEnabled="{Binding Path=IsEnabled,ElementName=CheckBox}">
                            <ls:KeyPressAction />
                        </ls:GameInputTrigger>
                    </b:Interaction.Triggers>
                </ls:LSToggleButton>
                
                <TextBlock FontSize="{StaticResource DefaultFontSize}" Foreground="{StaticResource LS_baseTxtColor}" Text="{Binding CheckBoxLabelProperty}" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding DataContext.Data.UIInputMethod, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="Keyboard">
                <Setter TargetName="CheckBox" Property="BoundEvent" Value="Unknown"/>
                <Setter TargetName="CheckBox" Property="ls:Input.Event" Value="Unknown"/>
                <Setter TargetName="CheckBox" Property="SoundID" Value="UI_HUD_Options_ToggleButton"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="HonourGameOverTemplate">
        <ControlTemplate.Resources>
            <BitmapImage x:Key="DescriptionDecor" UriSource="pack://application:,,,/Core;component/Assets/Messagebox/HonourMode/dialog_subframe.png"/>
            <BitmapImage x:Key="MainMenuImage" UriSource="pack://application:,,,/Core;component/Assets/Buttons/ico_btn_cross_d.png"/>
            <BitmapImage x:Key="LoadGameImage" UriSource="pack://application:,,,/Core;component/Assets/Buttons/ico_btn_load_d.png"/>
        </ControlTemplate.Resources>
        <StackPanel>
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="Loaded">
                    <ls:LSPlaySound Sound="UI_HUD_GameOver"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <TextBlock x:Name="TitleText" Text="{Binding Source='h4242ad23gc2e7g4a6fg9825g487e19d7e1ab', Converter={StaticResource TranslatedStringConverter}}" 
                       FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_tint100}" TextWrapping="Wrap" TextAlignment="Center" Margin="20,0" />
            <StackPanel x:Name="DescriptionPanel" Margin="0,50">
                <Image Source="{StaticResource DescriptionDecor}" Stretch="None"/>
                <TextBlock x:Name="PropertyText" ls:TextBlockFormatter.SourceText="{Binding Source='h33b1fe8dgf675g4ba9g9b65g9405137331cf', Converter={StaticResource TranslatedStringConverter}}"
                           FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_accent100TxtColor}" TextWrapping="Wrap" TextAlignment="Center" Margin="20,10"/>
                <StackPanel x:Name="EndDescriptionPanel" Orientation="Horizontal" Margin="20,50" HorizontalAlignment="Center">
                    <Image x:Name="MainMenuIcon" Source="{StaticResource MainMenuImage}" Stretch="None" VerticalAlignment="Top" Margin="0,3"/>
                    <TextBlock x:Name="EndDescription" ls:TextBlockFormatter.SourceText="{Binding Source='hed392e60g9d7dg4f8ag9868g08ba6efef31c', Converter={StaticResource TranslatedStringConverter}}"
                               FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_baseTxtColor}" TextWrapping="Wrap" TextAlignment="Left" Width="1000" Margin="10,0"/>
                </StackPanel>
                <StackPanel x:Name="LoadDescriptionPanel" Orientation="Horizontal" Margin="20,-40" HorizontalAlignment="Center">
                    <Image x:Name="LoadGameIcon" Source="{StaticResource LoadGameImage}" Stretch="None" VerticalAlignment="Top" Margin="0,3"/>
                    <TextBlock x:Name="LoadDescription" ls:TextBlockFormatter.SourceText="{Binding Source='h60e3d02bgd265g4ed3ga3d3g055312feda72', Converter={StaticResource TranslatedStringConverter}}"
                               FontSize="{StaticResource ScaledDefaultFontSize}" Foreground="{StaticResource LS_baseTxtColor}" TextWrapping="Wrap" TextAlignment="Left" Width="1000" Margin="10,0"/>
                </StackPanel>
                <Image Source="{StaticResource DescriptionDecor}" Stretch="None" RenderTransformOrigin="0.5, 0.5" Margin="0, 60">
                    <Image.RenderTransform>
                        <RotateTransform Angle="180"/>
                    </Image.RenderTransform>
                </Image>
            </StackPanel>
        </StackPanel>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding DataContext.Data.UIInputMethod, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="Controller">
                <Setter TargetName="PropertyText" Property="Margin" Value="0,40,0,0"/>
                <Setter TargetName="EndDescriptionPanel" Property="Margin" Value="0,60,0,20"/>
                <Setter TargetName="LoadDescriptionPanel" Property="Margin" Value="0,20"/>
                <Setter TargetName="MainMenuIcon" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="LoadGameIcon" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="DescriptionPanel" Property="Margin" Value="0,30"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

</ResourceDictionary>
