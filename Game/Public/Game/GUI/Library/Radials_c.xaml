
    <ResourceDictionary
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d">


    <BitmapImage x:Key="RadialPointer" UriSource="pack://application:,,,/Core;component/Assets/Radials/c_actionRadial_pointer.png"/>
    <BitmapImage x:Key="RadialDefaultBG" UriSource="pack://application:,,,/Core;component/Assets/Radials/c_radial_bg.png"/>

    <Style TargetType="{x:Type ls:Radial}" BasedOn="{StaticResource baseStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="RenderTransformOrigin" Value="0.5 0.5"/>
        <Setter Property="StopSelectionTreshHold" Value="0.3"/>
        <Setter Property="StartSelectionTreshHold" Value="0.8"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="SelectionSticky" Value="False"/>

        <Setter Property="ls:Radial.LeftEvent" Value="UIRadialLeft"/>
        <Setter Property="ls:Radial.RightEvent" Value="UIRadialRight"/>
        <Setter Property="ls:Radial.UpEvent" Value="UIRadialUp"/>
        <Setter Property="ls:Radial.DownEvent" Value="UIRadialDown"/>

        <Setter Property="HalfElementOffset" Value="True"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ls:Radial">
                    <Grid>
                        <Image VerticalAlignment="Center" HorizontalAlignment="Center" Source="{StaticResource RadialDefaultBG}" Stretch="Fill"  Margin="0,44,0,0" Width="1368" Height="1368"/>
                        <Canvas HorizontalAlignment="Center" VerticalAlignment="Center" >
                            <Canvas x:Name="PART_ContentHolder" Margin="{TemplateBinding Padding}"/>
                            </Canvas>
                        <DockPanel x:Name="PART_Rotation" RenderTransformOrigin="0.5 0.5" Visibility="Hidden" Margin="0,20,0,-20">
                            <Image VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5 0.5" Source="{StaticResource RadialPointer}" Stretch="None" Margin="0,-360,0,360">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="91"/>
                                </Image.RenderTransform>
                            </Image>
                        </DockPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger  Binding="{Binding LocalFocus, RelativeSource={RelativeSource Mode=Self}, Converter={StaticResource NullToBoolFalseConverter}}" Value="True" >
                            <Setter Property="Visibility" Value="Visible" TargetName="PART_Rotation"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ls:LSRadialListItem}" BasedOn="{StaticResource baseStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    
</ResourceDictionary>