<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:ls="clr-namespace:ls;assembly=Code"
                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    mc:Ignorable="d">

    <BitmapImage x:Key="ScreenshotHolder" UriSource="pack://application:,,,/Core;component/Assets/SaveLoad/frame_screenshot.png"/>
    <BitmapImage x:Key="LineSeparator" UriSource="pack://application:,,,/Core;component/Assets/SaveLoad_c/line_preview.png"/>
    <System:Double x:Key="PresenterWidth">1600</System:Double>
    <Thickness x:Key="SavefileMargin">0,120,0,0</Thickness>
    <Thickness x:Key="PresenterMargin">0,80,0,0</Thickness>
    <Thickness x:Key="ViewBoxMargin">80,0</Thickness>

    <!-- Message box to ensure user wants to delete a savegame -->
    <ls:LSMessageBoxData x:Key="MessageBoxSaveDelete"
                         Title="{Binding Source='h07d13857g9ac7g4a97g912cg78a67b932954', Converter={StaticResource TranslatedStringConverter}}"
                         UUID="UUID">
        <ls:LSMessageBoxData.Actions>
            <ls:LSGameCommandData ActionName="{Binding Source='hf52bf842g05beg48dega717gca15b3678e0e', Converter={StaticResource TranslatedStringConverter}}"
                                  Command="{Binding DataContext.DoDelete, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxA'}"/>
            <ls:LSGameCommandData ActionName="{Binding Source='heded8384gb4f5g439dg9883g5cf950b2bbfc', Converter={StaticResource TranslatedStringConverter}}" 
                                  Command="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="CloseMessageBox"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxB'}"/>
        </ls:LSMessageBoxData.Actions>
        <ls:LSMessageBoxData.Text>
            <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                <Binding Source="hff837222g4949g4631g9090g989ae93fbe29"/>
                <Binding Path="DataContext.SelectedSave.Title" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
            </MultiBinding>
        </ls:LSMessageBoxData.Text>
    </ls:LSMessageBoxData>

    <ls:LSMessageBoxData x:Key="MessageBoxSaveDeleteCampaignConfirmation"
                         Title="{Binding Source='ha58e0d43g4b0ag433ag939eg1c140baa7732', Converter={StaticResource TranslatedStringConverter}}"
                         Text="{Binding Source='h72ff8199g2db2g4b13g924cg70eb7879f77c', Converter={StaticResource TranslatedStringConverter}}"
                         UUID="UUID">
        <ls:LSMessageBoxData.Actions>
            <ls:LSGameCommandData ActionName="{Binding Source='hf52bf842g05beg48dega717gca15b3678e0e', Converter={StaticResource TranslatedStringConverter}}"
                                  Command="{Binding DataContext.DoDeleteCampaign, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxA'}"/>
            <ls:LSGameCommandData ActionName="{Binding Source='heded8384gb4f5g439dg9883g5cf950b2bbfc', Converter={StaticResource TranslatedStringConverter}}" 
                                  Command="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="CloseMessageBox"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxB'}"/>
        </ls:LSMessageBoxData.Actions>
    </ls:LSMessageBoxData>

    <ls:LSMessageBoxData x:Key="MessageBoxSaveDeleteCampaign"
                         Title="{Binding Source='ha58e0d43g4b0ag433ag939eg1c140baa7732', Converter={StaticResource TranslatedStringConverter}}"
                         UUID="UUID">
        <ls:LSMessageBoxData.Actions>
            <ls:LSGameCommandData ActionName="{Binding Source='hf52bf842g05beg48dega717gca15b3678e0e', Converter={StaticResource TranslatedStringConverter}}"
                                  Command="{Binding DataContext.OpenConfirmationDeleteCampaignCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="{StaticResource MessageBoxSaveDeleteCampaignConfirmation}"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxA'}"/>
            <ls:LSGameCommandData ActionName="{Binding Source='heded8384gb4f5g439dg9883g5cf950b2bbfc', Converter={StaticResource TranslatedStringConverter}}" 
                                  Command="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="CloseMessageBox"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxB'}"/>
        </ls:LSMessageBoxData.Actions>
        <ls:LSMessageBoxData.Text>
            <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                <Binding Source="h66937a39g1904g45a6gae4ag8fad832cc5ee"/>
                <Binding Path="DataContext.SelectedPlaythrough.ProtagonistName" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
            </MultiBinding>
        </ls:LSMessageBoxData.Text>
    </ls:LSMessageBoxData>

    <!-- Message boxes to ensure user wants to delete all the saves of a campaign (except latest) and confirming this action -->
    <ls:LSMessageBoxData x:Key="MessageBoxSaveDeleteCampaignButLatestConfirmation"
                         Title="{Binding Source='h9c2809d8g833dg4deagb0d9g5f0ab199cb41', Converter={StaticResource TranslatedStringConverter}}"
                         UUID="UUID">
        <ls:LSMessageBoxData.Actions>
            <ls:LSGameCommandData ActionName="{Binding Source='hf52bf842g05beg48dega717gca15b3678e0e', Converter={StaticResource TranslatedStringConverter}}"
                                  Command="{Binding DataContext.DoDeleteAllCampaignButLatest, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxA'}"/>
            <ls:LSGameCommandData ActionName="{Binding Source='heded8384gb4f5g439dg9883g5cf950b2bbfc', Converter={StaticResource TranslatedStringConverter}}" 
                                  Command="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="CloseMessageBox"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxB'}"/>
        </ls:LSMessageBoxData.Actions>
        <ls:LSMessageBoxData.Text>
            <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                <Binding Source="hbf7cfa8dgfed9g42c3gaf6eg218a67d5be4b"/>
                <Binding Path="DataContext.SelectedPlaythrough.LatestSave.Title" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
            </MultiBinding>
        </ls:LSMessageBoxData.Text>
    </ls:LSMessageBoxData>

    <ls:LSMessageBoxData x:Key="MessageBoxSaveDeleteCampaignButLatest"
                         Title="{Binding Source='h9c2809d8g833dg4deagb0d9g5f0ab199cb41', Converter={StaticResource TranslatedStringConverter}}"
                         UUID="UUID">
        <ls:LSMessageBoxData.Actions>
            <ls:LSGameCommandData ActionName="{Binding Source='hf52bf842g05beg48dega717gca15b3678e0e', Converter={StaticResource TranslatedStringConverter}}"
                                  Command="{Binding DataContext.OpenConfirmationDeleteCampaignCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="{StaticResource MessageBoxSaveDeleteCampaignButLatestConfirmation}"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxA'}"/>
            <ls:LSGameCommandData ActionName="{Binding Source='heded8384gb4f5g439dg9883g5cf950b2bbfc', Converter={StaticResource TranslatedStringConverter}}" 
                                  Command="{Binding DataContext.CustomEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                  CommandParameter="CloseMessageBox"
                                  BoundInput="{Binding DataContext.CurrentPlayer.UIData.InputEvents, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxB'}"/>
        </ls:LSMessageBoxData.Actions>
        <ls:LSMessageBoxData.Text>
            <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                <Binding Source="ha66a404cga5efg404dg80adg1a462b40c8b8"/>
                <Binding Path="DataContext.SelectedPlaythrough.ProtagonistName" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                <Binding Path="DataContext.SelectedPlaythrough.LatestSave.Title" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
            </MultiBinding>
        </ls:LSMessageBoxData.Text>
    </ls:LSMessageBoxData>

    <Style x:Key="SaveLoad.Title" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource LS_PrimaryColor}" />
        <Setter Property="FontSize" Value="{StaticResource ScaledMassiveFontSize}" />
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="SaveLoad.Cloud.Title" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource LS_baseTxtColor}" />
        <Setter Property="FontSize" Value="{StaticResource ScaledDefaultFontSize}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SaveLoad.Cloud.Label" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource LS_PrimaryColor}" />
        <Setter Property="FontSize" Value="{StaticResource ScaledLargeFontSize}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <ControlTemplate x:Key="SteamCloudSaveInfo">
        <ControlTemplate.Resources>
            <BitmapImage x:Key="CloudImage" UriSource="pack://application:,,,/Core;component/Assets/SaveLoad_c/c_ico_cloud.png"/>
        </ControlTemplate.Resources>
        <StackPanel Visibility="{Binding Path=., Converter={StaticResource NullToHiddenConverter}}" HorizontalAlignment="Center" Margin="-12 28 0 0">
            <Image x:Name="CloudIcon" Source="{StaticResource CloudImage}" Stretch="None"/>
            <TextBlock Text="{Binding Source='hc76b68d4g8daeg422eg80b2ge283aa2465d9', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.Cloud.Title}"/>
            <TextBlock x:Name="CloudSaveStatus" Text="{Binding Source='hb20007ddg7ba5g4432ga01eg42b1f30c0e2f', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.Cloud.Label}"/>
        </StackPanel>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding CloudStatus}" Value="NoSync">
                <Setter Property="Visibility" Value="Hidden"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CloudStatus}" Value="InSync">
                <Setter Property="Foreground" Value="{StaticResource LS_PrimaryColorDisabled}" TargetName="CloudSaveStatus"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CloudStatus}" Value="ToBeSynced">
                <Setter Property="Foreground" Value="{StaticResource SaveLoad.Downloading}" TargetName="CloudSaveStatus"/>
                <Setter Property="Text" Value="{Binding Source='h3efe7ad3g38e4g4155g888dg642ed634e5b6', Converter={StaticResource TranslatedStringConverter}}" TargetName="CloudSaveStatus"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="CrossSaveInfo">
        <ControlTemplate.Resources>
            <BitmapImage x:Key="CrossImage" UriSource="pack://application:,,,/Core;component/Assets/SaveLoad_c/c_ico_cross_save.png"/>
        </ControlTemplate.Resources>
        <StackPanel HorizontalAlignment="Center" Margin="-12 30 0 0" Visibility="{Binding Path=., Converter={StaticResource NullToHiddenConverter}}">
            <Image x:Name="CrossIcon" Source="{StaticResource CrossImage}" Stretch="None"/>
            <TextBlock Text="{Binding Source='hd9a78783g7021g4e8dga770g11c966ce5262', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.Cloud.Title}" />
            <TextBlock x:Name="CrossSaveStatus" Text="{Binding Source='hb20007ddg7ba5g4432ga01eg42b1f30c0e2f', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.Cloud.Label}"/>
        </StackPanel>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding CrossStatus}" Value="NoCrossSync">
                <Setter Property="Visibility" Value="Hidden"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CrossStatus}" Value="InCrossSync">
                <Setter Property="Foreground" Value="{StaticResource LS_PrimaryColorDisabled}" TargetName="CrossSaveStatus"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CrossStatus}" Value="Uploading">
                <Setter Property="Foreground" Value="{StaticResource SaveLoad.Uploading}" TargetName="CrossSaveStatus"/>
                <Setter Property="Text" Value="{Binding Source='h36ab7cddg5320g4ba0ga3f5g84b0c69c25b5', Converter={StaticResource TranslatedStringConverter}}" TargetName="CrossSaveStatus"/>
                <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad_c/c_ico_cross_save_uploading.png" TargetName="CrossIcon"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CrossStatus}" Value="Downloading">
                <Setter Property="Foreground" Value="{StaticResource SaveLoad.Downloading}" TargetName="CrossSaveStatus"/>
                <Setter Property="Text" Value="{Binding Source='hda248faeg2731g45a1g9687ga449aef4f1cf', Converter={StaticResource TranslatedStringConverter}}" TargetName="CrossSaveStatus"/>
                <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad_c/c_ico_cross_save_downloading.png" TargetName="CrossIcon"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CrossStatus}" Value="FailedUpload">
                <Setter Property="Foreground" Value="{StaticResource SaveLoad.Uploading}" TargetName="CrossSaveStatus"/>
                <Setter Property="Text" Value="{Binding Source='hf86b04ffg9073g422egab1agdfbf61109ae2', Converter={StaticResource TranslatedStringConverter}}" TargetName="CrossSaveStatus"/>
                <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad_c/ico_cross_save_uploading_issue.png" TargetName="CrossIcon"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CrossStatus}" Value="FailedDownload">
                <Setter Property="Foreground" Value="{StaticResource SaveLoad.Downloading}" TargetName="CrossSaveStatus"/>
                <Setter Property="Text" Value="{Binding Source='h3123b1adgf9cfg47b6gaf3fg8494b2353658', Converter={StaticResource TranslatedStringConverter}}" TargetName="CrossSaveStatus"/>
                <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad_c/ico_cross_save_downloading_issue.png" TargetName="CrossIcon"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="SaveLoad.DetailsTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource LS_accent100TxtColor}" />
        <Setter Property="FontSize" Value="{StaticResource ScaledDefaultFontSize}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="DemiBold"/>
    </Style>
    
    <ControlTemplate x:Key="SaveLoad.Details.Version">
        <StackPanel>
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontSize" Value="{StaticResource ScaledSmallishFontSize}"/>
                    <Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}"/>
                </Style>
            </StackPanel.Resources>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock>
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                            <Binding Source="hf5795482g056ag446fgb664gfe2b0007058e"/>
                            <Binding Source="hbbc4fb50ga17ag467dgb3b8g8db652071022" Converter="{StaticResource TranslatedStringConverter}"/>
                            <Binding Path="Version" FallbackValue=""/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <TextBlock x:Name="ValiditySeparator" Text=" - " Visibility="{Binding Visibility, ElementName=InvalidTextReason}"/>
                <TextBlock x:Name="InvalidTextReason" Text="" Visibility="Collapsed"/>
            </StackPanel>

            <TextBlock x:Name="SingleSaveDescription" Text="{Binding Source='hb276a3ccg5e63g47fag8820gb751dc159b4e', Converter={StaticResource TranslatedStringConverter}}" Visibility="Hidden"
                       Foreground="{StaticResource LS_warning50TxtColor}" Margin="0,12,0,0"/>
        </StackPanel>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding Validity}" Value="TooOld">
                <Setter TargetName="InvalidTextReason" Property="Visibility" Value="Visible"/>
                <Setter TargetName="InvalidTextReason" Property="Text" Value="{Binding Source='h4cb97c56g2888g45c4g8b54ga92efe29d05f', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Validity}" Value="TooNew">
                <Setter TargetName="InvalidTextReason" Property="Visibility" Value="Visible"/>
                <Setter TargetName="InvalidTextReason" Property="Text" Value="{Binding Source='h1a72f51bg19b8g489cg875dg60e3ca119f57', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Validity}" Value="DataNotReady">
                <Setter TargetName="InvalidTextReason" Property="Visibility" Value="Visible"/>
                <Setter TargetName="InvalidTextReason" Property="Text" Value="{Binding Source='hbe37675cg33d5g4f00gbcf0gd82ef213b101', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Validity}" Value="PatchNeeded">
                <Setter TargetName="InvalidTextReason" Property="Visibility" Value="Visible"/>
                <Setter TargetName="InvalidTextReason" Property="Text" Value="{Binding Source='h878832dcg5cd8g42c2g8875gf4674c24c591', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Validity}" Value="LoadHonourModeWhilePlaying">
                <Setter TargetName="SingleSaveDescription" Property="Visibility" Value="Visible"/>
            </DataTrigger>
			<DataTrigger Binding="{Binding Validity}" Value="ModdedCrossSaveConsole">
				<Setter TargetName="InvalidTextReason" Property="Visibility" Value="Visible"/>
				<Setter TargetName="InvalidTextReason" Property="Text" Value="{Binding Source='hfa5b8049g1dfag44f8g83e6gb65c58849d71', Converter={StaticResource TranslatedStringConverter}}"/>
			</DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="SavegameItemTemplateStyle" TargetType="ListBoxItem">
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        <Setter Property="Width" Value="1760"/>
        <Setter Property="Margin" Value="40,0,0,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <ControlTemplate.Resources>
                        <BitmapImage x:Key="CrossImage" UriSource="pack://application:,,,/Core;component/Assets/SaveLoad/ico_cross_save.png"/>
                        <BitmapImage x:Key="CloudImage" UriSource="pack://application:,,,/Core;component/Assets/SaveLoad/ico_cloud.png"/>
                        <BitmapImage x:Key="HasModsImage" UriSource="/Core;component/Assets/SaveLoad_c/c_ico_modStatus.png"/>
                        <BitmapImage x:Key="ConsoleIncompatibleImage" UriSource="/Core;component/Assets/SaveLoad_c/c_ico_modStatus_w3.png"/>
                    </ControlTemplate.Resources>

                    <ContentControl x:Name="ControlRoot" Style="{StaticResource FocusableContentControlStyle}" Tag="{Binding RelativeSource={RelativeSource AncestorType={x:Type Expander}}}" MinHeight="86">
                        <ContentControl.ToolTip>
                            <ls:LSTooltip x:Name="ModsIconTT" Content="{Binding Source=h61df9aeag7c90g43cbgaac8g1c3d458ebcee, Converter={StaticResource TranslatedStringConverter}}" Placement="Right" HorizontalOffset="50" VerticalOffset="-70" Visibility="{Binding Visibility, ElementName=HasModsIcon}"/>
                        </ContentControl.ToolTip>
                        <Grid x:Name="GridRoot" Background="Transparent" Margin="48, 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledDefaultFontSize}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" IsHitTestVisible="False">
                                <Run x:Name="TitleName" Text="{Binding Title}"/><Run x:Name="Location" Text="{Binding LevelName, StringFormat='{} - {0}'}" Foreground="{StaticResource LS_baseTxtColor}"/>
                            </TextBlock>

                            <Image x:Name="HasModsIcon" Source="{StaticResource HasModsImage}" Grid.Column="2" VerticalAlignment="Center" Stretch="None" Margin="10,0,0,0" Visibility="Hidden"/>
                            <Image x:Name="CrossIcon" Source="{StaticResource CrossImage}" Grid.Column="3" VerticalAlignment="Center" Stretch="None"/>
                            <Image x:Name="CloudIcon" Source="{StaticResource CloudImage}" Grid.Column="4" VerticalAlignment="Center" Stretch="None"/>
                        </Grid>
                    </ContentControl>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Title" Property="Foreground" Value="{StaticResource LS_extraspecialTxtColor}"/>
                        </Trigger>

                        <DataTrigger Binding="{Binding Type}" Value="Normal">
                            <Setter TargetName="Location" Property="Text" Value="{x:Null}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding Type}" Value="Quicksave">
                            <Setter TargetName="TitleName" Property="Text">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                        <Binding Source="hc2d2fcdeg94b7g419ag9c16g0bd8232d7d7e"/>
                                        <Binding Path="SaveID"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding Type}" Value="Autosave">
                            <Setter TargetName="TitleName" Property="Text">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                        <Binding Source="h0979ca13g2c30g4362gae55g5d0b3bdc2a45"/>
                                        <Binding Path="SaveID"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                        <!-- Single save -->
                        <DataTrigger Binding="{Binding Type}" Value="Honour">
                            <Setter TargetName="TitleName" Property="Text" Value="{Binding Source='hc46a669cgdbedg4bb4g8bfbg7940e7dd74d1', Converter={StaticResource TranslatedStringConverter}}"/>
                        </DataTrigger>
                        <!-- Honour Mode -->
                        <DataTrigger Binding="{Binding IsHonourMode}" Value="True">
                            <Setter TargetName="TitleName" Property="Text" Value="{Binding Source='h3bc72102g9b47g435fgaec8ga45b31d79bc5', Converter={StaticResource TranslatedStringConverter}}"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CloudStatus}" Value="NoSync">
                            <Setter Property="Visibility" Value="Hidden" TargetName="CloudIcon"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CloudStatus}" Value="ToBeSynced">
                            <Setter Property="Opacity" Value="0.6" TargetName="CloudIcon"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CrossStatus}" Value="NoCrossSync">
                            <Setter Property="Visibility" Value="Hidden" TargetName="CrossIcon"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CrossStatus}" Value="Uploading">
                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad/ico_cross_save_uploading.png" TargetName="CrossIcon"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CrossStatus}" Value="Downloading">
                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad/ico_cross_save_downloading.png" TargetName="CrossIcon"/>
                            <Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}" TargetName="Title"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CrossStatus}" Value="ToDownload">
                            <Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}" TargetName="Title"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CrossStatus}" Value="FailedUpload">
                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad/ico_cross_save_uploading_issue.png" TargetName="CrossIcon"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CrossStatus}" Value="FailedDownload">
                            <Setter Property="Source" Value="pack://application:,,,/Core;component/Assets/SaveLoad/ico_cross_save_downloading_issue.png" TargetName="CrossIcon"/>
                            <Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}" TargetName="Title"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding Validity}" Value="TooOld">
                            <Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}" TargetName="Title"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Validity}" Value="TooNew">
                            <Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}" TargetName="Title"/>
                        </DataTrigger>
						<DataTrigger Binding="{Binding Validity}" Value="ModdedCrossSaveConsole">
							<Setter Property="Foreground" Value="{StaticResource LS_accent00TxtColor}" TargetName="Title"/>
						</DataTrigger>

						<DataTrigger Binding="{Binding HasMods}" Value="True">
                            <Setter TargetName="HasModsIcon" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsCrossplay}" Value="True"/>
                                <Condition Binding="{Binding IsConsoleFriendly}" Value="False"/>
                                <Condition Binding="{Binding DataContext.Data.DefineCrossplayEnabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True"/>
                                <Condition Binding="{Binding DataContext.Data.LarianNetIsConnected, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True"/>
                                <Condition Binding="{Binding DataContext.Data.CrossplayIsEnabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="HasModsIcon" Property="Source" Value="{StaticResource ConsoleIncompatibleImage}"/>
                            <Setter TargetName="ModsIconTT" Property="Content" Value="{Binding Source=hebff55c6g3e4cg4193ga9c2gdafb6ced279b, Converter={StaticResource TranslatedStringConverter}}"/>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="PlaythroughItemTemplate" DataType="{x:Type ls:VMPlaythroughHolder}">
        <Expander x:Name="Playthrough" Background="Transparent" Header="{Binding ProtagonistName}" IsExpanded="False" Margin="0,0,0,20" Template="{StaticResource ExpanderButtonTemplate}">
            <b:Interaction.Behaviors>
                <ls:CollectionSortBehavior x:Name="PlaythroughSortBehavior" ItemsSource="{Binding Saves}" Comparer="{Binding DataContext.SaveComparer, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" />
            </b:Interaction.Behaviors>

            <b:Interaction.Triggers>
                <!-- We want to focus only if it's Load screen, as Save will focus on "New save" -->
                <b:EventTrigger EventName="Loaded">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding Tag, ElementName=PlaythroughSavegames}" Operator="Equal" RightOperand="InitialCampaign"/>
                                <b:ComparisonCondition LeftOperand="{Binding DataContext.IsSaving, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Operator="Equal" RightOperand="{StaticResource FalseValue}"/>
                                <b:ComparisonCondition LeftOperand="{Binding DataContext.IsMainMenu, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Operator="Equal" RightOperand="{StaticResource FalseValue}"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>

                    <ls:SetMoveFocusAction TargetName="LoadGame_c" FocusElement="{Binding ElementName=Playthrough}"/>
                </b:EventTrigger>

                <b:EventTrigger EventName="Loaded">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding DataContext.SelectedPlaythrough, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Operator="Equal" RightOperand="{Binding .}"/>
                                <b:ComparisonCondition LeftOperand="{Binding DataContext.IsSaving, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Operator="Equal" RightOperand="{StaticResource FalseValue}"/>
                                <b:ComparisonCondition LeftOperand="{Binding DataContext.IsMainMenu, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Operator="Equal" RightOperand="{StaticResource TrueValue}"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>

                    <ls:SetMoveFocusAction TargetName="LoadGame_c" FocusElement="{Binding ElementName=Playthrough}"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>

            <ListBox x:Name="PlaythroughSavegames"
                      ItemsSource="{Binding SortedItems, ElementName=PlaythroughSortBehavior, Mode=OneWay}" 
                      SelectionMode="Single" 
                      ItemContainerStyle="{StaticResource SavegameItemTemplateStyle}"
                      Background="Transparent" BorderBrush="Transparent"
                      Template="{StaticResource MinimalItemsControlTemplate}"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Expander>

        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding DataContext.CurrentPlaythroughID, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource NullToBoolTrueConverter}, ConverterParameter='EmptyString'}" Value="False"/>
                    <Condition Value="True">
                        <Condition.Binding>
                            <MultiBinding Converter="{StaticResource EqualConverter}">
                                <Binding Path="DataContext.CurrentPlaythroughID" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}" />
                                <Binding Path="PlaythroughString"/>
                            </MultiBinding>
                        </Condition.Binding>
                    </Condition>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="Playthrough" Property="IsExpanded" Value="True"/>
                <Setter TargetName="PlaythroughSavegames" Property="Tag" Value="InitialCampaign"/>
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <ControlTemplate x:Key="SaveDetailsTemplate" d:DataContext="{x:Type ls:VMSavegame}">
        <StackPanel x:Name="SaveDetails">
            <TextBlock Text="{Binding OwnerPlaythrough.ProtagonistName, Mode=OneWay}" Style="{StaticResource SaveLoad.DetailsTextStyle}" />
            <TextBlock Text="{Binding LevelName.Str, Mode=OneWay}" Style="{StaticResource SaveLoad.DetailsTextStyle}" />
            <TextBlock Text="{Binding TimeString, Mode=OneWay}" Style="{StaticResource SaveLoad.DetailsTextStyle}" />
        </StackPanel>
    </ControlTemplate>

    <ControlTemplate x:Key="SavePresenterTemplate" d:DataContext="{x:Type ls:DCSavegames}">
        <StackPanel Orientation="Vertical" Width="{StaticResource PresenterWidth}">
            <Grid MinHeight="180">
                <TextBlock x:Name="SelectedSaveTitle" Text="{Binding SelectedSave.Title}" HorizontalAlignment="Center" FontSize="{StaticResource ScaledBigFontSize}" Style="{StaticResource SaveLoad.Title}" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </Grid>
            <Grid x:Name="ScreenshotContainer">
                <Image Source="{StaticResource ScreenshotHolder}" Stretch="None"/>
                <Border Background="{Binding SelectedScreenshot}" Width="1262" Height="706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <Control Template="{StaticResource SaveDetailsTemplate}" DataContext="{Binding SelectedSave}" HorizontalAlignment="Center"/>
            
            <Image Source="{StaticResource LineSeparator}" HorizontalAlignment="Center"/>

            <Grid x:Name="Subdetails" MinHeight="310">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Control Grid.Column="0" Template="{StaticResource CrossSaveInfo}" DataContext="{Binding SelectedSave}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="40,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock Text="{Binding Source='hbb2f0430g4914g4a10g8e16g64475b192e02', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.DetailsTextStyle}" Foreground="{StaticResource LS_baseTxtColor}"/>
                    <TextBlock Text="{Binding SelectedSave.PlayTimeString, Mode=OneWay}" Style="{StaticResource SaveLoad.DetailsTextStyle}" FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding Source='h46616d84g0ebag4586g9230gca30c54e7596', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.DetailsTextStyle}" Foreground="{StaticResource LS_baseTxtColor}" Margin="0,40,0,0"/>
                    <TextBlock x:Name="Difficulty" Text="{Binding SelectedSave.Difficulty, Mode=OneWay}" Style="{StaticResource SaveLoad.DetailsTextStyle}" FontWeight="SemiBold"/>
                </StackPanel>

                <Control Grid.Column="2" Template="{StaticResource SteamCloudSaveInfo}" DataContext="{Binding SelectedSave}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="40,0"/>
            </Grid>

            <Control Template="{StaticResource SaveLoad.Details.Version}" HorizontalAlignment="Center" Margin="0,40,0,40" DataContext="{Binding SelectedSave}"/>
        </StackPanel>

        <ControlTemplate.Triggers>
            <!-- Single Save. Custom setting or failed honour mode -->
            <DataTrigger Binding="{Binding SelectedSave.Type}" Value="Honour">
                <Setter TargetName="SelectedSaveTitle" Property="Text" Value="{Binding Source='hc46a669cgdbedg4bb4g8bfbg7940e7dd74d1', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <!-- Honour mode -->
            <DataTrigger Binding="{Binding SelectedSave.IsHonourMode}" Value="True">
                <Setter TargetName="Difficulty" Property="Text" Value="{Binding Source='hb80200a7g8e69g4f66gbc18g4155d70f0dcc', Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="SelectedSaveTitle" Property="Text" Value="{Binding Source='h3bc72102g9b47g435fgaec8ga45b31d79bc5', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="CampaignPresenterTemplate" d:DataContext="{x:Type ls:DCSavegames}">
        <StackPanel Orientation="Vertical" Width="{StaticResource PresenterWidth}">
            <Grid MinHeight="180">
                <TextBlock Text="{Binding SelectedPlaythrough.ProtagonistName}" HorizontalAlignment="Center" FontSize="{StaticResource ScaledBigFontSize}" Style="{StaticResource SaveLoad.Title}" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </Grid>
            <Grid x:Name="ScreenshotContainer">
                <Image Source="{StaticResource ScreenshotHolder}" Stretch="None"/>
                <Border Background="{Binding SelectedScreenshot}" Width="1262" Height="706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <Control Template="{StaticResource SaveDetailsTemplate}" DataContext="{Binding SelectedPlaythrough.LatestSave}" HorizontalAlignment="Center"/>

            <Image Source="{StaticResource LineSeparator}" HorizontalAlignment="Center"/>

            <StackPanel HorizontalAlignment="Center" Height="310" VerticalAlignment="Top">
                <TextBlock Text="{Binding Source='hbb2f0430g4914g4a10g8e16g64475b192e02', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource SaveLoad.DetailsTextStyle}" Foreground="{StaticResource LS_baseTxtColor}"/>
                <TextBlock Text="{Binding SelectedPlaythrough.LatestSave.PlayTimeString, Mode=OneWay}" Style="{StaticResource SaveLoad.DetailsTextStyle}" FontWeight="SemiBold"/>
            </StackPanel>

            <Control Template="{StaticResource SaveLoad.Details.Version}" HorizontalAlignment="Center" Margin="0,40,0,40" DataContext="{Binding SelectedPlaythrough.LatestSave}"/>
        </StackPanel>
    </ControlTemplate>

    <Style x:Key="SaveGamesListStyle" TargetType="ItemsControl">
        <Setter Property="Height" Value="1640"/>
        <Setter Property="ItemTemplate" Value="{StaticResource PlaythroughItemTemplate}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
