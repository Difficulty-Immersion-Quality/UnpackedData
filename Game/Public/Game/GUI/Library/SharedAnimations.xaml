<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"

                    xmlns:ls="clr-namespace:ls;assembly=Code"
                    mc:Ignorable="d">
    
    <Storyboard x:Key="ShowHud.FadeIn" FillBehavior="HoldEnd">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0" />
            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.33" />
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>
    <Storyboard x:Key="ShowHud.FadeOut" FillBehavior="HoldEnd">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0" />
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.1" />
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <ControlTemplate x:Key="Hud.Root">
        <Grid x:Name="HudRoot">
            <b:Interaction.Triggers>
                <b:PropertyChangedTrigger Binding="{Binding Path=DataContext.CurrentPlayer.UIData.ShowHud, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ls:UIWidget}}}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding CurrentPlayer.UIData.ShowHud}" Operator="Equal" RightOperand="True" />
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <ls:LSControlStoryboard ControlStoryboardOption="Stop" Storyboard="{StaticResource ShowHud.FadeOut}" Target="{Binding ElementName=HudRootPresenter}" />
                    <ls:LSControlStoryboard ControlStoryboardOption="Play" Storyboard="{StaticResource ShowHud.FadeIn}" Target="{Binding ElementName=HudRootPresenter}" />
                </b:PropertyChangedTrigger>
                <b:PropertyChangedTrigger Binding="{Binding Path=DataContext.CurrentPlayer.UIData.ShowHud, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ls:UIWidget}}}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding CurrentPlayer.UIData.ShowHud}" Operator="Equal" RightOperand="False" />
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <ls:LSControlStoryboard ControlStoryboardOption="Stop" Storyboard="{StaticResource ShowHud.FadeIn}" Target="{Binding ElementName=HudRootPresenter}" />
                    <ls:LSControlStoryboard ControlStoryboardOption="Play" Storyboard="{StaticResource ShowHud.FadeOut}" Target="{Binding ElementName=HudRootPresenter}" />
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>
            
            <ContentPresenter x:Name="HudRootPresenter" Opacity="1"/>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding CurrentPlayer.UIData.ShowHud}" Value="False">
                    <Setter Property="IsHitTestVisible" Value="False" TargetName="HudRoot" />
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="hud.root.Style" TargetType="ls:UIWidget" BasedOn="{StaticResource {x:Type ls:UIWidget}}">
        <Setter Property="Opacity" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding CurrentPlayer.UIData.ShowHud}" Value="False">
                <Setter Property="IsHitTestVisible" Value="False"  />
                <Setter Property="Opacity" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="Hud.RootNoAnim">
        <ContentPresenter/>
    </ControlTemplate>

    <!-- NewGameSettings Animations --> 

    <System:Double x:Key="NewGameCard.ScaleTarget">1.1</System:Double>
    <Duration x:Key="NewGameCard.EnterDuration">0:0:8</Duration>
    <Duration x:Key="NewGameCard.ExitDuration">0:0:8</Duration>
    <Duration x:Key="NewGameCard.FadeOutDuration">0:0:0.2</Duration>
    <Duration x:Key="NewGameCard.FadeInDuration">0:0:0.8</Duration>
    <System:Double x:Key="NewGameCard.AccelerationIn">0</System:Double>
    <System:Double x:Key="NewGameCard.DecelerationIn">0.5</System:Double>
    <System:Double x:Key="NewGameCard.AccelerationOut">0</System:Double>
    <System:Double x:Key="NewGameCard.DecelerationOut">0.5</System:Double>

    <Storyboard x:Key="NewGameCard.ImageHover">
        <DoubleAnimation Storyboard.TargetName="DifficultyImage" Storyboard.TargetProperty="RenderTransform.ScaleX" Duration="{StaticResource NewGameCard.EnterDuration}" To="{StaticResource NewGameCard.ScaleTarget}" AccelerationRatio="{StaticResource NewGameCard.AccelerationIn}" DecelerationRatio="{StaticResource NewGameCard.DecelerationIn}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImage" Storyboard.TargetProperty="RenderTransform.ScaleY" Duration="{StaticResource NewGameCard.EnterDuration}" To="{StaticResource NewGameCard.ScaleTarget}" AccelerationRatio="{StaticResource NewGameCard.AccelerationIn}" DecelerationRatio="{StaticResource NewGameCard.DecelerationIn}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImageHover" Storyboard.TargetProperty="RenderTransform.ScaleX" Duration="{StaticResource NewGameCard.EnterDuration}" To="{StaticResource NewGameCard.ScaleTarget}" AccelerationRatio="{StaticResource NewGameCard.AccelerationIn}" DecelerationRatio="{StaticResource NewGameCard.DecelerationIn}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImageHover" Storyboard.TargetProperty="RenderTransform.ScaleY" Duration="{StaticResource NewGameCard.EnterDuration}" To="{StaticResource NewGameCard.ScaleTarget}" AccelerationRatio="{StaticResource NewGameCard.AccelerationIn}" DecelerationRatio="{StaticResource NewGameCard.DecelerationIn}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImageHover" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource NewGameCard.FadeInDuration}"/>
    </Storyboard>

    <Storyboard x:Key="NewGameCard.ImageDefault">
        <DoubleAnimation Storyboard.TargetName="DifficultyImage" Storyboard.TargetProperty="RenderTransform.ScaleX" Duration="{StaticResource NewGameCard.ExitDuration}" To="1" AccelerationRatio="{StaticResource NewGameCard.AccelerationOut}" DecelerationRatio="{StaticResource NewGameCard.DecelerationOut}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImage" Storyboard.TargetProperty="RenderTransform.ScaleY" Duration="{StaticResource NewGameCard.ExitDuration}" To="1" AccelerationRatio="{StaticResource NewGameCard.AccelerationOut}" DecelerationRatio="{StaticResource NewGameCard.DecelerationOut}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImageHover" Storyboard.TargetProperty="RenderTransform.ScaleX" Duration="{StaticResource NewGameCard.ExitDuration}" To="1" AccelerationRatio="{StaticResource NewGameCard.AccelerationOut}" DecelerationRatio="{StaticResource NewGameCard.DecelerationOut}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImageHover" Storyboard.TargetProperty="RenderTransform.ScaleY" Duration="{StaticResource NewGameCard.ExitDuration}" To="1" AccelerationRatio="{StaticResource NewGameCard.AccelerationOut}" DecelerationRatio="{StaticResource NewGameCard.DecelerationOut}"/>
        <DoubleAnimation Storyboard.TargetName="DifficultyImageHover" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource NewGameCard.FadeOutDuration}"/>
    </Storyboard>

</ResourceDictionary>