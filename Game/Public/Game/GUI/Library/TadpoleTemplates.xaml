						<Image.OpacityMask>
							<RadialGradientBrush x:Name="MaskBrush" MappingMode="Absolute" RadiusX="900" RadiusY="900" Center="310,426" GradientOrigin="{Binding Center, RelativeSource={RelativeSource Mode=Self}}">
								<RadialGradientBrush.GradientStops>
									<GradientStop x:Name="GradientStart" Color="White" Offset="1"/>
									<GradientStop x:Name="GradientStop" Color="Transparent" Offset="1"/>
								</RadialGradientBrush.GradientStops>
							</RadialGradientBrush>
						</Image.OpacityMask>
					</Image>

					<DataTemplate.Triggers>
						<DataTrigger Binding="{Binding State}" Value="Active">
							<DataTrigger.EnterActions>
								<BeginStoryboard x:Name="FadeInStoryboard">
									<BeginStoryboard.Storyboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="GradientStart" Storyboard.TargetProperty="Offset" From="{StaticResource InfectionStartFrom}" To="{StaticResource InfectionStartTo}" Duration="{StaticResource InfectionDuration}"/>
											<DoubleAnimation Storyboard.TargetName="GradientStop" Storyboard.TargetProperty="Offset" From="{StaticResource InfectionEndFrom}" To="{StaticResource InfectionEndTo}" Duration="{StaticResource InfectionDuration}"/>
										</Storyboard>
									</BeginStoryboard.Storyboard>
								</BeginStoryboard>
							</DataTrigger.EnterActions>
							<DataTrigger.ExitActions>
								<StopStoryboard BeginStoryboardName="FadeInStoryboard"/>
							</DataTrigger.ExitActions>
						</DataTrigger>

						<EventTrigger RoutedEvent="Loaded">
							<StopStoryboard BeginStoryboardName="FadeInStoryboard"/>
						</EventTrigger>

