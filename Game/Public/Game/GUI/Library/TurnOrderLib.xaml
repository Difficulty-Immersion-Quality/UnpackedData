    <SolidColorBrush x:Key="LS_PortraitDeadColor" Opacity="0.8" Color="{StaticResource HPColour}"/>

    <ls:SaturationEffect x:Key="ActedThisRoundEffect" Saturation="0"/>

    <ControlTemplate x:Key="DefaultProgressBar" TargetType="{x:Type ProgressBar}">
        <Grid x:Name="TemplateRoot" MinHeight="{TemplateBinding MinHeight}" >
            <Border x:Name="PART_Track" Background="{TemplateBinding Background}"  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="1"/>
            <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                <Border x:Name="IndicatorBorder" Margin="{TemplateBinding Padding}" Background="{TemplateBinding Foreground}"/>
            </Grid>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="LayoutTransform" TargetName="TemplateRoot">
                    <Setter.Value>
                        <RotateTransform Angle="-90"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="HealthBarStyle" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource LS_PortraitHealthBarColor}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Value" Value="{Binding Stats.Health.PercentValue, Mode=OneWay, Converter={StaticResource InvertPercConverter}}"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="1"/>
        <Setter Property="Orientation" Value="Vertical"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Stats.IsAlive}" Value="False">
                <Setter Property="Foreground" Value="{StaticResource LS_PortraitDeadRadialColor}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Storyboard x:Key="ParticipantAnimatedRemoveStoryboard">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)" >
            <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="200">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="(UIElement.Opacity)">
            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="0"/>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="Width" >
            <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="132"/>
            <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="0">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="Visibility" >
            <DiscreteObjectKeyFrame KeyTime="0:0:1.2" Value="{x:Static Visibility.Collapsed}"/>
        </ObjectAnimationUsingKeyFrames>
    </Storyboard>

    <ControlTemplate x:Key="HourglassTemplate">
        <Image x:Name="HourglassIcon" Width="70" Height="110" Source="{StaticResource OverlayHourglass}" Opacity="0.7" Stretch="None" Visibility="Collapsed"/>
        <ControlTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding PlayerCharacterProperties.EndTurnRequested}" Value="True"/>
                    <Condition Binding="{Binding Stats.Health.PercentValue, Mode=OneWay, Converter={StaticResource GreaterThanConverter}, ConverterParameter='0'}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="HourglassIcon" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsCurrentTurn}" Value="False"/>
                    <Condition Binding="{Binding IsWaitingNextRound}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="HourglassIcon" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding IsWaitingNextRound}" Value="True">
                <Setter TargetName="HourglassIcon" Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>


    <!-- Changing the size of the active portrait -->
    <Storyboard x:Key="TurnBasedPortraitActive" FillBehavior="HoldEnd" BeginTime="0:0:0.3">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                           Storyboard.TargetName="CharacterContainer">
            <EasingDoubleKeyFrame KeyTime="{StaticResource scaleUpTime}" Value="{StaticResource CombatantPortraitNormalScale}">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                           Storyboard.TargetName="CharacterContainer">
            <EasingDoubleKeyFrame KeyTime="{StaticResource scaleUpTime}" Value="{StaticResource CombatantPortraitNormalScale}">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin">
            <EasingThicknessKeyFrame KeyTime="{StaticResource scaleUpTime}" Value="{StaticResource CombatantPortraitScaleUpMargin}">
                <EasingThicknessKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingThicknessKeyFrame.EasingFunction>
            </EasingThicknessKeyFrame>
        </ThicknessAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Changing the size of the active portrait - additional animation for newly added characters -->

    <Storyboard x:Key="TurnBasedPortraitActive2" FillBehavior="HoldEnd" BeginTime="0:0:0.3">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" Storyboard.TargetName="CharacterContainer">
            <EasingDoubleKeyFrame KeyTime="{StaticResource scaleUpTime}" Value="{StaticResource CombatantPortraitNormalScale}">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" Storyboard.TargetName="CharacterContainer">
            <EasingDoubleKeyFrame KeyTime="{StaticResource scaleUpTime}" Value="{StaticResource CombatantPortraitNormalScale}">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin">
            <EasingThicknessKeyFrame KeyTime="{StaticResource scaleUpTime}" Value="{StaticResource CombatantPortraitScaleUpMargin}">
                <EasingThicknessKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingThicknessKeyFrame.EasingFunction>
            </EasingThicknessKeyFrame>
        </ThicknessAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Changing the size of the inactive portrait -->
    <Storyboard x:Key="TurnBasedPortraitInActive" FillBehavior="HoldEnd">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                           Storyboard.TargetName="CharacterContainer">
            <EasingDoubleKeyFrame KeyTime="{StaticResource scaleDownTime}" Value="{StaticResource CombatantPortraitSmallScale}">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                           Storyboard.TargetName="CharacterContainer">
            <EasingDoubleKeyFrame KeyTime="{StaticResource scaleDownTime}" Value="{StaticResource CombatantPortraitSmallScale}">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin">
            <SplineThicknessKeyFrame KeyTime="{StaticResource scaleDownTime}" Value="{StaticResource CombatantMargin}" />
        </ThicknessAnimationUsingKeyFrames>
    </Storyboard>

    <!--switching input -->
    <Storyboard x:Key="SwitchToInputAnimation">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                       Storyboard.TargetName="CharacterContainer">
            <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource CombatantPortraitNormalScale}"/>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                       Storyboard.TargetName="CharacterContainer">
            <DiscreteDoubleKeyFrame KeyTime="0" Value="{StaticResource CombatantPortraitNormalScale}"/>
        </DoubleAnimationUsingKeyFrames>

        <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin">
            <DiscreteThicknessKeyFrame KeyTime="0" Value="{StaticResource CombatantPortraitScaleUpMargin}"/>
        </ThicknessAnimationUsingKeyFrames>

        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="IconContainer" Storyboard.TargetProperty="Tag" >
            <DiscreteObjectKeyFrame KeyTime="0:0:0.1" Value="Active"/>
        </ObjectAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Changing the size of the active portrait -->
    <Storyboard x:Key="CombatantDisableCharacterAnimation" FillBehavior="HoldEnd" BeginTime="0:0:0.0">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FrameBGDisabled" Storyboard.TargetProperty="(UIElement.Opacity)">
            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0.8"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ActedThisRoundAlready" Storyboard.TargetProperty="(UIElement.Opacity)">
            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0.7"/>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <Storyboard x:Key="CombatStartIntroAnimation">
        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="IconState" Storyboard.TargetProperty="Tag" >
            <DiscreteObjectKeyFrame KeyTime="0" Value="InProgress"/>
        </ObjectAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="(UIElement.Opacity)" >
            <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" 
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)" >
            <EasingDoubleKeyFrame KeyTime="0" Value="100"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="0">
                <EasingDoubleKeyFrame.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>

        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="IconContainer" Storyboard.TargetProperty="Tag" >
            <DiscreteObjectKeyFrame KeyTime="0:0:0.6" Value="Active"/>
        </ObjectAnimationUsingKeyFrames>
    </Storyboard>
    <ControlTemplate x:Key="CombatantDataTemplate" TargetType="ListBoxItem">
        <Border x:Name="ElementContainer" d:DataContext="{d:DesignInstance {x:Type ls:Combatant}, IsDesignTimeCreatable=True}">
            <Grid x:Name="CharacterContainer" DataContext="{Binding CurrentCombatant}" Visibility="Visible" Opacity="0"
   VerticalAlignment="Center" RenderTransformOrigin="0.5,0.1" Tag="Unselected" Width="132" ToolTipService.PlacementTarget="{Binding ElementName=CombatantsListContainer}" >
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{StaticResource TurnOrderScale}" ScaleY="{StaticResource TurnOrderScale}"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- Character Icon -->
                <Rectangle x:Name="IconContainer" Stretch="Fill" Fill="{Binding Icon}" Width="108" Height="159" Margin="12,13,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Tag="Intro"/>
                <!-- Grey Overlay -->
                <Rectangle x:Name="ActedThisRoundAlready" Fill="DimGray" Width="106" Height="159" Margin="12,12,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Opacity="0.7" Visibility="Collapsed"/>
                <!-- Health-->
                <ProgressBar Template="{StaticResource DefaultProgressBarTemplate}" VerticalAlignment="Top" HorizontalAlignment="Left" Width="108" Height="159" 
              Margin="12,13,0,0" Style="{StaticResource HealthBarStyle}"/>

                <Border x:Name="IconState" Visibility="Collapsed"/>

                <!-- Vector Background-->
                <Path x:Name="frame" Stretch="Fill" VerticalAlignment="Top" HorizontalAlignment="Left" Width="120" Stroke="{StaticResource LS_PanelSelectedBorder}" StrokeThickness="1"  Fill="{StaticResource LS_PanelSelectedBorder}" Data="{StaticResource standardFrame}" Height="173" Margin="6,7,0,0" />

                <Path x:Name="FrameBGDisabled" Stretch="Fill" VerticalAlignment="Top" HorizontalAlignment="Left" Visibility="Collapsed" Width="120" Fill="{StaticResource LS_tint20}" Data="{StaticResource standardFrame}" Height="174" Margin="6,6,0,0" Opacity="0.8" />

                <Image x:Name="Selected" Margin="0,0,0,0" Visibility="Collapsed"  VerticalAlignment="Top" IsHitTestVisible="False" Source="{StaticResource DefaultFrameSelected}"
        Stretch="None" />

                <Image x:Name="frameCover" Height="188" Source="{StaticResource DefaultFrame}" Stretch="None" HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Top">
                    <Image.Tag>
                        <!--current character is controlled by the current player-->
                        <MultiBinding Converter="{StaticResource EqualConverter}">
                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="(ls:WidgetData.DataContext).CurrentPlayer.UserId"/>
                            <Binding Path="PlayerCharacterProperties.OwnerUserID"/>
                        </MultiBinding>
                    </Image.Tag>
                </Image>

                <!-- Hourglass icon, if end turn was requested -->
                <Control x:Name="turnTakenIndicator" Template="{StaticResource HourglassTemplate}" Margin="0,0,10,0"/>

                <Image x:Name="SelectionArrowIcon" Width="48" Stretch="UniformToFill" VerticalAlignment="Bottom" Visibility="Collapsed" Margin="0,0,0,-25" Source="{StaticResource UpArrowActive}"/>

                <!-- Workaround for the Command "Select character", as there is a known crash (fixed in Noesis 3.0.8) related to the multibinding in triggers if it's deleted.-->
                <Border x:Name="CanSelectCharacter">
                    <Border.Tag>
                        <MultiBinding Converter="{StaticResource BoolAndConverter}">
                            <Binding Path="IsCurrentTurn"/>
                            <Binding Path="(ls:WidgetData.DataContext).CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.IsCasting" RelativeSource="{RelativeSource TemplatedParent}" Converter="{StaticResource InvertBoolConverter}"/>
                        </MultiBinding>
                    </Border.Tag>
                </Border>

                <!-- Status Effects -->
                <Control x:Name="StatusHolder" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0,0,-224" Visibility="Visible" Template="{StaticResource CombatantStatusListTemplate}"/>

                <ls:LSEntityObject EntityRef="{Binding EntityHandle}" Background="Transparent"/>

                <!-- Concentration -->
                <Grid x:Name="ConcentrationGrid" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" Visibility="{Binding ConcentrationSpell, Converter={StaticResource NullToCollapsedConverter}}">
                    <Grid.ToolTip>
                        <ls:LSTooltip x:Name="ConcentrationTooltip" ls:TooltipExtender.Owner="{Binding Path=DataContext, ElementName=CharacterContainer}">
                            <ls:LSTooltip.Content>
                                <MultiBinding Converter="{StaticResource TooltipContextMultiConverter}">
                                    <Binding Source="Spell" />
                                    <Binding Path="(ls:TooltipExtender.Owner).ConcentrationSpell.PrototypeID" ElementName="ConcentrationTooltip"/>
                                </MultiBinding>
                            </ls:LSTooltip.Content>
                        </ls:LSTooltip>
                    </Grid.ToolTip>
                    <Ellipse Fill="{Binding Icon}" DataContext="{Binding ConcentrationSpell}" ToolTipService.Placement="Right" ToolTipService.IsEnabled="True" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                    <Image x:Name="ConcentrationBorder" Source="{StaticResource ConcentrationBorderIcon}" Stretch="UniformToFill" IsHitTestVisible="False" Width="66" Height="66"/>
                </Grid>
                <!-- Splitscreen player number label on targeted combatant -->
                <Control x:Name="CombatantTargetPlayer" Style="{StaticResource CombatantTargetPlayerStyle}" />

                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="MouseLeftButtonUp" >
                        <b:InvokeCommandAction IsEnabled="{Binding (ls:WidgetData.DataContext).CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.IsCasting, Converter={StaticResource InvertBoolConverter}, RelativeSource={RelativeSource TemplatedParent}}" 
                                Command="{Binding (ls:WidgetData.DataContext).SetCameraOnGameObject, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}" />
                        <b:InvokeCommandAction IsEnabled="{Binding Path=Tag, ElementName=CanSelectCharacter}" Command="{Binding (ls:WidgetData.DataContext).SelectCharacter, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                        <b:InvokeCommandAction IsEnabled="{Binding Path=Tag, ElementName=CanSelectCharacter}" Command="{Binding (ls:WidgetData.DataContext).PlaySelectCharacterReaction, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                        <ls:LSPlaySound Sound="UI_HUD_SelectCharacter"/>
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).TargetGameobjectCommand, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                    </b:EventTrigger>
                    <b:EventTrigger EventName="MouseEnter">
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).HighlightGameobject, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).ShowGameobjectInTarget, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                        <ls:LSPlaySound Sound="UI_Shared_Hover"/>
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).SetDebugUIEntityCommand, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding EntityHandle}"/>
                    </b:EventTrigger>
                    <b:EventTrigger EventName="MouseLeave">
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).ClearHighlightGameobject, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).HideGameobjectInTarget, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                        <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).ClearDebugUIEntityCommand, RelativeSource={RelativeSource TemplatedParent}}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </Grid>
            <b:Interaction.Triggers>
                <b:DataTrigger Binding="{Binding ElementName=CombatState, Path=Tag}" Value="CombatInProgress">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior >
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding Path=IsNew}" Operator="Equal" RightOperand="True"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <b:ControlStoryboardAction >
                        <b:ControlStoryboardAction.Storyboard>
                            <Storyboard x:Name="AddToCombatAnimation">
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="IconState" Storyboard.TargetProperty="Tag" >
                                    <DiscreteObjectKeyFrame KeyTime="0" Value="InProgress"/>
                                </ObjectAnimationUsingKeyFrames>

                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="Width" >
                                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="132">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>

                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" 
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)" >
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="300"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="300"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>

                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CharacterContainer" Storyboard.TargetProperty="(UIElement.Opacity)" >
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </b:ControlStoryboardAction.Storyboard>
                    </b:ControlStoryboardAction>
                </b:DataTrigger>
                <b:DataTrigger Binding="{Binding ElementName=CombatState, Path=Tag}" Value="UILoading">
                    <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).AddFinishedCommand, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                </b:DataTrigger>
                <b:EventTrigger EventName="Unloaded">
                    <b:ControlStoryboardAction Storyboard="{Binding ElementName=AddToCombatAnimation}" ControlStoryboardOption="Stop" />
                </b:EventTrigger>

                <b:DataTrigger Binding="{Binding ElementName=CharacterContainer, Path=Tag}" Value="Selected">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior >
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding ElementName=CombatState, Path=Tag}" Operator="Equal" RightOperand="CombatInProgress"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).ActNextRoundCommand, RelativeSource={RelativeSource TemplatedParent}}" 
                            CommandParameter="{Binding}"/>
                </b:DataTrigger>

                <b:EventTrigger SourceName="CharacterContainer" EventName="Loaded">
                    <b:ChangePropertyAction TargetName="IconContainer" PropertyName="Tag" Value="LoadedIntro" />
                </b:EventTrigger>

                <b:TimerTrigger SourceName="CharacterContainer" EventName="Loaded"
                 MillisecondsPerTick="{Binding (ItemsControl.AlternationIndex), 
                 RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBoxItem}}, 
                 Converter={StaticResource MultiplierConverter}, ConverterParameter=70}" TotalTicks="1">
                    <b:ChangePropertyAction TargetName="IconContainer" PropertyName="Tag" Value="StartIntro" />
                </b:TimerTrigger>

                <b:DataTrigger Binding="{Binding ElementName=CharacterContainer,Path=Visibility}" Value="Collapsed">
                    <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).RemoveFinishedCommand, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                </b:DataTrigger>

                <b:PropertyChangedTrigger Binding="{Binding ElementName=IconState, Path=Tag}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior >
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding Path=IsNew}" Operator="Equal" RightOperand="True"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <b:InvokeCommandAction Command="{Binding (ls:WidgetData.DataContext).AddFinishedCommand, RelativeSource={RelativeSource TemplatedParent}}" CommandParameter="{Binding}"/>
                </b:PropertyChangedTrigger>

            </b:Interaction.Triggers>
        </Border>

        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding ElementName=CombatState, Path=Tag}" Value="CombatInProgress">
                <Setter TargetName="CharacterContainer" Property="Opacity" Value="1"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CurrentCombatant.ActedThisRound}" Value="True">
                <Setter TargetName="IconContainer" Property="Effect" Value="{StaticResource ActedThisRoundEffect}"/>
                <Setter TargetName="ActedThisRoundAlready" Property="Visibility" Value="Visible"/>
                <Setter TargetName="FrameBGDisabled" Property="Visibility" Value="Visible"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="disableCharacterAnim1" Storyboard="{StaticResource CombatantDisableCharacterAnimation}" />
                </DataTrigger.EnterActions>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding CurrentCombatant.ActedThisRound}" Value="False"/>
                    <Condition Binding="{Binding CurrentCombatant.CanAct}" Value="False"/>
                    <Condition Binding="{Binding CurrentCombatant.IsWaitingNextRound}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="IconContainer" Property="Effect" Value="{StaticResource ActedThisRoundEffect}"/>
                    <Setter TargetName="ActedThisRoundAlready" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="FrameBGDisabled" Property="Visibility" Value="Visible"/>
                </MultiDataTrigger.Setters>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="disableCharacterAnim2" Storyboard="{StaticResource CombatantDisableCharacterAnimation}" />
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>


            <DataTrigger Binding="{Binding CurrentCombatant.IsWaitingNextRound}" Value="True">
                <Setter TargetName="IconContainer" Property="Effect" Value="{StaticResource ActedThisRoundEffect}"/>
                <Setter TargetName="ActedThisRoundAlready" Property="Visibility" Value="Visible"/>
                <Setter TargetName="FrameBGDisabled" Property="Visibility" Value="Visible"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="disableCharacterAnim3" Storyboard="{StaticResource CombatantDisableCharacterAnimation}" />
                </DataTrigger.EnterActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding CurrentCombatant.Stats.Health.PercentValue, Mode=OneWay, Converter={StaticResource GreaterThanConverter}, ConverterParameter='0'}" Value="False">
                <Setter TargetName="ActedThisRoundAlready" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ElementName=IconContainer, Path=Tag}" Value="StartIntro"/>
                    <Condition Binding="{Binding ElementName=CombatState, Path=Tag}" Value="CombatStart"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="CombatStartIntroAnim" Storyboard="{StaticResource CombatStartIntroAnimation}"/>
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ElementName=IconContainer, Path=Tag}" Value="LoadedIntro"/>
                    <Condition Binding="{Binding ElementName=CombatState, Path=Tag}" Value="CombatInProgress"/>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="SetTagActiveAnim">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="IconContainer" Storyboard.TargetProperty="Tag" >
                                <DiscreteObjectKeyFrame KeyTime="0" Value="Active"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ElementName=IconContainer, Path=Tag}" Value="LoadedIntro"/>
                    <Condition Binding="{Binding ElementName=CombatState, Path=Tag}" Value="CombatInProgress"/>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="SwitchToInputAnim" Storyboard="{StaticResource SwitchToInputAnimation}" />
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=ShouldBeRemoved}" Value="True"/>
                    <Condition Binding="{Binding Path=Tag, ElementName=CombatState}" Value="CombatStart"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="CharacterContainer" Property="Visibility" Value="Collapsed"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=ShouldBeRemoved}" Value="True"/>
                    <Condition Binding="{Binding Path=Tag, ElementName=CombatState}" Value="CombatInProgress"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="RemoveCombatantAnimated" Storyboard="{StaticResource ParticipantAnimatedRemoveStoryboard}"/>
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>

            <!-- Enemy Frame Style-->
            <DataTrigger Binding="{Binding CurrentCombatant.PlayerRelation}" Value="Enemy">
                <Setter TargetName="frame" Property="Fill" Value="{StaticResource frameTint.Hostile}" />
                <Setter TargetName="frame" Property="Stroke" Value="{StaticResource frameTint.Hostile}" />
                <Setter TargetName="ConcentrationBorder" Property="Source" Value="pack://application:,,,/Core;component/Assets/TargetInfo/concentration_enemy.png" />
            </DataTrigger>

            <!-- Neutral Frame Style-->
            <DataTrigger Binding="{Binding CurrentCombatant.PlayerRelation}" Value="Regular">
                <Setter TargetName="frame" Property="Fill" Value="{StaticResource frameTint.Neutral}" />
                <Setter TargetName="frame" Property="Stroke" Value="{StaticResource frameTint.Neutral}" />
            </DataTrigger>

            <!-- Party Frame Style -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding CurrentCombatant.PlayerRelation}" Value="Player"/>
                    <Condition Binding="{Binding ElementName=frameCover, Path=Tag}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="frame" Property="Fill" Value="{StaticResource frameTint.Party}" />
                    <Setter TargetName="frame" Property="Stroke" Value="{StaticResource frameTint.Party}" />
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>

            <!-- Coop Frame Style -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding CurrentCombatant.PlayerRelation}" Value="Player"/>
                    <Condition Binding="{Binding ElementName=frameCover, Path=Tag}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="frame" Property="Fill" Value="{StaticResource frameTint.Coop}" />
                    <Setter TargetName="frame" Property="Stroke" Value="{StaticResource frameTint.Coop}" />
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>

            <!-- Add New Joined Frames -->
            <!-- Character is joined to the right -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding PreviousTeamMember, Converter={StaticResource NullToBoolTrueConverter}}" Value="True"/>
                    <Condition Binding="{Binding NextTeamMember, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="frameCover" Property="Source" Value="{StaticResource DefaultFrameBegin}" />
                <Setter TargetName="frame" Property="Data" Value="{StaticResource joinBeginFrame}" />
                <Setter TargetName="FrameBGDisabled" Property="Data" Value="{StaticResource joinBeginFrame}" />
                <Setter TargetName="frameCover" Property="Margin" Value="0,0,0,0" />
                <Setter TargetName="frame" Property="Margin" Value="6,7,-8,0" />
                <Setter TargetName="frame" Property="Width" Value="128" />
                <Setter TargetName="FrameBGDisabled" Property="Margin" Value="6,6,-8,0" />
                <Setter TargetName="FrameBGDisabled" Property="Width" Value="128" />
                <Setter TargetName="Selected" Property="Margin" Value="0,0,-8,0" />
                <Setter TargetName="Selected" Property="Source" Value="{StaticResource DefaultFrameBeginSelected}" />
                <Setter TargetName="SelectionArrowIcon" Property="Margin" Value="-8,0,0,-25" />
                <Setter TargetName="ConcentrationGrid" Property="Margin" Value="-8,0,0,20" />
                <Setter TargetName="turnTakenIndicator" Property="Margin" Value="0,0,16,3" />
            </MultiDataTrigger>

            <!-- Character is joined to the left -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding PreviousTeamMember, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                    <Condition Binding="{Binding NextTeamMember, Converter={StaticResource NullToBoolTrueConverter}}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="frameCover" Property="Source" Value="{StaticResource DefaultFrameEnd}" />
                <Setter TargetName="frame" Property="Data" Value="{StaticResource joinEndFrame}" />
                <Setter TargetName="FrameBGDisabled" Property="Data" Value="{StaticResource joinEndFrame}" />
                <Setter TargetName="frameCover" Property="Margin" Value="-8,0,0,0" />
                <Setter TargetName="frame" Property="Margin" Value="-2,7,0,0" />
                <Setter TargetName="frame" Property="Width" Value="128" />
                <Setter TargetName="FrameBGDisabled" Property="Margin" Value="-2,6,0,0" />
                <Setter TargetName="FrameBGDisabled" Property="Width" Value="128" />
                <Setter TargetName="Selected" Property="Margin" Value="-8,0,0,0" />
                <Setter TargetName="Selected" Property="Source" Value="{StaticResource DefaultFrameEndSelected}" />
                <Setter TargetName="turnTakenIndicator" Property="Margin" Value="0,0,16,3" />
                <Setter TargetName="SelectionArrowIcon" Property="Margin" Value="-8,0,0,-25" />
            </MultiDataTrigger>

            <!-- Character is joined on both left and right-->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding PreviousTeamMember, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                    <Condition Binding="{Binding NextTeamMember, Converter={StaticResource NullToBoolTrueConverter}}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="frameCover" Property="Source" Value="{StaticResource DefaultFrameMiddle}" />
                <Setter TargetName="frameCover" Property="Margin" Value="-8,0,-8,0" />
                <Setter TargetName="FrameBGDisabled" Property="Data" Value="{StaticResource joinMiddleFrame}" />
                <Setter TargetName="frame" Property="Data" Value="{StaticResource joinMiddleFrame}" />
                <Setter TargetName="frame" Property="Margin" Value="-2,7,-8,0" />
                <Setter TargetName="frame" Property="Width" Value="136" />
                <Setter TargetName="Selected" Property="Margin" Value="-8,0,-8,0" />
                <Setter TargetName="Selected" Property="Source" Value="{StaticResource DefaultFrameMiddleSelected}" />
                <Setter TargetName="FrameBGDisabled" Property="Margin" Value="-2,6,-8,0" />
                <Setter TargetName="FrameBGDisabled" Property="Width" Value="136" />
                <Setter TargetName="SelectionArrowIcon" Property="Margin" Value="-10,0,0,-25" />
                <Setter TargetName="turnTakenIndicator" Property="Margin" Value="0,0,16,3" />
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="True">
                <Setter TargetName="SelectionArrowIcon" Property="Visibility" Value="Visible"/>
                <Setter TargetName="SelectionArrowIcon" Property="Source" Value="{StaticResource UpArrowInactive}"/>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="True"/>
                    <Condition Binding="{Binding CurrentCombatant.PlayerCharacterProperties.IsSelectedCharacter}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="Selected" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="SelectionArrowIcon" Property="Source" Value="{StaticResource UpArrowActive}"/>
                </MultiDataTrigger.Setters>
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding CurrentCombatant.PlayerRelation}" Value="Ally">
                <Setter TargetName="frame" Property="Fill" Value="{StaticResource frameTint.Ally}" />
                <Setter TargetName="frame" Property="Stroke" Value="{StaticResource frameTint.Ally}" />
            </DataTrigger>

            <DataTrigger Binding="{Binding CurrentCombatant.IsTargeted}"  Value="True">
                <Setter TargetName="FrameBGDisabled" Property="Visibility" Value="Visible" />
                <Setter TargetName="FrameBGDisabled" Property="Fill" Value="{StaticResource LS_tint100}" />
                <Setter TargetName="FrameBGDisabled" Property="Opacity" Value="1" />
                <Setter TargetName="ActedThisRoundAlready" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconContainer" Property="Effect" Value="{x:Null}"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding CurrentCombatant.Type}" Value="Item">
                <Setter TargetName="ConcentrationGrid" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>

            <!-- Changing the size of the active portrait  -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="True"/>
                    <Condition Binding="{Binding Path=Tag,ElementName=IconContainer}" Value="Active"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="CharacterContainer" Property="Tag" Value="Selected"/>
                    <Setter TargetName="StatusHolder" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger.Setters>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="CurrentTurnBS" Storyboard="{StaticResource TurnBasedPortraitActive}" />
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>

            <!-- Changing the size of the inactive portrait  -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="False"/>
                    <Condition Binding="{Binding Path=Tag,ElementName=IconContainer}" Value="Active"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter TargetName="CharacterContainer" Property="Tag" Value="Unselected"/>
                </MultiDataTrigger.Setters>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="ExitCurrentTurnBS" Storyboard="{StaticResource TurnBasedPortraitInActive}" />
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>

            <!-- Additional Animations to force newly added characters to show at enlarged size when they don't get a turn-->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding PreviousTeamMember.IsCurrentTurn}" Value="True"/>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="False"/>
                    <Condition Binding="{Binding Path=Tag,ElementName=IconContainer}" Value="Active"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="CurrentTurnBSNew1" Storyboard="{StaticResource TurnBasedPortraitActive2}" />
                </MultiDataTrigger.EnterActions>
                <MultiDataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="CurrentTurnBSNew1" />
                </MultiDataTrigger.ExitActions>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding NextTeamMember.IsCurrentTurn}" Value="True"/>
                    <Condition Binding="{Binding CurrentCombatant.IsCurrentTurn}" Value="False"/>
                    <Condition Binding="{Binding Path=Tag,ElementName=IconContainer}" Value="Active"/>
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard x:Name="CurrentTurnBSNew2" Storyboard="{StaticResource TurnBasedPortraitActive2}" />
                </MultiDataTrigger.EnterActions>
                <MultiDataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="CurrentTurnBSNew2" />
                </MultiDataTrigger.ExitActions>
            </MultiDataTrigger>

            <EventTrigger RoutedEvent="FrameworkElement.Unloaded">
                <StopStoryboard BeginStoryboardName="RemoveCombatantAnimated"/>
                <StopStoryboard BeginStoryboardName="CurrentTurnBS"/>
                <StopStoryboard BeginStoryboardName="ExitCurrentTurnBS"/>
                <StopStoryboard BeginStoryboardName="CurrentTurnBSNew1"/>
                <StopStoryboard BeginStoryboardName="CurrentTurnBSNew2"/>
                <StopStoryboard BeginStoryboardName="disableCharacterAnim1"/>
                <StopStoryboard BeginStoryboardName="disableCharacterAnim2"/>
                <StopStoryboard BeginStoryboardName="disableCharacterAnim3"/>
                <StopStoryboard BeginStoryboardName="SwitchToInputAnim"/>
                <StopStoryboard BeginStoryboardName="CombatStartIntroAnim"/>
                <StopStoryboard BeginStoryboardName="ScrollToLastAnim"/>
                <StopStoryboard BeginStoryboardName="SetTagActiveAnim"/>
            </EventTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
</ResourceDictionary>