<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    mc:Ignorable="d">

    <!--Keep  app.xaml  resources in line with this-->
    <ResourceDictionary.MergedDictionaries>
        <!--Load in the default Noesistheme-->
        <ResourceDictionary Source="NoesisTheme.DarkBlue.xaml" />
        <!--Now load ours and override where needed-->
        <ResourceDictionary Source="/Core;component/Library/Converters.xaml" />
        <ResourceDictionary Source="/Core;component/Library/Images.xaml" />
        <ResourceDictionary Source="/Core;component/Library/Images_c.xaml" />
        <ResourceDictionary Source="DefaultTheme.Colours.xaml" />
        <ResourceDictionary Source="Controller.Fonts.xaml" />
	    <ResourceDictionary Source="DefaultTheme_c.Fonts.xaml" />
    </ResourceDictionary.MergedDictionaries>
</ResourceDictionary>