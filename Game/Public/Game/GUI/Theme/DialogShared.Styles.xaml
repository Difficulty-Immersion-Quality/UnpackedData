<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:b="http://schemas.microsoft.com/xaml/behaviors"

	xmlns:System="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="DefaultTheme.Colours.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <System:Double x:Key="Dialogue.Answer.LineHeight">70</System:Double>
    <System:Double x:Key="Dialogue.SuggestedAnswer.LineHeight">64</System:Double>

    <System:Double x:Key="Dialogue.Dropshadow.Depth">2</System:Double>
    <System:Double x:Key="Dialogue.Dropshadow.BlurRadius">16.0</System:Double>
    <System:Double x:Key="Dialogue.Dropshadow.Opacity">0.6</System:Double>
    <System:Double x:Key="Dialogue.Dropshadow.Direction">270.0</System:Double>

    <!-- body text base style -->
    <Style x:Key="Dialogue.BodyTextStyleBase" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Dialogue.Answer.Normal}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
		<Setter Property="Effect">
			<Setter.Value>
                    <DropShadowEffect
                        Direction="{StaticResource Dialogue.Dropshadow.Direction}"
                        Color="{StaticResource Dialogue.Dropshadow}"
                        ShadowDepth="{StaticResource Dialogue.Dropshadow.Depth}"
                        BlurRadius="{StaticResource Dialogue.Dropshadow.BlurRadius}"
                        Opacity="{StaticResource Dialogue.Dropshadow.Opacity}"/>
			</Setter.Value>
		</Setter>
    </Style>

    <!-- answer text base style -->
    <Style x:Key="Dialogue.AnswerTextStyleBase" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Dialogue.Answer.Normal}" />
        <Setter Property="LineHeight" Value="{StaticResource Dialogue.Answer.LineHeight}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                        Direction="{StaticResource Dialogue.Dropshadow.Direction}"
                        Color="{StaticResource Dialogue.Dropshadow}"
                        ShadowDepth="{StaticResource Dialogue.Dropshadow.Depth}"
                        BlurRadius="{StaticResource Dialogue.Dropshadow.BlurRadius}"
                        Opacity="{StaticResource Dialogue.Dropshadow.Opacity}"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>