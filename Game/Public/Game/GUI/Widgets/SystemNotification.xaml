<ls:UIWidget x:Name="CrossplayOverlay"
             ls:UIWidget.ContextName="CrossplayNotifications"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignWidth="3840" d:DesignHeight="2160"
            d:DataContext="{d:DesignInstance {x:Type ls:DCLobby}, IsDesignTimeCreatable=True}">
    <ls:UIWidget.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Core;component/Library/CrossplayHelpers.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ls:UIWidget.Resources>
    <ls:UIWidget.Template>
        <ControlTemplate >
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" d:DataContext="{d:DesignInstance ls:DCCrossplayNotifications}">
                <!--NOTIFICATION-->
                <ItemsControl x:Name="NotificationsListBox" ItemsSource="{Binding Data.SystemNotificationsList}" VerticalAlignment="Bottom" HorizontalAlignment="Right"  HorizontalContentAlignment="Right">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type ls:VMCrossplayNotification}">
                            <Border x:Name="NotificationRoot" Tag="Opening" Opacity="1" HorizontalAlignment="Right" MinWidth="450">
                                <ls:LSButton x:Name="NotificationHolder" Margin="32" >
                                    <!--Requires a command to open the Friendslist if clicked-->
                                    <ls:LSButton.RenderTransform>
                                        <TranslateTransform X="0" Y="0" />
                                    </ls:LSButton.RenderTransform>
                                    <ls:LSNineSliceImage x:Name="NotificationBG" Style="{StaticResource SideTutorialsBackgroundKBMStyle}">
                                        <StackPanel x:Name="NotificationBGContent" IsHitTestVisible="False">
                                            <TextBlock x:Name="ActionInfoTxt" Text="{Binding Type, Converter={StaticResource EnumTranslatedStringConverter},ConverterParameter=hbfa00712gc05dg454bg89e8gacb7488da0f3}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource LS_accent75TxtColor}"/>
                                            <TextBlock Text="{Binding CrossplayUser.Name}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="MessageTxt" Text="{Binding Message}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>

                                            <ls:LSButton x:Name="KeyBoardButtonTrigger" Visibility="Collapsed"
                                                Style="{StaticResource BigBlueButtonStyle}"
                                                Command="{Binding DataContext.CustomEvent, ElementName=CrossplayOverlay}"
                                                CommandParameter="OpenFriendsList"
                                                Content="{Binding Source='h4da8ec3ag7693g451fg9e76g6a0fb6cc190f', Converter={StaticResource TranslatedStringConverter}}"
                                                Margin="0,10,0,-20"         
                                                HorizontalAlignment="Center" VerticalAlignment="Bottom"/>

                                            <Control x:Name="ControllerButtonTrigger" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed"
                                                     Width="{StaticResource ScaledControllerHintSize}" Height="{StaticResource ScaledControllerHintSize}"
                                                     DataContext="{Binding DataContext.CurrentPlayer.UIData.InputEvents, ElementName=CrossplayOverlay, Converter={StaticResource FindInputEventConverter}, ConverterParameter='ToggleInGameMenu'}"
                                                     Template="{StaticResource ControllerButton.ImageSwitcher}"/>
                                        </StackPanel>
                                    </ls:LSNineSliceImage>
                                </ls:LSButton>
                                <b:Interaction.Triggers>
                                    <b:DataTrigger Binding="{Binding ElementName=NotificationRoot,Path=Tag}" Value="StartHiding">
                                        <b:ControlStoryboardAction Storyboard.TargetName="NotificationRoot">
                                            <b:ControlStoryboardAction.Storyboard>
                                                <Storyboard FillBehavior="Stop">
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Storyboard.TargetName="NotificationHolder">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="NotificationHolder"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                        From="0"
                                                        To="416"
                                                        Duration="0:0:0.4">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </b:ControlStoryboardAction.Storyboard>
                                        </b:ControlStoryboardAction>
                                    </b:DataTrigger>

                                    <b:TimerTrigger EventName="Loaded" MillisecondsPerTick="12000" TotalTicks="1">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="Equal" RightOperand="LobbyInvitationReceived"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:ChangePropertyAction Value="StartHiding" PropertyName="Tag" TargetName="NotificationRoot"/>
                                    </b:TimerTrigger>
                                    <b:TimerTrigger EventName="Loaded" MillisecondsPerTick="3000" TotalTicks="1">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="NotEqual" RightOperand="LobbyInvitationReceived"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:ChangePropertyAction Value="StartHiding" PropertyName="Tag" TargetName="NotificationRoot"/>
                                    </b:TimerTrigger>

                                    <b:EventTrigger SourceName="NotificationHolder" EventName="Click">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="NotEqual" RightOperand="LobbyInvitationReceived"/>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="NotEqual" RightOperand="FriendRequestReceived"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:ChangePropertyAction Value="StartHiding" PropertyName="Tag" TargetName="NotificationRoot"/>
                                        <b:ChangePropertyAction Value="False" PropertyName="IsEnabled" TargetName="NotificationHolder"/>
                                    </b:EventTrigger>

                                    <b:EventTrigger SourceName="NotificationHolder" EventName="Click">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="Equal" RightOperand="LobbyInvitationReceived"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:ChangePropertyAction Value="StartHiding" PropertyName="Tag" TargetName="NotificationRoot"/>
                                        <b:ChangePropertyAction Value="False" PropertyName="IsEnabled" TargetName="NotificationHolder"/>
                                        <b:ChangePropertyAction Value="{Binding .}" PropertyName="Tag" TargetName="CrossplayOverlay"/>
                                    </b:EventTrigger>
                                    <b:EventTrigger SourceName="NotificationHolder" EventName="Click">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="Equal" RightOperand="LobbyInvitationReceived"/>
                                                    <b:ComparisonCondition LeftOperand="{Binding DataContext.Data.UIInputMethod, ElementName=CrossplayOverlay}" Operator="Equal" RightOperand="Controller"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:InvokeCommandAction Command="{Binding DataContext.CustomEvent, ElementName=CrossplayOverlay}" CommandParameter="OpenFriendsList"/>
                                    </b:EventTrigger>

                                    <b:EventTrigger SourceName="NotificationHolder" EventName="Click">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding Type}" Operator="Equal" RightOperand="FriendRequestReceived"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:ChangePropertyAction Value="StartHiding" PropertyName="Tag" TargetName="NotificationRoot"/>
                                        <b:ChangePropertyAction Value="False" PropertyName="IsEnabled" TargetName="NotificationHolder"/>
                                        <b:ChangePropertyAction Value="{Binding CrossplayUser}" PropertyName="Tag" TargetName="CrossplayOverlay"/>
                                        <b:InvokeCommandAction Command="{Binding DataContext.OpenMessageBox, ElementName=CrossplayOverlay}" CommandParameter="{DynamicResource OnFriendRequestReceivedMessageBox}"/>
                                    </b:EventTrigger>
                                    <b:StoryboardCompletedTrigger Storyboard="{Binding (b:Interaction.Triggers)[0].Actions[0].Storyboard, ElementName=NotificationRoot}">
                                        <b:Interaction.Behaviors>
                                            <b:ConditionBehavior>
                                                <b:ConditionalExpression>
                                                    <b:ComparisonCondition LeftOperand="{Binding ElementName=NotificationRoot, Path=Tag}" Operator="Equal" RightOperand="StartHiding"/>
                                                </b:ConditionalExpression>
                                            </b:ConditionBehavior>
                                        </b:Interaction.Behaviors>
                                        <b:ChangePropertyAction Value="DoneHiding" PropertyName="Tag" TargetName="NotificationRoot"/>
                                        <b:ChangePropertyAction Value="0" PropertyName="Opacity" TargetName="NotificationRoot"/>
                                        <b:InvokeCommandAction Command="{Binding DataContext.RemoveNotificationCommand, ElementName=CrossplayOverlay}" CommandParameter="{Binding}"/>
                                    </b:StoryboardCompletedTrigger>

                                    <b:EventTrigger EventName="Unloaded">
                                        <b:ControlStoryboardAction Storyboard="{Binding ElementName=NotificationRoot,Path=(b:Interaction.Triggers)[0].Actions[0].Storyboard}" ControlStoryboardOption="Stop"/>
                                    </b:EventTrigger>
                                </b:Interaction.Triggers>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Message}" Value="">
                                    <Setter TargetName="MessageTxt" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="FriendInviteSent">
                                    <Setter TargetName="MessageTxt" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="Connected">
                                    <Setter TargetName="MessageTxt" Property="Text" Value="{Binding Platform, Converter={StaticResource EnumTranslatedStringConverter}, ConverterParameter='hdb7e2a56g86d2g46c0g923cg11da095663d8'}"/>
                                    <Setter TargetName="MessageTxt" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="Disconnected">
                                    <Setter TargetName="MessageTxt" Property="Text" Value="{Binding Platform, Converter={StaticResource EnumTranslatedStringConverter}, ConverterParameter='hdb7e2a56g86d2g46c0g923cg11da095663d8'}"/>
                                    <Setter TargetName="MessageTxt" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Type}" Value="LobbyInvitationReceived"/>
                                        <Condition Binding="{Binding DataContext.Data.UIInputMethod, ElementName=CrossplayOverlay}" Value="Controller"/>
                                        <Condition Binding="{Binding DataContext.CurrentPlayer.UIData.IsCrossplayFriendsOpen, ElementName=CrossplayOverlay}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="ControllerButtonTrigger" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="NotificationHolder" Property="BoundEvent" Value="ToggleInGameMenu"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Type}" Value="LobbyInvitationReceived"/>
                                        <Condition Binding="{Binding DataContext.Data.UIInputMethod, ElementName=CrossplayOverlay}" Value="Keyboard"/>
                                        <Condition Binding="{Binding DataContext.CurrentPlayer.UIData.IsCrossplayFriendsOpen, ElementName=CrossplayOverlay}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="KeyBoardButtonTrigger" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="NotificationBGContent" Property="IsHitTestVisible" Value="True" />
                                </MultiDataTrigger>
                                <EventTrigger SourceName="NotificationRoot" RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard x:Name="ShowNotificationBS" >
                                        <BeginStoryboard.Storyboard>
                                            <Storyboard FillBehavior="Stop">
                                                <DoubleAnimation Storyboard.TargetName="NotificationHolder"
                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 From="416"
                                                                 To="0"
                                                                 Duration="0:0:0.4">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation 
                                                    Storyboard.TargetName="NotificationHolder"
                                                    Storyboard.TargetProperty="Margin"
                                                    From="0,-407,0,0"
                                                    To="0,0,0,0"
                                                    Duration="0:0:0.4">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard.Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger SourceName="NotificationRoot" RoutedEvent="FrameworkElement.Unloaded">
                                    <StopStoryboard BeginStoryboardName="ShowNotificationBS" />
                                </EventTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
            </Grid>
        </ControlTemplate>

    </ls:UIWidget.Template>

</ls:UIWidget>