<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ls="clr-namespace:ls;assembly=Code">
    <ls:WindowManager x:Key = "windowManager">
        <ls:WindowManager.Layers>
            <!--Please don't just add new layers without discussing this with a senior first-->
            <ls:Layer Name="Default"/>
            <ls:Layer Name="HUD"/>
            <ls:Layer Name="Panels"/>
            <!--HUDTop is a part of the HUD that needs to stay above the panels-->
            <ls:Layer Name="HUDTop"/>
            <ls:Layer Name="PopupPanels"/>
            <ls:Layer Name="Notifications"/>
            <ls:Layer Name="DragAndDrop"/>
            <ls:Layer Name="Pause"/>
            <ls:Layer Name="PauseOverlay"/>
            <ls:Layer Name="ScreenFade"/>
            <ls:Layer Name="MessageBox"/>
        </ls:WindowManager.Layers>
    </ls:WindowManager>
</ResourceDictionary>