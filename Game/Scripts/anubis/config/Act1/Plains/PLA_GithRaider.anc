game.configs.PLA_GithRaider = Config{
    params={
        corpseList = {
            type = EParamType.String,
            help = [['1', '2' or '3' (3 = generic else)]],
            required = false,
            default = [[2]]
        },
    },
    root=StateRef{game.roots.DefaultCharacter,
        combat = StateRef{game.states.DefaultCombat},
        genericBehaviours = StateRef{game.states.CrimesHumanoid},
        idle = StateRef{game.states.PLA_GithChokepoint_Confrontation,
            defaultBehaviour = StateRef{game.states.PLA_GithRaider,
                defaultIdle = StateRef{game.states.PLA_GithCorpseSearch,
                    corpseList = params.corpseList,
                },
            },
        }
    }
}
