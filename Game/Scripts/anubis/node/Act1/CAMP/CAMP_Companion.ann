            if params.behaviourPos == "CAMPPOS" then
                if campPos == nil or campPos.UUID == Guid("NULL_00000000-0000-0000-0000-000000000000") then
                    SetUnicastEntityEvent(me,"CampPosRequest")
                    Sleep(2.0)
                    return
                end

                idlePos = campPos

            else
                idlePos = Entity(params.behaviourPos)
            end

            if idlePos == nil or idlePos.UUID == Guid("NULL_00000000-0000-0000-0000-000000000000") then
                Sleep(2.0)
                return
            end

            if IsInDangerousSurfaceFor(idlePos, me.Character) then
                SteerTo(idlePos)
                Sleep(2.0)
                return
            end

            local moveResult = MoveTo(idlePos, MovementSpeed.Walk, true, false, 0.5, 1.5, false)

            if moveResult ~= error.MovementError.None then
                SteerTo(idlePos)
                Sleep(2.0)
                return
            end

            LookFrom(idlePos)

            mod.util.SleepRandom(sleepDurationMin, sleepDurationMax)
            if (idleAnim ~= nil) then
                if (idleAnimStart ~= nil and idleAnimEnd ~= nil) then
