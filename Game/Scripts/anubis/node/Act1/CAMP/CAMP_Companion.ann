game.states.CAMP_Drinking = State{function()
    description=[[Generic behaviour for drinking at the campsite]]

    params.behaviourPos = {type = EParamType.String, required = true,
        help = [[Name_GUID of point trigger where the character will stand for the behaviour]]}

    local drinkingAnim = Animation("CUST_Drinking_01_Drink_Wine_Glass_A_3f6ab5b5-6c83-456d-932e-23a260378b6b")

    local campPos = nil
    local drinkPos = nil
    local actionActive = false

    nodes.Drink = Action{
        function()
            if params.behaviourPos == "CAMPPOS" then
                if campPos == nil or campPos.UUID == Guid("NULL_00000000-0000-0000-0000-000000000000") then
                    SetUnicastEntityEvent(me,"CampPosRequest")
                    Sleep(2.0)
                    return
                end

                drinkPos = campPos

            else
                drinkPos = Entity(params.behaviourPos)
            end

            if drinkPos == nil or drinkPos.UUID == Guid("NULL_00000000-0000-0000-0000-000000000000") then
                Sleep(2.0)
                return
            end

            if IsInDangerousSurfaceFor(drinkPos, me.Character) then
                SteerTo(drinkPos)
                Sleep(2.0)
                return
            end

            MoveTo(drinkPos, MovementSpeed.Walk, true, false, 1.5, 2.5, false)
            LookFrom(drinkPos)

            try
                PlayAnimation(drinkingAnim)
            catch e if ls.CheckType(e, error.PlayAnimationFailed) then
                --DebugText(me, "Anim Failed: CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636" )
                Sleep(2.0)
                return
            end

            Sleep(math.random(2, 10))
        end,

        OnEnter = function()
            actionActive = true
        end,

        OnLeave = function()
            actionActive = false
            StopAnimation(me)
        end
    }

    events.EntityEvent = function(e)
        -- Camp Position Changed
        if e.TargetEntity == me and e.Event == "CampPositionChange" then
            campPos = e.Params[1]
            if actionActive then
                Interrupt()
            end
        end
   end

end}