game.roots.CAMP_GaleDouble = State{function ()

    local gale = Entity("S_Player_Gale_ad9af97d-75da-406a-ae13-7071c563f604")

    nodes.StandAtTrigger = Action{
        function()
            if GetDistanceTo(me, gale) > 5.0 then
                TeleportTo(me, gale)
            else
                SteerTo(gale)
                DebugText(me, "Looking forward animation")
            end
        Sleep(2.0)
    end
    }
end
}