game.states.CAMP_Jaheira = State {function()
    description = [[Behaviour of Jaheira at the campsite]]

    -- Flags
    local campNight = Flag("GLO_CAMP_NightMode_fb53edc2-9a89-4ad2-af83-20b5fe425cdd")

    -- State logic
    local selectedBehaviour = nil
    local ignoreReselectionUponInterrupt = false

    self.OnEnter = function()
        selectedBehaviour = nil
        ignoreReselectionUponInterrupt = false
    end

    nodes.CAMP_Jaheira = Selector {
        Valid = function(node)
            return CheckAnySelectable(node)
        end,

        function(nodes)
            -- Check if the behaviour was interrupted and enter it again if still valid
            if ignoreReselectionUponInterrupt == true and selectedBehaviour ~= nil and nodes.TryGetChild(selectedBehaviour).IsSelectable() then
                ignoreReselectionUponInterrupt = false
                return nodes.TryGetChild(selectedBehaviour)
            end

            -- Always clear this, in case it was interrupted but was not able to select a node
            ignoreReselectionUponInterrupt = false

            -- Select new behaviour
            local selectedNode = FindWeightedRandomSelectable(nodes, {
                [nodes.Whittling] = 1,
                [nodes.Whispering] = 2,
                [nodes.Relaxing] = 1
            })
            selectedBehaviour = selectedNode.Name
            return nodes.TryGetChild(selectedBehaviour)
        end
    }

    -- Full Camp Behaviours

    nodes.CAMP_Jaheira.Whispering = Proxy {
        game.states.CAMP_WorldBehaviourAtIdlePos,
        params = {  behaviourPos = "CAMPPOS",
                    worldBehaviourDialog = "BHVR_WRLD_CAMP_Jaheira_RatMessenger_3123e5bb-8e30-7da2-9901-8e59012b8075"}
    }

    -- Animations

    nodes.CAMP_Jaheira.Whittling = Proxy {
        game.states.CAMP_Idle,
        params = {  behaviourPos = "CAMPPOS",
                    idleAnimStart = "CUST_Jaheira_Whittling_01_Start_acdb767d-ba3e-4455-a016-d62da16091f9",
                    idleAnim = "CUST_Jaheira_Whittling_01_Loop_96344f40-2814-4267-99c4-2c30b57fd970",
                    idleAnimEnd = "CUST_Jaheira_Whittling_01_End_540f8604-171c-402a-9b18-ca80ed24bdb8",
                    loopIdleAnim = false,
                    idleAnimLength = 20.4,
                    idleAnimEndLength = 11.5,
                    sleepDurationMin = 20.0,
                    sleepDurationMax = 30.0}
    }

    nodes.CAMP_Jaheira.Relaxing = Proxy {
        game.states.CAMP_Idle,
        params = {  behaviourPos = "CAMPPOS",
                    idleAnimStart = "CUST_Jaheira_RelaxedSitting_01_Start_9aa14cf9-1094-4465-8ade-af335216dec8",
                    idleAnim = "CUST_Jaheira_RelaxedSitting_01_Loop_91e6773d-cfa2-4fe9-90c0-938acb314e2d",
                    idleAnimEnd = " CUST_Jaheira_RelaxedSitting_01_End_f9948253-64d5-4b02-863a-01eff0812e5e",
                    loopIdleAnim = false,
                    idleAnimLength = 24.5,
                    idleAnimEndLength = 5.86,
                    sleepDurationMin = 20.0,
                    sleepDurationMax = 30.0}
    }

    nodes.CAMP_Jaheira.Idle = Proxy {
        game.states.CAMP_Idle,
        params = {  behaviourPos = "CAMPPOS"}
    }

    -- Clear current behaviour on day<->night transition
    events.FlagSet = function(e)
        if e.Flag == campNight.Guid then
            selectedBehaviour = nil
            Interrupt()
        end
    end

    events.FlagCleared = function(e)
        if e.Flag == campNight.Guid then
            selectedBehaviour = nil
            Interrupt()
        end
    end

    events.EntityEvent = function(e)
        if (e.TargetEntity == me) then
            if e.Event == "InterruptCampBehaviour" then
                selectedBehaviour = nil
                Interrupt()
            elseif e.Event == "InterruptCampBehaviour_WithoutReselection" then
                Interrupt()
            end
        end
    end
end}