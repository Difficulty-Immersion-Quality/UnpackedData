game.states.CAMP_Jergal_Day = State{
    function()

        nodes.Proxy_HirelingsIntro = Proxy{
            CanEnter = function(node)
                return CheckAnySelectable(node)
            end,
            game.states.CAMP_Jergal_HirelingIntro
        }


        nodes.CAMP_Jergal_Day = Selector{
            function(nodes)
                return FindWeightedRandomSelectable(nodes, {
                    [nodes.Idle] = 1,
                    [nodes.Pondering] = 2,
                    [nodes.ReadBook] = 2,
                    [nodes.Writing] = 2,
                })
            end,
            Valid = function(nodes)
                return CheckAnySelectable(nodes)
            end
        }

        -- Full Camp Behaviours
        nodes.CAMP_Jergal_Day.Idle = Proxy{
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = nil,
                        loopIdleAnim = false,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 25.0
        },
        }

        nodes.CAMP_Jergal_Day.Pondering = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnimStart = "CUST_Pondering_01_Start_2d14e6a9-d3a3-4f98-9031-22831546c392",
                        idleAnim = "CUST_Pondering_01_Loop_a47454a1-05a2-4153-bdfe-7a0500fa62d0",
                        idleAnimEnd = "CUST_Pondering_01_End_e15cc480-7f1a-4ed4-8a3c-36355a37c644",
                        loopIdleAnim = false,
                        idleAnimLength = 26.2,
                        idleAnimEndLength = 4.9,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 15.0
            },
        }

        nodes.CAMP_Jergal_Day.ReadBook = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnimStart = "CUST_Reading_Old_Tome_01_Start_c773f46b-b7bf-46ff-9532-d3a174999c87",
                        idleAnim = "CUST_Reading_Old_Tome_01_7ce9c8f5-a969-4e66-a5c5-9a8c0d51d937",
                        idleAnimEnd = "CUST_Reading_Old_Tome_01_End_a5d237f3-8da8-49f5-a86a-864ee8f028a9",
                        loopIdleAnim = false,
                        idleAnimLength = 22.833333,
                        idleAnimEndLength = 2.0,
                        sleepDurationMin = 10.0,
                        sleepDurationMax = 30.0
            },
        }

        nodes.CAMP_Jergal_Day.Writing = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnimStart = "CUST_Writing_02_Start_cf445db4-01a3-4833-ab14-a66b19c439fe",
                        idleAnim = "CUST_Writing_02_Loop_896b83fb-27c3-41e0-924c-7ebf8473154b",
                        idleAnimEnd = "CUST_Writing_02_End_dab89293-d140-4345-bfcd-41be7a739665",
                        loopIdleAnim = false,
                        idleAnimLength = 7.5,
                        idleAnimEndLength = 6.6,
                        sleepDurationMin = 10.0,
                        sleepDurationMax = 25.0
            },
        }


    end
}

