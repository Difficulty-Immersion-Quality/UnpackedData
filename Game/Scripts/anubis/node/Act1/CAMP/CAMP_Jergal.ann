game.states.CAMP_Jergal_HirelingIntro = State{function()

    modules = { "shared.dialog" }

    --this is not great
    params.IsNightState = {  type = EParamType.Bool,
        required = false, default = false,
        help = [[Is this the night state or not]]
    }

    local showIntro = Flag("Hirelings_State_ShowIntro_b3983f00-096e-4e8b-82d5-8ae92a806dfc")
    local fx = nil
    local dialog = Dialog("CAMP_Withers_AD_HirelingsLookup_01729d3a-6652-9276-92d3-7b7f95a133f7")
    local animation = Dialog("CAMP_Withers_WB_HirelingsLookup_ebc7dd7e-ab4f-fa65-fc17-358b3d55d374")
    local campNightMode = Flag("GLO_CAMP_NightMode_fb53edc2-9a89-4ad2-af83-20b5fe425cdd")
    local isCurrentlyInCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")

    self.Valid = function()
        return GetFlag(showIntro)
    end

    self.OnEnter = function()
        helpers.PlayFX()
    end

    self.OnLeave = function()
        helpers.StopFX()
    end

    helpers.PlayFX = function()
        if fx == nil then
            --DebugText(me, "PlayFX ExclamationMark")
            --fx = PlayEffectAt(PrepareEffect("VFX_UI_ExclamationMark_01_a3018cf0-3a25-06ee-206a-3dd079332d80"), me, "Dummy_OverheadFX")
        end
    end

    helpers.StopFX = function()
        if fx ~= nil then
            --DebugText(me, "StopFX   ")
            StopEffect(fx)
            fx = nil
        end
    end

    helpers.IsCurrentStateValid = function()
        --return GetFlag(showIntro) and (GetFlag(campNightMode) == params.IsNightState) and GetFlag(isCurrentlyInCamp) -- check for camp as well since loading a savegame before we go to camp will have Withers show the !mark before even being able to talk to him in camp
        return GetFlag(showIntro) and GetFlag(isCurrentlyInCamp, me) -- check for camp as well since loading a savegame before we go to camp will have Withers show the !mark before even being able to talk to him in camp
    end

    nodes.HirelingsIntro = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(dialog,
                { minDelay = 10.0, cullingDistance = 30.0, waitForCompletion = false }, me)
            StartBehaviorDialog(animation, nil, true, me)
        end
    }

    events.SavegameLoaded = function(ev)
        if helpers.IsCurrentStateValid() then
            if fx == nil then
                helpers.PlayFX()
            end
        end
    end

    events.Activated = function(ev)
        if helpers.IsCurrentStateValid() then
            Interrupt()
        end
    end

    events.FlagSet = function(ev)
        if me.Active and ev.Flag == showIntro.Guid then
            Interrupt()
        end
    end
end}