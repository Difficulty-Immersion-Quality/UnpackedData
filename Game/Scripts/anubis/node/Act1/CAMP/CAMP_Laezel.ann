game.states.CAMP_Laezel = State {function()
    description = [[Behaviour of Lae'zel at Camp]]

    modules = {"shared.math"}

    -- Flags
    local GLO_CAMP_NightMode = Flag("GLO_CAMP_NightMode_fb53edc2-9a89-4ad2-af83-20b5fe425cdd")
    local hasGithyankiDisc1 = Flag("ORI_Laezel_State_HasOrpheusChapter1_24b4f0a1-0512-4164-8c5b-0e3bca62bfb2")
    local hasGithyankiDisc2 = Flag("ORI_Laezel_State_HasOrpheusChapter2_94ac2b16-58e6-4ebd-ba0f-2ae7ef59e5ef")
    local hasGithyankiDisc3 = Flag("ORI_Laezel_State_HasOrpheusChapter3_225b8f68-2134-499d-985b-cbd1d5d85624")
    local trainingWithDummyFlag = Flag("CAMP_Laezel_State_TrainingWithDummyBehaviourActive_df5017a5-f742-4ca1-aaf4-720b6780a95b")
    local noOffhandBehaviourFlag = Flag("CAMP_Laezel_State_NoOffhandWeaponBehaviourActive_30f13f96-d651-4f3a-a56f-9277ff2bc826")

    -- State logic
    local selectedBehaviour = nil
    local behaviourLoops = 0
    local ignoreReselectionUponInterrupt = false

    self.OnEnter = function()
        selectedBehaviour = nil
        ignoreReselectionUponInterrupt = false
    end

    -- Selector
    nodes.CAMP_Laezel = Selector {
        Valid = function(node)
            return CheckAnySelectable(node)
        end,

        function(nodes)
            -- Check if the behaviour was interrupted and enter it again if still valid
            if ignoreReselectionUponInterrupt == true and selectedBehaviour ~= nil and nodes.TryGetChild(selectedBehaviour).IsSelectable() then
                ignoreReselectionUponInterrupt = false
                return nodes.TryGetChild(selectedBehaviour)
            end

            -- Always clear this, in case it was interrupted but was not able to select a node
            ignoreReselectionUponInterrupt = false

            -- Reduce behaviour loops by 1
            if behaviourLoops > 0 then
                behaviourLoops = behaviourLoops - 1
            end

            -- If it has finished looping, or for some reason the current selectedBehaviour is nil or not selectable, pick a new node 
            if behaviourLoops == 0 or selectedBehaviour == nil or (selectedBehaviour ~= nil and not nodes.TryGetChild(selectedBehaviour).IsSelectable()) then
                behaviourLoops = 1
                local selectedNode = FindWeightedRandomSelectable(nodes, {
                    [nodes.Meditate] = 1,
                    [nodes.StandAndDrink] = 1,
                    [nodes.Sharpen] = 1,
                    [nodes.Alert] = 1,
                    [nodes.StudyGithyankiDisc] = 2,
                    [nodes.TrainWithDummy] = 1
                })

                selectedBehaviour = selectedNode.Name
            end

            return nodes.TryGetChild(selectedBehaviour)
        end
    }

    -- Full camp behaviours
    nodes.CAMP_Laezel.TrainWithDummy = Proxy {
        game.states.CAMP_Laezel_TrainWithDummy,

        OnEnter = function()
            behaviourLoops = math.random(1,3)
            SetFlag(trainingWithDummyFlag)
            SetFlag(noOffhandBehaviourFlag)
        end,

        OnLeave = function()
            ClearFlag(trainingWithDummyFlag)
            ClearFlag(noOffhandBehaviourFlag)
        end,

        OnInterrupt = function()
            ignoreReselectionUponInterrupt = true
        end
    }

    nodes.CAMP_Laezel.StudyGithyankiDisc = Proxy {
        game.states.CAMP_WorldBehaviourAtIdlePos,
        params = {  behaviourPos = "CAMPPOS",
                    worldBehaviourDialog = "BHVR_WRLD_CAMP_Laezel_ReadingGithyankiDisc_346c58df-096c-f237-6153-93573a9087c7"},
        Valid = function()
            return GetFlag(hasGithyankiDisc1,me) or GetFlag(hasGithyankiDisc2,me) or GetFlag(hasGithyankiDisc3,me)
        end
    }

    nodes.CAMP_Laezel.Meditate = Proxy {
        game.states.CAMP_Idle,
        params = {
            behaviourPos = "CAMPPOS",
            idleAnim = "CUST_Meditating_01_45b1a54b-b127-46d2-bfe6-daa8963398ea",
            idleAnimStart = "CUST_Meditating_01_Start_12c9c463-0762-4ef3-a24e-29b5254f580f",
            idleAnimEnd = "CUST_Meditating_01_End_ad0be56c-63b4-4b24-9859-ebcd282ba9f8",
            loopIdleAnim = false,
            idleAnimLength = 30.9,
            idleAnimEndLength = 13.7
        }
    }

    nodes.CAMP_Laezel.StandAndDrink = Proxy {
        game.states.CAMP_WorldBehaviourAtIdlePos,
        params = {
            behaviourPos = "CAMPPOS",
            worldBehaviourDialog = "BHVR_WRLD_GLO_StandAndDrink_Laezel_35811480-44c9-cf22-5089-ebaaafb7abc6"
        },

        OnEnter = function()
            behaviourLoops = math.random(1,3)
        end
    }

    nodes.CAMP_Laezel.Sharpen = Proxy {
        game.states.CAMP_Laezel_SharpeningSword,

        Valid = function()
            return (GetEquippedWeapon(me.Character, WeaponHandType.MainHand) ~= nil)
                    and (IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Longswords)
                    or IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Greatswords)
                    or IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Scimitars))
                    --others blades are too short
        end,

        OnEnter = function()
            behaviourLoops = math.random(1,3)
            SetFlag(noOffhandBehaviourFlag)
        end,

        OnLeave = function()
            ClearFlag(noOffhandBehaviourFlag)
        end,

        OnInterrupt = function()
            SetWeaponUnsheathed(me, false)
            ignoreReselectionUponInterrupt = true
        end
    }

    nodes.CAMP_Laezel.Alert = Proxy {
        game.states.CAMP_Laezel_Alert,

        OnInterrupt = function()
            ignoreReselectionUponInterrupt = true
        end
    }

    -- Clear current behaviour on day<->night transition
    events.FlagSet = function(e)
        if e.Flag == GLO_CAMP_NightMode.Guid then
            selectedBehaviour = nil
            Interrupt()
        end
    end

    events.FlagCleared = function(e)
        if e.Flag == GLO_CAMP_NightMode.Guid then
            selectedBehaviour = nil
            Interrupt()
        end
    end

    events.EntityEvent = function(e)
        if (e.TargetEntity == me) then
            if e.Event == "InterruptCampBehaviour" then
                selectedBehaviour = nil
                Interrupt()
            elseif e.Event == "InterruptCampBehaviour_WithoutReselection" then
                Interrupt()
            end
        end
    end
end}

game.states.CAMP_LaezelNightBehaviours = State {function()
    description = [[Lae'zel's behaviours at camp during the night]]

    modules = { "shared.util" }

    -- Dialogs
    local nightCRDs = {}

    -- Flags
    local CAMP_GLO_State_InCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")
    local CAMP_Laezel_State_HasMeditated = Flag("CAMP_Laezel_State_HasMeditated_ecc15f91-5ea2-4b60-84fd-3eade92d6683")

    -- Behaviours Vars
    local inProgressCrd = nil

    self.OnInit = function()
        nightCRDs["Ceremorphosis_NightOne"] = Guid("CAMP_Night1_CRD_Laezel_b8a8e03b-d221-7b7e-3053-fb6cb6313c42")
        nightCRDs["Monitor_PostHag"] = Guid("CAMP_MonitorPostHag_CRD_Laezel_e87b0f97-5620-5539-be59-177ff6776caa")
    end

    -- Behaviours tied to specific camp nights
    nodes.ceremorphosis_NightOne = Proxy {
        game.states.CAMP_Idle,
        params = {  behaviourPos = "CAMPPOS",
                    idleAnim = "CUST_LookingAround_63bcacef-5631-4ab3-9400-81b23cb18ca7"},

        Valid = function()
            return inProgressCrd == nightCRDs["Ceremorphosis_NightOne"]
        end
    }

    nodes.Monitor_PostHag = Proxy {
        game.states.CAMP_Idle,
        params = {  behaviourPos = "CAMPPOS",
                    idleAnim = "CUST_Meditating_01_45b1a54b-b127-46d2-bfe6-daa8963398ea",
                    idleAnimStart = "CUST_Meditating_01_Start_12c9c463-0762-4ef3-a24e-29b5254f580f",
                    idleAnimEnd = "CUST_Meditating_01_End_ad0be56c-63b4-4b24-9859-ebcd282ba9f8"
                },

        OnEnter = function()
            SetFlag(CAMP_Laezel_State_HasMeditated)
        end,

        Valid = function()
            return inProgressCrd == nightCRDs["Monitor_PostHag"]
        end
    }

    -- Default night behaviour
    nodes.DefaultBehaviour = Proxy {
        game.states.CAMP_Laezel,

        Valid = function()
            return inProgressCrd == nil
        end
    }

    -- Update inProgressCrd
    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "NightInProgress" and mod.util.ContainsValue(nightCRDs, e.Params[1]) then
            inProgressCrd = e.Params[1]
        end
    end

    events.FlagCleared = function(e)
        if e.Flag == CAMP_GLO_State_InCamp.Guid and e.Entity == me then
            inProgressCrd = nil
            Interrupt()
        end
    end
end}

game.states.CAMP_Laezel_SharpeningSword = State{function()

    description = [[Lae'zel sharpens her sword-like weapon, if that's what she has equipped. Main camp only.]]

    local behaviourDialog = nil
    local whetstonePoint1HS = nil
    local whetstonePoint2HS = nil
    local whetstonePoint = nil
    local whetstoneObject = nil

    nodes.SharpenWeapon = Action {
        function()
            SetWeaponUnsheathed(me, false)

            if GetEquippedWeapon(me.Character, WeaponHandType.MainHand) ~= nil then
                if  (IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Longswords) --ToDo: Check GUS-199635 to see if Longswords will be supported
                    or IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Scimitars))
                    and whetstonePoint1HS ~= nil and whetstonePoint1HS ~= "" and whetstoneObject ~= nil and whetstoneObject ~= "" then
                        --DebugText(me, "Assigning 1HS dialog")
                        whetstonePoint  = whetstonePoint1HS
                        behaviourDialog = Dialog("BHVR_WRLD_CAMP_LaezelGrindingWeapon_1HS_3d2363e5-8318-2427-b467-da5e73c61a15")
                elseif IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Greatswords) 
                    and whetstonePoint2HS ~= nil and whetstonePoint2HS ~= "" and whetstoneObject ~= nil and whetstoneObject ~= "" then
                        --DebugText(me, "Assigning 2HS dialog")
                        whetstonePoint = whetstonePoint2HS
                        behaviourDialog = Dialog("BHVR_WRLD_CAMP_LaezelGrindingWeapon_2HS_9795a909-9b6b-36ec-f2d8-4fb18c9ee787")
                end
            end

            if whetstonePoint ~= nil and behaviourDialog ~= nil then
                PopUnsheathedState(me)
                SetWeaponUnsheathed(me, true)
                Sleep(1.5)
                --DebugText(me, "CAMP_Laezel - Starting GrindingWeapons behaviour")
                try
                    StartBehaviorDialog(behaviourDialog, whetstonePoint.Trigger, true, me, whetstoneObject)
                catch e if ls.CheckType(e, error.BehaviorDialogStartFailed) then
                    Sleep(1.0)
                    --DebugText(me, "Behaviour failed to start")
                end
                --DebugText(me, "CAMP_Laezel - Finished GrindingWeapons behaviour")
                Sleep(2.0+2.0*math.random())
            else
                --DebugText(me, "CAMP_Laezel - No whetstone present")
                Sleep(2.0)
            end
        end,

        OnLeave = function()
            BehaviorDialogRequestGracefulStop(me, false, behaviourDialog)
            SetWeaponUnsheathed(me, false)
        end
    }

    self.CanEnter = function()
        return whetstoneObject ~= nil and whetstonePoint1HS ~= nil and whetstonePoint2HS ~= nil
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "CAMP_CamperInCamp_WLDMAIN" then
            whetstonePoint1HS = Entity("BHVR_WRLD_CAMP_LaezelGrindingWeapon_1HS_SceneTrigger_0a89a00e-0b70-8955-39d0-8e151ae8e669")
            whetstonePoint2HS = Entity("BHVR_WRLD_CAMP_LaezelGrindingWeapon_2HS_SceneTrigger_8177f8fa-3360-8d6e-1987-fdf7e6681c6c")
            whetstoneObject = Entity("S_CAMP_Laezel_WhetstoneAtTent_d56f4cbb-8b4d-8a54-1136-1a3eebbfdb98")
        elseif e.TargetEntity == me and e.Event == "CAMP_CamperInCamp_WLDCAVGRN" then
            whetstonePoint1HS = Entity("BHVR_WRLD_CAMP_LaezelGrindingWeapon_1HS_SceneTrigger_717a8805-3d7a-8e30-3006-0d0f18b1af13")
            whetstonePoint2HS = Entity("BHVR_WRLD_CAMP_LaezelGrindingWeapon_2HS_SceneTrigger_f868d0f1-656a-8249-10bd-7ce1e431d516")
            whetstoneObject = Entity("S_CAMP_Laezel_WhetstoneAtTent_2a0f7948-cc2b-8596-0b88-e8c2567e18a8")
        elseif e.TargetEntity == me and e.Event == "CAMP_CamperInCamp_WLDCAVSND" then
