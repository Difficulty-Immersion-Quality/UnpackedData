            elseif e.Event == "CAMP_CamperInCamp_INTMAIN" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_33d1fd06-0bf6-88e6-3aac-9d3cd57a15a0")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_e63168b0-69b5-8ea3-312e-e08408cf23a4")
            elseif e.Event == "CAMP_CamperInCamp_FARM" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_757be06f-3b1c-878e-3bd6-65349f237f8d")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_1390ae03-b58c-85d8-2346-fcc38cdbe38a")
            elseif e.Event == "CAMP_CamperInCamp_SLUMS" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_99023356-bcf4-8aa0-3ae0-c3961cef7965")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_27dc0ae4-07de-88b0-2e9e-c7a78a3fa715")
            elseif e.Event == "CAMP_CamperInCamp_ELFSONG" then
                sceneTrigger = nil
                trainingDummy = nil
            end
        end
    end
end}
