            whetstonePoint2HS = Entity("BHVR_WRLD_CAMP_LaezelGrindingWeapon_2HS_SceneTrigger_6364b8fa-1ecb-8fb3-13c4-d2c3605f38d8")
            whetstoneObject = Entity("S_CAMP_Laezel_WhetstoneAtTent_491c7cf2-d296-8755-0a23-b5124615164b")
        end
    end

end}

game.states.CAMP_Laezel_Alert = State{function()

    description = [[Lae'zel simply idles, sometimes unsheathing her weapon, being alert and ready for battle.]]

    modules = {"shared.math"}

    local combatIdleLoopAnim = Animation([[CUST_Idle_Still_Combat_01_590ea7e8-ae43-4307-916b-b1133ef47dfa]])
    local combatIdlePos = nil
    local actionActive = false

    self.Valid = function()
        return combatIdlePos ~= nil and combatIdlePos.UUID ~= Guid("NULL_00000000-0000-0000-0000-000000000000")
    end

    nodes.GetGith = Action {
        function()
            if IsInDangerousSurfaceFor(combatIdlePos, me.Character) then
                SteerTo(combatIdlePos)
                Sleep(2.0)
            else
                try
                    MoveTo(combatIdlePos, MovementSpeed.Walk, true, false, 1.5, 2.5, false)
                catch e if e.CheckType(e, error.MovementFailed) then
                    Sleep(2.0)
                    return
                end
                LookFrom(combatIdlePos)
                Sleep(math.random(15, 30))
                if GetEquippedWeapon(me.Character, WeaponHandType.MainHand) then
                    PopUnsheathedState(me)
                    SetWeaponUnsheathed(me, true)
                end
                Sleep(2)
                PlayAnimation(combatIdleLoopAnim, false, true)
                Sleep(math.random(10, 20))
                StopAnimation(me)
                if GetEquippedWeapon(me.Character, WeaponHandType.MainHand) then
                    SetWeaponUnsheathed(me, false)
                end
                Sleep(math.random(10, 20))
            end
        end,

        OnEnter = function()
            actionActive = true
        end,

        OnLeave = function()
            actionActive = false
            StopAnimation(me)
            SetWeaponUnsheathed(me, false)
        end,

        OnInterrupt = function()
            actionActive = false
            StopAnimation(me)
            SetWeaponUnsheathed(me, false)
        end
    }

    events.EntityEvent = function(e)
        -- Camp Position Changed
        if e.TargetEntity == me and e.Event == "CampPositionChange" then
            combatIdlePos = e.Params[1]
            if actionActive then 
                Interrupt()
            end
        end
   end

end}

game.states.CAMP_Laezel_TrainWithDummy = State{function()

    description = [[Lae'zel trains on a mindflayer dummy at her camp tent.]]

    local behaviourDialog = Dialog("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_d04e5307-dd41-6984-9eec-dc076835c002")
    local behaviourDialog_1HS = Dialog("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_1HS_601c0d85-4e2c-a9ad-c3bc-75e2df82227b")
    local behaviourDialog_2HS = Dialog("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_2HS_82812866-0cc9-a1d6-9560-47729467f759")
    local behaviourDialog_ToUse = nil

    local sceneTrigger = nil
    local trainingDummy = nil

    nodes.TrainWithDummy = Action {
        function()
            SetWeaponUnsheathed(me, false)

            behaviourDialog_ToUse = behaviourDialog

            if GetEquippedWeapon(me.Character, WeaponHandType.MainHand) ~= nil then
                if  (IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Longswords)
                or IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Scimitars)) then
                    --DebugText(me, "Assigning 1HS dialog")
                    behaviourDialog_ToUse = behaviourDialog_1HS
                elseif IsEquipmentWithProficiency(GetEquippedWeapon(me.Character, WeaponHandType.MainHand), ProficiencyGroup.Greatswords) then
                    --DebugText(me, "Assigning 2HS dialog")
                    behaviourDialog_ToUse = behaviourDialog_2HS
                end
            end

            if sceneTrigger ~= nil and trainingDummy ~= nil and behaviourDialog_ToUse ~= nil then
                PopUnsheathedState(me)
                SetWeaponUnsheathed(me, (behaviourDialog_ToUse ~= behaviourDialog))
                Sleep(1.5)
                --DebugText(me, "CAMP_Laezel - Starting TrainWithDummy behaviour")
                try
                    StartBehaviorDialog(behaviourDialog_ToUse, sceneTrigger.Trigger, true, me, trainingDummy)
                catch e if ls.CheckType(e, error.BehaviorDialogStartFailed) then
                    Sleep(1.0)
                    --DebugText(me, "Behaviour failed to start: [1]",e)
                end
                --DebugText(me, "CAMP_Laezel - Finished TrainWithDummy behaviour")
                Sleep(1.0)
            else
                --DebugText(me, "CAMP_Laezel - No scene trigger present")
                Sleep(2.0)
            end
        end,

        OnLeave = function()
            BehaviorDialogRequestGracefulStop(me, false, behaviourDialog_ToUse)
            SetWeaponUnsheathed(me, false)
        end
    }


    self.CanEnter = function()
        return sceneTrigger ~= nil and trainingDummy ~= nil
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me then
            if e.Event == "CAMP_CamperInCamp_WLDMAIN" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_b7157356-d199-885b-30a3-eeca92f85df9")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_b32fdaad-b085-8bbf-35a1-2cc32fd96c62")
            elseif e.Event == "CAMP_CamperInCamp_WLDCAVGRN" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_2e065b5d-0393-8d36-37d9-6db490c116a3")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_08cf073a-f163-86f1-2ff3-fa579a98a972")
            elseif e.Event == "CAMP_CamperInCamp_WLDCAVSND" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_918cae47-0653-8b66-532c-9a89730d3ec1")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_6a7dad4d-17d9-8afe-5dc6-b5efc51b3f22")
            elseif e.Event == "CAMP_CamperInCamp_WLDDUNABB" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_f10534e5-ad4b-83b4-6045-68d9d39ace89")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_d5d24949-fe28-8523-3c31-f044cd7acabc")
            elseif e.Event == "CAMP_CamperInCamp_WLDDUNSHA" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_770ed905-e070-863e-5311-6e960088f586")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_1c51f821-38da-8437-20fd-0fd599631673")
            elseif e.Event == "CAMP_CamperInCamp_WLDUND" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_e262a806-4705-83b2-4825-1c32c91af285")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_4d392149-4dd9-8266-278f-d0cddf3633d9")
            elseif e.Event == "CAMP_CamperInCamp_WLDBAS" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_85ac1d71-cec4-82f9-305f-cc5dc5d2fcc3")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_4b31413b-a8e4-8725-2b43-cdae7b33eb96")
            elseif e.Event == "CAMP_CamperInCamp_CREMAIN" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_48d9c2c7-8ae2-85a5-464b-01810c2dec7c")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_55abd6b7-6fc4-825a-3f35-aab4fca4d08c")
            elseif e.Event == "CAMP_CamperInCamp_CREINSIDE" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_c2ec9325-1c1d-8d89-46df-524f11d9b51b")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_a20a4e5c-a45a-8140-3398-fde2282489fa")
            elseif e.Event == "CAMP_CamperInCamp_SCLMAIN" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_f370c0a9-002c-8625-3684-c2c0a719b594")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_0af804e0-52bc-80d3-2d40-14ec1a3281f8")
            elseif e.Event == "CAMP_CamperInCamp_HAVEN" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_be3d9f85-76ab-8e70-5bcc-0a8f2cd217b2")
                trainingDummy = Entity("S_CAMP_Laezel_MindflayerDummy_aecd2c6d-ccea-8727-4ba5-7ed8e14a35ad")
            elseif e.Event == "CAMP_CamperInCamp_MOONRISE" then
                sceneTrigger = Entity("BHVR_WRLD_CAMP_Laezel_TrainWithDummy_SceneTrigger_ccacebb0-617c-8e9e-3924-3e964a61b8d6")
