game.states.CAMP_OwlbearCub = State {function()
    description = [[General behaviour of the Owlbear Cub at the campsite]]

    modules = {"shared.util","shared.math", "shared.moveto"}

    --This can be pick from campData
    local campPoint = Entity("S_CAMP_OwlbearCub_f6365a3a-b43e-41b4-8de8-bfb2dad002df")
    local campPoint_SafeTospline = Entity("S_CAMP_OwlbearCub_f6365a3a-b43e-41b4-8de8-bfb2dad002df")
    local dog = Entity("S_FOR_Courier_Dog_3059f69c-068d-4e28-8491-55953c027901")
    local dogChaseFlag = Flag("CAMP_Courier_Dog_Event_ChaseOwlbearCub_a52a966c-e387-42c6-85a8-ced6dd9d4a74")
    local owlbearCubDogNightConcludedFlag = Flag("NIGHT_OwlbearCubDog_902e10f8-e9d8-4eb6-ac0f-9ad8ba8787ed")
    local restFlag = Flag("CAMP_Courier_Dog_Event_Rest_dd64a974-2584-4ce6-bbd6-8bd55a76d362")
    local restPoint = Entity("S_CAMP_OwlbearCub_Night_001_57a4cf5d-9929-4751-9858-c2f07251e29b")
    local currentRestPoint = nil
    local facingPoint = Entity("S_OwlbearCubCourierDog_FacingPoint_001_0f8cdb3e-9f5a-424c-bac6-944fead4ceef")

    local chaseSpline = Spline("S_CAMP_GoblinHuntCelebration_DogChaseSpline_35ff5925-5cd6-4dfd-92b4-17843395b076")
    local targetSplineIndex = -1

    local restTime = 20
    local failSafeTime
    local playfulAnim = Animation([[CUST_Play_01_653ae4dc-c82a-44ad-84b6-ae6a1b16b54b]])
    local hasPlayedAnim = false

    local shadowheart = Entity("S_Player_ShadowHeart_3ed74f06-3c60-42dc-83f6-f034cb47c679")
    local callflag = Flag("CAMP_Shadowheart_Event_CallOwlbear_6a1fe539-f2ea-47fa-ab19-916958b23eee")
    local petarrivedflag = Flag("CAMP_Shadowheart_Event_PetArrived_3fc1c969-f630-4d20-a61e-b1924873d8e2")

    --------------------HELPERS---------------------
    helpers.action.PlayfulAnimTransition = function(target, isWaiting)
        LookAtEntity(target, 3.0)
        failSafeTime = 0 --In case the courier dog never gets in range for whatever reason
        while (GetDistance2DTo(me, target) > 3 and failSafeTime < 10) do
            if isWaiting then
                Sleep(1)
            end
            failSafeTime = failSafeTime + 1
        end
        PlayAnimation(playfulAnim,true,false)
    end

    --------------------NODES---------------------
    nodes.Play = ImmediateSelector {
        CanEnter = function()
            return GetFlag(owlbearCubDogNightConcludedFlag)
        end,

        Valid = function()
            return not dog.Character.IsDead
        end
    }

    nodes.Play.Rest = Action{
        CanEnter = function()
            return GetFlag(restFlag)
        end,

        function()
            if campPoint ~= campPoint_SafeTospline then
                currentRestPoint = campPoint
            else
                currentRestPoint = restPoint
            end
            if  not IsInDangerousSurfaceFor(currentRestPoint, me.Character, 2.0, true) then
                local moveResult = MoveTo(currentRestPoint, MovementSpeed.Walk, false, false, 2.5, 5.0, false)
                if moveResult ~= error.MovementError.None then
                    Wander(3.0,2.0, MovementSpeed.Walk, campPoint)
                else
                    if campPoint == campPoint_SafeTospline then
                        LookAtEntity(facingPoint, 3.0)
                    end
                    Sleep(restTime)
                end
            end
            ClearFlag(restFlag)
        end,
        OnLeave = function()
            ClearFlag(restFlag)
        end,

        Valid = function()
            return GetFlag(restFlag)
        end
    }

    nodes.Play.RunFromDog_Spline = Action {
        CanEnter = function()
            return GetFlag(dogChaseFlag) and (campPoint == campPoint_SafeTospline)
        end,

        function()
            if not hasPlayedAnim then
                helpers.PlayfulAnimTransition(dog, true)
                hasPlayedAnim = true
            end
            try
                DoPatrol(chaseSpline, true, MovementSpeed.Run, -1, false)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                SetFlag(restFlag)
            end
        end,

        Valid = function()
            return GetFlag(dogChaseFlag)
        end,

        OnLeave = function()
            hasPlayedAnim = false
        end
    }

    nodes.Play.RunFromDog_Wander = Action {
        CanEnter = function()
            return GetFlag(dogChaseFlag) and (campPoint ~= campPoint_SafeTospline)
        end,

        function()
            if not hasPlayedAnim then
                LookAtEntity(dog, 0.1)
                helpers.PlayfulAnimTransition(dog, true)
                hasPlayedAnim = true
            end
            Wander(15.0,30.0, MovementSpeed.Run, campPoint)
            SetFlag(restFlag)
        end,

        Valid = function()
            return GetFlag(dogChaseFlag)
        end,

        OnLeave = function()
            hasPlayedAnim = false
        end
    }

    nodes.Play.Follow = Action {
        CanEnter = function()
            return not GetFlag(dogChaseFlag)
        end,

        function()
            try
                MoveInRange(dog, 1.0, 1.5, MovementSpeed.Run)
            catch e if ls.CheckType(e, error.MovementFailed) then
                SetFlag(restFlag)
            end
            if not hasPlayedAnim then --If they are at destination, prevents anim from playing twice
                LookAtEntity(dog, 0.1)
                helpers.PlayfulAnimTransition(dog, false)
                hasPlayedAnim = true
            end
        end,

        Valid = function()
            return not GetFlag(dogChaseFlag)
        end,

        OnLeave = function()
            hasPlayedAnim = false
        end
    }

    nodes.Play.Wander = Action {
        function()
            Wander(3.0,math.random(2,5), MovementSpeed.Walk, dog)
            Sleep(math.random(1,3))
        end,

    }

    nodes.ShadowheartCall = Action {
        function()
            if mod.moveto.MoveToPoint(shadowheart, MovementSpeed.Run, me) then
                SteerTo(shadowheart)
                SetFlag(petarrivedflag)
                Sleep(5.0)
            else
                ClearFlag(callflag)
            end
        end,
        Valid = function()
            return GetFlag(callflag)
        end,
        OnLeave = function()
            ClearFlag(callflag)
        end
    }

    nodes.Wander = Action {
        function()
            Sleep(math.random(5,8))
            Wander(3.0,2.0, MovementSpeed.Walk, campPoint)
        end
    }

    --------------------EVENTS---------------------
    events.SplineControlPointReached = function(e)
        targetSplineIndex = e.NewIndex

        if mod.math.CoinToss(0.15) then
            ClearFlag(dogChaseFlag)
        end
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me then
            if e.Event == "CampPositionChange" then
                campPoint = e.Params[1]
            end
        end
    end

end}

game.states.CAMP_OwlbearCub_Night = State {function()

    description = [[Unique behaviour of the Owlbear Cub for important campsite events]]

    local owlbearCubDogFirstMeetFlag = Flag("CAMP_OwlbearCubDog_State_NightActive_e092ebb1-f756-4644-b4dc-5bf0c0df3fd7")
    local campPoint = Entity("S_CAMP_OwlbearCub_f6365a3a-b43e-41b4-8de8-bfb2dad002df")

    self.Valid = function()
        return GetFlag(owlbearCubDogFirstMeetFlag)
    end

    --------------------NODES---------------------
    nodes.Sleeping = Action {
        OnEnter = function()
            ApplyStatus(me, "SLEEPING", false, -1)
        end,

        function()
            WaitForInterrupt()
        end,

        Valid = function()
            return GetFlag(owlbearCubDogFirstMeetFlag) and not me.IsInCombat
        end
    }

    nodes.Wander = Action {
        function()
            -- TODO: Should wander in every camp
            Wander(20.0,5.0, MovementSpeed.Walk, campPoint)
            Sleep(math.random(5,8))
        end
    }

    --------------------EVENTS---------------------
    events.FlagCleared = function(e)
        if e.Flag == owlbearCubDogFirstMeetFlag.Guid then
            if HasActiveStatus(me, "SLEEPING") then
                RemoveStatus(me, "SLEEPING")
            end
        end
    end

    events.EnteredCombat = function(e)
        if e.Entity == me then
            if HasActiveStatus(me, "SLEEPING") then
                RemoveStatus(me, "SLEEPING")
            end
        end
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me then
            if e.Event == "CampPositionChange" then
                campPoint = e.Params[1]
            end
        end
    end

end}