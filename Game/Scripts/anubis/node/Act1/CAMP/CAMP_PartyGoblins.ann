game.states.CAMP_MainPartyLooting = State {function ()
    description = [[Looting corpses around the camp party.]]

    modules = {"shared.dialog", "shared.util"}

    params.LootSpline = {type=EParamType.String, required=false, default=nil, help=[[Spline this character uses to go around corpses and loot them.]]}
    params.InitialDelay = {type=EParamType.Int, required=false, default=0, help=[[Initial AD delay.]]}

    local initialDelayDone = false
    local lootCorpseAnim = Animation("CUST_LootingCorpse_01_c7d9d546-a74a-4471-9ab1-4175c389a872")
    local betrayal = false

    --Patrol
    local patrolSpline = Spline(params.LootSpline)
    local canWalkOnSpline = true
    local splineEvent = ""
    local AD = Dialog("CAMP_GoblinHuntCelebration_AD_CorpseLooters_e697a93a-a478-15d8-cdee-e3907a975f0e")
    local soloAD = Dialog("CAMP_GoblinHuntCelebration_AD_CorpseLooter003Solo_ff2b30af-4486-12ce-225b-2b1e1de462ec")
    local ADPartners = { Entity("S_CAMP_PartyGoblin_006_effef76f-4a36-45be-89bf-3824787b0d30"),
        Entity("S_CAMP_PartyGoblin_007_0b4bd4f2-4190-46fc-b9b9-826df468ee85") }
    local trioOrSolo = 0


    self.OnInit = function()
        StartTimer(me, "CAMP_GoblinHuntCelebration_InitialADDelay", params.InitialDelay, 0)
    end

    nodes.Betrayal = Action{
        function()
            SetWeaponUnsheathed(me, true, true)
            WaitForInterrupt()
        end,
        CanEnter = function()
            return betrayal
        end
    }

    nodes.AtLocation = Action {
        function()
            LookFrom(patrolSpline)
            Sleep(2)
            PlayAnimation(lootCorpseAnim, true, false)
            mod.util.SleepRandom(6.0,12.0)

            if initialDelayDone then
                if trioOrSolo < 2 then
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        AD,
                        {
                            waitForCompletion = true,
                            minDelay = 30.0,
                        },
                        me,
                        ADPartners
                    )
                    trioOrSolo = trioOrSolo + 1
                elseif trioOrSolo == 2 then
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        soloAD,
                        {
                            waitForCompletion = true,
                            minDelay = 30.0,
                        },
                        me
                    )
                    trioOrSolo = 0
                end
            end

            canWalkOnSpline = true
        end,
        Valid = function()
            return not canWalkOnSpline
        end,
        OnInterrupt = function()
            canWalkOnSpline = true
        end
    }

    nodes.Patrolling = Action {
        OnEnter = function()
            splineEvent = ""
        end,
        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Stroll)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                LookFrom(patrolSpline)
                Sleep(1)
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end,
    }

    events.SplineControlPointReached = function(e)
        canWalkOnSpline = false
        if e.Event ~= nil then
            splineEvent = e.Event
        else
            splineEvent = ""
        end
    end

    events.DialogEnded = function(e)
        if e.Instance.Automated then
            canWalkOnSpline = true
        end
    end

    events.TimerFinished = function(e)
        if(e.TimerName == "CAMP_GoblinHuntCelebration_InitialADDelay") then
            initialDelayDone = true
        end
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "CAMP_GoblinHuntCelebration_Betrayal" then
            betrayal = true
            Interrupt()
        end
    end
end}

game.states.CAMP_SubPartyLooting = State {function ()
    description = [[Looting corpses around the camp party.]]

    modules = {"shared.dialog", "shared.util"}

    params.SoloAD = {type=EParamType.String, required=false, default=nil, help=[[AD this character says when looting a corpse.]]}
    params.LootSpline = {type=EParamType.String, required=false, default=nil, help=[[Spline this character uses to go around corpses and loot them.]]}
    params.InitialDelay = {type=EParamType.Int, required=false, default=0, help=[[Initial AD delay.]]}

    local initialDelayDone = false
    local lootCorpseAnim = Animation("CUST_LootingCorpse_01_c7d9d546-a74a-4471-9ab1-4175c389a872")
    local betrayal = false

    --Patrol
    local patrolSpline = Spline(params.LootSpline)
    local canWalkOnSpline = true
    local splineEvent = ""
    local soloAD = Dialog(params.SoloAD)

    self.OnInit = function()
        StartTimer(me, "CAMP_GoblinHuntCelebration_InitialADDelay", params.InitialDelay, 0)
    end

    nodes.Betrayal = Action{
        function()
            SetWeaponUnsheathed(me, true, true)
            WaitForInterrupt()
        end,
        CanEnter = function()
            return betrayal
        end
    }

    nodes.AtLocation = Action {
        function()
            LookFrom(patrolSpline)
            Sleep(2)
            PlayAnimation(lootCorpseAnim, true, false)
            mod.util.SleepRandom(6.0,12.0)

            if initialDelayDone then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    soloAD,
                    {
                        waitForCompletion = false,
                        minDelay = 80.0,
                    },
                    me
                )
            end

            canWalkOnSpline = true
        end,
        Valid = function()
            return not canWalkOnSpline
        end,
        OnInterrupt = function()
            canWalkOnSpline = true
        end
    }

    nodes.Patrolling = Action {
        OnEnter = function()
            splineEvent = ""
        end,
        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Stroll)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                LookFrom(patrolSpline)
                Sleep(1)
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end,
    }

    events.SplineControlPointReached = function(e)
        canWalkOnSpline = false
        if e.Event ~= nil then
            splineEvent = e.Event
        else
            splineEvent = ""
        end
    end

    events.DialogEnded = function(e)
        if e.Instance.DialogUUID == Guid(params.SoloAD) then
            canWalkOnSpline = true
        end
    end

    events.TimerFinished = function(e)
        if(e.TimerName == "CAMP_GoblinHuntCelebration_InitialADDelay") then
            initialDelayDone = true
        end
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "CAMP_GoblinHuntCelebration_Betrayal" then
            betrayal = true
            Interrupt()
        end
    end
end}