game.states.CAMP_PartyBeachPatrolling = State {function ()
    description = [[Patrolling the beach area during the goblin party.]]

    modules = {"shared.dialog"}

    local betrayal = false

    -- Chase Dog
    local CAMP_GLO_State_InCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")
    local courierDog = Entity("S_FOR_Courier_Dog_3059f69c-068d-4e28-8491-55953c027901")

    --Patrol
    local patrolSpline = Spline("S_CAMP_BeachSpline_ab3528b0-dddf-4734-98cb-aa4bcd4d5079")
    local canWalkOnSpline = true
    local splineEvent = ""
    local drowCommander = Entity("S_GOB_DrowCommander_25721313-0c15-4935-8176-9f134385451b")
    local AD = Dialog("CAMP_GoblinHuntCelebration_AD_ReportingToDrow_7213670a-9394-8ec7-72e9-9587c5c9abbb")
    local soloAD = Dialog("CAMP_GoblinHuntCelebration_AD_GoblinGuardComplaint_c9099b96-81c8-2f47-174e-cee2695de222")

    nodes.Betrayal = Action{
        function()
            SetWeaponUnsheathed(me, true, true)
            WaitForInterrupt()
        end,
        CanEnter = function()
            return betrayal
        end
    }

    nodes.ChaseDog = Action{
        function()
            local moveResult = MoveTo(courierDog, MovementSpeed.Run, true, false, 1, 3, false)
            if moveResult ~= error.MovementError.None then
                SteerTo(courierDog)
                Sleep(2.0)
            end
        end,

        Valid = function()
            return GetFlag(CAMP_GLO_State_InCamp, courierDog)
        end
    }

    nodes.AtLocation = Action {
        function()
            LookFrom(patrolSpline)
            Sleep(20)

            if splineEvent == "CAMP_GoblinHuntCelebration_WithDrow" then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    AD,
                    {
                        waitForCompletion = true,
                        minDelay = 40.0,
                    },
                    me,
                    drowCommander
                )
            else
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    soloAD,
                    {
                        waitForCompletion = true,
                        minDelay = 40.0,
                    },
                    me
                )
            end

            canWalkOnSpline = true
        end,
        Valid = function()
            return not canWalkOnSpline
        end,
        OnInterrupt = function()
            canWalkOnSpline = true
        end
    }

    nodes.Patrolling = Action {
        OnEnter = function()
            splineEvent = ""
        end,
        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Stroll)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                LookFrom(patrolSpline)
                Sleep(1)
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end,
    }

    events.SplineControlPointReached = function(e)
        canWalkOnSpline = false
        if e.Event ~= nil then
            splineEvent = e.Event
        else
            splineEvent = ""
        end
    end

    events.DialogEnded = function(e)
        if e.Instance.Automated then
            canWalkOnSpline = true
        end
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "CAMP_GoblinHuntCelebration_Betrayal" then
            betrayal = true
            Interrupt()
        end
    end
end}

