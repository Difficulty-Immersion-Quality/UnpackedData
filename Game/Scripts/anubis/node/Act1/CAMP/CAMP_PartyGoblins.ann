game.states.CAMP_MainPartyPraying = State {function ()
    description = [[Praying to the absolute altar]]

    modules = {"shared.dialog", "shared.util"}

    local chantAnimation = Animation("CUST_Chanting_01_2b033b5d-6402-4ffe-af56-124a5dd7ba0e")
    local altar = Entity("S_CAMP_BloodAltar_ae7c1c27-3a7f-4d39-8b06-fe56879a7c37")
    local chantAD = Dialog("CAMP_GoblinHuntCelebration_AD_GoblinWorship_019a030b-d092-11d8-d5b6-b04d97d327f5")
    local interruptAD = Dialog("CAMP_GoblinHuntCelebration_AD_WorshipInterruption_68a294bf-6512-45b5-6237-49d09988bb48")
    local interruptTimerDone = true
    local interruptPraying = false
    local betrayal = false
    local ADPartner = Entity("S_CAMP_PartyGoblin_002_c7eabe93-d7dd-4345-b363-f156281d3fdb")

    nodes.Betrayal = Action{
        function()
            SetWeaponUnsheathed(me, true, true)
            WaitForInterrupt()
        end,
        CanEnter = function()
            return betrayal
        end
    }

    nodes.InterruptAD = Action {
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                interruptAD,
                {
                    waitForCompletion = true,
                    minDelay = 1.0,
                },
                me,
                ADPartner
            )
        end,
        OnEnter = function()
            interruptTimerDone = false
            StartTimer(me, "CAMP_GoblinHuntCelebration_PrayingInterruptionTimer", 80, 0)
        end,
        Valid = function()
            return interruptPraying
        end
    }

    nodes.Praying = Action {
        function()
            LookAtEntity(altar, 3.0)
            mod.util.SleepRandom(1.0,3.0)
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                chantAD,
                {
                    waitForCompletion = false,
                    minDelay = 20.0,
                },
                me
            )
            PlayAnimation(chantAnimation)
        end
    }

    events.TimerFinished = function(e)
        if(e.TimerName == "CAMP_GoblinHuntCelebration_PrayingInterruptionTimer") then
            interruptTimerDone = true
        end
    end

    events.DialogEnded = function(e)
        if e.Instance.DialogUUID == chantAD.Guid then
            if interruptTimerDone then
                interruptPraying = true
            end
        elseif e.Instance.DialogUUID == interruptAD.Guid then
            interruptPraying = false
        end
    end

    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "CAMP_GoblinHuntCelebration_Betrayal" then
            betrayal = true
            Interrupt()
        end
    end
end}

