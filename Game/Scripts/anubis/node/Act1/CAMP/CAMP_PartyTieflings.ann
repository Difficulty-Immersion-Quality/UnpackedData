game.states.CAMP_SitAndDrinkAndPetDog = State {function() 
    description = [[Sitting and waiting for Scratch to pass by]]

    params.seat = {type=EParamType.String, required=true, help=[[seat the character will sit on.]]}
    params.sitIdle = {type = EParamType.State, required = true,
        help = [[
            Workaround for not being able to pass params to staterefs in .ann files. Add CAMP_SitAndDrink State here with willDrink and seat params.
        ]]
    }

    local tieflingPetsDogFlag = Flag("CAMP_GoblinHuntCelebration_State_PettingDog_cc8b4a4d-99ca-41a1-b38a-57686feb7070")

    events.EntityEvent = function(ev)
        if ev.TargetEntity == me and ev.Event == "StartPetTheDog" and GetFlag(tieflingPetsDogFlag, me) then
            EndRepose(me)
            SetWeaponUnsheathed(me, false, true)
        end
    end

    nodes.WaitingForDog = Action {
        function() 
            Sleep(1.0)
        end,
        OnEnter = function()
            SetWeaponUnsheathed(me, false, false)
        end,
        Valid = function()
            return GetFlag(tieflingPetsDogFlag, me)
        end
    }

    nodes.SitAndDrink = Proxy {
        game.states.Sit,
        params = {
            seat = params.seat,
            sitIdle = params.sitIdle,
        },
    }
    
end}

