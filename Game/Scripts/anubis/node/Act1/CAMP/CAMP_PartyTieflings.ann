game.states.CAMP_FlirtyTiefling = State {function ()
    description = [[Patrolling the camp and talking with Bard.]]

    modules = {"shared.dialog", "shared.math", "shared.util"}

    params.AD = {type=EParamType.String, required=false, default=nil, help=[[AD played with bard.]]}
    params.backupAD = {type=EParamType.String, required=false, default=nil, help=[[AD played with backup bard.]]}

    local bard = Entity("S_DEN_Bard_4a405fba-3000-4c63-97e5-a8001ebb883c")
    local bardBackup = Entity("S_CAMP_TieflingBackup_001_39feb630-73d6-414c-a5cd-d02366ff26d7")
    local standAndDrinkDialog = Dialog("BHVR_WRLD_GLO_StandAndDrink_a4065598-1ea2-8866-d23f-f765b5008273")
    local AD = Dialog(params.AD)
    local backupAD = Dialog(params.backupAD)
    local canAD = true

    --Patrol
    local patrolSpline = Spline("S_CAMP_FlirtySpline_9c52ff82-3b15-483e-8546-ba907baad2a0")
    local canWalkOnSpline = true
    local splineEvent = ""
    local tieflingPetsDogFlag = Flag("CAMP_GoblinHuntCelebration_State_PettingDog_cc8b4a4d-99ca-41a1-b38a-57686feb7070")

    events.EntityEvent = function(ev)
        if ev.TargetEntity == me and ev.Event == "StartPetTheDog" and GetFlag(tieflingPetsDogFlag, me) then
            EndRepose(me)
            SetWeaponUnsheathed(me, false, true)
        end
    end

    nodes.WaitingForDog = Action {
        function() 
            Sleep(1.0)
        end,
        OnEnter = function()
            SetWeaponUnsheathed(me, false, false)
        end,
        Valid = function()
            return GetFlag(tieflingPetsDogFlag, me)
        end
    }

    nodes.ADBard = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialog(
                AD,
                {
                    waitForCompletion = true,
                },
                me,
                bard
            )
            canAD = false
        end,
        OnLeave = function()
            canAD = false
            StopTimer(me,"ADTimer_CAMP_GoblinHuntCelebration_AD_Bard")
            StartTimer(me,"ADTimer_CAMP_GoblinHuntCelebration_AD_Bard", 20.0 + math.random(0,10),0)
        end,
        Valid = function()
            return splineEvent == "CAMP_GoblinHuntCelebration_WithBard" and canAD and not bard.Character.IsDead and params.AD ~= nil
        end
    }

    nodes.ADBackup = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialog(
                backupAD,
                {
                    waitForCompletion = true,
                },
                me,
                bardBackup
            )
            canAD = false
        end,
        OnLeave = function()
            canAD = false
            StopTimer(me,"ADTimer_CAMP_GoblinHuntCelebration_AD_Bard")
            StartTimer(me,"ADTimer_CAMP_GoblinHuntCelebration_AD_Bard", 20.0 + math.random(0,10),0)
        end,
        Valid = function()
            return splineEvent == "CAMP_GoblinHuntCelebration_WithBard" and canAD and bard.Character.IsDead and params.backupAD ~= nil
        end
    }

    nodes.AtLocation = Action {
        function()
            LookFrom(patrolSpline)
            mod.util.SleepRandom(3.0, 10.0)
            StartBehaviorDialog(standAndDrinkDialog, nil, true, me)
            mod.util.SleepRandom(1.0, 5.0)
            canWalkOnSpline = true
        end,
        Valid = function()
            return not canWalkOnSpline
        end,
        OnInterrupt = function()
            canWalkOnSpline = true
        end
    }

    nodes.Patrolling = Action {
        OnEnter = function()
            splineEvent = ""
        end,
        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Stroll)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                LookFrom(patrolSpline)
                Sleep(1)
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end,
    }

    events.SplineControlPointReached = function(e)
        canWalkOnSpline = false
        if e.Event ~= nil then
            splineEvent = e.Event
        else
            splineEvent = ""
        end
    end

    events.DialogEnded = function(e)
        if e.Instance.Automated then
            canWalkOnSpline = true
        end
    end

    events.TimerFinished = function(e)
        if(e.TimerName == "ADTimer_CAMP_GoblinHuntCelebration_AD_Bard") then 
            canAD = true
        end
    end
end}

