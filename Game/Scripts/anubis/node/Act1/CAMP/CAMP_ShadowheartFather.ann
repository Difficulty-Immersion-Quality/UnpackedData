game.states.CAMP_ShadowheartFather = State{
    function()

        nodes.CAMP_ShadowheartFather = Selector{
            function(nodes)
                return FindWeightedRandomSelectable(nodes, { 
                    [nodes.Idle] = 1,
                    [nodes.HideFear] = 2,
                    [nodes.ArmsCrossed] = 2,
                    [nodes.Worried] = 2,
                })
            end,
            Valid = function(nodes)
                return CheckAnySelectable(nodes)
            end
        }
    
        -- Full Camp Behaviours
        nodes.CAMP_ShadowheartFather.Idle = Proxy{
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = nil,
                        loopIdleAnim = false,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 25.0
        },
        }

        nodes.CAMP_ShadowheartFather.HideFear = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnimStart = "CUST_HideFear_01_Start_32435d83-f7f4-4d82-b7e0-82ee3448bef3",
                        idleAnim = "CUST_HideFear_01_Loop_b5d270c7-65fa-41eb-a39d-ce0e250b4e2a",
                        idleAnimEnd = "CUST_HideFear_01_End_6397bbdd-4e8c-4901-a541-e412dfc16873",
                        loopIdleAnim = false,
                        idleAnimLength = 30.0,
                        idleAnimEndLength = 4.9,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 15.0
            },
        }

        nodes.CAMP_ShadowheartFather.ArmsCrossed = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnimStart = "CUST_ArmsCrossed_01_Start_dafd0bbc-012a-403c-aabe-4963aca9cf25",
                        idleAnim = "CUST_ArmsCrossed_01_Loop_e6c49668-99b1-41d6-8daa-7ed6864b4e71",
                        idleAnimEnd = "CUST_ArmsCrossed_01_End_ae43ea68-fc1b-456a-88ce-0e1d504e1d40",
                        loopIdleAnim = false,
                        idleAnimLength = 12.3,
                        idleAnimEndLength = 5.3,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 10.0
            },
        }

        nodes.CAMP_ShadowheartFather.Worried = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = "CUST_Worried_01_a4616816-be6d-4fa1-a65a-2da057196af4",
                        sleepDurationMin = 10.0,
                        sleepDurationMax = 15.0
            },
        }


    end
}