game.states.CAMP_SpiritOfTheLand = State{
    function()

        local flag_SpiritAwake = Flag("GLO_LiftingTheCurse_State_BreathHasBeenRestored_2113b54e-a140-4aa0-97ac-219fa7b7d038")

        nodes.SpiritSleeping = Proxy{
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = "DIAG_Pose_Lie_Supine_01_da2974cf-da03-4799-a707-33932de2332d",
                        loopIdleAnim = true,
                    },
            Valid = function()
                return not GetFlag(flag_SpiritAwake)
            end
        }

        nodes.CAMP_SpiritOfTheLand = Selector{
            function(nodes)
                return FindWeightedRandomSelectable(nodes, { 
                    [nodes.Idle] = 1,
                    [nodes.Sitting] = 2,
                    [nodes.SniffingAir] = 2,
                    [nodes.Worried] = 2,
                })
            end,
            Valid = function(nodes)
                return CheckAnySelectable(nodes)
            end
        }
    
        -- Full Camp Behaviours
        nodes.CAMP_SpiritOfTheLand.Idle = Proxy{
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = nil,
                        loopIdleAnim = false,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 25.0
        },
        }

        nodes.CAMP_SpiritOfTheLand.Sitting = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnimStart = "CUST_SittingGroundListening_01_Start_8c390bf1-f95d-40c3-a13e-0d30a74d8608",
                        idleAnim = "CUST_SittingGroundListening_01_Loop_e3dca236-9064-4613-8d5f-2b8b40f3294d",
                        idleAnimEnd = "CUST_SittingGroundListening_01_End_245f1cbf-22c2-4103-bd35-50e2e803a5f4",
                        loopIdleAnim = false,
                        idleAnimLength = 53.6,
                        idleAnimEndLength = 4.9,
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 25.0
            },
        }

        nodes.CAMP_SpiritOfTheLand.SniffingAir = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = "CUST_Sniffing_Air_01_92e7ac17-b123-4a26-8e4f-2f8df2502fc2",
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 10.0
            },
        }

        nodes.CAMP_SpiritOfTheLand.Worried = Proxy {
            game.states.CAMP_Idle,
            params = {  behaviourPos = "CAMPPOS",
                        idleAnim = "CUST_Worried_01_a4616816-be6d-4fa1-a65a-2da057196af4",
                        sleepDurationMin = 5.0,
                        sleepDurationMax = 15.0
            },
        }


    end
}