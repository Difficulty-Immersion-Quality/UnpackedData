game.states.CRA_ShadowHeart = State {function ()
    description = [[Behaviour of Shadow Heart]]
    modules = {"shared.util", "shared.dialog" }

    local UnconsciousFlag = Flag("CRA_ShadowheartRecruitment_State_Unconscious_a461603e-1423-4c54-a270-82f38ee470af")
    local BeachFlag = Flag("GLO_Shadowheart_State_BeachRecruitment_14468bb2-c6bf-4aa0-a00e-011ced4823fb")
    local tr_StartSpot = Entity("S_CRA_BeachShadowheartRecruit_566350d5-6331-4a87-afde-ef122c5f41a6")


    self.Valid = function()
        return CheckCurrentGameLevel("WLD_Main_A") and GetFlag(BeachFlag,nil)
    end

    nodes.Unconscious = Action {
        function()
            local moveResult = MoveTo(tr_StartSpot, MovementSpeed.Walk, true, false, 0.5, 4.0, false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                else 
                    if GetFlag(UnconsciousFlag,nil) then
                        if not HasActiveStatus(me, "CRA_UNCONSCIOUS_SHADOWHEART") then
                            ApplyStatus(me, "CRA_UNCONSCIOUS_SHADOWHEART")
                        end
                    end
                mod.util.SleepRandom(1.0, 4.0)
            end
        end
    }
end}