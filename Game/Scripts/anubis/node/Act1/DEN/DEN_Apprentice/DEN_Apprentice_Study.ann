game.states.DEN_Apprentice_Study = State { function ()

    modules = { "shared.dialog" }

    local studyingAD = Dialog([[DEN_Apprentice_AD_Studying_7030a0a1-10d6-3f2a-b1a8-c814328f8ec9]])
    local nearDeskBox = Entity([[S_DEN_AppChairBox_100bdc53-c506-42db-a3ba-5a2550f1fb14]])
    
    description = [[Nettie's behaviour in the secret library]]

    nodes.Idle = Action {
        function()
            Sleep(3)
            if not me.IsReposed then
                if IsInDangerousSurfaceFor(nearDeskBox, me.Character) then
                    SteerTo(nearDeskBox)
                    return
                else
                    local moveResult = MoveTo(nearDeskBox, MovementSpeed.Stroll)
                    if moveResult ~= error.MovementError.None then
                        SteerTo(nearDeskBox)
                        return
                    end
                end
                LookFrom(nearDeskBox)
            end
            mod.dialog.StartCheckedAutomatedDialogRateLimited(studyingAD, {minDelay = math.random(40, 60)}, me)
        end
    }

end}