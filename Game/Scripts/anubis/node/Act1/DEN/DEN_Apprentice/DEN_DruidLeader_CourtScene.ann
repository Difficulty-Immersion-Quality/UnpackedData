game.states.DEN_DruidLeader_CourtScene = State { function ()

    description = [[The main Shadow Druid, Court of Snakes scene behaviour.]]

    modules = { "shared.dialog" }

    -- Court of Snakes scene
    local snakeCourtAD = Dialog([[DEN_ShadowDruid_AD_SnakesCourt_ae8ed0a1-898c-d7b2-11d1-e8b20998e93b]])
    local opposedDruid = Entity([[S_DEN_DruidOpposed_322cf8d2-32ee-453f-987e-f12b32652b5d]])
    local snakeKid = Entity([[S_DEN_SnakeKid_02257c1c-bbec-4ae3-9bcb-31c75a0a982f]])
    local anim = Animation([[CUST_AccusingInCourt_01_Loop_82f29123-5574-4620-9c4d-f02055d6cfe7]])
    local cutsceneDone = false

    -----------------------------------------
    -- node section
    nodes.SnakeCourt_OutcomeReaction = Action {
        CanEnter = function()
            return cutsceneDone
        end,
        function()
            Sleep(1)
        end
    }

    nodes.SnakeCourt = Action {
        function()
            PlayAnimation(anim, false, true)
            while not cutsceneDone do
                Sleep(3)
                if (not cutsceneDone) and mod.dialog.AreSpeakersAvailableAndNear(me, 10.0, false, true, false, {opposedDruid, snakeKid}) then
                    StartAutomatedDialog(snakeCourtAD, true, me, snakeKid, opposedDruid)
                end
                Sleep(17)
            end
        end,
        OnLeave = function()
            StopAnimation(me)
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end
    }

    events.FlagSet = function(e)
        if e.Flag == Guid([[DEN_ShadowDruid_State_SnakesCourtDone_cf58dd01-e058-42b8-b1f1-976250296ce6]]) then
            cutsceneDone = true
        end
    end


end}
