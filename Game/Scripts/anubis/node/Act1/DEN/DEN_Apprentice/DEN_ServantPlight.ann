game.states.DEN_ServantPlight = State { function ()

    description = [[This druid servant is in the cave.]]
    
    -----------------------------------------
    -- Nodes
    nodes.Default = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.Default.Table = Proxy {
        game.states.DEN_GeneralGroveStates_LoopAnimateAtPointWithStartEnd,
        params={
            animLoop = "CUST_SurveyStore_01_Loop_acf0b680-3785-4b72-8e2e-8aadcde0fa75",
            animStart = "CUST_SurveyStore_01_Start_ad340a7d-3a60-4891-b331-d227dae8c1d3",
            animEnd = "CUST_SurveyStore_01_End_f5ffb4fb-b343-4cd9-80e0-54778d21f6c4",
            moveTarget = "S_DEN_PlightPoint_9ce8bedb-90bd-4bfc-a3bd-136be41938eb",
            lookFromMoveTarget = true,
            waitMin = 1.0,
            waitMax = 2.0,
        }
    }

    nodes.Default.Rest = Action {
        function()
            Sleep(math.random(4,8))
        end
    }

end}