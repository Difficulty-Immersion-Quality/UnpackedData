game.states.DEN_SnakesCourt = State { function ()

    description = [[To be used on NPCs that takes part of the Snakes Court scene.]]

    params.courtCustomState = {
        type = EParamType.State, required = false,
        default = nil,
        help = [[Use the default point or pass a state here.]]
    }
    params.courtDefaultPoint = {
        type = EParamType.String, required = false,
        default = nil,
        help = [[A point is required if the NPC doesn't use a custom state.]]
    }
    params.postSceneState = {
        type = EParamType.State, required = true,
        default = nil,
        help = [[State to use after the scene.]]
    }

    --the flag is set if there's no reaction
    local reactionDone = Flag("DEN_ShadowDruid_Event_ReactionDone_be576fb3-ba9c-4375-8870-e0f66e6eeb4c")

    nodes.SnakesCourt = Selector {
        CanEnter = function()
            return not GetFlag(reactionDone, me)
        end
    }
    nodes.SnakesCourt.Custom = Proxy {
        params.courtCustomState,
    }
    nodes.SnakesCourt.Default = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.courtDefaultPoint
        }
    }
    nodes.PostCourtIdle = Proxy {
        params.postSceneState,
    }
end}
