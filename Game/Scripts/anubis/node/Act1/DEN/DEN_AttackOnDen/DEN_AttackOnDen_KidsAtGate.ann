game.states.DEN_AttackOnDen_KidsAtGate = State { function ()

    description = [[The kids are at the main gate, either listening to Rikka talk or are sitting on the ground together.]]

    -----------------------------------------
    -- Params
    params.guardLiveState = {type=EParamType.State, required=true, default=nil, help=[[Kid is listening to guard's instructions]]}

    local gateGuard = Entity("S_DEN_Tiefling_001_82f8662d-76da-4352-b37e-01ba433b5d43")

    nodes.ListeningToGuard = Proxy {
        params.guardLiveState,
        Valid = function()
            return not gateGuard.Character.IsDead
        end,
    }

    nodes.SittingDown = Proxy {
        game.states.Sit,
            params={
                seat = [[]],
                sitOnGroundAsFallback = true
            },
    }

    events.Died = function(e)
        if e.Target == gateGuard then
            Interrupt()
        end
    end

end}