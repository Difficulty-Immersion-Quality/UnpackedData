game.states.DEN_AttackOnDen_VictoryParents = State { function ()

    modules = { "shared.moveto" }

    description = [[The kids are at the main gate, either listening to Rikka talk or are sitting on the ground together.]]

    params.position = {type = EParamType.String, required=true, default = nil, help=[[]]}

    local kid = Entity("S_DEN_SnakeKid_02257c1c-bbec-4ae3-9bcb-31c75a0a982f")
    local position = Entity(params.position)

    nodes.WithKid = Action{
        function()
            if mod.moveto.MoveToPoint(position,MovementSpeed.Stroll,me) then
                SteerTo(kid)
            end
        end,
        Valid = function()
            return not kid.Character.IsDead
        end
    }

    nodes.WithoutKid = Action{
        function()
            if mod.moveto.MoveToPoint(position,MovementSpeed.Stroll,me) then
                LookFrom(position)
            end
        end,
        Valid = function()
            return kid.Character.IsDead
        end
    }
end}

game.states.DEN_AttackOnDen_VictoryRangerTrader = State { function ()

    description = [[The tiefling is caring for the oxes before the road.]]

    modules = {"shared.moveto", "gustav.Act1.GroveRefugee"}

    local ox1 = Entity("S_DEN_Mule_001_06ed1274-9d16-4320-b5ad-162fca5fb85d")
    local ox2 = Entity("S_DEN_Mule_002_ac37baa6-624a-418d-a6ca-52ed9a77f00c")

    local standPoint1 = Entity("S_DEN_VictoryOxCarePos_001_7029c2b0-5be4-4ad6-993f-c52e2af259de")
    local standPoint2 = Entity("S_DEN_VictoryOxCarePos_002_b6222224-145a-458d-b8c3-e087fbfc29f4")
    local standPoint3 = Entity("S_DEN_VictoryOxCarePos_003_aa15f220-848a-419c-bbbe-456f645c286c")
    local standPoint4 = Entity("S_DEN_VictoryOxCarePos_004_7a5ee0dc-6c25-4d5f-a5a5-1c806ef7025e")
    local standPoint5 = Entity("S_DEN_VictoryOxCarePos_005_2c9289dc-1055-44a5-8bb9-1b32bff7f69d")

    local petAnimation = Animation("CUST_PettingOx_01_504cd5df-a26e-4813-a4e2-f048734bfe30")
    local checkCartAnimation = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
    local organizeAnimation = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")
    
    local crateItems = {
        Entity("S_DEN_LeaveApparel003_20edb5dd-5f04-4d7c-930e-c5f1b2217669"),
    }
    local goodsPos = {}
    local canAD = false

    -----------------------------------------
    -- State nodes

    self.OnInit = function()
        mod.GroveRefugee.SetGoodsPos(crateItems, goodsPos)  
    end
    
    -----------------------------------------
    -- state section

    nodes.Default = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.Default.PetOx1 = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint1,MovementSpeed.Stroll,me) then
                SteerTo(ox1)
                PlayAnimation(petAnimation, true, false)
                Sleep(math.random(4,8))
            end
        end,
        Valid = function()
            return not ox1.Character.IsDead
        end
    }

    nodes.Default.PetOx2 = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint2,MovementSpeed.Stroll,me) then
                SteerTo(ox2)
                PlayAnimation(petAnimation, true, false)
                Sleep(math.random(4,8))
            end
        end,
        Valid = function()
            return not ox2.Character.IsDead
        end
    }

    nodes.Default.CheckCart = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint3,MovementSpeed.Stroll,me) then
                LookFrom(standPoint3)
                PlayAnimation(checkCartAnimation, true, false)
                Sleep(math.random(12,18))
            end
        end
    }

    nodes.Default.CheckWares = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint4,MovementSpeed.Stroll,me) then
                LookFrom(standPoint4)
                PlayAnimation(organizeAnimation, true, false)
                Sleep(math.random(12,18))
            end
        end,
        Valid = function()
            return mod.GroveRefugee.CheckItemLocation(crateItems[1],goodsPos[1])
        end
    }

    nodes.Default.Rest = Action {
        function()
            if mod.moveto.MoveToPoint(standPoint5,MovementSpeed.Stroll,me) then
                LookFrom(standPoint5)
            end
            Sleep(math.random(4,8))
        end
    }

end}


