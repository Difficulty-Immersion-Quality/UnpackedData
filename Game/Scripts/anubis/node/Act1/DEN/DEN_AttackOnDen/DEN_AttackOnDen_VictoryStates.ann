game.states.DEN_AttackOnDen_VictoryChef = State { function ()

    description = [[The tiefling is helping others pick out weapons before they leave the Grove.]]

    modules = {"shared.moveto", "gustav.Act1.GroveRefugee", "shared.dialog"}

    local standPoint1 = Entity("S_DEN_VictoryChefPos_001_87282903-1455-4e9e-871a-16d7e1e8efbe")
    local standPoint2 = Entity("S_DEN_VictoryChefPos_002_83d3dcd6-e7aa-4908-a07f-75b3d641de18")
    local standPoint3 = Entity("S_DEN_VictoryChefPos_003_d18869e6-2cac-4f71-bba9-ca82034c4863")

    local son = Entity("S_DEN_Tiefling_008_03b6fae4-d250-4ce9-9a01-19cb427deb17")

    local withSonAD = Dialog("DEN_AttackOnDen_AD_ChefAndSonPacking_504c6f0f-a3e8-baf0-11a2-b1a1c9f0112f")

    local organizeAnimation = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")
    local withSonAnimation = Animation("CUST_SizingUpHeavyObject_01_721d00d0-32a0-488e-b1ec-3400ac2dbf62")

    local crateItems = {
        Entity("S_DEN_LeaveApparel007_0b5b2c91-2e9b-46a8-b999-6fa9b9d4a054"),
        Entity("S_DEN_LeaveApparel005_cf2dd37e-5ef0-485d-afd8-bd299df3e23a"),
    }
    local goodsPos = {}

    local canAD = true
    
    helpers.ResetADDelay = function(ADDelay)
        StopTimer(me, "DEN_AttackOnDen_WithSonADTimer")
        StartTimer(me, "DEN_AttackOnDen_WithSonADTimer", ADDelay, 0)
        canAD = false
    end

    -----------------------------------------
    -- state section

    self.OnInit = function()
        mod.GroveRefugee.SetGoodsPos(crateItems, goodsPos)  
    end

    nodes.Default = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.Default.WithSon = Action {
        function()
            Sleep(math.random(1,2))
            if mod.moveto.MoveToPoint(standPoint1,MovementSpeed.Stroll,me) then
                LookFrom(standPoint1)
                PlayAnimation(withSonAnimation, false, false)
                if (canAD and mod.dialog.IsSpeakerAvailable(son)) then
                    helpers.ResetADDelay(40)
                    StartAutomatedDialog(withSonAD, true, me, son)
                end
                Sleep(math.random(12,18))
            end
        end
    }

    nodes.Default.OrganizeCrate1 = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint2,MovementSpeed.Stroll,me) then
                LookFrom(standPoint2)
                PlayAnimation(organizeAnimation, true, false)
                Sleep(math.random(6,9))
            end
        end,
        Valid = function()
            return mod.GroveRefugee.CheckItemLocation(crateItems[1],goodsPos[1])
        end
    }

    nodes.Default.OrganizeCrate2 = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint3,MovementSpeed.Stroll,me) then
                LookFrom(standPoint3)
                PlayAnimation(organizeAnimation, true, false)
                Sleep(math.random(6,9))
            end
        end,
        Valid = function()
            return mod.GroveRefugee.CheckItemLocation(crateItems[2],goodsPos[2])
        end
    }

    events.TimerFinished = function(e)
        if(e.TimerName == "DEN_AttackOnDen_WithSonADTimer") then 
            canAD = true
        end
    end
end}

