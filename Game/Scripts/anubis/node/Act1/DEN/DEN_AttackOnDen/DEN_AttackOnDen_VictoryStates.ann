end}

game.states.DEN_AttackOnDen_VictoryTrainer = State { function ()

    description = [[Trainer acts as leader if Zevlor is dead, patrols gate otherwise.]]

    local tieflingLeader = Entity("S_DEN_TieflingLeader_475200ee-cc3c-4dbe-84b1-1820c02ea26a")
    
    -----------------------------------------
    -- state section

    nodes.Default = Proxy{
        game.states.DEN_GeneralGroveStates_Patrol,
        params = {
            lookFromNode = true,
            spline = [[S_DEN_TrainerVictorySpline_14ba7787-8381-4a6b-b27e-208c55c614a0]],
            waitAtNode = true,
            waitMax = 7,
            waitMin = 5,
        },
        Valid = function()
            return not tieflingLeader.Character.IsDead
        end
    }

    nodes.Leader = Proxy{
        game.states.DEN_TieflingLeader_BackupLeader,
        Valid = function()
            return tieflingLeader.Character.IsDead
        end
    }
end}

game.states.DEN_TieflingLeader_BackupLeader = State { function ()

    description = [[Cerys/Asharak Victory state (after Goblin Hunt or Attack on Den)]]

    local victoryPoint = Entity([[S_DEN_LeaderVictoryPos_04e4c483-3125-40bc-9bfe-e9bfa589b6d7]])
    local victoryWaitPoint = Entity([[S_DEN_VictoryLeaderWaitPos_5e1be949-9a96-471c-b218-87f9fd67c064]])
    local victoryLookAt = Entity([[S_DEN_DenIntroPoint_8ad7a3e5-9f17-4ec3-8693-03be2ca571a2]])
    local goblinHuntVictoryFlag = Flag("DEN_Refugees_State_LeadersAreDead_1e6a42ed-8313-4f46-57e2-20dbdb2df923")
    local metPlayerFlag = Flag("DEN_GoblinHunt_Event_LeaderMetPlayer_097d69b7-7e59-49ba-830a-b2b7f950aec7")

    nodes.WaitingForPlayer = Action {
        function()
            if not IsInDangerousSurfaceFor(victoryWaitPoint, me.Character)
                and (GetDistanceTo(me, victoryWaitPoint) > 2.0) then
                    try
                        MoveTo(victoryWaitPoint, MovementSpeed.Stroll, false, false, 0.5, 1.5)
                        LookFrom(victoryWaitPoint)
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        SteerTo(victoryWaitPoint)
                        Sleep(6.0)
                        return
                    end
            else
                LookFrom(victoryWaitPoint)
            end
            Sleep(6.0)
        end,
        Valid = function()
            return GetFlag(goblinHuntVictoryFlag) and not GetFlag(metPlayerFlag)
        end
    }

    nodes.Victory = Action {
        function()
            if not IsInDangerousSurfaceFor(victoryPoint, me.Character)
                and (GetDistanceTo(me, victoryPoint) > 2.0) then
                    try
                        MoveTo(victoryPoint, MovementSpeed.Stroll, false, false, 0.5, 1.5)
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        Sleep(6.0)
                    end
            else
                Sleep(6.0)
            end
            SteerTo(victoryLookAt, false, 5)
            Sleep(3)
        end
    }
end}

game.states.DEN_AttackOnDen_VictoryLover = State { function ()

    description = [[Taking care of lover and packing.]]
    modules = {"shared.moveto", "gustav.Act1.GroveRefugee", "shared.dialog"}

    local lover = Entity("S_GLO_YoungLover_01_dd9178e7-1e3f-43bc-8a38-666dfcac7d0c")

    local standPoint1 = Entity("S_DEN_VictoryLoverPos_857a8104-5090-494f-ba70-bb34b2a5dd4b")
    local standPoint2 = Entity("S_DEN_VictoryLoverPos_000_ab16fb22-b4da-412f-b500-75f00df73185")
    local standPoint3 = Entity("S_DEN_VictoryLoverPos_001_20a70213-24f7-49e3-894f-c5a92d028855")

    local packingAnimation = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")
    local tendingWorldDialog = Dialog("BHVR_WRLD_DEN_AttackOnDen_TendingToSittingCharacter_928ee024-7794-e755-39c3-cc65700039b4")
    local tendingWorldBehaviourTrigger = Entity("BHVR_WRLD_DEN_AttackOnDen_TendingToSittingCharacter_SceneTrigger_2431c338-ba6f-42fa-a403-6fa61f155cab")

    local crateItems = {
        Entity("S_DEN_LeaveApparel002_d61f3212-199b-423b-9b22-f25ad9084f77"),
        Entity("S_DEN_KidLeavingCrate_007_ab3d79cf-f002-41f8-beaa-23639ec35305"),
    }
    local goodsPos = {}

    local canAD = true

    local careDialog = Dialog("DEN_AttackOnDen_AD_LoversWithoutGuard_3b9e61b5-64c4-8bba-98b6-763202153c76")

    helpers.ResetADDelay = function(ADDelay)
        StopTimer(me, "DEN_AttackOnDen_LoversTimer")
        StartTimer(me, "DEN_AttackOnDen_LoversTimer", ADDelay, 0)
        canAD = false
    end
    -----------------------------------------
    -- State nodes

    self.OnInit = function()
        mod.GroveRefugee.SetGoodsPos(crateItems, goodsPos)  
    end
    
    -----------------------------------------
    -- state section

    nodes.Default = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.Default.CareForLover = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint1,MovementSpeed.Stroll,me) then
                LookFrom(standPoint1)
                if(canAD and mod.dialog.IsSpeakerAvailable(lover)) then
                    helpers.ADDelay(120)
                    StartAutomatedDialog(careDialog, true, me, lover)
                end
                StartBehaviorDialog(tendingWorldDialog, tendingWorldBehaviourTrigger.Trigger, true, me, lover)
            end            
        end,
        Valid = function()
            return not lover.Character.IsDead
        end
    }

    nodes.Default.InspectCrate1 = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint2,MovementSpeed.Stroll,me) then
                LookFrom(standPoint2)
                PlayAnimation(packingAnimation, true, false)
                Sleep(math.random(1,4))
            end
        end,
        Valid = function()
            return mod.GroveRefugee.CheckItemLocation(crateItems[1],goodsPos[1])
        end
    }

    nodes.Default.InspectCrate2 = Action {
        function()
            Sleep(math.random(2,4))
            if mod.moveto.MoveToPoint(standPoint3,MovementSpeed.Stroll,me) then
                LookFrom(standPoint3)
                PlayAnimation(packingAnimation, true, false)
                Sleep(math.random(1,4))
            end
        end,
        Valid = function()
            return mod.GroveRefugee.CheckItemLocation(crateItems[2],goodsPos[2])
        end
    }

    nodes.Default.Rest = Action {
        function()
            Sleep(1)
        end
    }

    events.TimerFinished = function(e)
        if(e.TimerName == "DEN_AttackOnDen_LoversTimer") then 
            canAD = true
        end
    end
end}