game.states.DEN_DevilishOx = State {function ()
    description = [[Behaviour of the mules in the den]]

    modules = {"shared.moveto"}

    ------------------------------------------------
    -- Params
    ------------------------------------------------
    params.moveTarget = {type = EParamType.String, required=false, default = nil, help=[[]]}

    ------------------------------------------------
    -- Local State variables
    ------------------------------------------------
    local moveTarget = Entity(params.moveTarget)
    local idleAnim = Animation("CUST_Strange_01_7819852c-d8b9-4ec5-8e44-330814c933fc")

    ------------------------------------------------ 
    -- Actions
    ------------------------------------------------

    nodes.InStable = Action
    {
        function()
            PlayAnimation(idleAnim, false, true)
        end,

        OnInterrupt = function()
            StopAnimation(me)
        end,

        OnLeave = function()
            StopAnimation(me)
        end
    }

    nodes.Idle = Action {
        function()
            if mod.moveto.MoveToPoint(moveTarget,MovementSpeed.Stroll,me) then
                LookFrom(moveTarget)
                WaitForInterrupt()
            end
        end
    }
end}