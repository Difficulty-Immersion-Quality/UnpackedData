game.states.DEN_GeneralGroveStates_MoveToAndTalk = State {function ()

    modules = {"shared.moveto"}

    params.moveTarget = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.lookTarget = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.lookFrom = {type = EParamType.Bool, required = false, default = false, 
    help=[[]]}

    local moveTarget = Entity(params.moveTarget)
    local lookTarget = Entity(params.lookTarget)
    local lookFrom = params.lookFrom
    local timerCheck = false

    self.OnEnter = function()
        StartTimer(me,"DEN_General_MoveToDialogPartnerTimer",10.0,0)
        timerCheck = true
    end

    nodes.MoveToAndTalk = Action {
        function()
            if mod.moveto.MoveToPoint(moveTarget,MovementSpeed.Stroll,me) then
                if lookTarget then
                    SteerTo(lookTarget)
                elseif lookFrom then
                    LookFrom(moveTarget)
                end
                if timerCheck then
                    StopTimer(me,"DEN_General_MoveToDialogPartnerTimer")
                    timerCheck = false
                end
                SetUnicastEntityEvent(me,"DEN_MovedToTalk")
                Sleep(math.random(1.0))
            end
        end
    }

    events.TimerFinished = function(e)
        if(e.TimerName == "DEN_General_MoveToDialogPartnerTimer") then 
            timerCheck = false
            SetUnicastEntityEvent(me,"DEN_MovedToTalk")
            Interrupt()
        end
    end

end}

game.states.DEN_GeneralGroveStates_stopAndTalk = State {function ()

    params.lookTarget = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}

    local lookTarget = Entity(params.lookTarget)

    nodes.stopAndTalk = Action {
        OnEnter = function()
            StopAnimation(me)
        end,
        function()
            SteerTo(lookTarget)
            WaitForInterrupt()
    end
    }
end}

game.states.DEN_GeneralGroveStates_Wander = State {function ()

    modules = { "gustav.Act1.GroveRefugee","shared.moveto"}

    params.anchor = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.wanderMin = {type = EParamType.Number, required = false, default = 2.0, 
    help=[[]]}
    params.wanderMax = {type = EParamType.Number, required = false, default = 3.0, 
    help=[[]]}

    local anchor = Entity(params.anchor)
    local wanderMin = params.wanderMin
    local wanderMax = params.wanderMax

    nodes.Wandering = Action {
        function()
            if mod.moveto.MoveToPoint(anchor,MovementSpeed.Stroll,me) then
                for i = 1, math.random(wanderMin, wanderMax), 1 do
                    Wander(1.5, 2.0, MovementSpeed.Stroll, anchor)
                    Sleep(math.random(2, 6))
                end
            end
        end
    }
end}

game.states.DEN_GeneralGroveStates_Patrol = State {function ()

    params.spline = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.patrolSpeed = {type = EParamType.String, required = false, default = "Stroll", 
    help=[[]]}
    params.waitAtNode = {type = EParamType.Bool, required = false, default = false, 
    help=[[]]}
    params.waitMin = {type = EParamType.Number, required = false, default = 3.0, 
    help=[[]]}
    params.waitMax = {type = EParamType.Number, required = false, default = 5.0, 
    help=[[]]}
    params.lookFromNode = {type = EParamType.Bool, required = false, default = false, 
    help=[[]]}
    params.animOnNode = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}

    local spline = Spline(params.spline)
    local prevSplineIndex = -1
    local currentSplineIndex = -1
    local targetSplineIndex = -1
    local canWalkOnSpline = true
    local waitAtNode = params.waitAtNode
    local waitMin = params.waitMin
    local waitMax = params.waitMax
    local lookFromNode = params.lookFromNode
    local animOnNode = Animation(params.animOnNode)
    local localWait = false
    local localLookFrom = false
    local customEvent = false

    -----------------------------------------
    -- Helper functions

    helpers.CheckSplineEvent = function(e)
        if e.Event == "Wait" then
            localWait = true
        elseif e.Event == "WaitLookFrom" then
            localWait = true
            localLookFrom = true
        elseif e.Event == "DEN_CustomNodeEvent1" then
            customEvent = true
            SetUnicastEntityEvent(me, "DEN_CustomNodeEvent1")
        elseif e.Event == "DEN_CustomNodeEvent2" then
            customEvent = true
            SetUnicastEntityEvent(me, "DEN_CustomNodeEvent2")
        elseif e.Event == "DEN_CustomNodeEvent3" then
            customEvent = true
            SetUnicastEntityEvent(me, "DEN_CustomNodeEvent3")
        end
    end

    -----------------------------------------

    nodes.Patrol = Action {
        function()
            try
                DoPatrol(spline,false,MovementSpeed[params.patrolSpeed])
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end
    }

    nodes.AtPoint = Action {
        function()
            if lookFromNode or localLookFrom then
                localLookFrom = false
                LookFrom(spline)
            end
            if animOnNode and (localWait or waitAtNode) and not customEvent then
                PlayAnimation(animOnNode, true, false)
            end
            if waitAtNode or localWait then
                localWait = false
                Sleep(math.random(waitMin,waitMax))
            end
            customEvent = false
            canWalkOnSpline = true
        end
    }

    events.SplineControlPointReached = function(e)
        helpers.CheckSplineEvent(e)
        canWalkOnSpline = false
        if e.EndReached then
            SetUnicastEntityEvent(me, "DEN_GroveRefugeeStopPatrol")
            ClearPatrol()
        end
    end
end}

