game.states.DEN_GeneralGroveStates_AnimateAtPointAndTalk = State {function ()

    modules = {"shared.moveto", "shared.dialog"}

    params.moveTarget = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.lookTarget = {type = EParamType.String, required = false, default = nil,  
    help=[[]]}
    params.lookFromMoveTarget = {type = EParamType.Bool, required = false, default = false,  
    help=[[]]}
    params.anim = { type = EParamType.String, required = false, default = nil,
    help=[[]]}
    params.repeatMin = {type = EParamType.Number, required = false, default = 1.0, 
    help=[[]]}
    params.repeatMax = {type = EParamType.Number, required = false, default = 1.0, 
    help=[[]]}
    params.waitMin = {type = EParamType.Number, required = false, default = 2.0, 
    help=[[]]}
    params.waitMax = {type = EParamType.Number, required = false, default = 4.0, 
    help=[[]]}
    params.moveWaitMin = {type = EParamType.Number, required = false, default = 1.0, 
    help=[[]]}
    params.moveWaitMax = {type = EParamType.Number, required = false, default = 1.0, 
    help=[[]]}
    params.loopingAnim = {type = EParamType.Bool, required = false, default = false,  
    help=[[]]}
    params.AD = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.ADPartners = {type=EParamType.String, arrayRange="..", required=false, default={}, 
    help=[[]]}
    params.ADMaxDistance = {type = EParamType.Number, required = false, default = 10.0, 
    help=[[]]}
    params.ADCheckSight = {type = EParamType.Bool, required = false, default = true, 
    help=[[]]}
    params.ADIgnoreCower = {type = EParamType.Bool, required = false, default = false, 
    help=[[]]}
    params.ADWaitForCompletion = {type = EParamType.Bool, required = false, default = false, 
    help=[[]]}
    params.ADFallbackSoloDialog = {type = EParamType.String, required = false, default = nil, 
    help=[[]]}
    params.ADMinDelay = {type = EParamType.Number, required = false, default = 40.0, 
    help=[[]]}
    params.ADCullingDistance = {type = EParamType.Number, required = false, default = 5.0, 
    help=[[]]}

    local AD = Dialog(params.AD)
    local fallbackSoloAD = Dialog(params.ADFallbackSoloDialog)
    local ADPartners = {}
    local ADTimerName = params.AD
    local canAD = true
    local notAnimating = true
    local moveTarget = Entity(params.moveTarget)
    local lookTarget = Entity(params.lookTarget)
    local lookFromMoveTarget = params.lookFromMoveTarget
    local anim = Animation(params.anim)
    local repeatMin = params.repeatMin
    local repeatMax = params.repeatMax
    local waitMin = params.waitMin
    local waitMax = params.waitMax
    local moveWaitMin = params.moveWaitMin
    local moveWaitMax = params.moveWaitMax
    local loopingAnim = params.loopingAnim


    self.OnInit = function()
        if #params.ADPartners > 0 then
            for _, speaker in pairs(params.ADPartners) do
                table.insert(ADPartners, Entity(speaker))
            end
        end
    end

    nodes = ImmediateSelector{}

    nodes.AD = Action {
        function()
            mod.dialog.StartCheckedAutomatedDialog(
                AD,
                {
                    maxDistance = params.ADMaxDistance,
                    checkSight = params.ADCheckSight,
                    ignoreCower = params.ADIgnoreCower,
                    waitForCompletion = params.ADWaitForCompletion,
                    fallbackSoloDialog = fallbackSoloAD,
                    cullingDistance = params.ADCullingDistance
                },
                me,
                table.unpack(ADPartners)
            )
            canAD = false
        end,
        OnLeave = function()
            canAD = false
            StopTimer(me,"ADTimer_" .. ADTimerName)
            StartTimer(me,"ADTimer_" .. ADTimerName, params.ADMinDelay + math.random(0,10),0)
        end,
        Valid = function()
            return canAD and notAnimating
        end
    }

    nodes.Working = Action {
        function()
        if not loopingAnim then
            Sleep(math.random(moveWaitMin,moveWaitMax))
            for i = math.random(repeatMin, repeatMax), 1, -1 do
                if mod.moveto.MoveToPoint(moveTarget,MovementSpeed.Stroll,me) then
                    notAnimating = false --prevent dialogue interrupting animation
                    if lookFromMoveTarget then
                        LookFrom(moveTarget)
                    elseif lookTarget then
                        SteerTo(lookTarget)
                    end
                    if anim then
                        PlayAnimation(anim)
                    end
                    Sleep(math.random(waitMin,waitMax))
                    if i == 1 then
                        notAnimating = true --ensure the character is in position before they can talk
                    end
                end
            end
        else
            if mod.moveto.MoveToPoint(moveTarget,MovementSpeed.Stroll,me) then
                notAnimating = true --ensure the character is in position before they can talk
                if lookFromMoveTarget then
                    LookFrom(moveTarget)
                elseif lookTarget then
                    SteerTo(lookTarget)
                end
                PlayAnimation(anim,false,true)
                DebugText(me, "Failed to play animation")
                WaitForInterrupt()
            end
        end
    end
    } 

    events.TimerFinished = function(e)
        if(e.TimerName == "ADTimer_" .. ADTimerName) then 
            canAD = true
        end
    end
end}

