game.states.DEN_General_Mule = State {function ()
    description = [[Behaviour of the mules in the den]]

    modules = {"shared.moveto"}

    -----------------------------------------
    --Params

    params.moveTarget = {type = EParamType.String, required=false, default = nil, help=[[]]}

    -----------------------------------------
    -- Local variables

    local moveTarget = Entity(params.moveTarget)

    nodes.Idle = Action {
        function()
            if mod.moveto.MoveToPoint(moveTarget,MovementSpeed.Stroll,me) then
                LookFrom(moveTarget)
                WaitForInterrupt()
            end
        end
    }

    
end}