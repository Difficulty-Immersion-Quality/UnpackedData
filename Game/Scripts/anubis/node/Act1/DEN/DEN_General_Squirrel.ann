game.states.DEN_General_Squirrel = State {function ()
    description = [[Behaviour of the squirrel in the den]]
    local anchorPoint = Entity("S_DEN_SquirrelPoint_f251a388-57c5-4fa7-b086-5c0c23114e5a")

    nodes.Wander = Action {
        function()
            try
                Wander(math.random() + math.random(5,9),math.random() + math.random(3,4),MovementSpeed.Walk,anchorPoint)
            catch e if ls.CheckType(e, error.MovementFailed) then
            end
            Sleep(math.random() + 2.0)
        end
    }
end}