game.states.DEN_GoblinScouts = State{ function ()

    modules = { "shared.dialog"}

    description = [[Behaviour of the interrogating goblin scout.]]

    local AD = Dialog([[DEN_GoblinScouts_AD_e9772457-2e92-f57e-efd3-7088cd7c3109]])
    local goblinSpeaker1 =  Entity([[S_DEN_GoblinScout_002_48c2871e-19e4-41da-8846-cc785fef64d3]])
    local goblinSpeaker2 = Entity([[S_DEN_GoblinScout_003_1dfab0db-e7b5-48b8-9034-59628ddefa76]])
    local goblinSpeaker3 = Entity([[S_DEN_GoblinScout_004_06a54b04-c141-4929-b21c-5f28737d88f7]])


    nodes.Idle = Action {
        function()
            Sleep(4)
            mod.dialog.StartCheckedAutomatedDialog(
                AD,
                {
                    waitForCompletion = true,
                    checkSight = false,
                    maxDistance = 20.0
                }, 
                me, 
                goblinSpeaker1, 
                goblinSpeaker2, 
                goblinSpeaker3
            )
            Sleep(4)
        end
    }
    
end}
