game.states.DEN_GoblinScouts_Captive = State{function ()
    description = [[Behaviour of the goblin scouts' captive.]]
    params.AD = {type=EParamType.State, required=false, default=nil, help=[[Role in repeating group AD]]}
    local HideoutPos = Entity("S_DEN_Hideout_SUB_8016de65-4be3-4083-960f-4d14a7455d4b")

    nodes = ImmediateSelector {}
    nodes.Stash = Proxy {
        game.states.DEN_GeneralGroveStates_AnimateAtPointAndTalk,
        params = {
            moveTarget = "S_DEN_Hideout_StashArea_11d74325-2323-4f77-8be8-24a9054a3573",
            lookTarget = "S_DEN_HideoutKidStash_6a957f96-e910-4a3b-ad12-03359775c4b8",
            anim = "CUST_SurveyingMess_01_Loop_1e13a321-d151-4fd8-bb94-38b69d36215a",
            loopingAnim = true,
            waitMin = 12,
            waitMax = 17,
            AD = "DEN_GoblinScouts_AD_Captive_1c9ac2cf-3d33-193e-2040-9b2c21d32fd7",
            ADMinDelay = 15
        },
        Valid = function()
            return IsInTrigger(me, HideoutPos.Trigger)
        end
    }
    nodes.Idle = Action {
        function()
            WaitForInterrupt()
        end
    }
end}
