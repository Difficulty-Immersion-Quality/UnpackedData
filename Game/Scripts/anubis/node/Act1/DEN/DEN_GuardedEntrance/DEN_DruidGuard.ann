game.states.DEN_DruidGuard = State { function ()

    description = [[Three guards blocking the entrance of the Sacred Pond area]]

    modules = { "shared.moveto" }

    params.guardPoint = { type= EParamType.String, required = true, help = [[Will stand at this point trigger.]] }

    local point = Entity(params.guardPoint)
    local combatLoopAnim = Animation([[CUST_Idle_Still_Combat_01_590ea7e8-ae43-4307-916b-b1133ef47dfa]])

    self.OnEnter = function()
        SetWeaponUnsheathed(me, true)
    end

    nodes.Guard = Action {
        function()
            if not IsInDangerousSurfaceFor(point, me.Character) then
                if mod.moveto.MoveToPoint(point, MovementSpeed.Walk, me) then
                    LookFrom(point)
                    PlayAnimation(combatLoopAnim, false, true)
                    WaitForInterrupt()
                end
            end
            SteerTo(point)
            Sleep(2.0)
        end,
        OnLeave = function()
            StopAnimation(me)
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end
    }

end}
