game.states.DEN_HarpyMeal_HarpyLeader = State { function ()
    
    description = [[Harpies on the beach in the Druid Grove]]

    modules = {"shared.moveto"}

    local charmedKid = Entity("S_DEN_CharmedKid_3b92c689-6024-4446-a6c9-584e9e8d77ca")
    local killedFlag = Flag("DEN_HarpyMeal_State_VictimDead_50cfd9b3-bf92-e441-e166-1466dcf1e185")
    local eatAnim = Animation("CUST_EatingCorpse_01_ea42da9e-15b5-4404-8fe2-9c0080b019c9")

    nodes.Idle = Action {
        function()
            WaitForInterrupt()
        end,
    Valid = function()
        return not GetFlag(killedFlag)
    end
    }

    nodes.EatCharmedKid = Action {
        function()
            if charmedKid ~= nil then
                if not me.IsInCombat and charmedKid.Character.IsDead and charmedKid.OnStage and CanSee(me,charmedKid) and (GetDistance2DTo(me, charmedKid) <= 1) then
                    if mod.moveto.MoveToPoint(charmedKid,MovementSpeed.Walk,me) then
                        Sleep(1.0)
                        try
                            PlayAnimation(eatAnim,true,false)
                        catch e if ls.CheckType(e, error.PlayAnimationFailed) then
                            DebugText(me, "Animation Failed")
                        end
                        Sleep(5.0)
                    end
                else
                    Sleep(6.0)
                end  
            else
                Sleep(6.0)
            end   
        end
    }



end}