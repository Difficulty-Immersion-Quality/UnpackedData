game.states.DEN_ProdigySibling = State {function ()
    description = [[Behaviour of the Prodigy's friends in the druids' grove]]
    params.argumentPoint = { type = EParamType.String, required = true, help = [[Seat before reaching a decision]]}
    params.stayPos = { type = EParamType.String, required = true, help = [[Position after deciding to stay]]}    
    local StayFlag = Flag("DEN_Prodigy_State_Staying_479db0b1-cc1b-78bf-3e7b-9840747fbd4f")

    nodes.Idle = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.argumentPoint
        },
        Valid = function()
            return not GetFlag(StayFlag,nil)
        end
    }

    nodes.Staying = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.stayPos
        }
    }
end}