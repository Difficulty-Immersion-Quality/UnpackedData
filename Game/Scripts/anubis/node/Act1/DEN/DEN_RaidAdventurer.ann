game.states.DEN_RaidAdventurer = State {function ()
        
    modules = { "shared.moveto"}
    --
    description = [[Behaviour of Remire in the Den. Participates in the raid, then goes clean up a wound in the cave, followed by some drinking.]]

    local ADDelay = 45

    --Flags
    local denFlag = Flag("DEN_AdventurersQuest_State_AtDen_a76436f9-d1c5-11ea-1340-fc7f5c02f87f")
    local followFlag = Flag("DEN_RaidingParty_Event_AdventurersToConfrontation_0b553dd3-afc8-4ab7-9046-8dd452bfc455")
    local confrontEndFlag = Flag("DEN_RaidingParty_Quest_ConfrontationResolved_dc97da68-5ed9-ffe2-7582-2533be0efbcd")
    local raidOverFlag = Flag("DEN_RaidingParty_Quest_GoblinRaidOver_98712d90-c46b-20c4-c4df-02c0117e85a5")
    local peaceFlag = Flag("DEN_RaidingParty_State_PeacefulResolution_f4529d52-b459-6545-b4bf-8b2fb2cd6f2f")
    local woundFlag = Flag("DEN_AdventurersQuest_State_CleanedWound_a2d0bd49-4d4e-5e71-edca-9fdca94befe4")
    local openGateFlag = Flag("DEN_RaidingParty_Event_GateIsOpened_735e0e81-bd67-eb67-87ac-40da4c3e6c49")
    local torturedAtDenFlag = Flag("GOB_TorturedAdventurer_State_Resting_75e6b157-74c3-4bb1-bba7-c8046cd1486d")

    --Bools
    local atDen = true
    local goDrink = false
    local canAD = true
    local isDrinking = false
    local returnedToCave = false

    --Characters
    local tieflingLeader = Entity("S_DEN_TieflingLeader_475200ee-cc3c-4dbe-84b1-1820c02ea26a")
    local adventurerLeader = Entity("S_DEN_AdventurerLeader_82d1b843-9e8c-48a5-9d87-caddea5c193c")
    local deadGoblin = Entity("S_DEN_DeadGoblinRaider_002_f23fc89a-e17a-4815-910c-91d39f68b6ab")
    local deadGoblin2 = Entity("S_DEN_DeadGoblinRaider_001_1f2818a7-ead4-4a9a-bc56-3e635d567324")

    --Triggers
    local cleanPoint = Entity("S_DEN_WoundCleanArea_e7af6d68-ebbb-4e4b-b565-84b210972317")
    local denPoint = Entity("S_DEN_AdventurerArea_002_963c5af9-111d-4325-a17b-b555449d3f38")
    local confrontPoint = Entity("S_DEN_ConfrontationPos_002_e7ec76ee-f3de-4c68-8d80-51f4d33c201c")
    local roadPoint = Entity("S_DEN_DeadPoint_002_d439f0fc-d2c1-4ac2-b5e0-69eda1d9e4d3")
    local roadPoint2 = Entity("S_DEN_DeadPoint_004_0afcf8d8-c81d-45a3-950a-f8f8c5265390")

    --Animations
    local cleanWoundAnim = Animation("CUST_InspectingWound_01_330bc6d6-151b-40a9-8724-3ec37d1115f7")
    local lookingDownAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0") 
    local angryAnimLoop = Animation("CUST_LookingAround_63bcacef-5631-4ab3-9400-81b23cb18ca7")
    local combatAnim = Animation("CUST_Idle_Still_Combat_01_590ea7e8-ae43-4307-916b-b1133ef47dfa")
    
    --Dialogs
    local gateAD = Dialog("DEN_RaidingParty_AD_Adventurer2AtGate_6431b34c-544b-77fd-5ad8-9f36ba501db6")
    local cleanWoundAD = Dialog("DEN_AdventurersQuest_AD_AdventurerCleaningWound_59aea764-12c8-35f9-4d22-99fa377caf7e")

    helpers.ResetADDelay = function()
        StopTimer(me, "DEN_AdventurersQuest_RaidADTimer")
        StartTimer(me, "DEN_AdventurersQuest_RaidADTimer", ADDelay, 0)
        canAD = false
    end

    -----------------------------------------
    -- Nodes

    nodes.OnRoad = Selector {
        CanEnter = function()
            return not atDen
        end,
        OnEnter = function()
            mod.moveto.CancelMoveTo()
        end,
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.OnRoad.AtCorpses = Action {
        function()
            if mod.moveto.MoveToPoint(roadPoint,MovementSpeed.Stroll,me) then
                LookFrom(roadPoint)
                PlayAnimation(lookingDownAnim, true, false)
            end
            Sleep(5)
        end,
    }

    nodes.OnRoad.AtCorpses2 = Action {
        function()
            if mod.moveto.MoveToPoint(roadPoint2,MovementSpeed.Stroll,me) then
                LookFrom(roadPoint2)
                PlayAnimation(lookingDownAnim, true, false)
            end
            Sleep(5)
        end
    }


    nodes.DEN = Selector {
        CanEnter = function()
            return atDen
        end
    }

    nodes.DEN.AtCave = Selector{
        CanEnter = function()
            return returnedToCave
        end
    }

    nodes.DEN.AtCave.TendToWound = Selector {
        CanEnter = function()
            return GetFlag(confrontEndFlag) and GetFlag(peaceFlag) and not isDrinking
        end
    }

    nodes.DEN.AtCave.TendToWound.Cleaning = Action {
        function()
            if GetDistance2DTo(me, cleanPoint) > 1.5 then
                try
                    MoveTo(cleanPoint)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    Sleep(6.0)
                end
            else
                LookFrom(cleanPoint)
                PlayAnimation(cleanWoundAnim, true, false)
                Sleep(3)
            end
        end,
        Valid = function()
            return not GetFlag(woundFlag, me) and not canAD
        end
    }

    nodes.DEN.AtCave.TendToWound.ComplainWithAD = Action {
        CanEnter = function()
            return canAD
        end,
        function()
            StartAutomatedDialog(cleanWoundAD, true, me)    
            helpers.ResetADDelay()
        end,
    }

    nodes.DEN.AtCave.TendToWound.GoDrink = Action {
        function()
            if not IsInDangerousSurfaceFor(denPoint, me.Character) then
                Sleep(2)
                if not goDrink then
                    StartAutomatedDialog(cleanWoundAD, true, me)
                    goDrink = true  
                end
                try
                    MoveTo(denPoint)
                    isDrinking = true
                catch e if ls.CheckType(e, error.MovementFailed) then
                    Sleep(6.0)
                end
            else
                SteerTo(denPoint)
                Sleep(4)
            end
        end,
        Valid = function()
            return GetFlag(woundFlag, me)
        end
    }

    nodes.DEN.AtCave.Idle = Proxy {
        game.states.Sit,
        params = {
            seat = "S_DEN_DrinkingStool_001_2cee12e7-d68b-44ce-a658-848e16875fcf",
            seatTrigger = "S_DEN_AdventurerArea_002_963c5af9-111d-4325-a17b-b555449d3f38",
            sitIdle = StateRef{game.states.DEN_RaidAdventurer_DENidle},
            nonSitIdle = StateRef{game.states.DEN_RaidAdventurer_DENidle}
        },
    }

    nodes.DEN.AtGate = Selector {
        CanEnter = function()
            return not returnedToCave
        end
    }

    nodes.DEN.AtGate.ReturnToCave = Action {
        function()
            if(GetFlag(openGateFlag)) then
                mod.moveto.MoveTo(cleanPoint,true,1.5,"Walk","DEN_AtDen_ReturnComplete")
            end
        end,
        CanEnter = function()
            return GetFlag(confrontEndFlag) and GetFlag(peaceFlag)
        end
    }

    nodes.DEN.AtGate.BeforeRaid = Action {
        OnEnter = function()
            SetWeaponUnsheathed(me, true)
        end,
        function()
            Sleep(2)
            PlayAnimation(combatAnim, false, true)
            Sleep(10.0)
            if(not IsInDialog(me,true)) then StartAutomatedDialog(gateAD,false,me) end
            Sleep(11.0)
        end,
        OnLeave = function()
            SetWeaponUnsheathed(me, false, false)
        end,
        Valid = function()
            return (not GetFlag(raidOverFlag))
        end
    }

    nodes.DEN.AtGate.AfterRaid = Action {
        function()
            Sleep(1)
        end,
        CanEnter = function()
            return (GetFlag(raidOverFlag) and not GetFlag(followFlag) and not GetFlag(confrontEndFlag))
        end
    }

    nodes.DEN.AtGate.Confront = Action {
        function()
            if mod.moveto.MoveToPoint(confrontPoint,MovementSpeed.Run,me) then
                SteerTo(tieflingLeader)
            end
            WaitForInterrupt()
        end,
        Valid = function()
            return (GetFlag(followFlag) and not GetFlag(confrontEndFlag))
        end
    }    

    nodes.DEN.AtGate.Leaving = Action {
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return GetFlag(confrontEndFlag) and not GetFlag(peaceFlag)
        end
    }

    -----------------------------------------
    -- Events

    events.EntityEvent = function(e)
        if (e.TargetEntity == me) then
            if(e.Event == "DEN_AtDen_ReturnComplete") then
                returnedToCave = true
                SetFlag(denFlag,me)
            elseif(e.Event == "DEN_NPC_LeftDen") then
                atDen = false
            end
        end
    end
    
    events.FlagSet = function(e)
        if(e.Flag == raidOverFlag.Guid) then
            if(adventurerLeader == nil) then
                adventurerLeader = FindEntity("S_DEN_AdventurerLeader_82d1b843-9e8c-48a5-9d87-caddea5c193c")
            end
            mod.moveto.MoveTo(adventurerLeader,true,3,"Run","DEN_BeforeConfrontation_MoveComplete")
        elseif(e.Flag == followFlag.Guid) then
            if(not adventurerLeader.Character.IsDead and not tieflingLeader.Character.IsDead) then
                mod.moveto.MoveTo(confrontPoint,true,1.5,"Run","DEN_GoToConfrontation_MoveComplete")
            end
        elseif(e.Flag == torturedAtDenFlag.Guid) then
            SetFlag(woundFlag, me)
        end
    end

    events.DialogEnded = function(e)
        if(e.Instance.DialogUUID == Guid("DEN_AdventurersQuest_RaidAdventurer_33617ce2-882e-8c82-83da-3c6b0e0b06ef")) then
            SetFlag(woundFlag, me)
        end
    end

    events.TimerFinished = function(e)
        if e.TimerName == "DEN_AdventurersQuest_RaidADTimer" then
            canAD = true
        end
    end

end}

game.states.DEN_RaidAdventurer_DENidle = State {function()

    description = [[Behaviour of Remire while sitting in the adventurer's corner of the cave area in Den.]]

    modules = {"shared.dialog"}

    local ADDelay = 70

    --Bools
    local canAD = false

    --Characters
    local adventurerLeader

    --Triggers
    local denArea

    --Animations
    local drinkingAnim = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")

    --Dialogs 
    local drinkingDualAD = Dialog("DEN_AdventurersQuest_AD_AradinAndRemira_5a37f1a2-6678-ebcf-7692-7874a3d1d67f")

    helpers.ResetADDelay = function()
        StopTimer(me, "DEN_AdventurersQuest_RaidADTimer")
        StartTimer(me, "DEN_AdventurersQuest_RaidADTimer", ADDelay, 0)
        canAD = false
    end

    self.OnInit = function()
        denArea = FindEntity("S_DEN_AdventurerArea_002_963c5af9-111d-4325-a17b-b555449d3f38")
        adventurerLeader = FindEntity("S_DEN_AdventurerLeader_82d1b843-9e8c-48a5-9d87-caddea5c193c")
    end

    self.OnEnter = function()
        StopTimer(me, "DEN_AdventurersQuest_RaidADTimer")
        StartTimer(me, "DEN_AdventurersQuest_RaidADTimer", 20, 0)
    end

    -----------------------------------------
    -- Nodes

    nodes.Idle = Action {
        function()
            try
                if(not IsInTrigger(me,denArea.Trigger) and not IsInDangerousSurfaceFor(denArea,me.Character,3.0)) then MoveTo(denArea) end
            catch e if ls.CheckType(e, error.MovementFailed) then
                DebugText(me,"Move Exception")
            end
            PlayAnimation(drinkingAnim, false, false)
            Sleep(20.0)
        end,
        Valid = function()
            return not canAD
        end
    }
    nodes.ADwithLeader = Action {
        function()
            if(mod.dialog.IsSpeakerAvailableAndNear(adventurerLeader, me, 15.0, true)) then
                StartAutomatedDialog(drinkingDualAD, true, adventurerLeader, me)
            end
            helpers.ResetADDelay()
        end,
        CanEnter = function()
            return canAD
        end
    }

    -----------------------------------------
    -- Events

    events.TimerFinished = function(e)
        if e.TimerName == "DEN_AdventurersQuest_RaidADTimer" then
            canAD = true
        end
    end
end}
