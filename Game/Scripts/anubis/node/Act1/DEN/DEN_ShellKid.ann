game.states.DEN_ShellKid = State { function () --DEPRECATED - KID REMOVED FOR EA --TODO REMOVE

    description = [[A tiefling refugee kid who likes to collect seashells]]


    -----------------------------------------
    -- Local variables

    local patrol = true

    -----------------------------------------
    -- Nodes

    nodes.Default = Selector {
        function(nodes)
            if patrol then
                return nodes.Patrol
            else
                return FindDifferentRandomSelectable(nodes)
            end
        end
    }

    nodes.Default.Patrol = Proxy {
        OnEnter = function()
            if not patrol then
                patrol = true
            end
        end,
        game.states.DEN_GeneralGroveStates_Patrol,
        params={
            spline = "S_DEN_ShellKid_Patrol_3a2da512-8915-46fc-80c7-4b0cfd3c2177",
            animOnWait = "CUST_Sniffing_Air_01_92e7ac17-b123-4a26-8e4f-2f8df2502fc2",
            waitAtNode = true,
            waitMin = 1.0,
            waitMax = 3.0
        }
    }

    nodes.Default.LookOut = Proxy {
        game.states.DEN_GeneralGroveStates_AnimateAtPoint,
        params={
            moveTarget = "S_DEN_ShellKid_LookoutPoint_99ecb913-7323-407d-a808-f72b25d46653",
            lookFromMoveTarget = true,
            anim = "CUST_Inspect_01_2c30ba8e-eca1-44b8-8f2a-4addbc34db17",
            waitMin = 1.0,
            waitMax = 1.0
        }
    }

    -----------------------------------------
    -- Events

    events.EntityEvent=function(e)
        if e.TargetEntity == me then
            if e.Event == "DEN_GroveRefugeeStopPatrol" then
                patrol = false
            end
        end
    end

end}