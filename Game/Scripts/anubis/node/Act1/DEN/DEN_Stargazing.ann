game.states.DEN_Stargazing = State {function ()
    description = [[Behaviour of the stargazing tiefling]]
    local LookAnim = Dialog("BHVR_WRLD_DEN_TelescopeStargazing_3dd299d8-4312-0a35-ac7d-221052a552e4")
    local Telescope = Entity("S_DEN_Telescope_2d0c2dd9-22fa-4d7c-a177-3b88564eae83")
    local TelescopeSceneTrigger = Entity("BHVR_WRLD_DEN_TelescopeStargazing_SceneTrigger_3293d65b-d760-437b-8ebc-3ebf9676ff64")
    local BugbearFlag = Flag("DEN_BugbearNinja_Dead_cc673032-ad3b-484e-b2cb-57f67c901b3d")

    events.FlagSet = function(e)
        if (e.Flag == BugbearFlag.Guid) then RemoveStatus(me,"FRIGHTENED") end
    end

    nodes.Sit = Proxy {
        game.states.Sit,
        params = {seat = "S_DEN_StargazerChair_a4f8961e-3924-4ead-80da-4c202d8a1bdf"},
        CanEnter = function()
            return GetFlag(BugbearFlag,nil) 
        end    
    }
    nodes.Telescope = Action {
        function()
            Sleep(1.0)
            if TelescopeSceneTrigger ~= nil and LookAnim ~= nil and Telescope ~= nil then
                --StartBehaviorDialog(LookAnim,TelescopeSceneTrigger.Trigger,false,me,Telescope)
                Sleep(20.0)
            end
            Sleep(math.random(3,7))
        end,
    }
end}
