game.states.DEN_TieflingRefugee_PickpocketTrader = State {function ()
    description = [[Tiefling Kid merchant in the Druid Grove. Is both a con themselves and a distraction for their pickpocket partner.]]

    modules = {"shared.dialog","shared.moveto"}

    -----------------------------------------
    -- Local variables
    local playerDetected = nil
    local States = {None = 0, Look = 1, Follow = 2}
    local currState = 0

    --Entities
    local atStallPos = Entity("S_DEN_PickpocketTrader_AtStall_6de7a842-b806-4c9f-b425-064d74e2ecf6")
    local hideoutPos = Entity("S_DEN_PickpocketMerchant_HideoutArea_bb70caa1-98ee-4c51-ab16-da81dee1a451")
    local abandonPos = Entity("S_DEN_PickpocketTrader_AtStall_6de7a842-b806-4c9f-b425-064d74e2ecf6")
    local pickpocket = Entity("S_DEN_Pickpocket_540ddc1f-42c6-4347-ba03-b3cf3d3942ab")
    local customer

    --Bools
    local saidLeaveLine = false
    local canAD = false
    local canTryAD = false
    local blockedAD = false
    local doneStealing = false
    local customerNear = false
    local waved = false

    --Dialogs
    local leaveLine = Dialog("DEN_Thieflings_AD_MerchantLeaves_c4a17297-34ad-1af4-3b70-e1bdae4dd5ae")
    local magicTrickAD = Dialog("DEN_Thieflings_AD_MagicTrick_0102c0ab-80c3-0bfb-9879-acbb12b2239a")
    local magicTrickSoloAD = Dialog("DEN_Thieflings_AD_PickpocketTrader_c2ee582e-4fb5-a37b-56ad-b49a430b6d91")

    --Animations
    local idleAnim = Animation("CUST_LookingAround_63bcacef-5631-4ab3-9400-81b23cb18ca7")
    local waveAnim = Animation("CUST_Waving_01_c974f0eb-9dee-4699-b3b4-abf2458bb941")

    --Flags
    local knowsRobbedFlag = Flag("DEN_Thieflings_Knows_PlayerRobbed_5069e274-6ede-e00d-aa94-784648a0499e")
    local merchantLeavesFlag = Flag("DEN_Thieflings_Event_MerchantKidLeaves_9783bb1f-bde7-c61a-16aa-89e267dd7180")
    local abandonFlag = Flag("DEN_Thieflings_Event_HideoutAbandoned_f3808740-25b9-4393-a947-7a1f7a88ebda")
    local inHideout = Flag("DEN_Thieflings_State_AtHideoutPoint_5f768dc1-8294-49ee-b2d2-964fcb22f5ff")
    local atAbandon = Flag("DEN_Thieflings_State_AtAbandonPoint_d76525c1-b7e4-46b0-9847-73a1fdad245e")
    local startAbandon = Flag("DEN_Thieflings_Event_Abandoning_883a6c02-9091-4b29-8bc3-99e070e3648b")
    local emptyingStash = Flag("DEN_Thieflings_State_EmptyingStash_2203ac44-6623-40e6-967e-1b95a7c9dfb2")

    -----------------------------------------
    -- Helper functions

    helpers.GetPlayer = function()
        local newdist = 0.0
        local olddist = 1000.0
        local chosenCustomer
        local active = GetActiveCharacters(me,10.0)
        for _,v in pairs(active) do
            if v.Character.IsPlayer and not chosenCustomer then
                chosenCustomer = v
            elseif(v.Character.IsPlayer) then
                newdist = GetDistance2DTo(me, v)
                if newdist <= olddist then
                    olddist = newdist
                    chosenCustomer = v
                end
            end
        end
        return chosenCustomer
    end

    -----------------------------------------
    -- Nodes

    nodes.Default = Selector{
        function(nodes)
            if ((canTryAD and canAD and mod.dialog.IsSpeakerAvailableAndNear(pickpocket, me, 5.0, true) and not customerNear) or not mod.dialog.IsSpeakerAvailable(pickpocket)) and nodes.doMagicAD.IsSelectable() and not GetFlag(merchantLeavesFlag) then
                return nodes.doMagicAD
            elseif canTryAD and nodes.doMagicAD.IsSelectable() and not GetFlag(merchantLeavesFlag) and not customerNear then
                return nodes.stopAndTalk
            else
                return nodes.AtStall
            end
        end,
        Valid = function()
            return not doneStealing
        end
    }

    nodes.Default.stopAndTalk  = Action {
        OnEnter = function()
            SetEntityEvent(pickpocket, "DEN_Pickpocket_MoveToTalk")
        end,
        Valid = function()
            return not canAD and not doneStealing and not customerNear
        end,
        function()
            if mod.moveto.MoveToPoint(atStallPos,MovementSpeed.Walk,me) then
                Sleep(1.0)
            end
        end
    }

    nodes.Default.doMagicAD = Action {
        OnEnter = function()
            canTryAD = false
            canAD = false
        end,
        function()
            mod.dialog.StartCheckedAutomatedDialog(
                magicTrickAD,
                {
                    waitForCompletion = true,
                    fallbackSoloDialog = magicTrickSoloAD
                },
                me,
                pickpocket
            )
            blockedAD = true
        end,
        OnLeave = function()
            blockedAD = true
            StopTimer(me,"ADTimer_DEN_Thieflings_AD_MagicTrick")
            StartTimer(me,"ADTimer_DEN_Thieflings_AD_MagicTrick", 40 + math.random(0,10),0)
        end,
        Valid = function()
            return not blockedAD and not doneStealing and not customerNear
        end
    }

    nodes.Default.AtStall= Action {
        OnEnter = function()
            canAD = false
        end,
        function()
            if (mod.dialog.IsSpeakerAvailable(pickpocket)) and not canAD then
                canTryAD = true
            end
            if mod.moveto.MoveToPoint(atStallPos,MovementSpeed.Walk,me) then
                if customerNear and not GetFlag(abandonFlag) and not GetFlag(knowsRobbedFlag) and not IsInDialog(me,false) then
                    customer = helpers.GetPlayer()
                    if customer and not waved then
                        waved = true
                        SteerTo(customer)
                        Sleep(0.5)
                        PlayAnimation(waveAnim,true,false)
                        Sleep(1.0)
                    end
                end
                LookFrom(atStallPos)
                PlayAnimation(idleAnim, true, false)
            end
        end,
        Valid = function()
            return not doneStealing
        end
    }

    nodes.TalkBeforeLeaving = Action {
        function()
            if mod.moveto.MoveToPoint(pickpocket,MovementSpeed.Walk,me) then
                StartAutomatedDialog(leaveLine,true,me,pickpocket)
            end
        end,
        Valid = function()
            return doneStealing and not saidLeaveLine
        end
    }

    nodes.doHideoutAD = Action {
        function()
            mod.dialog.StartCheckedAutomatedDialog(
                magicTrickAD,
                {
                    waitForCompletion = true,
                    fallbackSoloDialog = magicTrickSoloAD
                },
                me,
                pickpocket
            )
            blockedAD = true
        end,
        OnLeave = function()
            blockedAD = true
            StopTimer(me,"ADTimer_DEN_Thieflings_AD_MagicTrick")
            StartTimer(me,"ADTimer_DEN_Thieflings_AD_MagicTrick", 40 + math.random(0,10),0)
        end,
        Valid = function()
            return not blockedAD and (GetFlag(inHideout,me) and not (GetFlag(startAbandon,me) and not GetFlag(emptyingStash,me) or GetFlag(abandonFlag)))
        end
    }

    nodes.EmptyingStash= Action {
        function()
            Sleep(1)
        end,
        Valid = function()
            return GetFlag(emptyingStash,me)
        end
    }

    nodes.HideoutFollowing = Selector {
        function(nodes)
            return GetFirstCanEnter(nodes)
        end,
        Valid = function(node)
            return CheckAnySelectable(node) and currState ~= 0
        end
    }

    nodes.HideoutFollowing.FollowPlayer = Action{
        function()
            DebugText(me, "In Follow")
            if GetDistance2DTo(me, playerDetected) < 4.0 then
                LookAtEntity(playerDetected)
            else
                try
                    MoveTo(playerDetected, MovementSpeed.Run)
                catch ex if ls.CheckType(e, error.MovementFailed) then
                    DebugText(me, "Failed MoveTo(playerDetected)")
                end
            end
            Sleep(1.0)
        end,
        Valid = function()
            return playerDetected ~= nil and not playerDetected.Character.IsDead and CanSee(me, playerDetected) and GetDistance2DTo(me, playerDetected) < params.FollowDistance and not interruptedFollow and currState == 2
        end
    }

    nodes.HideoutFollowing.LookAtPlayer = Action{
        function()
            DebugText(me, "In Look")
            LookAtEntity(playerDetected)
            Sleep(0.5)
            interruptedFollow = false
        end,
        Valid = function()
            return playerDetected ~= nil and not playerDetected.Character.IsDead and CanSee(me, playerDetected) and currState == 1
        end
    }

    nodes.InHideout= Action {
        function()
            if mod.moveto.MoveToPoint(hideoutPos,MovementSpeed.Walk,me) then
                LookFrom(hideoutPos)
                PlayAnimation(idleAnim,true,false)
            end
        end,
        Valid = function()
            return not (GetFlag(startAbandon,me) or GetFlag(abandonFlag))
        end
    }

    nodes.AbandonedHideout= Action {
        function()
            if mod.moveto.MoveToPoint(abandonPos,MovementSpeed.Walk,me) then
                LookFrom(abandonPos)
                PlayAnimation(idleAnim,true,false)
            end
        end
    }

    -----------------------------------------
    -- event section
    events.EntityEvent = function(e)
        if(e.TargetEntity == me) then
            if(e.Event == "DEN_Thieflings_AbandonedHideout") then
                SetFlag(startAbandon,me)
                mod.moveto.MoveTo(abandonPos,true,1.5,"Run","DEN_Thieflings_ArriveAtAbandon",2.5,true,false)
            elseif(e.Event == "DEN_Thieflings_MerchantKidToHideout") then
                doneStealing = true
            elseif(e.Event == "DEN_MovedToTalk") then
                canAD = true
            elseif (e.Event == "DEN_Thieflings_ArriveAtHideout") then
                SetFlag(inHideout,me)
            elseif(e.Event == "DEN_Thieflings_ArriveAtAbandon") then
                SetFlag(atAbandon,me)
            elseif(e.Event == "DEN_Thieflings_PlayerNearStall") and not customerNear then
                customerNear = true
                waved = false
                if IsInDialog(me,false) then
                    DialogRequestStop(me,magicTrickAD)
                end
                Interrupt()
            elseif(e.Event == "DEN_Thieflings_PlayersLeftStall") then
                customerNear = false
            end
            if e.Event == "DEN_Thieflings_Event_SpottedPlayer" then
                currState = 1
                playerDetected = e.Params[1]
            elseif e.Event == "DEN_thieflings_Event_Follow" then
                currState = 2
                playerDetected = e.Params[1]
            elseif e.Event == "DEN_Thielfings_Event_StopFollow" then
                currState = 0
                playerDetected = nil
            end
        end
    end

    events.DialogEnded = function(e)
        if(e.Instance.DialogUUID == leaveLine.Guid) then
            saidLeaveLine = true
            SetEntityEvent(pickpocket, "DEN_Thieflings_MerchantKidToHideout");
            mod.moveto.MoveTo(hideoutPos,true,1.5,"Run","DEN_Thieflings_ArriveAtHideout",2.5,true,false)
        end
    end

    events.TimerFinished = function(e)
        if(e.TimerName == "ADTimer_DEN_Thieflings_AD_MagicTrick") then 
            blockedAD = false
        end
    end

end}