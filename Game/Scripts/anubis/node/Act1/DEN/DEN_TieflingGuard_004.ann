game.states.DEN_TieflingGuard_004 = State {function ()

    
    modules = { "shared.moveto", "shared.dialog"}

    description = [[Guard Rikka's behavior near the front gate of the druid grove]]

    -----------------------------------------
    -- Local variables
    --Entities
    local atBodyPos = Entity("S_DEN_KanonBodyPos_02_cfa0c4fe-b28d-44c6-9556-a862f92119c9")

    --Flags
    local mournFlag = Flag("DEN_General_State_KanonCorpseClear_2f31ab46-4850-444b-b826-c13c8ca854eb")
    local raidFlag = Flag("DEN_RaidingParty_Quest_GoblinRaidOver_98712d90-c46b-20c4-c4df-02c0117e85a5")

    --Bools
    local atKanon = false
    local canSit = true
    local timer = false
    local canAD = true

    --Dialogs
    local AD = Dialog("DEN_General_AD_TieflingGuard4_f2007d87-c708-22a9-74bb-f1e35e212284")

    --Nodes
    -----------------------------------------
    nodes.RaidIdle = Action{
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return not GetFlag(raidFlag,nil)
        end
    }
    
    nodes.AD = Action {
        function()
            mod.dialog.StartCheckedAutomatedDialog(
                AD,
                {
                    waitForCompletion = false
                },
                me
            )
            canAD = false
        end,
        OnLeave = function()
            canAD = false
            StopTimer(me,"ADTimer_DEN_General_AD_TieflingGuard4")
            StartTimer(me,"ADTimer_DEN_General_AD_TieflingGuard4", 60 + math.random(0,10),0)
        end,
        CanEnter = function()
            return canAD and (GetFlag(raidFlag) and not GetFlag(mournFlag))
        end
    }


    nodes.ToKanon = Action{
        OnEnter = function()
            mod.moveto.MoveTo(atBodyPos,true,1.5,"Walk","DEN_General_ReachedKanon")
        end,
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return GetFlag(mournFlag,nil) and not atKanon
        end
    }

    nodes.AtKanon = Proxy{
        game.states.DEN_GeneralGroveStates_AnimateAtPoint,
        params={
            moveTarget = "S_DEN_KanonBodyPos_02_cfa0c4fe-b28d-44c6-9556-a862f92119c9",
            lookFromMoveTarget = true,
            anim = "CUST_SizingUpHeavyObject_01_721d00d0-32a0-488e-b1ec-3400ac2dbf62",
            waitMin = 0.0,
            waitMax = 0.0
        },
        Valid = function()
            return GetFlag(mournFlag,nil) and atKanon
        end
    }

    nodes.Default = Selector{
        function(nodes)
            if canSit then
                return nodes.GateSit
            else
                return nodes.GateLedge
            end
        end,
        Valid = function()
            return not GetFlag(mournFlag,nil)
        end
    }

    nodes.Default.GateSit = Proxy{
        game.states.Sit,
        params = {
            seat = "S_DEN_TieflingGuard004_Seat_1b1835a3-d248-43cd-8fd4-9035ddeb19d4",
            seatTrigger = "S_DEN_TieflingGuard004_ChairArea_cc06b3fb-7f37-49c3-882d-849f3e350cf1",
            useSeatPositionAsFallBack = false,
            sitIdle = StateRef{game.states.DEN_TieflingGuard_004_SitAtGate},
            nonSitIdle = StateRef{game.states.DEN_TieflingGuard_004_StandAtGate}
        }
    }

    nodes.Default.GateLedge = Proxy{
        OnEnter = function()
            if not timer then
                timer = true
                StartTimer(me, "DEN_Tiefling004_PatrolFallbackTimer", 10.0, 0)
            end
        end,
        game.states.DEN_GeneralGroveStates_AnimateAtPoint,
        params={
            moveTarget = "S_DEN_TieflingGuard004_LedgeArea_bf870d3c-1c44-42f3-b3ad-8ea68fb4578f",
            lookFromMoveTarget = true,
            waitMin = 15.0,
            waitMax = 18.0,
        },
    }

    -----------------------------------------
    -- event section

    events.EntityEvent = function(e)
        if(e.TargetEntity == me) then
            if e.Event == "DEN_General_ReachedKanon" then
                atKanon = true
            elseif e.Event == "GLO_Sit_ManualInterrupt" then
                canSit = false
                Interrupt()
            end
        end
    end

    events.FlagSet = function(e)
        if e.Flag == mournFlag.Guid then
            StopAnimation(me)
            Interrupt()
        end
    end

    events.TimerFinished = function(e)
        if e.TimerName == "DEN_Tiefling004_PatrolFallbackTimer" then
            timer = false
            if not canSit then
                canSit = true
            end
        elseif(e.TimerName == "ADTimer_DEN_General_AD_TieflingGuard4") then 
            canAD = true
        end
    end
end}

game.states.DEN_TieflingGuard_004_SitAtGate = State{function()
    
    description = [[]]
    
    -----------------------------------------
    -- Params
    params.Custom = {type=EParamType.State, required=false, default=nil, help=[[State for Custom Behavior]]}
    
    -----------------------------------------
    -- Local variables

    local mournFlag = Flag("DEN_General_State_KanonCorpseClear_2f31ab46-4850-444b-b826-c13c8ca854eb")

    nodes.Sitting = Action{
        function()
            Sleep(math.random(15.0,18.0))
            SetEntityEvent(me, "GLO_Sit_ManualInterrupt")
        end
    }
    
    end}

game.states.DEN_TieflingGuard_004_StandAtGate = State{function()
    
    description = [[]]

    modules = {"shared.moveto"}
        
    -----------------------------------------
    -- Local variables
    local fallbackPos = Entity("S_DEN_Tiefling004Pos_72fc7c6d-f099-47e4-9263-ce4134a4ca12")
    local mournFlag = Flag("DEN_General_State_KanonCorpseClear_2f31ab46-4850-444b-b826-c13c8ca854eb")

    -----------------------------------------
    -- State nodes
    self.OnInit = function()
        SetWeaponUnsheathed(me,true)
    end

    -----------------------------------------
    -- Nodes

    nodes.Idle = Action {
        function()
            if mod.moveto.MoveToPoint(fallbackPos,MovementSpeed.Stroll,me) then
                LookFrom(fallbackPos,true)
                Sleep(math.random(15.0,18.0))
                SetEntityEvent(me, "GLO_Sit_ManualInterrupt")
            end
        end
    }

    end}

    game.states.DEN_PostDruidAttack_CheckingTrees = State { function ()

    description = [[Kaldani is looking around for trees to make barricades out of.]]

    local inspectTreeAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")

    local treeAD = Dialog("DEN_DruidAttack_AD_TreeCuttingAfterAttack_92f82035-737b-0186-be03-dd2693cc1604")

    local patrolSpline = Spline("S_DEN_TreeSpline_5f865fb2-3fdc-4ed6-9eef-bece3082ed52")
    local canWalkOnSpline = true


    helpers.ResetADDelay = function(delay)
        StopTimer(me, "DEN_PatrollingTrees_ADTimer")
        StartTimer(me, "DEN_PatrollingTrees_ADTimer", delay, 0)
        canAD = false
    end

    -----------------------------------------
    -- node section
    nodes.LookingForTree = Action {
        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Stroll)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                LookFrom(patrolSpline)
                Sleep(1)
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end,
    }

    nodes.ExaminingTree = Action{
        CanEnter = function()
            return not canWalkOnSpline
        end,
        function()
            LookFrom(patrolSpline)
            Sleep(1)
            if (canAD) then
                canAD = false
                StartAutomatedDialog(treeAD, false, me)
                helpers.resetADDelay(30)
            end
            PlayAnimation(inspectTreeAnim, true)
            canWalkOnSpline = true
        end,
        OnLeave = function()
            canWalkOnSpline = true
        end
    }

    events.SplineControlPointReached = function(e)
        canWalkOnSpline = false
    end
    
end}

game.states.DEN_PostDruidAttack_CheckingTrees = State { function ()

    description = [[Kaldani is looking around for trees to make barricades out of.]]

    local inspectTreeAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")

    local treeAD = Dialog("DEN_DruidAttack_AD_TreeCuttingAfterAttack_92f82035-737b-0186-be03-dd2693cc1604")
    local canAD = true

    local patrolSpline = Spline("S_DEN_TreeSpline_5f865fb2-3fdc-4ed6-9eef-bece3082ed52")
    local canWalkOnSpline = true


    helpers.ResetADDelay = function(delay)
        
        StopTimer(me, "DEN_PatrollingTrees_ADTimer")
        StartTimer(me, "DEN_PatrollingTrees_ADTimer", delay, 0)
        canAD = false
    end

    -----------------------------------------
    -- node section
    nodes.SearchingForTree = Action {
        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Stroll)
            catch e if ls.CheckType(e, error.StartPatrolFailed) then
                LookFrom(patrolSpline)
                Sleep(1)
                canWalkOnSpline = false
            end
        end,
        Valid = function()
            return canWalkOnSpline
        end,
    }

    nodes.ExaminingTree = Action{
        CanEnter = function()
            return not canWalkOnSpline
        end,
        function()
            if (canAD) then
                canAD = false
                StartAutomatedDialog(treeAD, false, me)
                helpers.resetADDelay(30)
            end
            PlayAnimation(inspectTreeAnim, true, false)
            canWalkOnSpline = true
        end,
        OnLeave = function()
            canWalkOnSpline = true
        end
    }

    events.SplineControlPointReached = function(e)
        canWalkOnSpline = false
    end
    
end}