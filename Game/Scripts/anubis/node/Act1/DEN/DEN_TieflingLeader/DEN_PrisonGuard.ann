game.states.DEN_PrisonGuard = State { function ()

    description = [[Zevlor's bodyguard (who used to guard the prison).]]

    modules = {"shared.moveto"}
    -----------------------------------------
    -- local state section
    local defaultPoint = Entity("S_DEN_PrisonGuardPoint_5d6d965e-32bd-4b0a-8202-5bd1a98db05a")
    local stretchAnim = Animation("CUST_LimberUp_01_bd13cb25-1dfb-4ea5-8218-9e96d11e3117")

    -----------------------------------------
    -- node section
    nodes.AtLeaderChamber = Selector {
        function(nodes)
            return FindWeightedRandomSelectable(nodes, {
                [nodes.Guard] = 3,
                [nodes.Stretch] = 1
            })
        end
    }

    nodes.AtLeaderChamber.Guard = Action {
        OnEnter = function()
            SetWeaponUnsheathed(me, true)
        end,
        function()
            if mod.moveto.MoveToPoint(defaultPoint, MovementSpeed.Stroll, me) then
                LookFrom(defaultPoint)
                Sleep(math.random(8, 12))
            end
        end
    }

    nodes.AtLeaderChamber.Stretch = Action {
        OnEnter = function()
            SetWeaponUnsheathed(me, false)
        end,
        function()
            if mod.moveto.MoveToPoint(defaultPoint, MovementSpeed.Stroll, me) then
                LookFrom(defaultPoint)
                Sleep(1)
                PlayAnimation(stretchAnim, true, false)
                Sleep(math.random(1, 3))
            end
        end
    }

    -----------------------------------------
    -- event section
end}