game.states.DEN_TieflingRefugee_RaidingParty = State {function ()
    
    modules = { "shared.moveto"}

    description = [[Events for tiefling refugees from the raiding party situation]]

    params.Dest = {type=EParamType.String, required=false, default=nil, help=[[Position for Action 1]]}

    self.CanEnter = function()
        return false
    end
    
    events.FlagSet = function(e)
        if(e.Flag == Guid("DEN_RaidingParty_Event_GateIsOpened_735e0e81-bd67-eb67-87ac-40da4c3e6c49") and params.Dest ~= nil) then
            mod.moveto.MoveTo(FindEntity(params.Dest),true,1.5,"Walk","DEN_GoToDen_MoveComplete",2.5,false,false)
        end
    end
end}