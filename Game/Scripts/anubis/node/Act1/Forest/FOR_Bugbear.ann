game.states.FOR_BugbearIdle = State { function ()

    modules = {"shared.character", "shared.dialog"}
    
    local dialog_mating = Dialog("BHVR_WRLD_FOR_BugBearMating_1d7fe67f-165f-eece-9f45-c79c500e8876")
    local trig_mating = Entity("S_FOR_TimelineTrigger_BugBearMating_0f08097b-791f-4fd0-b8c9-852d7869f36e")
    local char_ogre = Entity("S_FOR_OgreMate_489c7f56-b461-41a6-b519-7ef5f1a1bbdc")
    local flag_notmating = Flag("FOR_BugBearLove_State_StoppedMating_f2262579-8317-4d91-836d-a4c87899559b")

    nodes.Mating = Action {
        function()
            if mod.dialog.IsSpeakerAvailable(me) and mod.dialog.IsSpeakerAvailable(char_ogre) then
                try
                    StartBehaviorDialog(dialog_mating, trig_mating.Trigger, true, me, char_ogre)
                    BehaviorDialogRequestGracefulStop(me, false, nil)
                catch e if ls.CheckType(e, error.BehaviorDialogStartFailed) then
                    DebugText(me, "Error: Mating Dialog not working yet")
                    Sleep(3.0)
                end
            end
        end,
        OnLeave = function()
            BehaviorDialogRequestGracefulStop(me, false, nil)

        end,
        Valid = function()
            return not GetFlag(flag_notmating) and mod.dialog.IsSpeakerAvailable(me) and mod.dialog.IsSpeakerAvailable(char_ogre)
        end
    }

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end,
    }





end}