game.states.FOR_GnomeGoblin4_DelayBehaviour = State{
    function ()

        local FOR_GnomeWorg1 = Entity("S_FOR_GnomeWorg1_e595394b-fbc9-438a-be7a-5b6fb5c3261d")
        local FOR_GnomeGoblin4_AD_Leaving = Dialog("FOR_GnomeGoblin4_AD_Leaving_905d8657-ad9d-bf6c-4ccb-c0cbe7f63244")
        local didAD = false

        modules = {"shared.dialog"}

        nodes.LeaveAD = Action{
            function()
                Sleep(2.1)
                if not didAD and
                   mod.dialog.IsSpeakerAvailableAndNear(FOR_GnomeWorg1, me, 15.0, true) then
                    StartAutomatedDialog(FOR_GnomeGoblin4_AD_Leaving, true, me, FOR_GnomeWorg1)
                    didAD = true
                end
            end
        }

    end
}
    