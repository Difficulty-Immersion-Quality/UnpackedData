game.states.FOR_GnomeGoblin7_DelayBehaviour = State{
    function ()

        local FOR_GnomeGoblin1 = Entity("S_FOR_GnomeGoblin1_b2c582af-bc69-48b3-a004-648562dab404")
        local FOR_GnomeGoblin7_AD_Leaving = Dialog("FOR_GnomeGoblin7_AD_Leaving_2218b413-6e87-b04c-9111-0c369c3a84a4")
        local didAD = false

        --[[self.OnInit = function()
            FOR_GnomeGoblin1 = FindEntity("S_FOR_GnomeGoblin1_b2c582af-bc69-48b3-a004-648562dab404d")
        end]]

        modules = {"shared.dialog"}

        nodes.LeaveAD = Action{
            function()
                SteerTo(FOR_GnomeGoblin1)
                Sleep(0.8)
                if not didAD then
                    StartAutomatedDialog(FOR_GnomeGoblin7_AD_Leaving, true, me)
                    didAD = true
                end
            end
        }

    end
}
    