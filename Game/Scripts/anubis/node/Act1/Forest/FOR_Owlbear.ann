game.states.FOR_Owlbear = State {function()
    description = [[Behaviour of the Owlbear at the cave]]

    local tr_wander
    local tr_lookAt
    local tr_lookAtEgg
    
    self.OnInit = function()
        tr_wander = FindEntity("S_FOR_Owlbear_WanderTrigger_b375964b-59ca-4ae7-8cb2-93706f9b03f6")
        tr_lookAt = FindEntity("S_FOR_PriestsOfTheConqueringGod_OwlbearCavePoint_001_38e5cc37-7547-4978-b7a0-44e1c5fd6c8a")
        tr_lookAtEgg = FindEntity("S_FOR_Owlbear_EggSteerTo_Trigger_4a93f1b9-c645-475d-9e7d-97d659907127")
    end

    nodes.Wander = Action {
        function()
            Sleep(math.random(5,10))
            Wander(5.0, math.random(3.0,5.0), MovementSpeed.Walk, tr_wander)
            if(math.random(0,10) < 5) then
                SteerTo(tr_lookAt)
            else
                SteerTo(tr_lookAtEgg)
            end
        end
    }

end}