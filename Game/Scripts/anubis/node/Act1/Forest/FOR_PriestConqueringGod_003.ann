game.states.GOB_PriestConqueringGod_003 = State{function ()

    description = [[Behaviour for S_GOB_PriestConqueringGod_003]]

    --modules = { }

    self.OnInit = function()
    end

    events.EnteredCombat = function(ev)
        if ev.Entity == me then
            local ch_Owlbear = FindEntity("S_FOR_OwlBear_e903a41f-8ef7-46dc-a847-7d0ec2804d08")
            ApplyStatus(me, "BLEEDING", true, 12.0, ch_Owlbear)
        end
    end

    events.LeftCombat = function(ev)
        if ev.Entity == me and not ev.Entity.Character.IsDead then
            Die(me, DeathType.DOT, nil)
        end
    end

    nodes.Default = Action{
        function()
            WaitForInterrupt()
        end
    }
end}