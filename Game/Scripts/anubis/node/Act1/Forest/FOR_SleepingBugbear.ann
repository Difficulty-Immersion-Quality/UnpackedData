game.states.FOR_SleepingBugbear = State{
    function()
        local bed = Entity("S_FOR_SleepingBugbear_InvisibleBed_1a87a689-e8d4-4659-b8f5-9e99d0804b96")

        nodes = ImmediateSelector{}

        nodes.Action_GoToSleep = Action{
            function()
                -- If the resting pos is in a dangerous surface, wait for one turn
                if not IsInDangerousSurfaceFor(bed, me.Character, 1.0) then
                    try
                        MoveTo(bed)
                        Sleep(3.0)
                        ApplyStatus(me, "FOR_SLEEPINGBUGBEAR_SLEEPING")
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        DebugText(me, "Error: MovementFailed")
                        Sleep(3.0)
                    end
                else
                    Sleep(6.0)
                end
            end,
            Valid = function()
                return not HasActiveStatus(me, "FOR_SLEEPINGBUGBEAR_SLEEPING")
            end,
        }

        nodes.Sleeping = Action{
            function()
                WaitForInterrupt()
            end,
        }
    end
}