game.states.GLO_RegionProxies_Act1 = State { function ()

    local inCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")

    description = [[Contains a proxy for each region in Act1. To be used on global entities in this Act only.]]

    params.CAMP = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the campsite.]]
    }
    params.CRA = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the crash site.]]
    }
    params.CHA = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in Selune's chapel.]]
    }
    params.DEN = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the druids' grove.]]
    }
    params.FOR = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the forest.]]
    }
    params.PLA = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the plains.]]
    }
    params.HAG = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the hag's swamp.]]
    }
    params.GOB = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the goblin camp.]]
    }
    params.UND = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the underdark.]]
    }
    params.act1 = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in WLD_Main_A.]]
    }

    nodes = ImmediateSelector {}

    nodes.CAMP = Proxy {
        params.CAMP,
        Valid = function()
            return GetFlag(inCamp,me)
        end
    }


    nodes.Act1 = ImmediateSelector {
        Valid = function(node)
            return CheckCurrentGameLevel("WLD_Main_A") and CheckAnySelectable(node)
        end
    }
    nodes.Act1.CRA = Proxy {
        params.CRA
    }
    nodes.Act1.CHA = Proxy {
        params.CHA
    }
    nodes.Act1.DEN = Proxy {
        params.DEN
    }
    nodes.Act1.FOR = Proxy {
        params.FOR
    }
    nodes.Act1.PLA = Proxy {
        params.PLA
    }
    nodes.Act1.HAG = Proxy {
        params.HAG
    }
    nodes.Act1.GOB = Proxy {
        params.GOB
    }
    nodes.Act1.UND = Proxy {
        params.UND
    }
    nodes.Act1.Main = Proxy {
        params.act1
    }

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end
    }
end}