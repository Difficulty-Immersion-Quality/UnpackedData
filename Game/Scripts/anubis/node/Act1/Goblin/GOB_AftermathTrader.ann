game.states.GOB_AftermathTrader = State{function()
    description = [[Behavior of a goblin trader left behind after Goblin camp is cleared:
     - checks festiv tables for anything of value
     - taking a break at bbq zone
     - checks trader's corner
     - checks corpses if there's any]]

    modules = { "shared.math", "shared.util" }

    local tablePoses = {
        Entity("S_GOB_Festivities_TableTrigger_000_81c40abd-0ff6-4402-88d2-d2f21b5537db"),
        Entity("S_GOB_Festivities_TableTrigger_001_NoVolo_9dddfcbd-1722-4ac5-84e0-317ba69cc540"),
        Entity("S_GOB_Festivities_TableTrigger_003_NoVolo_a289a241-6b46-4d1d-a898-2eca7c54eb85"),
        Entity("S_GOB_PriestsOfTheConqueringGod_GoblinCampPoint_002_5277cd72-d223-4f6c-a8b6-f35c685f0309"),
    }
    local traderPos = Entity("S_GOB_Festivities_Trader_Position_002_e92fea21-3621-48cd-8c67-f4e0a94debba")
    local bbqPos = Entity("S_GOB_RoastingDwarf_CheckPos_467dbd63-8098-4307-b300-29915e7a82d1")

    local animLoot = Animation("CUST_LootingCorpse_01_c7d9d546-a74a-4471-9ab1-4175c389a872")
    local animValuables = Animation("CUST_LookingForValuables_01_eab8704c-97f7-4124-bab1-55deeadff528")
    local animStretch = Animation("CUST_Stretching_01_9af703b0-c02f-4c17-bfee-7e11f1f80d6b")
    local animThink = Animation("CUST_Thinking_01_97588786-d9bf-4d18-879b-1bd3dcaa62ba")
    local animIdle = {
        Animation("CUST_Investigating_LookingAround_01_dfbe749c-d0c2-4f4f-91cf-f1caaec3f3bf"),
        Animation("CUST_Investigating_LookingAround_02_ab739447-e85f-4fca-b1d4-fb783d61fa9c"),
        Animation("CUST_Investigating_LookingAround_03_41d0a2ea-f16e-435c-bbf3-a8499b873fd5"),
        Animation("CUST_Stretching_01_9af703b0-c02f-4c17-bfee-7e11f1f80d6b"),
        Animation("CUST_Thinking_01_97588786-d9bf-4d18-879b-1bd3dcaa62ba"),
    }

    local tableInd = 1
    local valids = {
        true, true, true, true
    }

    local movementSpeed = nil
    
    self.OnInit = function()
        movementSpeed = MovementSpeed.Stroll
    end


    nodes.LootTables = Action{
        Valid = function()
            return valids[1] and not IsInDangerousSurfaceFor(tablePoses[tableInd], me.Character)
        end,

        function()
            local res = MoveTo(tablePoses[tableInd], movementSpeed, false, false, 0.5, 1.0, false)
            if res == error.MovementError.None then
                LookFrom(tablePoses[tableInd])
                PlayAnimation(animValuables, true)
                tableInd = math.random(1, 4)
                valids[1] = false
            else
                SteerTo(tablePoses[tableInd])
                mod.util.SleepRandom(1.0, 3.0)
                tableInd = math.random(1, 4)
            end
        end
    }

    nodes.Rest = Action{
        Valid = function()
            return valids[2] and not IsInDangerousSurfaceFor(bbqPos, me.Character)
        end,

        function()
            local res = MoveTo(bbqPos, movementSpeed, false, false, 0.5, 1.5, false)
            if res == error.MovementError.None then
                if mod.math.CoinToss(0.5) then
                    PlayAnimation(animStretch, true)
                else
                    PlayAnimation(animThink, true)
                end
                valids[2] = false
            else
                SteerTo(bbqPos)
                mod.util.SleepRandom(1.0, 3.0)
            end
        end
    }

    nodes.LootTrader = Action{
        Valid = function()
            return valids[3] and not IsInDangerousSurfaceFor(traderPos, me.Character)
        end,

        function()
            local res = MoveTo(traderPos, movementSpeed, false, false, 0.5, 1.0, false)
            if res == error.MovementError.None then
                LookFrom(traderPos)
                PlayAnimation(animValuables, true)
                valids[3] = false
            else
                SteerTo(traderPos)
                mod.util.SleepRandom(1.0, 3.0)
            end
        end
    }

    nodes.LootBody = Action{
        Valid = function()
            return valids[4]
        end,

        function()
            local corpses = {}
            local actives = GetActiveCharacters(me, 20.0)
            for k, v in pairs(actives) do
                if v.IsDead then
                    table.insert(corpses, v)
                end
            end
            local _, corpse = mod.util.RandomFrom(corpses)
            if corpse ~= nil then
                local res = MoveTo(corpse, movementSpeed, false, false, 0.5, 1.0, false)
                if res == error.MovementError.None then
                    SteerTo(corpse)
                    PlayAnimation(animLoot, true)
                else
                    SteerTo(corpse)
                    mod.util.SleepRandom(1.0, 3.0)
                end
            end
            valids[4] = false
        end
    }

    nodes.Fallback = Action{
        function()
            local ind = math.random(1, 5)
            PlayAnimation(animIdle[ind], true)
            Sleep(1.0)
            for k,v in pairs(valids) do
                valids[k] = true
            end
        end
    }
end}