game.states.GOB_Branding_GoblinSulky = State{function()
    -- Local params
    local anchor

    -- State nodes
    self.OnInit = function()
        anchor = FindEntity("S_GOB_GoblinSulky_HomeTrigger_1ba31547-149f-4ad1-a60d-7455bc309ae5")
    end

    -- Nodes
    -- Wander around anchor point
    nodes.Action_Wander = Action{
        function()
            if not IsInDangerousSurfaceFor(anchor, me.Character) then
				if GetDistanceTo(me, anchor) > 2.0 then
					try
						MoveTo(anchor,MovementSpeed.Walk)
					catch e if ls.CheckType(e, error.MovementFailed) then
						LookAtEntity(anchor, 3.0)
						Sleep(2.0)
                    end
                end
            end
            Wander(2.0,1.0,MovementSpeed.Walk,anchor)
            Sleep(2.0)
        end
    }
end
}