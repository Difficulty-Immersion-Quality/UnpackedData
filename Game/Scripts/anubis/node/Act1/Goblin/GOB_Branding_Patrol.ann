game.states.GOB_Branding_Patrol = State{function()

    -- Behaviour params
    params.patrolSpline = {type=EParamType.String, help="Patrol spline"}
    
    -- Local params
    local patrolSpline

    -- State nodes
    self.OnInit = function()
        patrolSpline = Spline(params.patrolSpline)
    end

    -- Nodes
    -- Patrol along spline
    nodes.Action_Patrol = Action{
        function()
            DoPatrol(patrolSpline, false, MovementSpeed.Walk)
        end,
        Valid = function()
            return patrolSpline ~= nil
        end
    }
    
    -- Fallback
    nodes.Action_Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }
end
}