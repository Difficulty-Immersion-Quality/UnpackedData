game.states.GOB_AttackOnDen_PissingGoblins_Bossy = State {function ()

    modules = {"shared.moveto", "shared.dialog"}

    local position = Entity("S_DEN_PeeingGoblinPos_003_1a674c41-adad-4ba9-837b-da7cd2e8a559")
    local animation = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")
    local AD = Dialog("DEN_AttackOnDen_AD_RaidersAtPool_bd5526cb-0616-6d1a-1487-831d13fe8cc1")
    local crafty = Entity("S_GOB_RaiderCrafty_d0269a95-45f2-4877-b301-0c1740f3dd7d")
    local funny = Entity("S_GOB_RaiderFunny_b1e2d6a7-0fad-4485-ae2e-2ec78ce4e658")
    local violent = Entity("S_GOB_RaiderViolent_71620f09-46cb-4c03-b874-7c97926e6fbf")

    nodes.WatchingPissingGoblins = Action {
        function()
            Sleep(math.random(2, 6))
            if mod.moveto.MoveToPoint(position, MovementSpeed.Stroll, me) then
                LookFrom(position)
                PlayAnimation(animation, true, false)
                SetDoNotFace(me, true)
                SetDoNotFace(crafty, true)
                SetDoNotFace(funny, true)
                SetDoNotFace(violent, true)
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    AD,
                    {
                        waitForCompletion = true,
                        minDelay = 25.0
                    },
                    me, crafty, funny, violent
                )
            end
        end, 
        OnLeave = function()
                SetDoNotFace(me, false)
                SetDoNotFace(crafty, false)
                SetDoNotFace(funny, false)
                SetDoNotFace(violent, false)
        end
    } 
end}
