game.states.GOB_RaiderCunning = State{
    function()
        description = [[Behaviour after the raid of the goblin next to the battle horn]]

        modules = {"shared.util"}

        --------------------------------------------------------
        -- Local variables
        local lookFromPos = Entity("S_DEN_CunningPos_80492b7b-fd2f-4685-a3e2-b635930232f8")
        local lookingFarAnim = Animation("CUST_LookingFar_01_5643e3dc-9631-4dba-b303-128fc29abfa7")
        --------------------------------------------------------

        --------------------------------------------------------
        -- Nodes
        nodes.Action_LookFar = Action{
            function()
                if not IsInDangerousSurfaceFor(lookFromPos, me.Character) then
                    try
                        MoveTo(lookFromPos)
                        LookFrom(lookFromPos)
                        PlayAnimation(lookingFarAnim, true, false)
                        mod.util.SleepRandom(3.0, 9.0)
                    catch e if ls.CheckType(e, error.MovementFailed) or ls.CheckType(e, error.PlayAnimationFailed) then
                        DebugText(me, "Error: Movement/PlayAnimationFailed")
                        Sleep(3.0)
                    end
                else
                    SteerTo(lookFromPos)
                    Sleep(3.0)
                end
            end,
            OnLeave = function()
                StopAnimation(me)
            end
        }
        --------------------------------------------------------
    end
}