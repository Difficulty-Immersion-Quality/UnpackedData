game.states.GOB_GoblinBrash = State{function()
    description = [[Anubis state for S_GOB_GoblinBrash]]

    local tr_DefaultPos = nil

    self.OnInit = function()
        tr_DefaultPos = FindEntity("S_GOB_GoblinBrash_HomeTrigger_d643f000-08ce-40f3-a473-5214f1ccaffc")
    end

    nodes.Default = Action{
        function()
            try
                MoveTo(tr_DefaultPos)
                LookFrom(tr_DefaultPos)
            catch ex if ls.CheckType(ex, error.MovementFailed) then
                DebugText(me, "MoveTo tr_DefaultPos failed")
            end
            Sleep(1.0)
        end
    }

end}
