game.states.GOB_GoblinPriestOgre = State{function()
    modules = { "shared.util" }

    description = [[Behaviour of an ogre in Goblin Priest's dungeon]]

    local tr_Pos1, tr_Pos2, tr_Pos3, tr_NextPos = nil

    self.OnInit = function()
        tr_Pos1 = FindEntity("S_GOB_GoblinPriestOgre_Pos_01_29d73de6-c5fe-4e97-81ac-e6c5f33bb859")
        tr_Pos2 = FindEntity("S_GOB_GoblinPriestOgre_Pos_02_78632795-911e-4ae1-934a-8bc9927c8611")
        tr_Pos3 = FindEntity("S_GOB_GoblinPriestOgre_Pos_03_995fa1d7-5247-4073-b38f-6a3c9d219935")
    end

    nodes.Walk = Action{
        function()
            tr_NextPos = tr_Pos1
            try
                MoveTo(tr_NextPos)
                LookFrom(tr_NextPos)
            catch ex if ls.CheckType(ex, error.MovementFaied) then
                DebugText(me, "Failed MoveTo tr_Pos1")
            end
            mod.util.SleepRandom(5.0, 12.0)

            tr_NextPos = tr_Pos2
            try
                MoveTo(tr_NextPos)
                LookFrom(tr_NextPos)
            catch ex if ls.CheckType(ex, error.MovementFaied) then
                DebugText(me, "Failed MoveTo tr_Pos2")
            end
            mod.util.SleepRandom(5.0, 12.0)

            tr_NextPos = tr_Pos3
            try
                MoveTo(tr_NextPos)
                LookFrom(tr_NextPos)
            catch ex if ls.CheckType(ex, error.MovementFaied) then
                DebugText(me, "Failed MoveTo tr_Pos3")
            end
            mod.util.SleepRandom(5.0, 12.0)
        end
    }

    nodes.Default = Action{
        function()
            WaitForInterrupt()
        end
    }
end}