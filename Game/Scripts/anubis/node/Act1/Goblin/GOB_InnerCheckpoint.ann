game.states.GOB_InnerCheckpoint_Backup = State{function()
    description = [[State for the guardians of an inner gates in goblin camp]]

    nodes.Default = Action{
        function()
            WaitForInterrupt()
        end
    }
end}

game.states.GOB_GuardTense = State{function()
    description = [[State for the guardians of an inner gates in goblin camp]]

    nodes.Default = Action{
        function()
            WaitForInterrupt()
        end
    }
end}


game.states.GOB_GuardUpset = State{function()
    description = [[State for the guardians of an inner gates in goblin camp]]

    modules = { "shared.dialog" }

    local ch_ADPartner = nil
    local dlg_AD = Dialog("GOB_Guards_AD_Idle_bc163395-c744-30bd-7b8c-975df2c78529")
    local s_CanADTimerString = "GOB_GuardTens_CanADTimer"
    local b_CanDoAD = true

    self.OnInit = function()
        ch_ADPartner = FindEntity("S_GOB_GuardTense_97409af2-6e52-4e9d-83df-bd4827ca7992")
        b_CanDoAD = true
    end

    events.TimerFinished = function(ev)
        if ev.TimerName == s_CanADTimerString then
            b_CanDoAD = true
        end
    end

    nodes = ImmediateSelector{}

    nodes.AD = Action{
        function()
            if mod.dialog.IsSpeakerAvailableAndNear(ch_ADPartner, me, 15.0, true) then
                mod.dialog.StartAutomatedDialogWithWait(dlg_AD, me, ch_ADPartner)
                b_CanDoAD = false
                StartTimer(me, s_CanADTimerString, 30.0, 1)
            end
            Sleep(1.0)
        end,

        CanEnter = function()
            return b_CanDoAD
        end
    }

    nodes.Default = Action{
        function()
            WaitForInterrupt()
        end
    }
end}
