game.states.GOB_OwlbearCub = State {function()
    description = [[Behaviour of the Owlbear Cub in the goblin camp]]
    local IntroPosition
    local GobFlag = Flag("FOR_OwlBear_LastCubResolution_ToGoblinCamp_f804d502-80bb-ce09-3e34-735573a5ffa1")
    local BallFlag = Flag("GOB_ChickenChase_State_OwlbearReplacedChicken_aabd6c48-57e4-12bb-8123-912f747f1f07")

    self.OnInit = function()
        IntroPosition = FindEntity("S_GOB_ChickenChase_OwlbearAppearPosition_10a6b193-be30-4094-84ac-c968d2a0e810")
    end
    self.Valid = function()
        return GetFlag(GobFlag, me)
    end

    nodes = ImmediateSelector {}
    nodes.ChickenChase = Proxy {
        game.states.GOB_ChickenChase_Ball,
        Valid = function()
            return GetFlag(BallFlag,nil)
        end
    }
    nodes.MoveToIntroPosition = Action {
        function()
            try
                MoveTo(IntroPosition)
            catch e if ls.CheckType(e, error.MovementFailed) then
                DebugText(me,"Move Exception")
            end
            Sleep(2.0)
        end,
        Valid = function()
            return GetDistance2DTo(me,IntroPosition) > 3.0
        end
    }
    nodes.Intro = Action {
        function()
            WaitForInterrupt()
        end
    }
end}