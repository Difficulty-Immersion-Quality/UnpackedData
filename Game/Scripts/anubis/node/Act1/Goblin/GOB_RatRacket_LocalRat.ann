game.states.GOB_RatRacket_LocalRat = State{function()
    modules = { "shared.util" }

    description = [[Anubis behaviour for a couple of rats in goblin camp interior]]

    params.WanderArea = { type = EParamType.String, required = true,
        help = [[Trigger to wander in for the rat]]}

    local tr_WanderArea = nil

    self.OnInit = function()
        tr_WanderArea = FindEntity(params.WanderArea)
    end

    nodes = Selector{
        function(nodes)
            return GetRandomCanEnter(nodes)
        end
    }

    nodes.Sleep = Action{
        function()
            mod.util.SleepRandom(3.0, 10.0)
        end
    }

    nodes.WanderArea = Action{
        function()
            Wander(tr_WanderArea, 3.0)
        end,

        Valid = function()
            return tr_WanderArea ~= nil
        end
    }

end}