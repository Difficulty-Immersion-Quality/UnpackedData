game.states.GOB_ShadowHeart = State {function ()
    description = [[
        ShadowHeart behaviour at Goblin camp.
    ]]

    local GobFlag = Flag("GLO_Shadowheart_State_GobRecruitment_56a87492-2550-4232-ae52-c1a01ceeacc1")

    self.CanEnter = function()
        return GetFlag(GobFlag)
    end

    nodes.Nothing = Action {
        function()
            WaitForInterrupt()
        end
    }
end}