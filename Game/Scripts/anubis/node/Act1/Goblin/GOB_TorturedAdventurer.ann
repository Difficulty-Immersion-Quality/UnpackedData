game.states.GOB_TorturedAdventurer = State{function ()

    local freedFlag = Flag("GOB_Torturers_State_PrisonerFreed_c3ebd7d6-243c-f355-5cff-94ceb315d5c9")
    local leaveTrigger = Entity("S_GOB_TorturedAdventurer_EscapeMove1_ba4958ac-e37d-436c-b40e-2ca536062829")
    local restFlag = Flag("GOB_TorturedAdventurer_State_Resting_75e6b157-74c3-4bb1-bba7-c8046cd1486d")
    local bedroll = Entity("S_DEN_TorturedAdventurer_IdleBedroll_0e3bf7f6-9c73-4dca-8728-ded6ef833f1c")    
    local fetalAnim = Animation("CINE_CampSleep_FetalPose_Loop_01_23648e25-26f7-4210-98a9-73ff57a223d2")

    nodes.LieFetal = Action{
        function()
            PlayAnimation(fetalAnim, false, true)
            WaitForInterrupt()
        end,
        Valid  = function()
            return GetFlag(restFlag) and GetDistance2DTo(me,bedroll)<1.0
        end
    }

    nodes.MoveToBedRoll = Action{
        function()
           UseItem(bedroll.Item,true,true,true,false)
        end,
        CanEnter = function()
            return GetFlag(restFlag) and GetDistance2DTo(me,bedroll)>=1.0
        end
    }

    nodes.MoveTo = Action{
    function()
        MoveTo(leaveTrigger,MovementSpeed.Run,false,false,1,2,false)
        WaitForInterrupt()
    end,
    CanEnter = function()
        return GetFlag(freedFlag)
    end
    }

    nodes.Idle = Action{
    function()
        WaitForInterrupt()
    end,
    Valid = function()
        return not GetFlag(freedFlag)
    end
    }
end}