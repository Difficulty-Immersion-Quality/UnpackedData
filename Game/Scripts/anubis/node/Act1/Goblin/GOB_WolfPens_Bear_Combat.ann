game.states.GOB_WolfPens_Bear_Combat = State{function()

    modules = { "shared.items" }

    local it_cageDoor = Entity("S_GOB_WolfPens_CageDoor_002_19b032a0-e027-4524-96f9-1c0cd48d726e")
    local tr_cage = Entity("S_GOB_WolfPens_Cage002Trigger_59104718-66ff-418a-b7ac-46696a1e2fc3")
    local fl_Enraged = Flag("GOB_WolfPens_State_BearEnraged_9b6a106b-6431-42b9-8ac1-48ba2a79e46b")
    local fl_CombatCutsceneHappened = Flag("GOB_WolfPens_State_CombatCutsceneHappened_54a81a88-e628-4820-a84f-b0a5603e459d")

    self.Valid = function()
        return me.CanActInCombatTeamTurn
            and IsInTrigger(me, tr_cage.Trigger)
            and not GetFlag(fl_CombatCutsceneHappened)
            and GetFlag(fl_Enraged)
            and not mod.items.SafeIsDestroyed(it_cageDoor)
            and not it_cageDoor.Item.IsOpened
            and not it_cageDoor.Item.IsOpening
    end

    nodes.State_StartCombatCutscene = Action{

        function()
            SetEntityEvent(me, "GOB_WolfPens_StartCombatCutscene")
            Sleep(2.0) -- delay for Osiris to start the dialog
        end
    }

end
}