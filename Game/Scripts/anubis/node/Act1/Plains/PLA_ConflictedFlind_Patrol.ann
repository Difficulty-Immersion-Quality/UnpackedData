game.states.PLA_ConflictedFlind_Patrol = State { function()

    description = [[State for simple patroling]]

    -----------------------------------------
    -- params section
    params.patrolSpline = { type = EParamType.String, required = true, help = [[
        Patrol spline to use
    ]]}

    params.movementSpeed = { type = EParamType.String, required = false, default = "Walk", help = [[
        Movement speed for patrol (Stroll, Walk, Run or Sprint)
    ]]}

    -----------------------------------------
    -- local state section
    local targetSplineIndex = -1
    local patrolSpline

    -----------------------------------------
    -- state node functions
    self.OnInit = function()
        patrolSpline = Spline(params.patrolSpline)
    end

    -----------------------------------------
    -- node section
    nodes.Patroling = Action {
        function()
            DoPatrol(patrolSpline, false, MovementSpeed[params.movementSpeed], targetSplineIndex, false)
        end,
        OnLeave = function()
            ShortPatrolInterrupt()
        end
    }

    -----------------------------------------
    -- event section
    events.SplineControlPointReached = function(e)
        targetSplineIndex = e.NewIndex
    end
end}
