    local PLA_TavernInvestigation_DesireDoor2 = Entity("S_PLA_TavernInvestigation_DesireDoor2_e6b2f9ca-a59b-4842-8c1b-1b6499b884f7")
    local PLA_DesireFreedTrigger4 = Entity("S_PLA_DesireFreedTrigger4_cb4432ec-c626-4e2e-88dc-61d002f6bc29")
    local CUST_TrappedInBurningRoom_01_Start = Animation("CUST_TrappedInBurningRoom_01_Start_615c9132-88c5-491f-865a-17d702d3e4bf")
    local CUST_TrappedInBurningRoom_01_Loop = Animation("CUST_TrappedInBurningRoom_01_Loop_9b028c56-45eb-4d6d-93ce-c813ee5f9cdd")
    local CUST_TrappedInBurningRoom_01_End = Animation("CUST_TrappedInBurningRoom_01_End_40d421ea-f345-4194-84c5-025472ec5b1a")

    local playingCoughAnimation = false
    local DidRecognitionAD = false

    modules = {"shared.items" }

    self.OnInit = function()
        PLA_Desire_AD_Trapped = Dialog("PLA_Desire_AD_Trapped_1c13e7f1-f12d-36f1-1211-1c3e9b72ecf2")
        PLA_Desire_AD_FF1 = Dialog("PLA_Desire_AD_FF1_3eabc470-bcf2-c5e4-4862-be54e44e5be9")
        PLA_Desire_AD_FF2 = Dialog("PLA_Desire_AD_FF2_f829b775-884f-e4de-984c-8282ebc680e2")
        PLA_DesireTrappedRoom = FindEntity("S_PLA_DesireTrappedRoom_3063bdd1-3c92-4c46-9804-15098cfe54ad")
        PLA_DesireJumpFromTrigger = FindEntity("S_PLA_DesireJumpFromTrigger_1da9530c-743f-47f8-9b7f-0b03ef330284")
        PLA_DesireJumpToTrigger = FindEntity("S_PLA_DesireJumpToTrigger_408288b7-77d9-4573-bf8c-4591d7de5e76")
        PLA_Tavern_Support3 = FindEntity("S_PLA_Tavern_Support3_52471f6d-8514-4168-96da-0f09b7a3b36f")
        PLA_DesirePath_003 = FindEntity("S_PLA_DesirePath_003_23a8e412-c7ef-40cc-8ffc-a17a49709fa7")
        PLA_DesirePath_004 = FindEntity("S_PLA_DesirePath_004_67014598-c580-405b-91d1-88f5336fad85")
        PLA_DesireSideBuilding = FindEntity("S_PLA_DesireSideBuilding_b7f015ba-8712-4e08-953f-6177cc8b2830")
        PLA_DesireTavernHome = FindEntity("S_PLA_DesireTavernHome_eb049670-0bb3-4563-a4e7-2ebf2f66e09f")
        PLA_TavernInvestigation_DesireDoor = FindEntity("S_PLA_TavernInvestigation_DesireDoor_4f19d4a7-b9b0-4a6f-a9ce-b2442ad8a307")
        PLA_DesirePath_007 = FindEntity("S_PLA_DesirePath_007_168e8688-baa8-455b-b4ec-812270b2d0c7")
        PLA_FlamingFist1 = FindEntity("S_PLA_FlamingFist1_646a4195-4091-4dc9-81e1-cff2604f3911")
        PLA_FlamingFist2 = FindEntity("S_PLA_FlamingFist2_48b99fd9-f34e-4c11-a1a6-435ea6ef1c80")
        pathList = {FindEntity("S_PLA_DesirePath_001_8ded4e65-9d93-4091-a993-fd02d6410476"),
                    FindEntity("S_PLA_DesirePath_002_f84febe6-91c7-4727-a35d-2602858b293d"),
                    PLA_DesirePath_003,
                    PLA_DesirePath_004,
                    FindEntity("S_PLA_DesirePath_005_7033aeb4-ab90-40cc-8c96-c87e153317aa"),
                    FindEntity("S_PLA_DesirePath_006_c2cdecc0-549e-48f4-8a95-7d15a2e2ae6f"),
                    PLA_DesirePath_007}
        pathListb={FindEntity("S_PLA_DesirePathb_001_5bfedf07-0be2-41ef-acf5-78baa53bc00b"),
                   FindEntity("S_PLA_DesirePathb_002_5bdcff9f-b865-439a-a0c5-fd460cf94df5"),
                   FindEntity("S_PLA_DesirePathb_003_bca1c072-e798-44d8-98ec-d5f883b117ba"),
                   FindEntity("S_PLA_DesirePathb_004_cb2b057c-3717-4bed-b325-948062eedcb7"),
                   FindEntity("S_PLA_DesirePathb_005_dab0ad1c-defa-4efd-9282-6edf6108c25c"),
                   FindEntity("S_PLA_DesirePathb_006_c0b9861d-c337-4d49-88e7-a6be1517c724"),
                   FindEntity("S_PLA_DesirePathb_007_8755a286-c39c-475a-bd0c-de8d9dbaa647"),
                   FindEntity("S_PLA_DesirePathb_008_ae737c1e-f1c8-4d44-95df-259a18d38a26"),
                   FindEntity("S_PLA_DesirePathb_009_33b81a03-170b-4feb-a8f0-a14d286345a8")}
        pathListc={FindEntity("S_PLA_DesirePathc_000_d3a5ad8f-ad3c-462e-b87f-1fbfe7aba19d"),
                   FindEntity("S_PLA_DesirePathc_001_4b8c8a05-cbc8-4eec-916c-729ce92c8780"),
                   FindEntity("S_PLA_DesirePathc_002_55e4ba27-1d33-4ab1-84a0-17c5e770d772"),
                   FindEntity("S_PLA_DesirePathc_003_29976b1c-68ff-4554-8d48-ceb5ed9f2f17"),
                   FindEntity("S_PLA_DesirePathc_004_8c330487-c570-4088-94d8-7e661b00c288"),
                   FindEntity("S_PLA_DesirePathc_005_a4717331-ab95-419f-b413-777288117ab6"),
                   FindEntity("S_PLA_DesirePathc_006_2fe0e845-34c7-49e0-88d1-6e85f941b42d"),
                   FindEntity("S_PLA_DesirePathc_007_ab571912-f6cc-406d-8c42-97ffc292dddb"),
                   FindEntity("S_PLA_DesirePathc_009_9c9de636-0b48-45f6-b98e-76c4b3058784"),
                   FindEntity("S_PLA_DesirePathc_010_ee3c824b-4c18-44e2-9554-0b4d53a995a6"),
                   FindEntity("S_PLA_DesirePathc_011_949072c1-1b37-4db9-99a4-e1ffe7317852"),
                   FindEntity("S_PLA_DesirePathb_007_8755a286-c39c-475a-bd0c-de8d9dbaa647"),
                   FindEntity("S_PLA_DesirePathb_008_ae737c1e-f1c8-4d44-95df-259a18d38a26"),
                   FindEntity("S_PLA_DesirePathb_009_33b81a03-170b-4feb-a8f0-a14d286345a8")}
        PLA_DesireSpotFF = FindEntity("S_PLA_DesireSpotFF_4e4a06d4-0926-4440-94a9-bd320ccd00bc")
        PLA_DesireFreedTrigger3 = FindEntity("S_PLA_DesireFreedTrigger3_14dd7e9d-9041-4619-953c-d3c05116d027")
        PLA_DesireFreedTrigger2 = FindEntity("S_PLA_DesireFreedTrigger2_6ecb7b16-2371-40de-b948-1f18d227d9d6")

        PLA_TavernInvestigation_Quest_WallCollapsed = Flag("PLA_TavernInvestigation_Quest_WallCollapsed_391d017d-cbfb-768a-086d-ea404313eab4")

    end

    helpers.action.CheckSafePath = function(list) --TODO: Replace with a nicer way to check if there's a clear path.
        local bestDistance = GetDistanceTo(me, list[1])
        local bestTrigger = 1
        for i = 2, #list, 1 do
            local currentDistance = GetDistanceTo(me, list[i])
            if currentDistance < bestDistance then
                bestDistance = currentDistance
                bestTrigger = i
            end
        end
        local moveResult = nil
        local j = #list
        repeat
            moveResult = nil
            moveResult = MoveTo(list[j], MovementSpeed.Run, false, true, 0.5, 0.5, false)
            j = j - 1
        until
            (moveResult == error.MovementError.None or
            j <= bestTrigger)
        return j == #list and moveResult == error.MovementError.None
    end

    nodes.Action_Freed = Action{function()
        Sleep(0.5)
            if not GetFlag(PLA_TavernInvestigation_Quest_WallCollapsed) and
               not DidRecognitionAD then
                if IsInTrigger(PLA_FlamingFist1, PLA_DesireSpotFF.Trigger) and
                   not PLA_FlamingFist1.Character.IsDead and
                   not PLA_FlamingFist1.IsInCombat and
                   not PLA_FlamingFist1.Character.IsInteractionDisabled then
                    DidRecognitionAD = true
                    StartAutomatedDialog(PLA_Desire_AD_FF1, true, me, PLA_FlamingFist1)
                elseif IsInTrigger(PLA_FlamingFist2, PLA_DesireSpotFF.Trigger) and
                    not PLA_FlamingFist2.Character.IsDead and
                    not PLA_FlamingFist2.IsInCombat and
                    not PLA_FlamingFist2.Character.IsInteractionDisabled then
                    DidRecognitionAD = true
                    StartAutomatedDialog(PLA_Desire_AD_FF2, true, me, PLA_FlamingFist2)
                end
            end
            if GetDistanceTo(me, PLA_DesirePath_007) > 2.0 and
                not IsInDangerousSurfaceFor(PLA_DesirePath_007, me.Character) then
                try
                    MoveTo(PLA_DesirePath_007)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    Sleep(3.0)
                end
            else
                Sleep(2.0)
            end
        end,
        CanEnter = function()
            return IsInTrigger(me, PLA_DesireFreedBoxTrigger.Trigger)
        end
    }

    nodes.Action_JumpDown = Action{
        function()
            local jumpFrom = FindValidPosition(PLA_DesirePath_003, 4.0, me, true)
            local jumpTo = FindValidPosition(PLA_DesirePath_004, 4.0, me, true)
            if jumpFrom and jumpTo then
                try 
                    MoveTo(jumpFrom, MovementSpeed.Run)
                    UseSpell("Projectile_PLA_DesireJump", jumpTo, nil, nil, nil, true, true)
                catch e if ls.CheckType(e, error.MovementFailed) or ls.CheckType(e, error.UseSpellFailed) then
                    SteerTo(PLA_DesirePath_003)
                    Sleep(2.0)
                end
            else
                SteerTo(PLA_DesirePath_003)
                Sleep(2.0)
            end
        end,
        Valid = function()
            return IsInTrigger(me, PLA_DesireSideBuilding.Trigger)
        end
    }

    nodes.Action_FleeThroughDoor = Action{
    function()
        helpers.CheckSafePath(pathList)
        Sleep(2.0)
    end,
    Valid = function()
        return ((IsInTrigger(me, PLA_DesireTrappedRoom.Trigger) and
                 mod.items.SafeIsDestroyed(PLA_TavernInvestigation_DesireDoor) or
                 not PLA_TavernInvestigation_DesireDoor.Item.IsLocked)) or
                (not IsInTrigger(me, PLA_DesireTrappedRoom.Trigger) and
                 IsInTrigger(me, PLA_DesireFreedTrigger3.Trigger)) and
               not IsInTrigger(me, PLA_DesireSideBuilding.Trigger)
    end,
    }

    nodes.Escape2 = Action{
        function()
            if mod.items.SafeIsDestroyed(PLA_Tavern_Support3) then
                local successfulJump = false
                local jumpFrom = FindValidPosition(PLA_DesireJumpFromTrigger, 2.0)
                local jumpTo = FindValidPosition(PLA_DesireJumpToTrigger, 2.0)
                if jumpFrom and jumpTo then
                    try 
                        MoveTo(jumpFrom, MovementSpeed.Run)
                        UseSpell("Projectile_PLA_DesireJump", jumpTo, nil, nil, nil, true, true)
                        successfulJump = true
                    catch e if ls.CheckType(e, error.MovementFailed) or ls.CheckType(e, error.UseSpellFailed) then
                        SteerTo(PLA_DesireJumpFromTrigger)
                        Sleep(2.0)
                    end
                end
            end
            if not successfulJump then
                helpers.CheckSafePath(pathListc)
            end
        end,
        Valid = function()
            return IsInTrigger(me, PLA_DesireTrappedRoom.Trigger) and
                   (mod.items.SafeIsDestroyed(PLA_Tavern_Support3) or
                    mod.items.SafeIsDestroyed(PLA_TavernInvestigation_DesireDoor2))
        end
    }
    
    nodes.Action_InRoom = Action{function()
        Sleep(0.5)
        if not IsInDangerousSurfaceFor(PLA_DesireTavernHome, me.Character) then
            if GetDistanceTo(me, PLA_DesireTavernHome) > 4.0 then
                try
                    MoveTo(PLA_DesireTavernHome)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    LookAtEntity(PLA_DesireTavernHome, 3.0)
                    Sleep(2.0)
                end
            else
                LookFrom(PLA_DesireTavernHome)
                PlayAnimation(CUST_TrappedInBurningRoom_01_Loop, false, true)
                if sleepCounter == 0 then
                    StartAutomatedDialog(PLA_Desire_AD_Trapped, true, me)
                    sleepCounter = math.random(4, 6)
                else
                    sleepCounter = sleepCounter - 1
                end
            end
        else
            LookAtEntity(PLA_DesireTavernHome, 3.0)
        end
        Sleep(1.5)
    end,
    Valid = function()
        return IsInTrigger(me, PLA_DesireTrappedRoom.Trigger) and
               not mod.items.SafeIsDestroyed(PLA_Tavern_Support3) and
               not mod.items.SafeIsDestroyed(PLA_TavernInvestigation_DesireDoor2) and
               not mod.items.SafeIsDestroyed(PLA_TavernInvestigation_DesireDoor) and
               PLA_TavernInvestigation_DesireDoor.Item.IsLocked
    end,
    OnLeave = function()
        StopAnimation(me)
    end
    }

    nodes.RunOutPathb = Action{
        function()
            if not DidRecognitionAD then
                if IsInTrigger(PLA_FlamingFist1, PLA_DesireSpotFF.Trigger) and
                    CanSee(me, PLA_FlamingFist1) and
                    not PLA_FlamingFist1.Character.IsDead and
                    not PLA_FlamingFist1.IsInCombat and
                    not PLA_FlamingFist1.Character.IsInteractionDisabled then
                    DidRecognitionAD = true
                    StartAutomatedDialog(PLA_Desire_AD_FF1, true, me, PLA_FlamingFist1)
                elseif IsInTrigger(PLA_FlamingFist2, PLA_DesireSpotFF.Trigger) and
                    CanSee(me, PLA_FlamingFist2) and
                    not PLA_FlamingFist2.Character.IsDead and
                    not PLA_FlamingFist2.IsInCombat and
                    not PLA_FlamingFist2.Character.IsInteractionDisabled then
                    DidRecognitionAD = true
                    StartAutomatedDialog(PLA_Desire_AD_FF2, true, me, PLA_FlamingFist2)
                end
         end
            if IsInTrigger(me, PLA_DesireFreedTrigger4.Trigger) then
                helpers.CheckSafePath(pathListc)
            else
                if not helpers.CheckSafePath(pathListb) then
                    if not playingCoughAnimation then
                        PlayLoopingAnimation(CUST_TrappedInBurningRoom_01_Start, {CUST_TrappedInBurningRoom_01_Loop}, CUST_TrappedInBurningRoom_01_End)
                        playingCoughAnimation = true
                    end
                    Sleep(1.0)
                end
            end
            Sleep(2.0)
        end,
        Valid = function()
            return not IsInTrigger(me, PLA_DesireTrappedRoom.Trigger) and
                   not IsInTrigger(me, PLA_DesireFreedTrigger3.Trigger)
        end,
        OnLeave = function()
            if playingCoughAnimation then
                playingCoughAnimation = false
                StopAnimation(me, false)
            end
        end
    }

end
}