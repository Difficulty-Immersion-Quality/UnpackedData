game.states.PLA_FlamingFist8 = State{
    function ()

        local PLA_FlamingFist8_State_StudyingCorpses = Flag("PLA_FlamingFist8_State_StudyingCorpses_06f81227-b524-44d3-bf1d-911478c2ac52")
        local PLA_FlamingFist8Home = Entity("S_PLA_FlamingFist8Home_25d8f28d-fbf5-4971-bde0-b25cbdebeed1")
        local PLA_FlamingFist8_CorpseBox = Entity("S_PLA_FlamingFist8_CorpseBox_bdbbb67a-19ae-4fd6-86eb-eae30ce864d9")
        local PLA_Tavern_DeadFF6 = Entity("S_PLA_Tavern_DeadFF6_8c93ab9c-9717-4a89-a7df-afbb033436a7")
        local CUST_Kneeling_01 = Animation("CUST_Kneeling_01_02aaa9cc-c087-41d4-ac42-461b51306e5f")

        nodes.ExamineBodies = Action{function()
            LookAtEntity(PLA_FlamingFist8_CorpseBox, 3.0)
            PlayAnimation(CUST_Kneeling_01, false, true)
            --TODO: Remove this once animation is in.
            DebugText(me, "Kneeling down, examining corpse")
            WaitForInterrupt()
            --
        end,
        OnEnter = function()
            SetFlag(PLA_FlamingFist8_State_StudyingCorpses, me)
        end,
        OnLeave = function()
            ClearFlag(PLA_FlamingFist8_State_StudyingCorpses, me)
            StopAnimation(me)
        end,
        Valid = function()
            return IsInTrigger(me, PLA_FlamingFist8Home.Trigger) and
                   (IsInTrigger(PLA_Tavern_DeadFF6, PLA_FlamingFist8_CorpseBox.Trigger))
        end
        }

        nodes.FallBack = Action{
            function()
                if not IsInDangerousSurfaceFor(PLA_FlamingFist8Home, me.Character) then
                    MoveTo(PLA_FlamingFist8Home)
                else
                    Sleep(3.0)
                end
            end
        }

    end
}
