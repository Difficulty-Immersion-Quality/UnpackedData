game.states.PLA_FlamingFists_Outside = State{
    function()
        params.tavernBurning = {type = EParamType.State, help=[[
            What they do while the obstruction is present.
        ]]}

        params.tavernBurnt = {type = EParamType.State, help=[[
            What they do when Desire is freed
        ]]}

        local PLA_TavernInvestigation_Quest_WallCollapsed
        local PLA_FlamingFists_State_WatchingTavern
        local PLA_TavernInvestigation_State_BurntDown = Flag("PLA_TavernInvestigation_State_BurntDown_ad34c392-4499-402c-ae51-8c3d40985f8b")


        self.OnInit = function()
            PLA_TavernInvestigation_Quest_WallCollapsed = Flag("PLA_TavernInvestigation_Quest_WallCollapsed_391d017d-cbfb-768a-086d-ea404313eab4")
            PLA_FlamingFists_State_WatchingTavern = Flag("PLA_FlamingFists_State_WatchingTavern_175f93d0-cd59-4f13-b66d-3d8cce3818b1")
        end

        nodes.EverythingBurntDown = Proxy{
            params.tavernBurnt,
            Valid = function()
                return GetFlag(PLA_TavernInvestigation_State_BurntDown)
            end
        }

        nodes.EverythingBurning = Proxy{
            params.tavernBurning,
            CanEnter = function()
                return not GetFlag(PLA_TavernInvestigation_State_BurntDown)
            end
        }

    end
}
