game.states.PLA_GithChokepoint_Confrontation = State { function ()
    description = [[Block further behaviours on the githyanki once the confrontation starts. The knight doesn't need it because he's not part of the combat following the confrontation]]

    params.defaultBehaviour = {
        type = EParamType.State, required = true,
        help = [[Pass the githyanki's default behaviour.]]
    }

    -----------------------------------------
    -- Local variables
    local confrontationOngoingFlag = Flag("PLA_GithChokepoint_State_ConfrontationIsOngoing_9c3fc7db-3ac3-4b6d-b895-106601db5d4a")
    local githKnight = Entity("S_GLO_GithKnight_2adce2df-0799-49dc-b867-ba7ca21e9aea")

    -----------------------------------------
    -- State nodes
    nodes.OngoingConfrontation = Action {
        CanEnter = function()
            return GetFlag(confrontationOngoingFlag)
        end,
        function()
            SteerTo(githKnight)
            Sleep(5)
        end
    }

    nodes.DefaultBehaviour = Proxy {
        params.defaultBehaviour
    }
end}
