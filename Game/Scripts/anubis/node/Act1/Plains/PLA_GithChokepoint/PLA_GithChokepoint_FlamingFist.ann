game.roots.PLA_GithChokepoint_FlamingFist = State { function ()
    description = [[They loop an animation until they die. They do absolutely nothing else so giving them a DefaultCharacter root would be too much.]]

    params.idle = {type = EParamType.State, help=[[
        Default behaviour that will be executed when not in combat or otherwise blocked (moving for items, generic behaviours and certain status for characters)
    ]]}

    nodes.Idle = Proxy{
        OnEnter = function()
            SetDoNotFace(me, true)
            SetWeaponUnsheathed(me, true)
        end,
        params.idle
    }
end}
