game.states.PLA_PersistentFlame = State {
    function ()

        params.expandFire = {type = EParamType.Bool, default = false, 
        help=[[Should this flame create a fire surface around it?]]}

        self.OnInit = function()
            local flame = PrepareEffect("VFX_LightSources_PLA_Fire_PersistentFlame_A_01_4a29a9fc-c6a3-cf4e-a0a5-0c7d5375f0ab")
            PlayEffectAt(flame, me)
        end

        nodes.CreateFlame = Action {
            function()
                Sleep(1.5)
                CreateSurfaceAt(me, SurfaceType.FIRE, 2.0, -1.0)
                Sleep(1.5)
                CreatePuddleAt(me, SurfaceType.FIRE, 20, 30, 10, 15, 0.1, -1.0, nil)                
                Sleep(1.5)
                CreatePuddleAt(me, SurfaceType.FIRE, 20, 30, 10, 15, 0.1, -1.0, nil)                
                Sleep(1.5)
            end,
            CanEnter = function()
                return params.expandFire and not FindSurface(me, 0.0, 1.0, SurfaceType.FIRE, 100)
            end
        }

        nodes.Sleep = Action {
            function()
                Sleep(2.0)
            end,
            CanEnter = function()
                return not params.expandFire or FindSurface(me, 0.0, 1.0, SurfaceType.FIRE, 100) ~= nil
            end
        }


    end
}