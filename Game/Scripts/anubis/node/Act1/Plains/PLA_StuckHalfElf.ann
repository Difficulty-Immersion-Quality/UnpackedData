                                 Entity("S_PLA_HalfElfPath_005_95685d4a-4895-4ad5-9de4-3ef8bf6700c0"),
                                 Entity("S_PLA_HalfElfPath_006_a0eb211a-2516-4c0f-a1d8-5c1c5e9ebe20"),
                                 Entity("S_PLA_HalfElfPath_007_5ec8f5f9-b4ef-40fb-9351-53518f5f0a5a"),
                                 Entity("S_PLA_HalfElfPath_008_3d33aebf-439d-4de2-b382-4413e0376ae8"),
                                 Entity("S_PLA_HalfElfPath_009_eb24301c-5e13-43bf-ba38-30b44381d713"),
                                 Entity("S_PLA_HalfElfPath_010_cba73ead-edfc-4a23-8147-9480a31bd8eb"),
                                 Entity("S_PLA_HalfElfPath_011_ebabf4fb-0568-48da-b3a2-7c67a434b1f2"),
                                 Entity("S_PLA_HalfElfPath_012_1e1946e0-c6f6-4ba4-88ed-833b500f6891"),
                                 Entity("S_PLA_HalfElfPath_013_c0e82ac7-30d9-4c72-8d8a-7c36eeeed487"),
                                 Entity("S_PLA_HalfElfPath_015_96876829-5f6d-468c-b34c-ebe6cd211f97"), -- 
                                 Entity("S_PLA_HalfElfPath_016_38be3f7c-9988-4818-84ba-bc12e4bb5e3c"), --'Out of order' to make sure the character picks the closest point
                                 Entity("S_PLA_HalfElfPath_017_87c2e7da-661a-4446-87d0-fff2052917c0"), --
                                 Entity("S_PLA_HalfElfPath_014_ac1aa980-ebad-4d7e-83c9-db48355c3f89")}
    local outsideTriggerList = {Entity("S_PLA_StuckHalfElf_OutsideTrigger01_8eeba639-9a9f-410f-88ad-b571d48402a9"),
                                Entity("S_PLA_StuckHalfElf_OutsideTrigger02_a9339d1d-7c55-4dde-8a5b-6bc3cbbc801b"),
                                Entity("S_PLA_StuckHalfElf_OutsideTrigger03_6672de90-8554-469e-b871-3501730fbf45"),
                                Entity("S_PLA_StuckHalfElf_OutsideTrigger04_2ff39f40-d96c-4b1b-9414-fdbb3d9947c1"),
                                Entity("S_PLA_StuckHalfElf_OutsideTrigger05_d9919843-8b77-43cd-ba01-da298e8e89ff")}
    local PLA_StuckHalfElf_FreedTrigger = Entity("S_PLA_StuckHalfElf_FreedTrigger_37541d1f-d461-4411-8704-af2e767908f5")
    local outsideIndex = 1
    local PLA_Tavern_DeadCiv1 = Entity("S_PLA_Tavern_DeadCiv1_1ed658d0-e88a-4b7b-ab9e-1e520ae7d0c7")
    local didWifeAD = false
    local PLA_StuckHalfElf_AD_FoundWife = Dialog("PLA_StuckHalfElf_AD_FoundWife_6adb5eee-75c1-ce5f-8e8f-b2f25a13b8d0")
    local PLA_StuckHalfElf_AD = Dialog("PLA_StuckHalfElf_AD_fd8a9193-0d8f-670d-76e6-a42039861d3d")
    local PLA_StuckHalfElf_State_FireStarted = Flag("PLA_StuckHalfElf_State_FireStarted_2785238e-5a98-4b39-b668-f26885a8db8d")
    local PLA_TavernInvestigation_State_HalfElfFoundWife = Flag("PLA_TavernInvestigation_State_HalfElfFoundWife_6cd9377b-e300-4396-94d0-c537fd193a48")
    local PLA_StuckHalfElf_TavernBox = Entity("S_PLA_StuckHalfElf_TavernBox_fc69dced-9f44-4760-9378-8598b4a9e859")
    local PLA_StuckHalfElf_State_HeadingToWife = Flag("PLA_StuckHalfElf_State_HeadingToWife_3eb6d0dd-cb93-cc29-f6e5-bbb7a9b27aea")
    local PLA_StuckHalfElf_NearWifeCorpse  = Entity("S_PLA_StuckHalfElf_NearWifeCorpse_cd059bea-aaef-48a5-94c7-2ba01ed91bc9")
    local PLA_StuckHalfElf_AD_Searching = Dialog("PLA_StuckHalfElf_AD_Searching_04dd48e4-7d45-5042-e363-f627bc0d455c")
    local PLA_StuckHalfElf_Room1Box = Entity("S_PLA_StuckHalfElf_Room1Box_98660638-e875-49d4-a0b0-95d39ae56728")
    local PLA_StuckHalfElf_Room2Box = Entity("S_PLA_StuckHalfElf_Room2Box_4b69d9af-c776-4fdc-86bd-bfb52bb3b0ad")
    local PLA_TavernInvestigation_RoomDoor2 = Entity("S_PLA_TavernInvestigation_RoomDoor2_f4ad4ed3-5906-47a4-b874-20c7c96780d0")
    local PLA_TavernInvestigation_RoomDoor3 = Entity("S_PLA_TavernInvestigation_RoomDoor3_9fff6aeb-8bd1-43bd-b215-ef218729e0b1")
    local CUST_PanicLookingAround_01 = Animation("CUST_PanicLookingAround_01_988e60aa-11f3-49b7-8de5-aa9f20cdc9dc")
    local CUST_KneelingCrying_01_Loop = Animation("CUST_KneelingCrying_01_Loop_9ea4a039-0c6c-4b5a-8d56-6a1bb64aa602")
    local PLA_StuckHalfElf_State_OneFailed = Flag("PLA_StuckHalfElf_State_OneFailed_adfb15af-33a3-541d-480b-5fed6f21684a")
    local PLA_StuckHalfElf_HallwayBox = Entity("S_PLA_StuckHalfElf_HallwayBox_2c1870aa-5873-4329-905b-87fd6b9df0a0")

    modules = {"shared.dialog", "shared.moveto", "shared.items" }

    helpers.action.CheckSafePath = function(list) --TODO: Replace with a nicer way to check if there's a clear path.
        local bestDistance = GetDistanceTo(me, list[1])
        local bestTrigger = 1
        for i = 2, #list, 1 do
            local currentDistance = GetDistanceTo(me, list[i])
            if currentDistance < bestDistance then
                bestDistance = currentDistance
                bestTrigger = i
            end
        end
        DebugText(me, "best trigger: [1]", list[bestTrigger].Name)
        for i = #list, bestTrigger, -1 do
            if not IsInDangerousSurfaceFor(list[i], me.Character) then
                local foundpoint = false
                try
                    MoveTo(list[i], MovementSpeed.Run)
                    foundpoint = true
                catch e if ls.CheckType(e, error.MovementFailed) then
                    DebugText(me, "Can't move [1]", tostring(e))
                end
                if foundpoint then
                    break
                end
            end 
        end
    end

    events.StatusApplied = function(e)
        if e.Status.StatusID == "PLA_PINNEDUNDERBEAM" and
           me.Active and
           not GetFlag(PLA_StuckHalfElf_State_OneFailed) then
            StartTimer(me, "PLA_StuckHalfElf_StuckAD", 20, 0)
        end
    end

    events.StatusRemoved = function(e)
        if e.Status.StatusID == "PLA_PINNEDUNDERBEAM" and
           not GetFlag(PLA_StuckHalfElf_State_OneFailed) then
            StopTimer(me, "PLA_StuckHalfElf_StuckAD")
        end
    end

    events.Activated = function(e)
        if HasActiveStatus(me, "PLA_PINNEDUNDERBEAM") and
           not GetFlag(PLA_StuckHalfElf_State_OneFailed) then
            if GetFlag(PLA_StuckHalfElf_State_FireStarted) then
                StartTimer(me, "PLA_StuckHalfElf_StuckAD", 5.0*math.random()+5.0, 0)
            else
                StartTimer(me, "PLA_StuckHalfElf_StuckAD", 20.0*math.random()+20.0, 0)
            end
        end
    end

    events.Deactivated = function(e)
        if HasActiveStatus(me, "PLA_PINNEDUNDERBEAM") and
           not GetFlag(PLA_StuckHalfElf_State_OneFailed) then
            StopTimer(me, "PLA_StuckHalfElf_StuckAD")
        end
    end

    events.FlagSet = function(e)
        if e.Flag == PLA_StuckHalfElf_State_FireStarted.Guid and
           HasActiveStatus(me, "PLA_PINNEDUNDERBEAM") and 
           me.Active and
           not GetFlag(PLA_StuckHalfElf_State_OneFailed) then
            StartAutomatedDialogImmediate(PLA_StuckHalfElf_AD, me)
            StopTimer(me, "PLA_StuckHalfElf_StuckAD")
            StartTimer(me, "PLA_StuckHalfElf_StuckAD", 5.0*math.random()+5.0, 0)
        elseif e.Flag == PLA_StuckHalfElf_State_OneFailed.Guid and
               HasActiveStatus(me, "PLA_PINNEDUNDERBEAM") and 
               me.Active then
                StopTimer(me, "PLA_StuckHalfElf_StuckAD")
        end
    end

    events.TimerFinished = function(e)
        if e.TimerName == "PLA_StuckHalfElf_StuckAD" and
           HasActiveStatus(me, "PLA_PINNEDUNDERBEAM") and
           not GetFlag(PLA_StuckHalfElf_State_OneFailed) then
            if mod.dialog.IsSpeakerAvailable(me) then
                StartAutomatedDialogImmediate(PLA_StuckHalfElf_AD, me)
            end
            StartTimer(me, "PLA_StuckHalfElf_StuckAD", 20.0*math.random()+20.0, 0)
        end
    end

    nodes.FoundWife = Action{
        function()
            if (GetDistanceTo(me, PLA_Tavern_DeadCiv1) < 15) or
               (IsInTrigger(me, PLA_StuckHalfElf_FreedTrigger.Trigger) and
                IsInTrigger(PLA_Tavern_DeadCiv1, PLA_StuckHalfElf_FreedTrigger.Trigger)) then
                if not didWifeAD then
                    SteerTo(PLA_Tavern_DeadCiv1)
                    PlayAnimation(CUST_KneelingCrying_01_Loop, false, true)
                    StartAutomatedDialog(PLA_StuckHalfElf_AD_FoundWife, true, me)
                    didWifeAD = true
                end
                if not IsInDangerousSurfaceFor(PLA_Tavern_DeadCiv1, me.Character) then
                    if GetDistanceTo(me, PLA_Tavern_DeadCiv1) > 4 then
                        try
                            MoveTo(PLA_Tavern_DeadCiv1, MovementSpeed.Run)
                            
                        catch e if ls.CheckType(e, error.MovementFailed) then
                            --Sleep further down will delay another attempt.
                        end
                    else
                        SteerTo(PLA_Tavern_DeadCiv1)
                        PlayAnimation(CUST_KneelingCrying_01_Loop, false, true)
                    end
                end
            end
            Sleep(4.0)
        end,
        CanEnter = function()
            return GetFlag(PLA_TavernInvestigation_State_HalfElfFoundWife) and
                   not IsInTrigger(me, PLA_StuckHalfElf_TavernBox.Trigger)
        end
    }


    nodes.GoFindWife = Action{
        function()
            if IsInTrigger(me, PLA_StuckHalfElf_NearWifeCorpse.Trigger) then
                Wander(PLA_StuckHalfElf_NearWifeCorpse, 5.0, MovementSpeed.Sprint)
                Sleep(1.0)
            else
                mod.moveto.MoveTo(PLA_StuckHalfElf_NearWifeCorpse, true, 1.5, "Sprint", "", 4.0, true)
                Sleep(1.5)
            end
        end,
    CanEnter = function()
        return GetFlag(PLA_StuckHalfElf_State_HeadingToWife, me) and 
               not IsInTrigger(me, PLA_StuckHalfElf_TavernBox.Trigger)
    end,
    Valid = function()
        return not GetFlag(PLA_TavernInvestigation_State_HalfElfFoundWife)
    end
    }

    nodes.FleeHallway = Action {
        function()
            Sleep(1.0)
            helpers.CheckSafePath(triggerList3)
        end,
        CanEnter = function()
            return IsInTrigger(me, PLA_StuckHalfElf_HallwayBox.Trigger)
        end
    }

    nodes.FleeRoom1 = Action{
        function()
            if mod.items.SafeIsDestroyed(PLA_TavernInvestigation_RoomDoor3) then
                helpers.CheckSafePath(triggerList3)
            elseif mod.items.SafeIsDestroyed(PLA_TavernInvestigation_RoomDoor2) then
                helpers.CheckSafePath(triggerList2)
            else --TODO here: add alternative to run through door3.
                helpers.CheckSafePath(triggerList)
            end
        end,
        CanEnter = function()
            return not IsInTrigger(me, PLA_StuckHalfElf_FreedTrigger.Trigger) and
                   IsInTrigger(me, PLA_StuckHalfElf_Room1Box.Trigger)
        end
    }

    nodes.FleeRoom2 = Action{
        function()
                helpers.CheckSafePath(pathList)
        end,
        CanEnter = function()
            return not IsInTrigger(me, PLA_StuckHalfElf_FreedTrigger.Trigger) and
                   IsInTrigger(me, PLA_StuckHalfElf_Room2Box.Trigger)
        end
    }

    nodes.FleeMainRoom = Action{
        function()
            Sleep(1.0)
            helpers.CheckSafePath(triggerListMainRoom)
        end,
        CanEnter = function()
            return not IsInTrigger(me, PLA_StuckHalfElf_FreedTrigger.Trigger) and
                   not IsInTrigger(me, PLA_StuckHalfElf_Room1Box.Trigger) and
                   not IsInTrigger(me, PLA_StuckHalfElf_Room2Box.Trigger)
        end
    }

    nodes.Fled = Action{
        function()
            try
                if not IsInDangerousSurfaceFor(outsideTriggerList[outsideIndex], me.Character) then
                    MoveTo(outsideTriggerList[outsideIndex], MovementSpeed.Run)
                    LookFrom(outsideTriggerList[outsideIndex])
                    StartAutomatedDialog(PLA_StuckHalfElf_AD_Searching, false, me)
                end
                    PlayAnimation(CUST_PanicLookingAround_01, true, false)
                    if outsideIndex < 5 then
                        outsideIndex = outsideIndex + 1
                    else
                        outsideIndex = 1
                    end
            catch e if ls.CheckType(e, error.MovementFailed) then
                PlayAnimation(CUST_PanicLookingAround_01)
                LookAtEntity(outsideTriggerList[outsideIndex], 3.0)
            end
        end,
        CanEnter = function()
            return IsInTrigger(me, PLA_StuckHalfElf_FreedTrigger.Trigger)
        end
    }

end
}