game.states.PLA_StuckHalfElf_Backdraft = State {
    function ()
        
        local effect

        self.OnInit = function()
            effect = PrepareEffect("VFX_Environment_DoorBackdraft_01_3c27bf39-ed05-9193-333a-846adb8b33c5")
        end

        events.EntityEvent = function(e)
            if e.TargetEntity == me then
                if e.Event == "PLA_StuckHalfElf_Backdraft" then
                    DebugText(me, "Shooting spell")
                    PlayEffectAt(effect, me)
                    ShootZone("Zone_PLA_StuckHalfElf_Backdraft", me, ls.math.Vector3(0, 0, 0),  me.ForwardDirection)
                end
            end
        end

        nodes.Sleep = Action {
            function()
                WaitForInterrupt()
            end
        }


    end
}