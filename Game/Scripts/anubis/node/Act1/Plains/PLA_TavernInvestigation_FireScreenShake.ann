game.states.PLA_TavernInvestigation_FireScreenShake = State{
    function()
        modules = {"shared.util"}

        self.OnEnter = function()
            SetVisible(me, false)
        end

        -- Triggers screen shakes around the tavern
        nodes.Action_ScreenShake = Action{
            function()
                mod.util.SleepRandom(6.0, 12.0)
                if FindSurface(me, 0.0, 3.0, SurfaceType.FIRE, 30) then
                    SetEntityEvent(me, "PLA_TavernInvestigation_FireCameraShake")
                end
            end
        }
    end
}