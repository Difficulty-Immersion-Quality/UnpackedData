game.expressions.PLA_ZhentDungeon_DetectDarkness = Expression{

    ttl = 0.3,

    function() -- Evaluator function
        if not me.OnStage then
            return false
        end
        return (GetObscuredState(me) == ObscuredState.HeavilyObscured)--: receiving Variant<Entity, float3> and returning enum
    end,
    -- Argument types, must be exactly the number of arguments in the evaluator function, where ... is counted as
    -- one argument (all params to be plugged into those args should have this type)
    args = {},
    -- Result type
    --
    -- Will be validated in run-time, so choose wisely
    --
    -- Optional. EParamType.Bool by default
    result = EParamType.Bool
}


game.states.PLA_ZhentDungeon_DarknessDetector = State{

    function()

        local PLA_ZhentDungeon_State_EntranceDarknessDetected = Flag("PLA_ZhentDungeon_State_EntranceDarknessDetected_27ff4aba-e2b9-4e0f-aef8-a27777d77f1a")
        local PLA_ZhentDungeon_State_FallBack = Flag("PLA_ZhentDungeon_State_FallBack_7a94f079-2bc8-495e-99f2-5b04b03a7d1d")

        local primed = false --These objects react to the light disappearing, but the light appears after this object initiates, so we wait for the area to be illuminated.
        params.activeCheck = {type = EParamType.Bool, help=[[
            Takes an expression that is true when the light is out.
        ]]}
        nodes.WaitForPrime = Action{
            function()
                WaitForInterrupt()
            end,
            Valid = function()
                return params.activeCheck and
                       not primed
            end 
        }
        nodes.Prime = Action{
            function()
                DebugText(me, "Primed!")
                primed = true
            end,
            CanEnter = function()
                return not primed
                       and not params.activeCheck
                       
            end
        }

        nodes.Disappear = Action{
            function()
                SetOnStage(me, false)
                WaitForInterrupt()
            end,
            CanEnter = function()
                return GetFlag(PLA_ZhentDungeon_State_EntranceDarknessDetected) or
                       GetFlag(PLA_ZhentDungeon_State_FallBack)
            end
        }

        nodes.Activate = Action{
            function()
                SetFlag(PLA_ZhentDungeon_State_EntranceDarknessDetected, nil)
            end,
            CanEnter = function()
                return params.activeCheck
            end
        }

        nodes.Wait = Action{
            function()
                WaitForInterrupt()
            end,
            Valid = function()
                return not params.activeCheck and
                       not GetFlag(PLA_ZhentDungeon_State_EntranceDarknessDetected) and
                       not GetFlag(PLA_ZhentDungeon_State_FallBack)
            end
        }

        events.LevelLoaded  = function(e)
            primed = false
        end


    end
}
