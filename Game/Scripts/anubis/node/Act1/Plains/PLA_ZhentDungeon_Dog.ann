game.states.PLA_ZhentDungeon_Dog = State{
    function ()

        params.master = {type = EParamType.String, help=[[
            The dog's master
        ]]} 

        local master

        self.OnInit = function()
            master = FindEntity(params.master)
        end

        nodes.FollowMaster = Action{
            function()
                if not IsInDangerousSurfaceFor(master, me.Character) then                        
                    local distance = GetDistanceTo(master, me)
                    if distance > 4.0 then
                        if distance > 6.0 then
                            try
                                MoveTo(master, MovementSpeed.Sprint, false, true, 2.0, 4.0)
                            catch e if ls.CheckType(e, error.MovementFailed) then
                                LookAtEntity(master, 3.0)
                                Sleep(2.0)
                            end
                        else
                            try
                                MoveTo(master, MovementSpeed.Walk, false, true, 2.0, 4.0)
                            catch e if ls.CheckType(e, error.MovementFailed) then
                                LookAtEntity(master, 3.0)
                                Sleep(2.0)
                            end
                        end
                    else
                        if math.random() < 0.5 then
                            LookAtEntity(master, 3.0)
                            Sleep(5.0) --Look at master.
                        else
                            try
                                Wander(2.0, 2.0, MovementSpeed.Run, master) --I am excited!
                            catch e if ls.CheckType(e, error.MovementFailed) then
                                LookAtEntity(master, 3.0)
                                Sleep(2.0)
                            end
                            LookAtEntity(master, 3.0)
                            Sleep(3.0) --Look at master.
                        end
                    end
                else
                    LookAtEntity(master, 3.0)
                    Sleep(3.0)
                end
            end
        }

    end
}


