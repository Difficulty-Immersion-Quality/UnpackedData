game.states.PLA_ZhentDungeon_Dog_03 = State{
    function()

        local PLA_ZhentDungeon_Dog_03_Home

        local animation = Animation("CUST_LayOnGround_01_d5c91bea-432f-4b56-918c-f9460a4c7023")

        self.OnInit = function()
            PLA_ZhentDungeon_Dog_03_Home = FindEntity("S_PLA_ZhentDungeon_Dog_03_Home_e5a6a6a7-918c-4131-82bf-6f7d183bf8a1")
        end

        nodes.LieDown = Action{function()
            if not IsInDangerousSurfaceFor(PLA_ZhentDungeon_Dog_03_Home, me.Character) then
                if GetDistanceTo(me, PLA_ZhentDungeon_Dog_03_Home) > 2.0 then
                    try
                        MoveTo(PLA_ZhentDungeon_Dog_03_Home)
                        LookFrom(PLA_ZhentDungeon_Dog_03_Home)
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        LookAtEntity(PLA_ZhentDungeon_Dog_03_Home, 3.0)
                        Sleep(8.0)
                    end
                else
                    PlayAnimation(animation, false, true)
                    WaitForInterrupt()
                end
            else
                LookAtEntity(PLA_ZhentDungeon_Dog_03_Home, 3.0)
                PlayAnimation(animation, false, true)
                Sleep(8.0)
            end
            Sleep(15.0)
        end
        }

    end
}