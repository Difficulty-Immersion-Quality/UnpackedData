game.states.PLA_ZhentDungeon_SecretWall =  State{function ()

    description = [[Object glows up if an Investigation check is passed.]]

    params.minDistance = {type = EParamType.Number, required=false, default=3.0, help=[[
        minimum distance that players are required to be in
    ]]}

    local discovered = false
    local failedPlayers = {}
    local activeEffect

    nodes.MyAction = Action{
        function()
            WaitForInterrupt()
        end
    }

    events.Activated = function()
        if not discovered then
            StartTimer(me, "CheckSight", 0.5, -1)
        end
    end

    events.Deactivated  = function(_) 
        if not discovered then
            StopTimer(me, "CheckSight")
        end
    end

    events.TimerFinished  = function(e)
        if e.TimerName == "CheckSight" then
            local actives = GetActiveCharacters(me, 10.0)
            for _,char in pairs(actives) do
                DebugLog("Wall Timer Tick on"..char.Name)
                if char.Character.IsPlayer and
                   not failedPlayers[char.UUID.String] then
                    failedPlayers[char.UUID.String] = true
                    SetEntityEvent(char, "PLA_CheckInvestigation", me)
                         --TODO: Change to a passive check from Anubis.
                end
            end
        end
    end

    events.EntityEvent = function(e)
        if e.Event == "PLA_ZhentWallReveal" then
            StopTimer(me, "CheckSight")
            discovered = true
            local discoveredEffect = PrepareEffect("VFX_Script_Perception_Default_01_46bd169e-bbb5-a6fe-0fe7-97c64f620d5d")
            activeEffect = PlayEffectAt(discoveredEffect, me)
        elseif e.Event == "PLA_ZhentLiftAreaEntered" then
            if not discovered then
                StopTimer(me, "CheckSight")
                discovered = true
            end
            if activeEffect ~= nil then
                StopEffect(activeEffect)
            end            
        end
    end
end
}
    