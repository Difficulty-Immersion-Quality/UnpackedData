game.states.PLA_ZhentDungeon_Zhent08 = State{
    function()

        local PLA_ZhentDungeon_Zhent08_Rope01 = Entity("S_PLA_ZhentDungeon_Zhent08_Rope01_5c01c1f8-a297-4e82-a1fc-bdf5d3f5cab9")
        local PLA_ZhentDungeon_Zhent08_Rope02 = Entity("S_PLA_ZhentDungeon_Zhent08_Rope02_28cbafac-9d4c-431c-985e-90d26801fdb0")
        local PLA_ZhentDungeon_Zhent08_Patrol = Spline("S_PLA_ZhentDungeon_Zhent08_Patrol_2b587689-e997-4063-a4a3-0380d9f9407b")
        local ropeAnim = Animation("CUST_CheckingBridgeRope_01_34552f2b-3477-487d-9c32-9b58624bb8b2")

        local checkRopes = false

        self.Valid = function()
            return checkRopes
        end

        nodes.Action_CheckRopes = Action{
            function()

                local ropePos
                if math.random() > 0.5 then
                    ropePos = PLA_ZhentDungeon_Zhent08_Rope01
                else
                    ropePos = PLA_ZhentDungeon_Zhent08_Rope02
                end

                if not IsInDangerousSurfaceFor(ropePos, me.Character) then
                    try
                        MoveTo(ropePos)
                        LookFrom(ropePos)
                        PlayAnimation(ropeAnim)
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        LookAtEntity(ropePos, 3.0)
                        Sleep(2.0)
                    end
                end

                checkRopes = false
            end
        }

        events.SplineControlPointReached = function(e)
            if e.Event == "PLA_ZhentDungeon_CheckRopes" then
                checkRopes = true
            end
        end
    end
}