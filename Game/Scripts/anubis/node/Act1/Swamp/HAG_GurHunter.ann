game.states.HAG_GurHunter = State{function()

    local defaultPos = Entity("S_HAG_GurHunter_Pos_62a28c12-7fd0-4027-b354-98491e3dd1a6")
    local fl_DisappearOutOfSight = Flag("HAG_GurHunter_DisappearOutOfSight_4f8326fa-2636-43f8-b62e-4c086b0d6efe")
    local fl_BackpackHandled = Flag("HAG_GurHunter_BackpackHandled_69e772f5-ed4c-4565-9697-47c1c9eb1bba")
    
    nodes.DisappearOutOfSight = Action{
        function()
            SetFlag(Flag("GEN_DisappearOutOfSight_5dc33889-cbfb-c3d2-9e4e-8d826bf8566f"), me)            
            WaitForInterrupt()
        end,
        Valid = function()
            return GetFlag(fl_DisappearOutOfSight, me) and GetFlag(fl_BackpackHandled, nil)
        end
   }

    nodes.Default = Action{
        function()
            if (GetDistanceTo(me, defaultPos) > 1.0) then
                try
                    MoveTo(defaultPos)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    DebugText(me, "Debug : Movement failed")
                end
            end
            LookFrom(defaultPos)
            Sleep(5.0)
        end
   }

end
}