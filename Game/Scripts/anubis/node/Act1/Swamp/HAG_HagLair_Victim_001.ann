game.states.HAG_HagLair_Victim_001 = State{
    function ()
        

        local HAG_Hag_SummonedVictims = Flag("HAG_Hag_SummonedVictims_755d8269-7864-b72c-f355-b00aa02cd17e")
        local HAG_Hag_State_HagGivenMercy = Flag("HAG_Hag_State_HagGivenMercy_a3c0a36a-ccce-4f35-7b54-9ab22d6ac534")
        local HAG_Hag_State_IsDead = Flag("HAG_Hag_State_IsDead_781391e2-7d33-642d-28c0-e9b06cde32bb")

        nodes.WaitForPlayer = Action{
            function()
                WaitForInterrupt()
            end,
            CanEnter = function()
                return GetFlag(HAG_Hag_SummonedVictims) or
                       GetFlag(HAG_Hag_State_HagGivenMercy) or
                       GetFlag(HAG_Hag_State_IsDead)
            end
        }

        nodes.ReturnHome = Proxy{
            game.states.GLO_StandAtTrigger,
            params = {trigger = [[S_HAG_HagLair_Victim_001_Home_2a2f67b4-d523-4674-8b83-b2879c7e77d6]]},
            CanEnter = function()
                return not GetFlag(HAG_Hag_SummonedVictims) and
                       not GetFlag(HAG_Hag_State_HagGivenMercy) and
                       not GetFlag(HAG_Hag_State_IsDead)
            end
        }

    end
}
