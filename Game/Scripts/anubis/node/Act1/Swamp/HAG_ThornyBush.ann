game.states.HAG_ThornyBush = State{function()
    description = [[State for the Thorny Bushes in the hag's swamp]]

    local stealFruitEvent = "HAG_StealFruitFromBush"
    local stealPenaltyStatus = "HAG_SMALLCUT"

    nodes.Idle = Action{
        function()
            WaitForInterrupt()
        end
    }

    events.UseStarted = function(e)
        RequestPassiveRoll(e.User.Character, me, Skill.SleightOfHand, DifficultyClass("DC_Legacy_10_625be976-7a67-4394-97c8-14c69715ae4b"), stealFruitEvent)
    end

    events.RollResult = function(e)
        if  e.RollSubject == me and
            e.Event == stealFruitEvent and
            e.Type == RollResultType.Failure then 
                ApplyStatus(e.Roller, stealPenaltyStatus, true, 60)
        end
    end
end}