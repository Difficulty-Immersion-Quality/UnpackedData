game.states.UND_DuergarCamp_Spiders = State{function()
    description=[[Behaviours for Spiders in Ketheric City]]

    modules = {"shared.util","shared.math","shared.moveto"}
    --flags
    local UND_Spiderfight_Aggro = Flag("GLO_UND_SpiderFight_Aggro_c929e223-1daa-78f8-cbe8-689e331cf12a")
    local UND_Spiderfigth_Leave = Flag("GLO_UND_SpiderFight_SpidersLeave_c35dd327-908d-1ef0-be2f-bc9cbd65aea9")
    --animations
    local angryStart = Animation("CUST_Angry_01_Start_ebe25dce-800f-4662-ac29-ba2adc5b36b6")
    local angryLoop = {Animation("CUST_Angry_01_Loop_4b288089-9bad-477b-909b-10aa79e5a370")}
    local angryEnd = Animation("CUST_Angry_01_End_ee31d4d8-00bd-4ff7-8c21-c1698022c4e2")
    --Entities
    local leadSpider = Entity("S_UND_DuergarLoyalPatroller_01_Spider_01_82f367a2-14c0-46cf-82d1-f070c87cf95a")
    -- Nodes

    --Having AD dialog with the lead spider, and periodically get angry and calm down
    nodes.Argue = Action{
        function()
            LookAtEntity(leadSpider, 3.0)
            mod.util.SleepRandom(1.0,6.0)
            --go into angry animation loop
            DebugText(me, "Animation: Angry posturing")
            PlayLoopingAnimation(angryStart, angryLoop, angryEnd,false)
            mod.util.SleepRandom(1.0,6.0)
            --Go back to regular idle
            StopAnimation(me)
            DebugText(me, "Animation: back to idle")
        end,
        Valid = function()
            return not GetFlag(UND_Spiderfight_Aggro, nil) and not GetFlag(UND_Spiderfigth_Leave, nil)
        end        
    }

    
    nodes.PostFight = Action{
        function()
            if GetDistanceTo(me,leadSpider)>1.0 then
                local moveResult = MoveTo(leadSpider,MovementSpeed.Walk,true,false,1.0,2.0,false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Movement to wait position failed")
                    Sleep(2.0)
                end
            end
            LookAtEntity(leadSpider, 3.0)
            DebugText(me,"Devouring animation looping")
            mod.util.SleepRandom(2.0,5.0)
        end,
        Valid = function()
            return GetFlag(UND_Spiderfight_Aggro, nil) and not GetFlag(UND_Spiderfigth_Leave, nil)
        end        
    } 

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end
    }

end}