game.states.UND_DuergarPatroller_01 = State{function()
    params.patrolSpline = {type=EParamType.String, help="Patrol spline"}

    modules = { "shared.util","shared.math" }

    local patrolSpline
    local lookFromSpline = false
    local currentSplinePoint = 0

    self.OnInit = function()
        patrolSpline = Spline(params.patrolSpline)
    end


    nodes.Action_LookFromSpline = Action{
        function()
           LookFrom(patrolSpline)
           mod.util.SleepRandom(2.0,6.0)
           lookFromSpline = false
        end,
        CanEnter = function()
            return lookFromSpline
        end
    }

    nodes.Action_Patrol = Action{
        function()
            DoPatrol(patrolSpline, false, MovementSpeed.Walk)
        end,
        Valid = function()
            return patrolSpline ~= nil and not lookFromSpline
        end
    }

    nodes.Action_Fallback = Action{
        function()
            Sleep(5.0)
        end
    }

    events.SplineControlPointReached = function(ev)
        lookFromSpline = true
    end
end}