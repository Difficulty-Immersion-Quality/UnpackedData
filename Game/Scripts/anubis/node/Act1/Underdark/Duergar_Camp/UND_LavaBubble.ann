game.states.UND_LavaBubble = State{function()
    description = [[Behaviour for the lava bubble hazards in Ketheric City]]

    self.OnInit = function()
        ApplyStatus(me, "UND_LAVABUBBLE", true, 6.0, me)
    end

    nodes.WaitToBurst = Action{
        function()
            WaitForInterrupt()
        end
    }

    events.StatusRemoved = function(e)
        if e.Status.StatusID == "UND_LAVABUBBLE" and not me.Item.IsDestroyed then
            Die(me, DeathType.EXPLODE, me, false, true)
        end
    end
end}