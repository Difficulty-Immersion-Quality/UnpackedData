game.states.UND_AdamantineForge_LavaDrawer = State{
    function()

        local startPoint = Entity("S_UND_AdamantineForge_LavaPourLoopPoint_55e67f17-7f79-4685-85a4-d1ab2a0391f9")
        local outsideArea = Entity("S_UND_AdamantineForge_FloodTrigger_Out_165507de-6d49-43e3-88f9-6cee70a050dd")
        local insideStartPoint = Entity("S_UND_AdamantineForge_LavaSurface2c_31bba918-aaf9-4daf-a720-8108aaf200cf")
        local insideArea = Entity("S_UND_AdamantineForge_FloodTrigger_In_f39f03c5-2c3f-40f5-9562-2115b0d7ceb1")
        local insideArea2 = Entity("S_UND_AdamantineForge_FloodTrigger_In2_1ffe95d9-9e51-4972-af17-7d31e8f6e4f9")
		local insidePoint2a = Entity("S_UND_AdamantineForge_LavaSurface5_2_700e401f-ab91-4dde-9d10-c31bae8cf879")
		local insidePoint2b = Entity("S_UND_AdamantineForge_LavaSurface5_1_03208de9-76a2-4f4e-8fe0-a4b2fd9b58f6")
        local outsidePoint2a = Entity("S_UND_AdamantineForge_LavaSurface9o_2_28eb4941-c71c-4569-bf78-0ca123e1d419")
		local outsidePoint2b = Entity("S_UND_AdamantineForge_LavaSurface8o_1_8f6a6b48-284b-4952-a65b-c74e435703a0")
    
        nodes.Action_Idle = Action{
            function()
                WaitForInterrupt()
            end
        }

        events.EntityEvent = function(ev)
            if ev.Event == "UND_AdamantineForge_TestLava2" then
                CreateSurfaceAt(startPoint, SurfaceType.LAVA, outsideArea, 9.0, true, nil, 11.0, 0.05)
                StartTimer(me, "UND_AdamatineForge_InnerLava", 0.5, 0)
				StartTimer(me, "UND_AdamatineForge_ExtraLava", 2.3, 0)
            end
        end

        events.TimerFinished = function(ev)
            if (ev.TimerName == "UND_AdamatineForge_InnerLava") then
                CreateSurfaceAt(insideStartPoint, SurfaceType.LAVA, insideArea, 9.0, true, nil, 4.0, 0.05)
            elseif (ev.TimerName == "UND_AdamatineForge_ExtraLava") then
                CreateSurfaceAt(insidePoint2a, SurfaceType.LAVA, insideArea2, 7.0, true, nil, 20.0, 0.05)
                CreateSurfaceAt(insidePoint2b, SurfaceType.LAVA, insideArea2, 7.0, true, nil, 20.0, 0.05)
                CreateSurfaceAt(outsidePoint2a, SurfaceType.LAVA, outsideArea, 7.0, true, nil, 18.0, 0.05)
                CreateSurfaceAt(outsidePoint2b, SurfaceType.LAVA, outsideArea, 7.0, true, nil, 18.0, 0.05)
            end
        end


    end
}