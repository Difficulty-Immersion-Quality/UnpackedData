game.states.UND_AnimatedArmor = State{function()
    description = [[State for an Animated Armor found in Arcane Tower in the Underdark]]

    modules = { "shared.math", "shared.util" }

    local fl_Sleep = Flag("UND_AnimatedArmor_Sleep_efbf4c95-3e11-4e12-be99-1b72ffdfb226")
    local dlg_AD = Dialog("UND_AnimatedArmor_AD_5526b32a-6d14-75f2-3968-b12959305428")
    local f_ADTimeout = 25.0
    local s_ADReset = "Timer.UND_AnimatedArmor.AD"
    local b_CanDoAD = false

    self.OnInit = function()
        helpers.CanDoADReset(mod.math.random(1.0, 10.0))
    end

    helpers.CanDoADReset = function(f_time)
        b_CanDoAD = false
        StartTimer(me, s_ADReset, f_time, 0)
    end

    events.TimerFinished = function(ev)
        if ev.TimerName == s_ADReset then
            b_CanDoAD = true
        end
    end

    nodes.AD = Action{
        function()
            StartAutomatedDialogImmediate(dlg_AD, me)
            helpers.CanDoADReset(f_ADTimeout)
        end,

        CanEnter = function()
            return b_CanDoAD
        end
    }

    nodes.Sleep = Action{
        function()
            mod.util.SleepRandom(10.0, 15.0)
        end
    }

end}
