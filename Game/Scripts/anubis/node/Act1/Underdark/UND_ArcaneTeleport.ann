game.states.UND_ArcaneTeleport = State{function()
    description = [[State for an Arcane Teleport at Arcane Tower in the Underdark]]

    local s_Drain = "UND_SUSSURTREEANTIMAGIC"
    local fl_PowerOn = Flag("UND_ArcaneTower_MainPowerOn_9423ae80-9b08-4fda-95c6-1832f753ca2b")

    nodes.Activated = Action{
        function()
            WaitForInterrupt()
        end,

        OnEnter = function()
            SetEntityEvent(me, "UND_ArcaneTeleport_Activate")
        end,

        Valid = function()
            return not HasActiveStatus(me, s_Drain) and GetFlag(fl_PowerOn)
        end
    }

    nodes.Dectivated = Action{
        function()
            WaitForInterrupt()
        end,

        OnEnter = function()
            SetEntityEvent(me, "UND_ArcaneTeleport_Deactivate")
        end,

        Valid = function()
            return HasActiveStatus(me, s_Drain) or not GetFlag(fl_PowerOn)
        end
    }
end}
