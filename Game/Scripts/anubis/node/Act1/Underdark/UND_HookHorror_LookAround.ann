game.states.UND_HookHorror_LookAround = State{function ()

    modules = { "shared.math", "shared.params", "shared.util" }

    params.LookFrom = { type = EParamType.String, arrayRange = "1..", required = true,
        help = [[Point triggers that Hook Horrors are looking from]]}

    local tr_LookFrom = nil

    self.OnInit = function()
        tr_LookFrom = mod.params.ParamArrayToEntityList(params.LookFrom)
    end

    nodes.LookFrom = Action{
        function()
            local i_RandIdx = math.random(#tr_LookFrom)
            local tr_Pos = tr_LookFrom[i_RandIdx]
            local movementSpeed = MovementSpeed.Walk
            if (math.random() > 0.7) then
                movementSpeed = MovementSpeed.Run
            end
            try
                MoveTo(tr_Pos, movementSpeed)
                LookFrom(tr_Pos)
                DebugText(me, "Animation: Look around")
                mod.util.SleepRandom(4.0, 5.0)
            catch ex if ls.CheckType(ex, error.MovementFailed) then
                DebugText(me, "Movement failed to randPos")
                Sleep(1.0)
            end
        end
    }
end}
