game.states.UND_LoneDuergar_Idle = State{function()

    --------------------------------------------------
    -- Local variables

    local anim = Animation("CUST_SharpeningAxe_01_Loop_f56b8872-add0-4ca7-b513-917c2be8bef9")
    local chair = Entity("S_UND_LoneDuergar_SittingRock_5e046e02-42af-4395-8273-d759fa453c3a")
    --------------------------------------------------
    -- nodes

    nodes.playAnim = Action{
        function()
            if not me.IsReposed then
                UseItem(chair.Item,true,true)
            end
            local weapon = GetEquippedWeapon(me.Character, WeaponHandType.Any)
            if (weapon ~= nil) and
               (IsEquipmentWithProficiency(weapon, ProficiencyGroup.Greataxes)) then
                try
                    SetWeaponUnsheathed(me, true)
                    PlayAnimation(anim,true,false)
                catch e if ls.CheckType(e, error.PlayAnimationFailed) then
                    DebugText(me, ("Anim Failed: Sharpening Axe"))
                    Sleep(2.0)
                end
                SetWeaponUnsheathed(me, false)
            end
            Sleep(math.random(6, 12))
        end
    }

end}