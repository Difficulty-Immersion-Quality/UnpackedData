game.states.UND_LoneDuergar_Henchman = State {function()

    params.idleAnim = {type = EParamType.String, required = false, default = "",
        help = [[Idle animation for Gekh's henchmen]]}

    params.homeTrigger = {type = EParamType.String, required = false, default = "",
        help = [[Default position for the duergar to stand while they wait]]}

    ------------------------------------------
    -- Animations

    local idleAnim = Animation(params.idleAnim)
    local homeTrigger = Entity(params.homeTrigger)

    nodes.Idle = Action{
        function()
            local moveResult = MoveTo(homeTrigger, MovementSpeed.Walk, false, false, 0.2, 0.5, false)

            if moveResult ~= error.MovementError.None then
                SteerTo(homeTrigger)
                Sleep(2.0)
            else
                LookFrom(homeTrigger)
                try
                    PlayAnimation(idleAnim, false, true)
                catch e if ls.CheckType(e, error.PlayAnimationFailed) then
                    DebugText(me, ("Anim Failed: " .. params.idleAnim))
                    Sleep(2.0)
                end

                WaitForInterrupt()
            end          
        end
    }
end}