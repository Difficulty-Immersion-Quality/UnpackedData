game.states.UND_MonkAmulet_Amulet = State{function()
    description=[[Behaviour for the haunted Monk's Amulet]]

    modules = {"shared.dialog", "shared.util"}

    local beckonAD = Dialog("UND_MonkAmulet_AD_BeckonPlayer_44c2303e-4f9c-1726-084c-cfd9781117e8")
    local foundAmulet = Flag("UND_MonkAmulet_State_FoundAmulet_843c2dc4-0066-47f7-a23b-8eef3965ffd3")

    nodes.BeckonPlayer = Action {
        function()
            if not IsInDialog(me, false) then
                StartAutomatedDialogRateLimited(beckonAD, 15.0,30.0,true,me)
                mod.util.SleepRandom(15.0, 20.0)
            end
            
        end,

        CanEnter = function()
            return not GetFlag(foundAmulet)
        end
    }

    nodes.Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }
end}