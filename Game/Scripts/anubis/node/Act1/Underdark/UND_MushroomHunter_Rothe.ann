game.states.UND_MushroomHunter_Rothe = State
{
    function ()

        local anim_Consume = Animation("UTIL_Consume_01_88f95a55-7bc5-4f12-b507-d6569d745856")

        nodes.Default = Selector {
            function(nodes)
                return FindRandomSelectable(nodes)
            end
        }

        nodes.Default.StandAtTrigger = Proxy{
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = "S_UND_MushroomHunter_Rothe_StandAtTrigger_fcb2a1ff-84e7-4f11-b429-4251cee25066"
            }
        }

        nodes.Default.Idle = Action {
            function()
                Sleep(6.0)
            end
        }

        nodes.Default.Eat = Action {
            function()
                PlayAnimation(anim_Consume, true)
                Sleep(6.0)
            end
        }

    end
}
