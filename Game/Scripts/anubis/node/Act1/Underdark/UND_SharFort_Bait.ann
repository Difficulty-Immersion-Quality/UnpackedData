game.states.UND_SharFort_Bait = State{function()

    description = [[
        Behaviour for the minotaur "bait" creature, who will rush at the Selune Fort gates
        trying to smash them, and (in most cases) dying from the traps guarding it.
    ]]

    modules = { "shared.math" }

    local idleRandomCombatAnim = Animation("IDLE_Random_Combat_01_6dd3d472-9e11-47bf-8f7a-04e75ffe6c26")
    local idleRandomPeaceAnim = Animation("IDLE_Random_Peace_01_b5d99946-0646-4bdd-88a0-9604872a0dd9")
    local wanderTrigger = Entity("S_UND_SharFort_RatWanderTrigger_918d4e38-37f1-4725-af26-47282beb6f83")
    local fortDoors = Entity("S_UND_SharFort_Door_89f297fb-f018-4fe5-8a91-7d5f3248f687")
    local attackPos = Entity("S_UND_SharFort_RatAttackPos_81b0f118-4308-427a-bd48-66d41fef87e8")

    local rushAtTheDoor = false
    local movedToAttack = false
    local forceUpdates = false

    helpers.DisableForceUpdate = function()
        if rushAtTheDoor then
            SetForceUpdate(me,false)
            rushAtTheDoor = false
        end
    end

    helpers.EnableForceUpdate = function()
        if not rushAtTheDoor then
            SetForceUpdate(me,true)
            rushAtTheDoor = true
        end
    end

    nodes.WanderAtFort = Action {
        function()
            if not IsInTrigger(me, wanderTrigger.Trigger) then
                local pos = TriggerGetRandomPosition(wanderTrigger.Trigger)
                if pos ~= nil then
                    MoveTo(pos, MovementSpeed.Sprint)
                    PlayAnimation(idleRandomPeaceAnim)
                end
            else
                helpers.DisableForceUpdate()         
            end
            Wander(wanderTrigger, 5.0, MovementSpeed.Run)
            PlayAnimation(idleRandomPeaceAnim)
        end,
        CanEnter = function()
            return fortDoors.Item.IsDestroyed or fortDoors.Item.IsOpened or IsInTrigger(me, wanderTrigger.Trigger)
        end
    }

    nodes.AttackingDoor = Action {
        function()
            SetWeaponUnsheathed(me, true)
            if not movedToAttack or GetDistance2DTo(me, fortDoors) > 20 then
                MoveTo(attackPos, MovementSpeed.Run)
                LookFrom(attackPos)
                movedToAttack = true     
                PlayAnimation(idleRandomCombatAnim, false) -- may stuck while being hit
                Sleep(3)
                UseSpell("Rush_Charge_Minotaur", fortDoors, nil, nil, nil, true, true, true)
            end
            Attack(fortDoors)
            Sleep(mod.math.random(0.5, 1.1))
        end,
        CanEnter = function()
            return rushAtTheDoor
        end,
        Valid = function()
            return not fortDoors.Item.IsDestroyed and not fortDoors.Item.IsOpened and not IsInTrigger(me, wanderTrigger.Trigger)
        end
    }

    nodes.WaitingForThePlayerApproach = Action {
        function()
            PlayAnimation(idleRandomCombatAnim)
            Sleep(mod.math.random(1, 3))
        end,
        Valid = function()
            return not rushAtTheDoor
        end,
    }

    events.EntityEvent = function(e)
        if e.Event == "UND_SharFort_BaitStartsMoving" then
            helpers.EnableForceUpdate()
            movedToAttack = false
        end
    end

    events.Destroyed = function(e)
        if e.Entity == fortDoors then
            helpers.DisableForceUpdate()
        end
    end

    events.Dying = function(e)
        if e.Target == me then
            helpers.DisableForceUpdate()
        end
    end

    events.EnteredCombat = function(e)
        if e.Entity == me then
            SetUnicastEntityEvent(me, "ClearPeaceReturn")
        end
    end
end}