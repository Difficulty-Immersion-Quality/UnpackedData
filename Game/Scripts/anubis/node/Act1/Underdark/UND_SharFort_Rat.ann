game.states.UND_SharFort_Rat = State{
    function()
        modules = {"shared.util"}

        local trWander = Entity("S_UND_SharFort_RatWander_95157c4a-6a88-4d01-890d-4aa984c34b87")

        nodes.Action_Wander = Action{
            function()
                try
                    Wander(trWander, 1.0, MovementSpeed.Run)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    DebugText(me, "Error: MovementFailed")
                end
                mod.util.SleepRandom(2.0, 4.0)
            end
        }
    end
}