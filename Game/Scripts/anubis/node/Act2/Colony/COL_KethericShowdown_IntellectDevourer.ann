
game.states.COL_KethericShowdown_IntellectDevourer = State{function ()

    -----------------------------------------
    -- Local variables
    local doSleep = false
    local sleepTimeMin = 6.0
    local sleepTimeMax = 18.0

    -----------------------------------------
    -- Nodes

    nodes.Sleep = Action {
        function()
            Sleep(math.random()*(sleepTimeMax-sleepTimeMin)+sleepTimeMin)

            doSleep = false
        end,
        CanEnter = function()
            return doSleep
        end
    }     

    -- One leader will be chosen among the intellect devourers
    -- The leader will do the patrol and the followers will follow through Osiris
    -- Following will interrupt this idle behaviour
    nodes.FollowPatrol = Proxy{
        game.states.GEN_Patrol,
        params = {
            patrolSpline = "S_COL_KethericShowdown_IntellectDevourers_Patrol_fcde65e1-518a-4e82-a7f6-9b583b24098c",
            patrolReverse = false,
            patrolSpeed = "Walk",
            startSplineIndex = -1,
        }
    }   

    -----------------------------------------
    -- Events
    events.SplineControlPointReached = function(e)
        if e.Event == "Sleep" then
            doSleep = true
        end
    end
end}
