game.states.COL_Showdown_Nightsong = State { function ()

    local showdownFlag = Flag("COL_KethericShowdown_State_Started_33489af3-23b7-4340-bbf6-19033c9dae03")
    local kethericDead = Flag("GLO_Ketheric_State_Dead_668558ed-0052-0777-64f7-a8a197c40cc5")
    local epilogue = Flag("SCE_State_AtEpilogue_3541abb5-6aaf-48c7-bf30-5a13b3abc718")

    self.CanEnter = function()
        return GetFlag(showdownFlag) and not GetFlag(epilogue, me)
    end

    nodes.AfterDefeat = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_COL_KethericShowdown_Nightsong_AfterCombat_Point_6ebeacb2-5080-4e99-bdd7-b062563e33bc"
        },
        CanEnter = function()
            return GetFlag(kethericDead)
        end
    }

    nodes.Showdown = Action {
        function()
            
        end
    }

end}