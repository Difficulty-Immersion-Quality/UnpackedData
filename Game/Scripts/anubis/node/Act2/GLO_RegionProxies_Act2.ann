game.states.GLO_RegionProxies_Act2 = State { function ()

    local inCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")

    description = [[Contains a proxy for each region in Act2. To be used on global entities in this Act only.]]

    params.CAMP = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the campsite.]]
    }

    params.SCE = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the the Epilogue.]]
    }
    params.COL = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the Colony.]]
    }
    params.SHA = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in Shar's temple.]]
    }
    params.SCL = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the shadowcursed land.]]
    }
    params.MOO = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in Moonrise Towers.]]
    }
    params.HAV = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in Haven.]]
    }
    params.act2 = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in SCL_Main_A.]]
    }

    nodes = ImmediateSelector {}

    nodes.CAMP = Proxy {
        params.CAMP,
        Valid = function()
            return GetFlag(inCamp,me)
        end
    }

    nodes.Act2 = ImmediateSelector {
        Valid = function(node)
            return CheckCurrentGameLevel("SCL_Main_A") and CheckAnySelectable(node)
        end
    }
    nodes.Act2.SCE = Proxy {
        params.SCE
    }
    nodes.Act2.COL = Proxy {
        params.COL
    }
    nodes.Act2.SHA = Proxy {
        params.SHA
    }
    nodes.Act2.SCL = Proxy {
        params.SCL
    }
    nodes.Act2.MOO = Proxy {
        params.MOO
    }
    nodes.Act2.HAV = Proxy {
        params.HAV
    }
    nodes.Act2.Main = Proxy {
        params.act2
    }

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end
    }
end}