game.states.HAV_Bard = State {function ()

    description = [[Behaviour of Alfira in Haven]]

    local fl_EnterPermission = Flag("HAV_EnteringHaven_State_GainedAccess_07c776da-353a-9050-e9be-c42d51a99412")
    local tr_VouchPoint = Entity("S_HAV_EnteringHaven_AlfiraPoint_86e4a9c8-e2a0-4464-9921-480bdb0400d7")

    nodes.EnteringHaven_Voucher = Action{
        Valid = function()
            return not GetFlag(fl_EnterPermission)
        end,
        function()
            if not IsInDangerousSurfaceFor(tr_VouchPoint, me.Character) and GetDistanceTo(me,tr_VouchPoint) > 2 then
                local moveResult = MoveTo(tr_VouchPoint, MovementSpeed.Walk, false, true, 2.0, 3.0, false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                end
            end
            Sleep(4.0)
        end
    }

    nodes.Sitting = Proxy {
        game.states.Sit,
        params = {
            seat = "S_HAV_BardSeat_3130b939-9918-4a26-9a3d-46a56dfa0c4e",
            seatTrigger = "S_HAV_BardSeatArea_8efc159c-0e90-42b1-a95c-9f6b92adc005",
            sitIdle = StateRef{game.states.HAV_Bard_Sitting},
        }
    } 

    nodes.Default = Action {
        function()
            WaitForInterrupt()
        end
    }

end}

game.states.HAV_Bard_Sitting = State {function ()

    description = [[Behaviour of Alfira in Haven while he is sitting]]

    nodes.Default = Action {
        function()
            WaitForInterrupt()
        end
    }

end}