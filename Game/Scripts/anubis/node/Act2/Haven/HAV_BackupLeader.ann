game.states.HAV_BackupLeader = State {function ()

    modules = {"shared.moveto"}

    description = [[Behaviour of Cerys in Haven]]

    local armsCrossedAnim = Animation("CUST_ArmsCrossed_01_Loop_e6c49668-99b1-41d6-8daa-7ed6864b4e71")

    local position = Entity("S_HAV_BackupLeaderPos_c5fbf71a-440c-4ad6-9731-400fb20dff68")

    nodes.Standing = Action {
        function()
            if mod.moveto.MoveToPoint(position, MovementSpeed.Walk, me) then
                LookFrom(position)
            else
                SteerTo(position)
            end
            PlayAnimation(armsCrossedAnim, false, true)
            WaitForInterrupt()
        end,
        OnLeave = function()
            StopAnimation(me)
        end
    }

end}