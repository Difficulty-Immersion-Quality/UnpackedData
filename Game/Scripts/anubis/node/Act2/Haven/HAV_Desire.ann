game.states.HAV_Desire = State{
    function()
        local HAV_Desire_State_NightsongFollowupWaiting = Flag("HAV_Desire_State_NightsongFollowupWaiting_133cc440-1ace-4482-b07d-3c4e4d134a23")

        nodes.NightsongFollowup_OnSquare = Proxy{
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = [[S_HAV_NightsongFollowup_FlorrickPos_Square_e556932a-b14c-4b22-abea-5a4f2532762d]]
            },
            CanEnter = function()
                return GetFlag(HAV_Desire_State_NightsongFollowupWaiting)
            end
        }

        nodes.AtInn = Proxy{
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = [[S_HAV_FlorrickPos_ab39d643-3ba1-41db-aafe-aca064be0e0c]]
            },
            CanEnter = function()
                return not GetFlag(HAV_Desire_State_NightsongFollowupWaiting)
            end
        }
    end
}