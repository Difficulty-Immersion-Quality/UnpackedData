game.states.HAV_GhoulAttack_Combat = State{function()

    modules = { "shared.character", "shared.items", "shared.util" }

    description = [[Generic state for fighters during Ghoul Attack.
    If NPC falls out of combat, it searches for enemies in Haven region and runs towards it.
    If there's no enemies, stays at predefined trigger]]

    params.DefaultPosition = { type = EParamType.String,
        default = "S_HAV_GhoulAttack_Default_a0de75dc-c6a6-4ec8-b0e9-d3ed2b9df7ef",
        help = [[Default position for the NPC]]
    }

    local tr_SearchForEnemiesTrigger = Entity("S_HAV_GhoulAttackStateObject_0e0cd36f-faab-49cc-9c35-0b52fd681d6d")
    local tr_Position = Entity(params.DefaultPosition)
    local fl_GhoulAttackEnded = Flag("HAV_Mood_State_Alert_b073eeb9-1d29-449f-baf5-74307e63d085")
    local anim_LookAround = { Animation("HUM_F_Rig_DFLT_CUST_Investigating_LookingAround_01_16125ef6-c9af-0370-2dbd-efba3786477e"),
        Animation("HUM_F_Rig_DFLT_CUST_Investigating_LookingAround_02_7e9b0293-8941-c2d5-a234-72cc3455cc39"),
        Animation("HUM_F_Rig_DFLT_CUST_Investigating_LookingAround_03_e1c79d44-d520-bc15-2ec8-dca788886fb1") }
    local fac_Enemies = nil

    local ent_Enemy = nil

    self.OnInit = function()
        fac_Enemies = FindFaction("Act2_HAV_FlamingSpy_Hostile_caa2c8a9-67d2-479b-91ad-f460e66cfd9b")
    end

    events.EnteredCombat = function(ev)
        ent_Enemy = nil
    end

    events.LeftCombat = function(ev)
        ent_Enemy = nil
    end

    nodes.EnemiesNearby = Selector{
        Valid = function()
            return not GetFlag(fl_GhoulAttackEnded)
        end
    }

    nodes.EnemiesNearby.FindEnemy = Action{
        function()
            local chars = GetActiveCharacters(tr_SearchForEnemiesTrigger, 50.0)
            if #chars > 0 then
                for _, char in ipairs(chars) do
                    if not mod.character.IsDefeated(char, true) and char.Faction == fac_Enemies then
                        ent_Enemy = char
                    end
                        Sleep(2.0)
                end
            end
            if ent_Enemy == nil then
                local items = GetActiveItems(tr_SearchForEnemiesTrigger, 50.0)
                if #items > 0 then
                    for _, item in ipairs(items) do
                        try
                            if not mod.items.SafeIsDestroyed(item) and item.Faction == fac_Enemies then
                                ent_Enemy = item
                            end
                        catch ex if ls.CheckType(ex, error.FactionNotSet) then
                            -- do nothing, but don't catch all cause we don't want to suppress any important error
                        end
                            Sleep(2.0)
                    end
                end
            end
        end,

        Valid = function()
            return ent_Enemy == nil
        end
    }

    nodes.EnemiesNearby.RunToEnemy = Action{
        function()
            if not IsInDangerousSurfaceFor(ent_Enemy, me.Character) and not HasActiveStatus(me, "HAV_GHOULSPIKED") then
                local moveResult = MoveTo(ent_Enemy, MovementSpeed.Run, false, true)

                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                end
            else
                Sleep(1.0)
            end
        end
    }

    nodes.EnemiesDefeated = Action{
        function()
            if not IsInDangerousSurfaceFor(tr_Position, me.Character) and not HasActiveStatus(me, "HAV_GHOULSPIKED") then
                local moveResult = MoveTo(tr_Position, MovementSpeed.Walk, false, true)

                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                else
                    PlayAnimation(mod.util.RandomFrom(anim_LookAround), true, false)
                end
            end
            mod.util.SleepRandom(3.0, 10.0)
        end
    }
end}

game.states.HAV_GhoulAttack_Hide = State{function()

    modules = { "shared.character", "shared.items", "shared.util" }

    description = [[Generic state for hiding npcs during Ghoul Attack.]]

    params.DefaultPosition = { type = EParamType.String,
        required = false,
        help = [[Default position for the NPC]]
    }

    local tr_Position = Entity(params.DefaultPosition)
    local fl_GhoulAttackEnded = Flag("HAV_Mood_State_Alert_b073eeb9-1d29-449f-baf5-74307e63d085")

    nodes.Default = Action{
        function()
            if tr_Position ~= nil then
                if not IsInDangerousSurfaceFor(tr_Position, me.Character) and not HasActiveStatus(me, "HAV_GHOULSPIKED") then
                    local moveResult = MoveTo(tr_Position, MovementSpeed.Walk, false, true)
                    if moveResult ~= error.MovementError.None then
                        DebugText(me, "Error: MoveTo failed")
                        Sleep(3.0)
                    else
                        PlayAnimation(mod.util.RandomFrom(anim_LookAround), true, false)
                    end
                end
                mod.util.SleepRandom(3.0, 10.0)
            end
        end
    }
end}