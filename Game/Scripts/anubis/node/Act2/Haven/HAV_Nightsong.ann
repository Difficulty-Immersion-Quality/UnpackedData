game.states.HAV_Nightsong_Hope = State { function ()
    description = [[
        Behaviour for Nightsong while she is in Haven, after
        returning from the Shar Temple and meeting with Isobel.
    ]]

    modules = {"shared.moveto"}

    local receivedBonesFlag = Flag([[SCL_ShadowCurse_Event_GiveBonesToIsobel_26c0ec08-561f-411f-9053-458341c6a7e9]])
    local finishedResearchFlag = Flag([[SCL_ShadowCurse_Event_BonesResearchProgressed_91936c5f-a3f6-741a-3f1f-ac956ee649f5]])
    local researchAnim = Animation([[CUST_DebugAsset_CustomAnim_01_95ff9541-9c09-4356-8f50-da327d7a64bc]])
    local researchPoint = Entity([[S_HAV_NightsongResearchPoint_9be48115-97c0-412f-83bd-32b411418644]])
    local roomPoint = Entity([[S_HAV_NightsongFollowup_NightsongPos_Room_fec9a316-3db9-4918-a3c2-6d00b8f29ce9]])
    local isobel = Entity([[S_HAV_Isobel_263bfbfc-6160-46f4-a9e1-1089cdb5c211]])

    nodes.ResearchingBones = Action {
        --Stand with Isobel while she's researching the Bones of Contention
        CanEnter = function()
            return GetFlag(receivedBonesFlag) and not GetFlag(finishedResearchFlag)
        end,
        function()
            Sleep(2)
            if mod.moveto.MoveToPoint(researchPoint, MovementSpeed.Stroll, me, 2.0) then
                LookFrom(researchPoint)
                Sleep(10)
                PlayAnimation(researchAnim, true, false)
                Sleep(10)
            end
        end,
    } 

    nodes.Idle = Action {
        function()
            Sleep(2)
            mod.moveto.MoveToPoint(roomPoint, MovementSpeed.Stroll, me, 2.0)
        end
    }
end}