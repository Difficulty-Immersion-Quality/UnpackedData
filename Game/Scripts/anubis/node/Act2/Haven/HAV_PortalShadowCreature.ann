game.states.HAV_PortalShadowCreature = State{function()

    local PortalPoint = Entity("S_HAV_NearPortalPoint_c596f2ee-5048-4b5d-ac8d-748cda835ee0")

    nodes.MoveToPortal = Action {
        function()
            if not IsInDangerousSurfaceFor(PortalPoint, me.Character) and GetDistanceTo(me,PortalPoint) > 2 then
                local moveResult = MoveTo(PortalPoint, MovementSpeed.Run, false, true, 2.0, 3.0, false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                end
            end
            Sleep(2.0)
        end
    }

end}