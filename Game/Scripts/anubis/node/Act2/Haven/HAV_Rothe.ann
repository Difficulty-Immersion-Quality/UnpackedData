game.states.HAV_Rothe = State{function()

    modules = { "shared.math", "shared.util" }

    description = [[Common state for 3 Rothes in Haven that transform into Shadow Rothes during Haven Siege]]

    local tr_InnGroundFloor = Entity("S_HAV_Siege_EnemiesRoamTrigger_963047cd-0486-43ea-bd4d-4a437b554736")
    local fac_Shadows = nil
    local b_Transformed = false

    self.OnInit = function()
        fac_Shadows = FindFaction("ACT2_HAV_ShadowCreatures_b0b8d20c-89f8-4433-bd62-5cbcbae2e9bc")
        b_Transformed = (me.Faction == fac_Shadows)
    end

    events.BaseFactionChanged = function(ev)
        b_Transformed = (ev.NewFaction == fac_Shadows)
    end

    nodes.BeforeTransform = Action{
        function()
            WaitForInterrupt()
        end,

        Valid = function()
            return not b_Transformed
        end
    }

    nodes.AfterTransform = Proxy{
        game.states.HAV_Siege_Enemy
    }

end}