game.states.HAV_ShadowCreature = State {function()
    description = [[Behaviour for creatures that attack Haven during Shadow Siege]]

    local fl_AttackCharge = Flag("HAV_ShadowSiege_CreatureAttack_530605c7-9939-4801-875c-bd35b8c92224")

    nodes.Init = Action{
        function()
            DebugText(me, "Init")
            Sleep(2.0)
        end,

        CanEnter = function()
            return not GetFlag(fl_AttackCharge, me)
        end
    }

    nodes.AttackCharge = Action{
        function()
            DebugText(me, "AttackCharge")
            Sleep(2.0)
        end,

        CanEnter = function()
            return GetFlag(fl_AttackCharge, me)
        end
    }
end}