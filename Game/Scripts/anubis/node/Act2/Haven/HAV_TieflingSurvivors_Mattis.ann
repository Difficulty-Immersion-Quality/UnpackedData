game.states.HAV__TieflingSurvivors_Mattis = State {function ()

    description = [[Behaviour of Mattis in Haven]]

    modules = {"shared.moveto", "shared.dialog"}

    local AD = Dialog("HAV_TieflingSurvivors_AD_Mattis_d9556cf6-577b-b98c-e4ac-2d1d01b1e90b")

    nodes.HAV_Default = Action {
        function()
            DebugText(me, "I'm Mattis. Default state")
            mod.dialog.StartCheckedAutomatedDialogRateLimited(AD, {minDelay = 24.0, waitForCompletion = true},me)
            Sleep(6.0)
        end
    }


end}