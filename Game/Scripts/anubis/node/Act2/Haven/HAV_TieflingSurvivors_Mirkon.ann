game.states.HAV_TieflingSurvivors_Mirkon = State {function ()

    description = [[Behaviour of Mirkon in Haven]]

    local defaultPos = Entity("S_HAV_TieflingSurvivors_MirkonDefaultPosition_e4a48b5a-d111-478d-b674-29382b8e3e76")

    nodes.HAV_Default = Action {
        function()
            Wander(3.0,6.0,MovementSpeed.Walk,defaultPos)
            Sleep(4.0)
            --WaitForInterrupt()
        end,
        Valid = function()
            return not IsInDialog(me,false)
        end
    }

    nodes.HAV_IsInDialog = Action {
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return IsInDialog(me,false)
        end
    }

end}