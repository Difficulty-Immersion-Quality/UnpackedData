game.states.HAV_TieflingSurvivors_Umi = State {function ()

    description = [[Behaviour of the Umi in Haven]]
    
    modules = {"shared.moveto"}

    ----------Flags

    local alertFlag = Flag("HAV_Mood_State_Alert_b073eeb9-1d29-449f-baf5-74307e63d085")
    local prodigyIntroFlag = Flag("HAV_TieflingSurvivors_Event_ProdigyIntro_95cd5597-af9a-1fac-aada-e857199dae88")
    
    ----------Triggers

    local withRolanPos = Entity("S_HAV_BarKidPos_001_6e4a22d2-779f-4a25-800d-161a7e7e3657")
    local cleanGlassPos = Entity("S_HAV_BarCounterPos_002_05df3d83-5ab0-4675-8de1-845bbdcb0dd9")
    local cleanCounterPos = Entity("S_HAV_BarCounterPos_001_5a5d70c4-36bf-4b56-9c2d-7c9a4e9c1c8e")

    ----------Animations

    local armsCrossedAnim = Animation("CUST_ArmsCrossed_01_e52783f3-520a-4f34-aaca-8f48e3c9336f")
    local cleanGlassDialog = Dialog("BHVR_WRLD_HAV_CleaningGlass_5e2884bb-a749-cdc9-cc38-1fab544e8345")
    local glass1 = Entity("S_HAV_KidGlass_002_854bc744-66c3-404c-be8d-6a229d5b786a")
    local glass2 = Entity("S_HAV_KidGlass_003_56a19634-c052-4f26-9c2e-ffeeceb3e218")
    local cleanGlassTrigger1 = Entity("S_BHVR_WRLD_HAV_CleaningGlass_002_3c1d50bd-2219-4175-aa8b-3395f68324e7")
    local cleanGlassTrigger2 = Entity("S_BHVR_WRLD_HAV_CleaningGlass_003_9b17d1ce-185f-49b9-b7c2-8167389312be")

    ----------Bools

    local prodigySceneOver = false

    nodes.WithProdigy = Action{
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return not GetFlag(prodigyIntroFlag)
        end
    }

    nodes.Bartending = Selector{
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end,
    }

    nodes.Bartending.WithRolan = Action{
        function()
            if mod.moveto.MoveToPoint(withRolanPos,MovementSpeed.Stroll,me) then
                LookFrom(withRolanPos)
            end
            Sleep(math.random(5,8))
        end,
    }

    nodes.Bartending.CleanCounter = Action{
        function()
            if mod.moveto.MoveToPoint(cleanCounterPos,MovementSpeed.Stroll,me) then
                LookFrom(cleanCounterPos)
                StartBehaviorDialog(cleanGlassDialog, cleanGlassTrigger2.Trigger, true, me, glass2)
            end
            Sleep(math.random(5,8))
        end,
    }

    nodes.Bartending.CleanGlass = Action{
        function()
            if mod.moveto.MoveToPoint(cleanGlassPos,MovementSpeed.Stroll,me) then
                LookFrom(cleanGlassPos)
                StartBehaviorDialog(cleanGlassDialog, cleanGlassTrigger1.Trigger, true, me, glass1)
            end
            Sleep(math.random(5,8))
        end,
    }

    nodes.Bartending.Counter = Action{
        function()
            if mod.moveto.MoveToPoint(cleanCounterPos,MovementSpeed.Stroll,me) then
                LookFrom(cleanCounterPos)
                PlayAnimation(armsCrossedAnim, false, true)
            end
            Sleep(math.random(5,8))
        end,
    }

end}
