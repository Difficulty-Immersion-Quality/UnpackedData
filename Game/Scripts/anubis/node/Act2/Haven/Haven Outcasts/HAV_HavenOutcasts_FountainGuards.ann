game.states.HAV_HavenOutcasts_FountainGuard_Main = State{function()
    ----------------------------------
    -- Local variables

    modules = {"shared.moveto", "shared.dialog"}

    local standPoint = Entity("S_HAV_HavenOutcasts_Pos_FountainGuards_Melee_2_28d22cfb-97ef-49b6-8747-d003d6ce239b")
    ----------------------------------
    -- Nodes

    nodes.MoveTo = Action {
        function()
            mod.moveto.MoveToPoint(standPoint, MovementSpeed.Walk, me)
            LookFrom(standPoint)
            Sleep(12)
        end,
        CanEnter = function()
            return GetDistance2DTo(me, standPoint) > 1
        end
    }

    nodes.InAD = Action{
        function()
            Sleep(3)
        end,
        CanEnter = function()
            return IsInDialog(me,false)
        end
    }

    nodes.Fallback = Action{
        function()
            LookFrom(standPoint)
            DebugText(me,"Fallback")
            Sleep(4)
        end
    }
end
}

game.states.HAV_HavenOutcasts_FountainGuard_Secondary = State{function()
    ----------------------------------
    -- Local variables

    modules = {"shared.moveto", "shared.dialog"}

    local standPoint = Entity("S_HAV_HavenOutcasts_Pos_FountainGuards_Melee_1_57bc045d-fd01-49d5-ac35-4cd03cf6ecbd")
    local secondGuard = Entity("S_HAV_HavenOutcasts_FountainGuards_Melee_2_271478dd-7efb-4ca7-b40c-593bbea91a85")
    local AD = Dialog("HAV_HavenOutcasts_AD_FountainGuards_ThreeWay_b377f4d8-5d6b-dd42-b3d4-10bd2a26c22f")

    ----------------------------------
    -- Nodes

    nodes.MoveTo = Action {
        function()
            mod.moveto.MoveToPoint(standPoint, MovementSpeed.Walk, me) 
            LookFrom(standPoint)
            Sleep(12)
        end,
        CanEnter = function()
            return GetDistance2DTo(me, standPoint) > 1
        end
    }

    nodes.AD = Action {
        function()
            DebugText(me,"Trying AD")
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                AD,
                {
                    waitForCompletion = true,
                    minDelay = 30.0,
                },
                me,
                secondGuard
            )
            Sleep(16)
        end,
        CanEnter = function()
            return mod.dialog.IsSpeakerAvailable(secondGuard) and GetDistance2DTo(me,secondGuard) < 5.0
        end
    }

    nodes.Fallback = Action{
        function()
            LookFrom(standPoint)
            DebugText(me,"Fallback")
            Sleep(4)
        end
    }

end
}