game.states.MOO_BazarGuard = State { function()
--------------------------------PARAMS--------------------------------
    params.idlePoint = {type = EParamType.String, required = true, help = [[Position where the guard will stand whenever he's idling]]}
--------------------------------LOCAL--------------------------------
--------------------------------NODES--------------------------------
    nodes.Idle = Proxy {
        game.states.GLO_StandAtTrigger,
        params = { 
            trigger = params.idlePoint
         }
    }
--------------------------------EVENTS--------------------------------
end}