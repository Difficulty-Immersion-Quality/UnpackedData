game.states.MOO_DockGuard_Jumper = State {function ()
    description = [[Behaviour of the guard at the Moonrise Tower docks by the Tadpole Shipment]]

    modules = { "shared.moveto" }
    --------------------------------ENTITY--------------------------------
    local standingPoint = Entity("S_MOO_DockPos_000_5319051c-c269-4b3f-b8ea-4efb21776a52")
    local jumpToPoint = Entity("S_MOO_DockJumpToPoint_a96839e0-4769-48f5-8533-96038d99a72c")
    local jumpFromPoint = Entity("S_MOO_DockJumpFromPoint_931effba-5e7b-4196-b5b7-e29eb33e7e18")
    local dockGuard1 = Entity("S_MOO_DockGuard_001_646fba8c-6972-4162-aa7a-f0df28bb1f51")
    local dockGuard2 = Entity("S_MOO_DockGuard_002_352693eb-0ef0-4949-86c5-ba78081d9fb4")

    local crates = {
        Entity("S_MOO_DockCrate_006_a6f4ed02-aa7b-4f1f-afb9-8954f2935469"),
        Entity("S_MOO_CargoFood_001_95b0fe20-8e20-45e0-bda3-5f12e293088d"),
        Entity("S_MOO_DockCrate_000_7b5578f9-bae5-487e-8cf9-4a5c5cc1c113"),
        Entity("S_MOO_DockCrate_001_5e23dc27-372d-40ec-9d0d-3118d6cfe821"),
        Entity("S_MOO_DockCrate_003_f3ca31f9-5dc1-42bc-9e5e-047c541b5782")
    }

    --------------------------------FLAG--------------------------------
    local jumpFlag = Flag("MOO_Docks_Event_GuardJumped_c44a224f-3917-4438-91a8-20335d34fcdf")
    local toldTrueSoulFlag = Flag("MOO_Docks_State_ToldTrueSoul_12fb8b02-eb67-94ea-51da-9320ab4bd1cc")
    local fixedMind = Flag("MOO_Docks_GuardJumper_FixedMind_5ae5802f-0e82-996f-ea68-61718086b289")

    local inspectAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
    local boredAnim = Animation("CUST_Bored_01_23588ba8-fafb-438c-9bc5-660ff6650aef")

    local isInspectingCrate = false

    --------------------------------NODES--------------------------------
    nodes = ImmediateSelector {}

    nodes.Jump = Action {
        function()
            if mod.moveto.MoveToPoint(jumpFromPoint,  MovementSpeed.Sprint, me) then
                UseSpell("Projectile_Jump", jumpToPoint,  nil, nil, nil, true, true, true)
                --Guard is dead at this point
            else
                if not HasAppliedStatus(me, "ANIM_COWER") then
                    ApplyStatus(me, "ANIM_COWER")
                end
            end
            Sleep(1)
        end,

        Valid = function()
            return GetFlag(jumpFlag)
        end
    }

    nodes.MindBroken = Action {
        CanEnter = function()
            return GetFlag(toldTrueSoulFlag) and not GetFlag(fixedMind)
        end,

        function()
            if not HasAppliedStatus(me, "ANIM_COWER") then
                ApplyStatus(me, "ANIM_COWER")
            end

            if mod.moveto.MoveToPoint(standingPoint, MovementSpeed.Walk, me) then
                LookFrom(standingPoint)
            else
                SteerTo(standingPoint, 3.0)
            end
            Sleep(4 + 4 * math.random())
        end
    }

    nodes.InspectCrates = Action {
        CanEnter = function()
            return isInspectingCrate and #crates > 0
        end,

        function()
            if #crates > 0 then
                for i = #crates, 1, -1 do
                    if crates[i].Item.IsDestroyed or (GetDistanceTo(me, crates[i]) > 20.0) then
                        table.remove(crates, i)
                    end
                end
                local selectedCrate = crates[math.random(1, #crates)]
                if  selectedCrate ~= nil then
                    if mod.moveto.MoveToPoint(selectedCrate, MovementSpeed.Walk, me) then
                        SteerTo(selectedCrate)
                        PlayAnimation(inspectAnim)
                        Sleep(1 + 3 * math.random())
                        isInspectingCrate = false
                    end
                end
            end
        end,

        OnLeave = function()
            isInspectingCrate = false
        end
    }

    nodes.BoredIdle = Action {
        function()
            if mod.moveto.MoveToPoint(standingPoint, MovementSpeed.Walk, me) then
                LookFrom(standingPoint)
                PlayAnimation(boredAnim)
            else
                SteerTo(standingPoint, 3.0)
            end
            Sleep(4 + 4 * math.random())
            isInspectingCrate = true
        end
    }

    events.FlagSet = function(e)
        if e.Flag == fixedMind.Guid and HasActiveStatus(me, "ANIM_COWER") then
            RemoveStatus(me, "ANIM_COWER")
        end
    end
end}