
game.states.MOO_DockGuard_Patrol = State{function ()
    description = [[Behaviour of the patrolling guards at the Moonrise Tower docks]]

    modules = { "shared.dialog" }

    --------------------------------PARAMS--------------------------------
    params.patrolSpline = { 
        type = EParamType.String, required = true,
        help = [[Patrol spline GUID for the guard]] 
    }

    params.patrolSpeed = { 
        type = EParamType.String, required = true,
        help = [[Patrol speed for the guard]] 
    }

    params.AD = { 
        type = EParamType.String, required = true,
        help = [[AD on witnessing Guard 000 jumping into water]] 
    }

    --------------------------------ENTITY--------------------------------
    local jumpFromPoint = Entity("S_MOO_DockJumpFromPoint_931effba-5e7b-4196-b5b7-e29eb33e7e18")
    local jumpToPoint = Entity("S_MOO_DockJumpToPoint_a96839e0-4769-48f5-8533-96038d99a72c")

    --------------------------------FLAG--------------------------------
    local witnessFlag = Flag("MOO_Docks_Event_WitnessJump_88cbe282-918b-4fc0-a15a-9a1e24ee05ff")

    --------------------------------DIALOG--------------------------------
    local AD = Dialog(params.AD)

    --------------------------------BOOL--------------------------------
    local isWitness = true
    
    --------------------------------NODES--------------------------------
    nodes = ImmediateSelector {}

    nodes.Witness = Action {
        function()
            if GetDistance2DTo(me, jumpFromPoint) <= 20 or CanSee(me, jumpFromPoint) then
                SteerTo(jumpToPoint)
                Sleep(1 + 3 * math.random())
                mod.dialog.StartCheckedAutomatedDialog(
                    AD,
                    {
                        waitForCompletion = true
                    },
                    me
                )
                Sleep(8 + 8 * math.random())
                isWitness = false
            else
                isWitness = false
            end
        end,

        Valid = function()
            return GetFlag(witnessFlag) and isWitness
        end,

        OnLeave = function()
            isWitness = false
        end
    }

    nodes.Patrol = Proxy {
        game.states.GEN_Patrol,
        params = {
            patrolSpline = params.patrolSpline,
            patrolSpeed = params.patrolSpeed
        }
    }
end
}