game.states.MOO_Assault_Desire = State { function()
    
    modules = { "shared.moveto" }

    local joinedAssaultFlag = Flag([[MOO_Assault_State_FlorrickJoined_5b8c3bb0-0147-4f6b-9268-6d0e5f9bc50b]])
    local defendPrisonFlag = Flag("MOO_Assault_State_ThroneRoomDefeated_273c4470-055c-45cb-aa6b-eee08524a6c3")
    local mainEntrancePoint = Entity("S_MOO_AssaultAllyReadyPoints_002_e5495c58-765c-4a1a-95b6-3bf987818422")
    local prisonStairsPoint = Entity("S_MOO_PrisonStairsDefencePoint_59349da9-2e46-48cf-9b78-84881acd0c43")
    local allyReadyFlag = Flag("MOO_Assault_State_AllyReadyPositions_f0316e51-b885-472a-a8db-b5cf64aca732")

    self.CanEnter = function()
        return GetFlag(joinedAssaultFlag)
    end

    nodes.DefendPrison = Action{
        CanEnter = function()
            return GetFlag(defendPrisonFlag)
        end,
        function()
            if mod.moveto.MoveToPoint(prisonStairsPoint,MovementSpeed.Run,me) then
                LookFrom(prisonStairsPoint)
                Sleep(1)
            end
            Sleep(1)
        end
    }

    nodes.MoveIntoTower = Action{
        CanEnter = function()
            return GetFlag(allyReadyFlag)
        end,
        function()
            if mod.moveto.MoveToPoint(mainEntrancePoint,MovementSpeed.Run,me) then
                LookFrom(mainEntrancePoint)
                Sleep(1)
            end
            Sleep(1)
        end
    }

    nodes.AssaultIntro = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = [[S_MOO_AssaultFlorrickPoint_da2285cc-805d-400b-baa3-b21c7fb4b8df]]
        },
    }

end}