game.states.MOO_Assault_Zrell = State{function ()
    description = [[Z'rell behaviour during the assault on Moonrise]]

    modules = { "shared.dialog", "shared.moveto" }

    local harpersReadyFlag = Flag("MOO_Assault_State_AllyReadyPositions_f0316e51-b885-472a-a8db-b5cf64aca732")
    local assaultPoint = Entity("S_MOO_AssaultZrellStartingPoint_da58ac8b-b9a5-4d2b-955a-2e829680d564")
    local calloutAD = Dialog("MOO_Assault_AD_ZrellCallout_1afe6c08-93e2-86ce-1f86-601ed5275fce")
    local tauntAD = Dialog("MOO_Assault_AD_ZrellTaunt_fee56de4-48ec-b6f0-ad49-e01c7d1fd821")

    nodes.WaitingInBazaar = Action {
        function()
            local delayTime = 8.0 + 12.0 * math.random()
            if mod.moveto.MoveToPoint(assaultPoint,  MovementSpeed.Walk, me) then
                if GetFlag(harpersReadyFlag) then
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        tauntAD,
                        {
                            waitForCompletion = true,
                            minDelay = delayTime,
                        },
                        me
                    )
                else
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        calloutAD,
                        {
                            waitForCompletion = true,
                            minDelay = delayTime,
                        },
                        me
                    )
                end
            else
                SteerTo(assaultPoint)
                Sleep(1.0)
            end
        end
    }

end
}