game.states.MOO_DriderCaravan_Goblins = State{function()
    --------------------------------MODULE--------------------------------
    modules = {"shared.dialog"}
    --------------------------------PARAMS--------------------------------
    params.breakPosition = {type = EParamType.String, required = true, help = [[Position where character will take a break]]}
    params.breakSpeakers = {type = EParamType.String, arrayRange = "..", default = {}, required = false, help = [[Optional Speakers partaking the break AD]]}
    --------------------------------LOCAL---------------------------------
    local pickUpAnim = Animation("CUST_PickUpRock_01_3ccf77d6-a104-11ea-bb37-0242ac130002")
    local drinkingAnim = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")
    local breakAD = Dialog("MOO_DriderCaravan_AD_OnBreak_30689b94-9b62-9075-9769-0dbfe928827f")
    local breakPosition = Entity(params.breakPosition)
    local kegPoint = Entity("S_MOO_DriderCaravan_Keg_6e670ed6-fb7c-42d0-99bb-e07931d12e1f")
    local mugPoint = Entity("S_MOO_DriderCaravan_GoblinMug_c391d40b-b557-4ba9-ba3a-5f54c7d01980")

    local speakers = {}
    local hasMug = false
    local hasDrink = false
    local sipCounter = 0
    --local drinkCounter = 0

    --------------------------------NODES---------------------------------
    self.OnInit = function()
        if #params.breakSpeakers > 0 then
            for _, speaker in pairs(params.breakSpeakers) do
                table.insert(speakers, Entity(speaker))
            end
        end
    end

    nodes.OnBreak = Action{
        function()
            SetWeaponUnsheathed(me, false)
            if GetDistanceTo(me, breakPosition) > 2 then
                MoveTo(breakPosition, MovementSpeed.Walk)
            end
            LookFrom(breakPosition)
            local isEven = (math.random(1,3) % 2) == 0
            if isEven and speakers ~= {} then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        breakAD,
                        {
                            waitForCompletion = true,
                            minDelay = 30.0,
                        },
                        me,
                        table.unpack(speakers)
                    )
            elseif not isEven then
                PlayAnimation(drinkingAnim)
                sipCounter = sipCounter - 1
                if sipCounter == 0 then 
                    hasDrink = false
                    --drinkCounter = drinkCounter + 1
                end 
            end
            Sleep(math.random(7.0, 10.0))
        end,
        OnEnter = function()
            sipCounter = math.random(5, 10)
        end,
        Valid = function()
            return hasDrink 
        end
    }

    nodes.FillingDrink = Action {
        function ()
            SetWeaponUnsheathed(me, false)
            if MoveTo(kegPoint, MovementSpeed.Walk) ~= error.MovementError.None then
                DebugText(me, "Error: MovementFailed")
                Sleep(3.0)
                return
            end

            LookFrom(kegPoint)
            Sleep(6.0)
            hasDrink = true
        end,
        Valid = function()
            return hasMug and not hasDrink
        end
    }

    nodes.GettingDrink = Action{
        function()
            SetWeaponUnsheathed(me, false)
            if MoveTo(mugPoint, MovementSpeed.Walk, false, false, 0.5, 1.0, false) ~= error.MovementError.None then
                DebugText(me, "Error: MovementFailed")
                Sleep(1.0)
                return
            end

            LookFrom(mugPoint)
            --PlayAnimation(pickUpAnim)
            hasMug = true
        end,
        Valid = function()
            return not hasMug
        end
    }
end}