game.states.MOO_EntranceGhoul_001 = State{function ()
    description = [[Talking with Ghoul 2 about how much they dislike the winged ghouls]]

    modules = { "shared.dialog", "shared.moveto" }

    local AD = Dialog("MOO_EntranceCheckpoint_AD_Ghouls_21f52240-b6eb-50a0-8d35-6e6225867e2c")
    local idlePoint = Entity("S_MOO_EntranceGhoulPoint_001_e63d0cca-1593-46bb-86c3-1b55f64d2555")
    local ghoul2 = Entity("S_MOO_EntranceGhoul_002_2e7447e5-35dd-4cdd-8426-43a6afe0edc7")

    nodes.IdleAD = Action {
        function()
            if mod.moveto.MoveToPoint(idlePoint,  MovementSpeed.Walk, me) then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    AD,
                    {
                        waitForCompletion = true,
                        minDelay = 40.0,
                    },
                    me,
                    ghoul2
                )
                Sleep(2.0)
            else
                SteerTo(idlePoint)
            end
        end
    }

end
}