game.states.MOO_Execution_Goblin3 = State{function ()

    modules = {"shared.moveto"}

    params.trigger = {type = EParamType.String, help=[[
        The trigger at which the character stands.
    ]]}

    local executionTrigger = Entity(params.trigger)
    local MOO_GroundFloor_State_ExecutionOver
    local MOO_Execution_State_GoblinFleeADDone
    local MOO_Execution_EscapedTrigger = Entity("S_MOO_ExecutionEscapePoint_ed45cf90-6398-4d6d-835a-4427db7b91ae")
    local MOO_Execution_Goblin3_AD = Dialog("MOO_Execution_Goblin3_AD_fb32e0c0-317a-ec80-9491-5914b1f15d91")
    local cower = Animation("STAT_Fear_Combat_01_Loop_bbf65b93-0377-4f38-9bf0-2bc064f41a13")
    local MOO_Execution_Area = Entity("S_MOO_ExecutionArea_12abecc1-49d4-4253-a435-01d82d00abda")
    local MOO_Execution_State_ReleaseGoblins = Flag("MOO_Execution_State_ReleaseGoblins_96f7f255-8c72-9a60-3ca8-b23df0dc21cb")

    self.OnInit = function()
        MOO_GroundFloor_State_ExecutionOver = Flag("MOO_GroundFloor_State_ExecutionOver_1560c0ae-5fec-4e7c-a6e7-35e9c33bbbeb")
        MOO_Execution_State_GoblinFleeADDone = Flag("MOO_Execution_State_GoblinFleeADDone_a55d0f3a-de46-67a7-f8f4-15ac10fa728f")
    end



    nodes.WaitForFlee = Action{function()
        Sleep(0.3)
        StartAutomatedDialog(MOO_Execution_Goblin3_AD, true, me)
    end,
    Valid = function()
        return GetFlag(MOO_GroundFloor_State_ExecutionOver) and
               not GetFlag(MOO_Execution_State_GoblinFleeADDone)
    end
}

    nodes.Imprisoned = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {trigger = "S_MOO_Prison_ExecutionGoblin3Home_04987b36-a930-4d27-9220-93cce315b4d2"},
        Valid = function()
            return GetFlag(MOO_GroundFloor_State_ExecutionOver) and
                   GetFlag(MOO_Execution_State_ReleaseGoblins)
        end
    }

    nodes.Flee = Action{
        function()
            Sleep(0.3)
            mod.moveto.MoveTo(MOO_Execution_EscapedTrigger, true, 2.0, "Run", "MOO_Execution_Fled")
        end,
        Valid = function()
            return (GetFlag(MOO_GroundFloor_State_ExecutionOver) and
                    not GetFlag(MOO_Execution_State_ReleaseGoblins)) or
                   not IsInTrigger(me, MOO_Execution_Area.Trigger)
        end
    }


    nodes.WaitingForDeath = Action{
        function()
            if not IsInDangerousSurfaceFor(executionTrigger, me.Character) then
                if GetDistanceTo(me, executionTrigger) > 2.0 then
                    try
                        MoveTo(executionTrigger)
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        LookAtEntity(executionTrigger, 3.0)
                        Sleep(2.0)
                    end
                else
                    LookFrom(executionTrigger)
                    PlayAnimation(cower, false, true)
                    WaitForInterrupt()
                end
            else
                LookAtEntity(executionTrigger, 3.0)
            end
            Sleep(2.0)
        end,
        Valid = function()
            return not GetFlag(MOO_GroundFloor_State_ExecutionOver) and
                   IsInTrigger(me, MOO_Execution_Area.Trigger)                   
        end
    }

end
}
