game.states.MOO_ExecutionerOgre = State{ function ()
    description = [[Shared state used to select states before and after execution]]

    modules = { "shared.moveto" }

--------------------------------LOCAL--------------------------------

    local atChapelFlag = Flag("MOO_ZrellBriefing_State_AtChapel_34eef078-f459-4d18-a66d-bbd79eba50b6")

--------------------------------NODES--------------------------------

    nodes.AtExecutionerRoom = Proxy{
        game.states.GLO_StandAtTrigger,
        params={trigger = "S_MOO_ExecutionerOgrePoint_80f2c181-0d1c-4cd2-9144-19550b3f2655"},
        Valid = function()
            return not GetFlag(atChapelFlag)
        end
    }
    nodes.AtChapel = Proxy{
        game.states.GLO_StandAtTrigger,
        params={trigger = "S_MOO_OgreChapelPos_49e69f30-220f-4f9a-baab-dd124f0e0265"},
        Valid = function()
            return GetFlag(atChapelFlag)
        end
    }

end
}