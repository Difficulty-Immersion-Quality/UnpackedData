
game.states.MOO_HookHorror_Patrol= State{function ()

    -----------------------------------------
    -- Params
    params.sleepTimeMin = {type = EParamType.Number,required = false,default = 4.0,
        help = [[Waiting duration for spline points with the script event 'Sleep' on that point (edit it on the spline).]]}
    params.sleepTimeMax = {type = EParamType.Number,required = false,default = 7.0,
        help = [[Waiting duration for spline points with the script event 'Sleep' on that point (edit it on the spline).]]}

    -----------------------------------------
    -- Local variables
    local canPatrol = true

    -----------------------------------------
    -- State nodes
    self.OnInit = function()
        canPatrol = true
    end

    -----------------------------------------
    -- Nodes

    nodes.Sleep = Action {
        function()
            Sleep(params.sleepTimeMin+(math.random()*(params.sleepTimeMax-params.sleepTimeMin)))

            canPatrol = true
        end,
    }        

    -----------------------------------------
    -- Events
    events.SplineControlPointReached = function(e)
        if e.Event == "Sleep" then
            canPatrol = false
        else
            canPatrol = true
        end
    end

    self.Valid = function()
        return not canPatrol
    end
end}
