game.states.MOO_Jailbreak_MintharaGuard = State { function()

    params.guardTrigger = {type = EParamType.String, help=[[
        The trigger at which the character stands after watching Minthara.
    ]]}

    nodes.Guarding = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.guardTrigger
        }
    }
end
}
