game.states.MOO_MintharaFate_Minthara = State{function()

    local executionDone = Flag("MOO_GroundFloor_State_ExecutionOver_1560c0ae-5fec-4e7c-a6e7-35e9c33bbbeb")
    local mintharaBrainwashed = Flag("MOO_MintharaFate_State_Pacified_bddd4113-9486-84fe-a88b-70ad9d87d00c")
    local mintharaInTorture = Flag("MOO_MintharaFate_State_Torture_2c490890-6b9f-4411-bda4-be2b7981708b")
    local mintharaFreed = Flag("MOO_MintharaFate_State_Freed_b77a54f6-a1e8-20a7-b932-9a0c10547a39")
    local torturersAttacked = Flag("MOO_MintharaFate_Event_FightTorturers_9533b62a-0146-a079-76ca-789288c2d6b6")

    local mintharaLookAt = Entity("S_MOO_MintharaFate_LookAtPoint_a4e903c6-e573-4157-9b7f-471f49a1799a")

    nodes.Tortured = Action{
        OnEnter = function()
            ApplyStatus(me, "MOO_MINTHARAFATE_TORTURE", false, -1.0, me)
        end,
        function()
            SteerTo(mintharaLookAt)
            Sleep(60.0)
        end,
        Valid = function()
            return GetFlag(mintharaInTorture) and not (GetFlag(mintharaFreed) or GetFlag(torturersAttacked) or GetFlag(mintharaBrainwashed))
        end, 
        OnLeave = function()
            RemoveStatus(me, "MOO_MINTHARAFATE_TORTURE", me)
        end
    }

    nodes.Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }

end
}