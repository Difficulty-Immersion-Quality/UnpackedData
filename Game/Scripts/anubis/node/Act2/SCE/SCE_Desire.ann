game.states.SCE_Desire = State{
function()
    local inEpilogue = Flag("SCE_State_AtEpilogue_3541abb5-6aaf-48c7-bf30-5a13b3abc718")

    local afterDebrief = Flag("SCE_RavenguardFollowUp_State_FlorrickAfterDebrief_4e36a4c8-e358-41f8-aa7d-1fb2d76ed4c1")

    nodes =ImmediateSelector{}

    self.Valid = function()
        return GetFlag(inEpilogue, me)
    end

    nodes.Action_AfterDebriefStandOnTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_SCE_FlorrickPoint_AfterDebrief_d01633f6-cd53-48da-8121-cb0e653da86f"
        },
        Valid = function()
            return GetFlag(afterDebrief)
        end
    }

    nodes.Action_DebriefStandOnTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_SCE_FlorrickPoint_3920fecd-d435-4dbf-9314-20d15cd44e20"
        }
    }
end
}