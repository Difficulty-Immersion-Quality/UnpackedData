game.states.SHA_LastJusticiar_RatExtinguisher = State{function()
    description=[[This rat will turn off a specific light source if it is lit]]

    params.LightToExtinguish = {type=EParamType.String, default = "",
        help = [[The light the rat will turn off]]}

    params.IdlePos = {type=EParamType.String, default = "",
        help = [[Idle pos for the rat when not turning the light off]]}

    local light = Entity(params.LightToExtinguish)
    local idlePos = Entity(params.IdlePos)

    nodes.Extinguish = Action{
        function()
            UseItem(light.Item)
        end,

        Valid = function()
            return HasActiveStatus(light, "BURNING")
        end
    }

    nodes.Idle = Action{
        function()
            MoveTo(idlePos, MovementSpeed.Stroll, false, false, 0.2, 0.5, false)
            Sleep(2.0)
        end
    }
end}