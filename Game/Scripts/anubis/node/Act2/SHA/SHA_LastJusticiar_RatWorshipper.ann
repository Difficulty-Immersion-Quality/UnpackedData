game.states.SHA_LastJusticiar_RatWorshipper = State{function()
    description=[[This rat will follow the player around while the player is in a certain area]]

    modules = {"shared.dialog", "shared.util"}

    params.WorshipAD = {type=EParamType.String, default = "",
        help = [[Optional AD for the rat to play while following the player]]}

    local worshipAD = Dialog(params.WorshipAD)

    nodes.Worship = Action{
        function()
            mod.util.SleepRandom(1.0, 10.0)
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                worshipAD,
                {
                    waitForCompletion = true,
                    minDelay = 10.0,
                },
                me
            )
        end,

        CanEnter = function()
            return worshipAD ~= nil
        end
    }

    nodes.Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }
end}