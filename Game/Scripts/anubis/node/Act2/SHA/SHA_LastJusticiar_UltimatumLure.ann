game.states.SHA_LastJusticiar_UltimatumLure = State{function()
    description=[[Invisible helper that loops an AD to grab the players attention]]

    modules = {"shared.dialog", "shared.util"}

    local beckonAD = Dialog("SHA_LastJusticiar_AD_UltimatumLure_86d70594-75ff-63a7-eb91-2de6e0d05460")

    nodes.BeckonPlayer = Action {
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                beckonAD,
                    {
                        waitForCompletion = true,
                        minDelay = 15.0,
                    },
                    me
                )
            Sleep(1.0)
        end
    }

    nodes.Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }
end}