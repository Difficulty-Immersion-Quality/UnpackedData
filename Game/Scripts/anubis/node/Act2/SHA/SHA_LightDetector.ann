game.states.SHA_LightDetector = State{
    function()
        description = [[Detects if the item is under light or darkness and throws DetectorUnderLight or DetectorInDarkness respectively.]]

        params.activeCheck = {type = EParamType.Bool, help=[[
            Takes an expression that is true when the light is out.
        ]]}

        nodes.Action_UnderLight = Action{
            function()
                SetEntityEvent(me, "DetectorUnderLight")
                WaitForInterrupt()
            end,
            Valid = function()
                return not params.activeCheck
            end
        }

        nodes.Action_InDarkness = Action{
            function()
                SetEntityEvent(me, "DetectorInDarkness")
                WaitForInterrupt()
            end,
            Valid = function()
                return params.activeCheck
            end
        }
    end
}