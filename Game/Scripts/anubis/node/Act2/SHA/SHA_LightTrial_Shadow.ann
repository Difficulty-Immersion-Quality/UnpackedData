game.states.SHA_LightTrial_Shadow = State{
    function()
        ------------------------------------------------
        -- Local variables
        local patrolSpline = Spline("S_SHA_LightTrial_ShadowPatrol_d281a188-8bfc-4169-8017-0577b4038711")
        local patrolSplineIndex = 0
        ------------------------------------------------

        ------------------------------------------------
        -- Nodes
        nodes.Action_Patrol = Action{
            function()
                try
                    DoPatrol(patrolSpline, false, MovementSpeed.Walk, patrolSplineIndex)
                catch e if ls.CheckType(e, error.MissingComponent) then
                    DebugText(me, "Error: MissingComponent")
                    Sleep(3.0)
                end
            end,
        }
        ------------------------------------------------

        ------------------------------------------------
        -- Events
        events.SplineControlPointReached = function(e)
            patrolSplineIndex = e.NewIndex
        end
        ------------------------------------------------
    end
}