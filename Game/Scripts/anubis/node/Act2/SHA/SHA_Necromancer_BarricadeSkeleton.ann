game.states.SHA_Necromancer_BarricadeSkeleton = State{function()
    description = [[Skeletons that guard Balthazar's room while he is hiding]]

    modules = {"shared.util", "shared.dialog"}

    params.GuardingAD = {type=EParamType.String, default = "",
        help = [[Optional AD to play while guarding Balthazar's room]]}

    params.IdleAnim = {type=EParamType.String, default = "",
        help = [[Optional idle anim to play while guarding Balthazar]]}

    local idleAnim = Animation(params.IdleAnim)
    local guardingAD = Dialog(params.GuardingAD)
    local talkedFlag = Flag("SHA_Necromancer_State_TalkedToNecromancer_8f64e0d6-7144-43f4-b685-c1307bf5bc3e")

    nodes.Idle = Action{
        function()
            if idleAnim ~= nil then
                PlayAnimation(idleAnim, false, true)
            end

            if guardingAD ~= nil and not GetFlag(talkedFlag) then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    guardingAD,
                    {
                        waitForCompletion = true,
                        minDelay = 30.0,
                    },
                    me
                )
            end

            mod.util.SleepRandom(1.5, 3.5)
        end
    }
end}