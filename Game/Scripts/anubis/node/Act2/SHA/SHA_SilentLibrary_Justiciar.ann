game.states.SHA_SilentLibrary_Justiciar = State{function()
    description=[[Justiciars will patrol and stop at various points to inspect books]]

    params.ActionPos1 = {type = EParamType.String, required = false, default = "",
        help = [[object to move to and perform an action at]]}

    params.ActionAnim1 = {type = EParamType.String, required = false, default = "",
        help = [[Animation to play at the action point]]}

    params.ActionPos2 = {type = EParamType.String, required = false, default = "",
        help = [[Optional extra object to move to and perform an action]]}

    params.ActionAnim2 = {type = EParamType.String, required = false, default = "",
        help = [[Animation to play at the action point]]}

    params.ActionPos3 = {type = EParamType.String, required = false, default = "",
        help = [[Optional extra object to move to and perform an action]]}

    params.ActionAnim3 = {type = EParamType.String, required = false, default = "",
        help = [[Animation to play at the action point]]}

    params.LookAtActionPos = {type = EParamType.Bool, required = false, default = false,
        help = [[If the Justiciar should look at the Action Pos - if false, it will look from the Action Pos]]}

    params.WaitTime = {type = EParamType.Int, required = false, default = 10,
        help = [[How long the Justiciar will wait at an ActionPos before moving on]]}

    local actionPos1 = nil
    local actionPos2 = nil
    local actionPos3 = nil

    local actionAnim1 = Animation(params.ActionAnim1)
    local actionAnim2 = Animation(params.ActionAnim2)
    local actionAnim3 = Animation(params.ActionAnim3)

    helpers.action.MoveToActionPos = function(position, anim)
        if not IsInDangerousSurfaceFor(position, me.Character) then
            local moveResult = MoveTo(position, MovementSpeed.Stroll, true, false, 0.5, 1.0, false)

            if moveResult ~= error.MovementError.None then
                SteerTo(position)
                DebugText(me, "MOVEMENT FAILED")
                Sleep(2.0)
                return
            end

            if params.LookAtActionPos then
                SteerTo(position)
            else
                LookFrom(position)
            end

            PlayAnimation(anim, false, true)
            Sleep(params.WaitTime)
        else
            SteerTo(position)
            Sleep(2.0)
        end
    end

    helpers.action.MoveToActionPos2 = function(position, anim)
        if not IsInDangerousSurfaceFor(position, me.Character) then
            local moveResult = MoveTo(position, MovementSpeed.Stroll, true, false, 0.5, 1.0, false)

            if moveResult ~= error.MovementError.None then
                SteerTo(position)
                DebugText(me, "MOVEMENT FAILED")
                Sleep(2.0)
                return
            end

            if params.LookAtActionPos then
                SteerTo(position)
            else
                LookFrom(position)
            end

            PlayAnimation(anim, false, true)
            Sleep(params.WaitTime)
        else
            SteerTo(position)
            Sleep(2.0)
        end
    end

    helpers.action.MoveToActionPos3 = function(position, anim)
        if not IsInDangerousSurfaceFor(position, me.Character) then
            local moveResult = MoveTo(position, MovementSpeed.Stroll, true, false, 0.5, 1.0, false)

            if moveResult ~= error.MovementError.None then
                SteerTo(position)
                DebugText(me, "MOVEMENT FAILED")
                Sleep(2.0)
                return
            end

            if params.LookAtActionPos then
                SteerTo(position)
            else
                LookFrom(position)
            end

            PlayAnimation(anim, false, true)
            Sleep(params.WaitTime)
        else
            SteerTo(position)
            Sleep(2.0)
        end
    end

    self.OnInit = function()
        if params.ActionPos1 ~= "" then
            actionPos1 = Entity(params.ActionPos1)
        end

        if params.ActionPos2 ~= "" then
            actionPos2 = Entity(params.ActionPos2)
        end

        if params.ActionPos3 ~= "" then
            actionPos3 = Entity(params.ActionPos3)
        end
    end

    nodes.PatrolLibrary = Action{
        function()
            if actionPos1 ~= nil then
                helpers.MoveToActionPos(actionPos1, actionAnim1)
            end

            if actionPos2 ~= nil then
                helpers.MoveToActionPos(actionPos2, actionAnim2)
            end

            if actionPos3 ~= nil then
                helpers.MoveToActionPos(actionPos3, actionAnim3)
            end
        end
    }
end}