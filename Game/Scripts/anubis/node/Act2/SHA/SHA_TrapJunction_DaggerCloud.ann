game.states.SHA_TrapJunction_DaggerCloud = State{function()
    description=[[Dagger clouds that move between two points]]

    params.OriginalPosition = {type = EParamType.String, required = false, default = "",
        help=[[Place where the dagger cloud will begin and where it returns to after reaching its destination]]}

    params.TargetPosition = {type = EParamType.String, required = false, default = "",
        help=[[Where the dagger cloud will move to before returning to its original position]]}

    local originalPosition = Entity(params.OriginalPosition)
    local targetPosition = Entity(params.TargetPosition)

    nodes.MoveBetweenPoints = Action{
        function()
            if GetDistanceTo(me, originalPosition) < 0.3 then
                MoveItem(me, targetPosition)
            elseif GetDistanceTo(me, targetPosition) < 0.3 then
                MoveItem(me, originalPosition)
            end
        end
    }

    events.OnStageChanged = function(e)
        if e.OnStage then
            TeleportTo(me, originalPosition)
        end
    end
end}