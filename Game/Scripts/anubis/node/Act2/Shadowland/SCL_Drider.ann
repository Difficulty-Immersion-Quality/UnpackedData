game.states.SCL_Drider = State{
function()
    modules = { "shared.moveto", "shared.dialog", "shared.util", "shared.items" }

    local moonlantern = Entity("S_GLO_DriderMoonlantern_4591d212-8f1b-4b85-880c-dc94f76702f4")
    local droppedLantern = Flag("SCL_Drider_Event_AcquiredMoonlanternWithoutFight_cb3bc317-8358-47f4-831e-44ff812ec2b0")
    local equipLanternTries = 0

    local sidedWithCaravan = Flag("SCL_Drider_State_SidedWithCaravan_57a698da-0149-48d1-91fa-9a84a5dcc293")
    local scatter = Flag("SCL_Drider_Event_CaravanScatters_b496248c-87b9-4412-911a-18e81b669aaf")

    local disappear = Flag("SCL_Drider_Event_RunsAwayFromCaravan_817288ba-ed53-4cf6-ae94-2ea833bad4e3")
    local genDisappearOutOfSight = Flag("GEN_DisappearOutOfSight_5dc33889-cbfb-c3d2-9e4e-8d826bf8566f")

    local hasToWaitAtCaravanCamp = Flag("SCL_Drider_State_WaitAtCaravanStart_c2414538-2e56-428e-935e-35d0b11a1ff8")
    local waitAtCaravanPos = Entity("S_SCL_Drider_StartEscortPos_93a0731b-5d62-4cf5-84a2-c88190560cc4")

    local waitingAfterAmbush = Flag("SCL_Drider_State_WaitingAtAmbushAfterCombat_84d5065a-2648-d39d-d331-78ab4b68621d")
    local waitingAfterAmbushPos = Entity("S_SCL_Drider_Drider_AmbushMoveTo_66e426d4-5c60-4581-ad99-8ec850d090dc")

    local spPathToTower = Spline("S_SCL_DriderPathToTower_84f72cdc-b050-4888-8991-3801ee303453")

    local flArrivedToTower = Flag("SCL_Drider_Event_ArrivedToTower_e8d310c2-0b05-4e42-912b-e7199759de2a")
    local flEscortCaravan = Flag("SCL_Drider_Event_EscortCaravan_f6387817-27c0-4917-80d3-e6d9c2424663")
    local flRestAtThroneRoom = Flag("SCL_Drider_State_RestAtThroneRoom_f9f54076-af16-4ef8-99e9-5bc8d2084861")
    local runningTowardsTower = Flag("SCL_Drider_State_RunningTowardsMoonrise_f7a1bf4a-14e5-4aea-9f44-ee6542164cd0")

    local chapelPos = Entity("S_SCL_Drider_ChapelPoint_b348fc80-b45d-4129-926b-9ad00acfcee5")
    local chapelAD = Dialog("MOO_Drider_AD_33ca70db-c068-6336-bcf0-af12771b85a0")

    local deepcurseWaitPos = Entity("S_SCL_Drider_WaitAtBridge_820a0cb4-990d-445f-9d36-91d4e9ef429a")
    local deepcurseHostile = Flag("SCL_Drider_State_WaitingHostileBeforeDeepCurse_11c15680-eb03-460e-96a1-745a3d3a0d56")

    -- Escort behaviours
    local escortingPlayers = Flag("SCL_Drider_State_EscortingPlayers_387819d2-65d3-496b-9d59-ef37bac817dc")
    local townDeepCurseArea = Entity("S_ShadowCurse_BlightArea_Town_f2091d2d-2ac6-4e7e-ba08-315ffdd3e40a")
    local pausedEscortAD = Dialog("SCL_Drider_AD_EscortInterrupted_6968c419-ef81-5c2c-9800-94861d6a3386")
    local movingBackToBridge = Flag("SCL_Drider_State_MovingBackToTWNBridge_e245945e-469f-4083-998e-43bf2cba02b8")

    -- House rooftop
    local houseLadder = Entity("S_SCL_Drider_HouseCobweb_fa0015b4-44be-48fd-a992-79363efc522c")
    local rooftop = Entity("S_SCL_Drider_HouseRooftop_147b6fdd-1387-4291-9268-b959ff4ed855")
    local jumpFrom = Entity("S_SCL_Drider_Rooftop_JumpFrom_000_1b0c1ee9-647f-47c6-adee-d14ca7de2fc6")
    local jumpTo = Entity("S_SCL_Drider_Rooftop_JumpTo_000_79148886-f0ee-473d-88c8-083507466b03")

    helpers.PlayerOutOfEscortRange = function()
        local activeCharacters = GetActiveCharacters(me, 30)

        -- Check if the straggler was a player
        for _, char in ipairs(activeCharacters) do
            if  char.Character.IsPlayer and
                char.Character.IsEscortFollower and
                GetDistanceTo(me, char) > GetStatsExtraDataValue("EscortStragglerDistance") then
                    return true
            end
        end

        -- If there was no active player found nearby it means all players are outside of his range
        return false
    end

    helpers.AnyPlayerInEscortRange = function()
        local activeCharacters = GetActiveCharacters(me, 30)

        -- Check if the straggler was a player
        for _, char in ipairs(activeCharacters) do
            if  char.Character.IsPlayer and
                char.Character.IsEscortFollower and
                GetDistanceTo(me, char) <= GetStatsExtraDataValue("EscortStragglerDistance") then
                    return true
            end
        end
        return false
    end

    helpers.action.MoveToPosAndEscort = function(pos, movementSpeed)
        if not IsInDangerousSurfaceFor(pos, me.Character) and GetDistanceTo(pos, me) > 2.0 then
            local moveToResult = MoveTo(pos, movementSpeed, false, false, 0.0, 0.5, false)
            if moveToResult ~= error.MovementError.None then
                DebugText(me, "Error: movement failed")
                SteerTo(pos)
                Sleep(3.0)
            else
                LookFrom(pos)
            end
        else
            DoEscort()
        end
    end

    helpers.action.CanTakeMoonlantern = function()
        return GetDistanceTo(me, moonlantern) < 50.0 and not moonlantern.Item.IsInInventory
    end

    nodes = ImmediateSelector{}

    nodes.Action_RestAtChapel = Action{
        OnEnter = function()
            SendCaretSplineControlPointReachedEvents(me, false)
        end,
        function()

            if mod.moveto.MoveToPoint(chapelPos, MovementSpeed.Walk, me, 1.0) then
                LookFrom(chapelPos)

                mod.dialog.StartCheckedAutomatedDialog(
                    chapelAD,
                    {
                        minDelay = 20.0
                    },
                    me)

                mod.util.SleepRandom(6.0, 12.0)
            else
                Sleep(3.0)
            end
        end,
        CanEnter = function()
            return GetFlag(flArrivedToTower) and GetFlag(flRestAtThroneRoom)
        end
    }

    nodes.Proxy_RestAtTower = Proxy{
        OnEnter = function()
            SendCaretSplineControlPointReachedEvents(me, false)
        end,
        game.states.GLO_StandAtTrigger,
            params = {
                trigger = "S_SCL_Drider_StandAtTower_4ea41e07-5b9a-4b18-9ed9-82c9a6d4281f"
            },
        CanEnter = function()
            return GetFlag(flArrivedToTower)
        end
    }

    -- If for any reason the NPC has to run away keep doing it
    nodes.Action_DisappearOutOfSight = Action{
        function()
            SetFlag(genDisappearOutOfSight, me)
            Sleep(3.0)
        end,
        Valid = function()
            return GetFlag(disappear, me)
        end
    }

    nodes.Action_TakeMoonlanternOrScatter = Action{
        function()
            Sleep(0.5)
            if IsInInventoryOf(moonlantern, me) then
                Equip(me.Character, moonlantern.Item)
                Sleep(1.0)

            elseif helpers.CanTakeMoonlantern() and equipLanternTries < 3 then -- After three tries if still can't equip lantern scatter
                if mod.moveto.MoveToPoint(moonlantern, MovementSpeed.Run, me, 1.0) then
                    if helpers.CanTakeMoonlantern() and GetDistanceTo(me, moonlantern) < 1.5 then -- Recheck that drider can take moonlantern
                        ToInventory(moonlantern, me, 1, false, false)
                        Equip(me.Character, moonlantern.Item)
                        Sleep(1.0)

                    else
                        equipLanternTries = equipLanternTries + 1
                        SteerTo(moonlantern)
                        Sleep(3.0)

                    end
                else
                    equipLanternTries = equipLanternTries + 1
                    SteerTo(moonlantern)
                    Sleep(3.0)

                end
            else
                SetFlag(scatter)
                Sleep(3.0)

            end
        end,
        OnLeave = function()
            equipLanternTries = 0
        end,
        Valid = function()
            -- If Drider dropped the lantern intentionally don't go through equipment
            if GetFlag(droppedLantern) then
                return false
            end

            local hasMoonlanternEquipped = GetEquippedWeapon(me.Character, WeaponHandType.OffHand) == moonlantern
            if not hasMoonlanternEquipped then
                hasMoonlanternEquipped = GetEquippedWeapon(me.Character, WeaponHandType.MainHand) == moonlantern
            end
            return  not hasMoonlanternEquipped
        end
    }

    -- Edge case if Drider ends combat encounter at the roof of the ambush and ladder was destroyed.
    nodes.Action_JumpFromRooftop = Action {
        function()
            if mod.moveto.MoveToPoint(jumpFrom, MovementSpeed.Walk, me, 1.0) then
                local validPosition = FindValidPosition(jumpTo, 4.0, me, true)
                if validPosition ~= nil then
                    UseSpell("Projectile_Jump_Drider", validPosition, nil, nil, nil, true, true)
                else
                    DebugText(me, "Error: failed to find a valid position")
                    Sleep(3.0)
                end
            else
                SteerTo(jumpFrom)
                Sleep(3.0)
            end
        end,
        Valid = function()
            return mod.items.SafeIsDestroyed(houseLadder) and IsInTrigger(me, rooftop.Trigger)
        end
    }

    nodes.Proxy_WaitAtAmbushAfterCombat = Action{
        function()
            helpers.MoveToPosAndEscort(waitingAfterAmbushPos, MovementSpeed.Walk)
        end,
        Valid = function()
            return me.Character.IsEscortLeader and GetFlag(waitingAfterAmbush)
        end
    }

    nodes.Action_WaitAtCaravanCamp = Action{
        function()
            helpers.MoveToPosAndEscort(waitAtCaravanPos, MovementSpeed.Walk)
        end,
        Valid = function()
            return me.Character.IsEscortLeader and GetFlag(hasToWaitAtCaravanCamp)
        end
    }

    nodes.Action_WaitAtBridgeHostile = Action{
        function()
            helpers.MoveToPosAndEscort(deepcurseWaitPos, MovementSpeed.Walk)
        end,
        Valid = function()
            return me.Character.IsEscortLeader and GetFlag(deepcurseHostile)
        end
    }

    nodes.State_Escort = Selector{
        OnEnter = function()
            SendCaretSplineControlPointReachedEvents(me, true) -- Can't disable caret events on leave in case the behaviour becomes inactive
        end,
        Valid = function(nodes)
            return me.Character.IsEscortLeader and
                    GetFlag(flEscortCaravan) and
                    not GetFlag(flArrivedToTower)
        end,
    }

    nodes.State_Escort.Action_WaitingDuringEscort = Action {
        function()
            DoEscort() -- Need to keep it alive every frame
            -- Check if the straggler was a player and start AD
            if GetFlag(escortingPlayers) and helpers.PlayerOutOfEscortRange() then
                mod.dialog.StartCheckedAutomatedDialog(
                    pausedEscortAD,
                    {
                        minDelay = 20.0
                    },
                    me)
            end

            -- Case for the Drider pausing his behaviour because a player stayed behind while in TWN: go back to bridge. Only go back if ALL players are out of range
            if  GetFlag(escortingPlayers) and
                not helpers.AnyPlayerInEscortRange() and
                IsInTrigger(me, townDeepCurseArea.Trigger) then
                    SetFlag(movingBackToBridge)
                    if mod.moveto.MoveToPoint(deepcurseWaitPos, MovementSpeed.Run, me, 1.0) then
                        LookFrom(deepcurseWaitPos)
                        mod.util.SleepRandom(6.0, 12.0)
                    end
            end
        end,
        Valid = function()
            return  me.Character.IsEscortWaiting
        end,
        OnLeave = function()
            ClearFlag(movingBackToBridge)
        end
    }

    nodes.State_Escort.Action_RunToTower = Action{
        function()
            try
                DoEscortPatrol(spPathToTower, false, MovementSpeed.Run, -1)
            catch e if ls.CheckType(e, error.MissingComponent) then
                DebugText(me, "Error: MissingComponent at the escort behaviour")
                Sleep(3.0)
            end
        end,
        Valid = function()
            return  GetFlag(runningTowardsTower)
        end
    }

    nodes.State_Escort.Action_MoveToTower = Action{
        function()
            try
                DoEscortPatrol(spPathToTower, false, MovementSpeed.Walk, -1)
            catch e if ls.CheckType(e, error.MissingComponent) then
                DebugText(me, "Error: MissingComponent at the escort behaviour")
                Sleep(3.0)
            end
        end
    }

    nodes.Action_Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }

    events.SplineControlPointReached = function(e)
        if e.Event == "SCL_Drider_StopIfNotFollowing" and not GetFlag(sidedWithCaravan) then
            SetFlag(deepcurseHostile)
        elseif e.EndReached then
            SetFlag(flArrivedToTower)
        end
    end

    events.CaretSplineControlPointReached = function(e)
        if e.Event == "SCL_Drider_StopIfNotFollowing" and not GetFlag(sidedWithCaravan) then
            SetFlag(deepcurseHostile)
        elseif e.EndReached then
            SetFlag(flArrivedToTower)
        end
    end
end
}