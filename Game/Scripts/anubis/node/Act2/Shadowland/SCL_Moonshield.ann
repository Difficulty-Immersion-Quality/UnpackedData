game.roots.SCL_Moonshield = State{
function ()
    local initialized = false

    description = [[Dummy state that does not do anything]]
    -- public API
    nodes.Idling = function()
        WaitForInterrupt()
    end

    events.LevelLoaded = function(e)
        if e.Level == "SCL_Main_A" and not initialized then
            ApplyStatus(me, "SCL_MOONSHIELD_AURA", true, -1)
            initialized = true
        end
    end
end
}
