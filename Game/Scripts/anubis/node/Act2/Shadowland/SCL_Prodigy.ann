game.states.SCL_Prodigy = State{
    function()
        description = [[Rolan behaviour for the scene in SCL with the shadows.]]

        local idlePos = Entity("S_SCL_ProdigyFendingOffShadowsPos_95a79018-5012-4682-802c-cb9fc652f1c6")
        local inSCL = Flag("HAV_ProdigyLament_State_InShadowlands_68d204cb-3017-455e-9d80-c02abbc9f477")

        self.Valid = function()
            return GetFlag(inSCL)
        end

        nodes.Action_Idle = function()
            if not IsInDangerousSurfaceFor(idlePos, me.Character) then
                local moveToResult = MoveTo(idlePos, MovementSpeed.Walk, false, false, 0.5, 1.0, false)

                if moveToResult ~= error.MovementError.None then
                    SteerTo(idlePos)
                    DebugText(me, "Error: movement failed")
                    Sleep(3.0)
                else
                    LookFrom(idlePos)
                    WaitForInterrupt()
                end
            else
                SteerTo(idlePos)
                Sleep(3.0)
            end
        end
    end
}