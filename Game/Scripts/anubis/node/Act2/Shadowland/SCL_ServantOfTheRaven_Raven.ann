game.states.SCL_ServantOfTheRaven_Raven = State{function()
    local tr_homeTrigger
    local sitIdle = Animation("IDLE_Still_Peace_01_07e81afc-95c4-452b-ac68-5cbb74710cca")

    modules = {"shared.util","shared.math"}

    self.OnInit = function()
        tr_homeTrigger = FindEntity("S_SCL_ServantOfTheRaven_Raven_HomeTrigger_4bfc08ca-28a0-40fa-b14b-3b1cac121333")
    end

    nodes.Action_SitIdle = Action{
        function()
            if GetDistanceTo(me, tr_homeTrigger) > 2.0 then
				try
					MoveTo(tr_homeTrigger)
				catch e if ls.CheckType(e, error.MovementFailed) then
					LookFrom(tr_homeTrigger)
					Sleep(2.0)
				end
			end
            LookFrom(tr_homeTrigger)
            SitOnGround(me)
            try
                PlayAnimation(sitIdle)
            catch e if ls.CheckType(e, error.PlayAnimationFailed) then
                DebugText(me, "Animation Override Failed")
            end
            Sleep(2.0)
        end,
        Valid = function()
            return not IsInDialog(me)
        end
    }

    nodes.Action_Fallback = Action{
        function()
            Sleep(5.0)
        end
    }
end}