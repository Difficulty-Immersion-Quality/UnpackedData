game.states.SCL_ShadowBird = State{
    function()
        modules = {"shared.util"}

        description = [[Small behaviour for the cursed shadow birds in SCL]]

        local wanderArea = Entity("S_SCL_ShadowBirds_WanderArea_07e38bcc-2f30-4a94-8d5a-51660abf69f9")

        nodes.Action_Wander = Action{
            function()
                mod.util.SleepRandom(3.0, 6.0)
                try
                    Wander(wanderArea, 6.0, MovementSpeed.Stroll)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    DebugText(me, "Error: movement failed")
                    Sleep(3.0)
                end
            end
        }

    end
}