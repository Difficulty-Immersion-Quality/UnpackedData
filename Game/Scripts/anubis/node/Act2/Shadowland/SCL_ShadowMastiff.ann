game.states.SCL_ShadowMastiff = State{function()

    params.mastiffTrigger = { type = EParamType.String, required = false, default = nil, help = [[Fallback trigger for Shadow Mastiffs out of combat]]}

    nodes.StandAtTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
                trigger = params.mastiffTrigger
            }
        }

    nodes.Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }
end
}