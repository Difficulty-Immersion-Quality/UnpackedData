game.states.TWN_AasimarSurvivor_FetidOoze = State { function ()
    description = [[
        Behaviour for the Fetid ooze in Aasimar survivor situation. Same as usual ooze, but without wander.
    ]]


    nodes.AcidTrailSpawn = Proxy{
        game.states.SurfaceTrailSpawner,
        params = {
            SurfaceType = "ACID"
        }
    }

    nodes.Action_Idle = Action{
        function()
            WaitForInterrupt()
        end
    }
end}