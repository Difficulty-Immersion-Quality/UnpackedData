game.states.TWN_Distillery_Zombie = State { 
    
    function ()

        modules = {"shared.dialog"}

        params.AD = {type = EParamType.String, required = true, help=[[]]}
        params.WanderTrigger = {type = EParamType.String, required = true, help=[[]]}

        local AD = Dialog(params.AD)
        local WanderTrigger = Entity(params.WanderTrigger)

        nodes.Default = Action {
            function() 
                if AD ~= nil then               
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        AD,
                        {
                            waitForCompletion = false,
                            minDelay = 24.0,
                        },
                        me                    
                    )
                else
                    DebugText(me, "Dialog is null")
                end
                Wander(WanderTrigger, 6.0, MovementSpeed.Stroll)
                Sleep(6.0)
            end,            
        }        

        nodes.Fallback = Action {
            function()                
                Sleep(6.0)
            end,            
        }
      
    end
}