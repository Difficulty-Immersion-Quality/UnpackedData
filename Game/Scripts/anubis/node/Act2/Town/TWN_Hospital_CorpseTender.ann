game.states.TWN_Hospital_CorpseTender = State { function()

    modules = { "shared.moveto" }

    local standingSpot = Entity("S_TWN_Hospital_CorpseTenderSpot_2be5fdb1-5fca-4dc4-943a-6b1732138fad")
    local corpse = Entity("S_TWN_Hospital_Reception_TendedCorpse_d15d2347-6b23-4ad6-a49c-6e9d8c2069e7")

    nodes.GetToCorpse = Action
    {
        function()
            if mod.moveto.MoveTo(standingSpot,true,0.5,"Walk","TWN_Hospital_Receptionist_GetToReception") then  
                LookFrom(standingSpot)
            end
        end,
        Valid = function()
            return GetDistance2DTo(me, standingSpot) >= 0.5
        end,
    }    

    nodes.TendToCorpse = Action{
        function()
            DebugText(me,"Tending animation")
            Sleep(6)
        end,
        CanEnter = function()
            return GetDistance2DTo(me, corpse) <= 0.5
        end
    }

    nodes.Fallback = Action 
    {
        function()
            WaitForInterrupt()
        end,
    }

end}