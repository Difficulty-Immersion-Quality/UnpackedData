game.states.TWN_Hospital_Patient = State { function()

    description = [[]]
    local fl_Released = Flag("TWN_Hospital_State_PatientReleased_2d47b88f-3c8e-4f74-8833-6934c7a6b70d")
    local tr_EscapePoint = Entity("S_TWN_Hospital_PatientEscapePosition_2904fff5-f507-440d-b54c-23bc11120c59")

    nodes.RunAway = Action
    {
        function()
            MoveTo(tr_EscapePoint, MovementSpeed.Walk)            
        end,
        Valid = function()
            return GetFlag(fl_Released)
        end,
    }    

    nodes.DefaultBehaviour = Proxy {
        game.states.Sit,
        params = {
            seat = "S_TWN_Hospital_Chair_5cf9348a-4162-484d-833d-50671254f770"
        },
        Valid = function()
            return not GetFlag(fl_Released)
        end,
    }

end}