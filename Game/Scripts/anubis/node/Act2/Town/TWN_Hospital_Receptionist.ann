game.states.TWN_Hospital_Receptionist = State { function()

    modules = { "shared.moveto" }

    local receptionSpot = Entity("S_TWN_Hospital_Reception_Receptionist_3baf6794-2c83-4bd3-b2dd-70b4a9f98503")

    nodes.StandAtReception = Action
    {
        function()
            if mod.moveto.MoveTo(receptionSpot,true,0.5,"Walk","TWN_Hospital_Receptionist_GetToReception") then  
                LookFrom(receptionSpot)
            end
        end,
        Valid = function()
            return GetDistance2DTo(me, receptionSpot) >= 0.5
        end
    }    

    nodes.LookFrom = Action
    {
        function()
            LookFrom(receptionSpot)
            Sleep(6)
        end,
        CanEnter = function()
            return GetDistance2DTo(me, receptionSpot) <= 0.7
        end
    }    

    nodes.Fallback = Action 
    {
        function()
            WaitForInterrupt()
        end,
    }

end}