game.states.TWN_Korrilla = State{
    function()

    modules = {"shared.math", "shared.dialog", "shared.util"}
    description = [[Behaviour script for Korrilla watching the palyer in TWN]]

    local townTrigger = Entity("S_GLO_KorrillaInTWNZone_44826a38-af34-488f-8330-12b05d81de80")

    --Korrilla sneaks around in camp and every time she arrives at a node, she looks at the player for a bit
    nodes.InTownWatching = Action{
        function()
                local targetchar = nil
                local actives = GetActiveCharacters(me,  50)
                for _,char in pairs(actives) do
                    if char.Character.IsPlayer then
                        if targetchar == nil then
                            targetchar = char
                        else                        
                            if GetDistanceTo(me, targetchar) > GetDistanceTo(me, char) then
                                targetchar = char
                            end
                        end
                    end
                end
                if targetchar then
                    SteerTo(targetchar, false, 20)
                    LookAtEntity(targetchar, 2.0)
                end
                Sleep(2.0)
        end,
        Valid = function()
            return IsInTrigger(me, townTrigger.Trigger)
        end
    }

    nodes.Idle = Action{
        function()
            WaitForInterrupt()
        end
    }


end}