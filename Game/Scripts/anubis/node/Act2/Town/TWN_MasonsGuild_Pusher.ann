game.states.TWN_MasonsGuild_Pusher = State{function()

    description = [[Helper that pushes characters and items away. Part of a trap.]]

    params.attackSpell = {type = EParamType.String, required = true,
        help = [[Spell that is used to push characters and items away.]]}

    local canShoot = false

    nodes.Push = Action{
        function()
            DebugText(me, "PUSHING")
            ShootZone(params.attackSpell, me, ls.math.Vector3(0, 0, 0),  me.ForwardDirection)
            canShoot = false
        end,
        Valid = function()
            return canShoot
        end
    }

    nodes.Sleep = Action{
        function()
            DebugText(me, "SLEEPING")
            Sleep(6.0)
        end,
        Valid = function()
            return not canShoot
        end
    }

    events.EntityEvent = function(ev)
        if ev.TargetEntity == me and ev.Event == "TWN_MasonsGuild_Push" then
            canShoot = true
        end
    end

end}