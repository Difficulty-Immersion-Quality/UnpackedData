game.states.TWN_Tollhouse_TollhouseMaster = State{
    function()

        modules = { "shared.math", "shared.util",  "shared.dialog"}

        params.AD = {type=EParamType.String, required=false, default=nil, help=[[
            Default AD
        ]]}

        local dlg_AD = Dialog(params.AD)
        local patrolPos000 = Entity("S_TWN_Tollhouse_TollhouseMaster_PatrolPos_001_8edc5030-d0f8-44e4-837b-1f923e1db3c9")
        local patrolPos001 = Entity("S_TWN_Tollhouse_TollhouseMaster_PatrolPos_002_a883a3fa-b774-4f04-81a9-9d743c2b4a74")
        local patrolPos002 = Entity("S_TWN_Tollhouse_TollhouseMaster_PatrolPos_003_254282da-b56b-44c6-bd1a-b1961e9690a8")        

        nodes.PatrolBehavior = Action {                  
            function()
                DebugText(me, "Patrol")
                MoveTo(patrolPos000, MovementSpeed.Walk)
                LookFrom(patrolPos000)
                Sleep(mod.math.random(3, 9))
                MoveTo(patrolPos001, MovementSpeed.Walk)
                LookFrom(patrolPos001)
                Sleep(mod.math.random(3, 9))
                try
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        dlg_AD,
                        {                            
                            minDelay = 10.0,
                            cullingDistance = 20.0,
                            waitForCompletion = false
                        },
                        me)
                catch e if ls.CheckType(e, error.AutomatedDialogStartFailed) then
                    --
                end
                MoveTo(patrolPos002, MovementSpeed.Walk)
                LookFrom(patrolPos002)
                Sleep(mod.math.random(3, 9))
            end
        }
    end
}