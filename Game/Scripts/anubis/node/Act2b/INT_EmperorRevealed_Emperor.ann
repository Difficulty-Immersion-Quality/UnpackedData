game.states.INT_EmperorRevealed_Emperor = State{
    function()

        modules = { "shared.math", "shared.util", "shared.moveto" }

        local MetEmperorFlag = Flag("INT_EmperorRevealed_Event_SceneComplete_2fa4811a-8757-40e7-a0bb-dc7e210dd6e6")

        nodes.Wander = Proxy {
            game.states.GEN_Wander,
            params = {
                trigger = [[S_INT_AstralPlaneArea_37dec4e1-9db0-44a9-bd39-a5f4362d2ab2]],
                wanderMin = 6,
                wanderMax = 9,
                sleepMin = 3,
                sleepMax = 9},
            CanEnter = function()
                return GetFlag(MetEmperorFlag)
            end
        }

        nodes.Idle = Action {
            function()
                Sleep(1)
            end
        }
    end
}