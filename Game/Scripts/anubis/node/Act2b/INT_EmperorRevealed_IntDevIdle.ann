game.states.INT_EmperorRevealed_IntDevIdle = State{
    function ()

        modules = {"shared.math", "shared.moveto"}

        local subduedOrpheusFlag = Flag("INT_EmperorRevealed_Event_OrpheusNearlyDefeated_5c6065fb-0d96-44b4-9ffb-3e1bacc9e097")
        local canGoToSkull = Flag("INT_EmperorRevealed_State_CanGoToSkull_19affb40-2d94-432e-a970-cfcc48bfb304")

        nodes.WanderAfterOrpheus = Proxy {
            game.states.GEN_Wander,
            params = {
                trigger = [[S_INT_AstralPlaneArea_37dec4e1-9db0-44a9-bd39-a5f4362d2ab2]],
                wanderMin = 6,
                wanderMax = 9,
                sleepMin = 3,
                sleepMax = 9},
            CanEnter = function()
                return GetFlag(subduedOrpheusFlag)
            end
        }

        nodes.IdleFallback = Action {
            function()
                WaitForInterrupt()
            end
        }
    end
}
