
game.states.END_AbsoluteCannonFodder_001_Idle = State{function ()
    description = [[Defending the path to the brain stem]]

    modules = {"shared.dialog", "shared.moveto"}

    local idlePoint = Entity("S_END_AbsoluteIdle_001_985614f2-f3a1-4b06-94e9-d53730b09b79")
    local AD = Dialog("END_HighHallInterior_AD_FodderOnGuard_83141aa6-6879-0443-02c0-37658ec276d7")
    local guard002 = Entity("S_END_AbsoluteCannonFodder_002_c1605cd8-238e-4589-a4fd-1d9c4edab015")

    nodes.Idle = Action {
        OnEnter = function()
            SetDoNotFace(me, true)
        end,
        function()
            if mod.moveto.MoveToPoint(idlePoint,  MovementSpeed.Walk, me) then
                LookFrom(idlePoint)
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        AD,
                        {
                            waitForCompletion = true,
                            minDelay = 30.0,
                        },
                        me,
                        guard002
                    )
            else
                SteerTo(idlePoint)
            end
            Sleep(1)
        end,
        OnLeave = function()
            SetDoNotFace(me, false)
        end
    }


end
}

