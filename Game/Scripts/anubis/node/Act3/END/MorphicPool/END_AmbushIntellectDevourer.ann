game.states.END_AmbushIntellectDevourer = State{function ()
    description = [[In the case they appear without spotting the player, they'll wander around]]

    
    nodes.Wander = Action {
        function()
            Sleep(3.0 + 6.0 * math.random())
            Wander(5.0, 7.0, MovementSpeed.Walk)
        end
    }
    

end
}