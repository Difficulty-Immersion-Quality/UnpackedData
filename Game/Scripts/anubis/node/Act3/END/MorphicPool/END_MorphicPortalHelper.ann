game.states.END_MorphicPortalHelper = State{function ()
    description = [[Simple script to just control the portal opening event timing in combat]]

--------------------------------LOCAL--------------------------------
    local emperorAppearedFlag = Flag("END_MorphicPool_Event_EmperorAppeared_018786de-ef01-47ca-b86f-b930ada8a326")
    local emperorLeftFlag = Flag("END_MorphicPool_Event_EmperorLeft_bc7d1730-f210-479b-9de5-563bcf784f00")

--------------------------------NODES--------------------------------

    nodes.Idle = Action {
        function()
            Sleep(5)
        end
    }

end
}