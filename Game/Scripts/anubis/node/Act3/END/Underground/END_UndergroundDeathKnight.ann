game.states.END_UndergroundDeathKnight = State{function()

    local atHaltPoint = false
    local patrolSpline = Spline("S_END_Underground_DeathKnightPatrol_16828ecb-da50-4e78-957f-c1c87cc39c5b")

    self.Valid = function()
        return not me.IsInCombat
    end

    nodes.State_PausePatrolDeathKnight = Action{
        CanEnter = function()
            return atHaltPoint
        end,
        
        OnEnter = function()
            atHaltPoint = false
        end,

        function()
            if not atHaltPoint then
                Sleep(3.0)
            end
        end
    }

    nodes.State_PatrolDeathKnight = Action{
        Valid = function()
           return not atHaltPoint;
        end,

        function()
            try
                DoPatrol(patrolSpline, false, MovementSpeed.Walk, 0)
            catch e if ls.CheckType(e, error.MissingComponent) then
                DebugText(me, "Error: MissingComponent")
                Sleep(3.0)
            end
        end
    }

    

    events.SplineControlPointReached = function(e)
        if e.Event == "END_Underground_DeathKnight_HaltPoint" then
            atHaltPoint = true
        end
    end
end
}