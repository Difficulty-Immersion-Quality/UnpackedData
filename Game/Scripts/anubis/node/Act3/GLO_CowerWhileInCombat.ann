game.states.GLO_CowerWhileInCombat = State{function ()
    local GLO_State_Cowering = Flag("GLO_State_Cowering_cf16110e-3767-4585-8028-83cb9857adcd")
    local GLO_State_NoCower = Flag("GLO_State_NoCower_8180293e-4d0d-4e9b-9dfc-b195d4c67ddb")

    description = [[
        Simplified combat cowering state that works when the character themselves are in combat.
        (standard cower works when the combat happens nearby).
    ]]

    self.Valid = function()
        return not GetFlag(GLO_State_NoCower,me)
    end

    self.OnEnter = function()
        SetFlag(GLO_State_Cowering, me)
        ApplyStatus(me, "ANIM_COWER")
    end

    self.OnLeave = function()
        RemoveStatus(me, "ANIM_COWER")
        ClearFlag(GLO_State_Cowering, me)
    end

    -- actions
    nodes.Cower = Action {
        function()
            WaitForInterrupt()
        end
    }
end}
