game.states.GLO_RegionProxies_Act3 = State { function ()

    local inCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")

    description = [[Contains a proxy for each region in Act3. To be used on global entities in this Act only.]]

    params.CAMP = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the campsite.]]
    }
    params.WYR = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only on the Wyrm's Crossing.]]
    }
    params.act3 = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in BGO_Main_A.]]
    }

    nodes = ImmediateSelector {}

    nodes.CAMP = Proxy {
        params.CAMP,
        Valid = function()
            return GetFlag(inCamp,me)
        end
    }

    nodes.Act3 = ImmediateSelector {
        Valid = function(node)
            return CheckCurrentGameLevel("BGO_Main_A") and CheckAnySelectable(node)
        end
    }
    nodes.Act3.WYR = Proxy {
        params.WYR
    }
    nodes.Act3.Main = Proxy {
        params.act3
    }

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end
    }
end}