game.states.LOW_BaldursMouth_BroadsheetSeller = State { function ()
    description = [[ Silfy the broadsheetseller sells her newspapers at Posthouse, and will eventually get better at it. ]]

    local ADbad = "WYR_Posthouse_BroadsheetSeller_AD_723c3b7c-412b-bb08-f0be-84c7d920a8e3"
    local ADgood = "LOW_BaldursMouth_AD_PaperBoys_2f9f653b-f5af-f8c0-d17f-47c3a0af158d"
    local ADInTrigger = "S_LOW_BaldursMouth_Point_PaperGirl_4b252084-a62c-4c6e-abba-62bb31d27695"
    local ADSwitchFlag = Flag("LOW_BaldursMouth_State_BroadSheetSellerGoodAtSelling_f9c8a94d-746f-4687-b991-0959e73aee79")

    nodes.BroadsheetSeller_ADInTrigger_Bad = Proxy {
        game.states.WYR_ADInTrigger,
        params = {
            trigger = ADInTrigger,
            AD = ADbad
        },
        Valid = function ()
            return not GetFlag(ADSwitchFlag)
        end
    }

    nodes.BroadsheetSeller_ADInTrigger_Good = Proxy {
        game.states.WYR_ADInTrigger,
        params = {
            trigger = ADInTrigger,
            AD = ADgood
        },
        Valid = function ()
            return GetFlag(ADSwitchFlag)
        end
    }
end}