game.states.LOW_BaldursMouth_PaperBoys = State{
    function()
        
        params.idleAnimation = {type = EParamType.String, required = true, help = [[Idle animation.]]}

        params.timelineTrigger = {type = EParamType.String, required = true, help = [[Timeline Scene Trigger.]]}

        local behaviorDialog = Dialog("BHVR_WRLD_GLO_PaperBoysWaving_789d3d7a-9c31-8b6e-288a-d0e9157d0db0")
        local trigger = Entity(params.timelineTrigger)
        local animation = Animation(params.idleAnimation)
        local isIdle = true

        self.Valid = function()
            return isIdle
        end
        nodes.Action_Idle = Action{
            function()
                try 
                    StartBehaviorDialog(behaviorDialog, trigger.Trigger, true, me)
                catch e then
                PlayAnimation(animation, false, true)
                end
            end
        }
    end
}