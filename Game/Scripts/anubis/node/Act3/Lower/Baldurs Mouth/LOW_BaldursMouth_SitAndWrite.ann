game.states.LOW_BaldursMouth_SitAndWrite = State {
    function()
    description = [[Sitting and writing on desks.]]

    modules = {"shared.dialog", "shared.math", "shared.util"}


    local sceneTrigger = Entity("S_LOW_BaldursMouth_BHVR_WRLD_SitAndWrite_DWF_M_3303528b-f63f-46f7-b001-8fb04e857870")

    local dwarfTimeline = Dialog("BHVR_WRLD_SitAndWrite_DWF_M_9f148535-380e-7016-0b44-8cc9628faa9e")
    local dwarfChair = Entity("S_LOW_BaldursMouth_WritersSeat_001_e3a28b32-91f8-4479-a224-50f724610254")

    local gnomeTimeline = Dialog("BHVR_WRLD_SitAndWrite_GNO_F_b966d728-cc8d-55a2-df14-fa95146d39e2")
    local gnomeChair = Entity("S_LOW_BaldursMouth_WritersSeat_000_603c307c-fda9-4a24-ba11-9fed1f5d5c80")

    local humFTimeline = Dialog("BHVR_WRLD_SitAndWrite_HUM_F_9bb11294-0627-cf49-8099-d9f859034a46")
    local humFChair = Entity("S_LOW_BaldursMouth_WritersSeat_002_1f24a837-4566-4a69-a2f4-3989aeadc234")

    local humMTimeline = Dialog("BHVR_WRLD_SitAndWrite_HUM_M_994987a5-894a-c4bc-451d-028180e8d3d7")
    local humMChair = Entity("S_LOW_BaldursMouth_WritersSeat_002_1f24a837-4566-4a69-a2f4-3989aeadc234")

    local selectedTimeline = nil
    local selectedChair = Entity("S_LOW_BaldursMouth_WritersSeat_001_e3a28b32-91f8-4479-a224-50f724610254")

    local readyToWrite = 1
    

    nodes.WriteBehavior = Action{
        function()
            if IsTagged(me,Tag("DWARF_486a2562-31ae-437b-bf63-30393e18cbdd")) and not IsTagged(me,Tag("FEMALE_3806477c-65a7-4100-9f92-be4c12c4fa4f")) then
                selectedTimeline = dwarfTimeline
                selectedChair = dwarfChair
            elseif IsTagged(me,Tag("GNOME_1f0551f3-d769-47a9-b02b-5d3a8c51978c")) then
                selectedTimeline = gnomeTimeline
                selectedChair = gnomeChair
            elseif IsTagged(me,Tag("HUMAN_69fd1443-7686-4ca9-9516-72ec0b9d94d7")) then
                if IsTagged(me,Tag("FEMALE_3806477c-65a7-4100-9f92-be4c12c4fa4f")) then
                    selectedTimeline = humFTimeline
                    selectedChair = humFChair
                else
                    selectedTimeline = humMTimeline
                    selectedChair = humMChair
                end
            end



            if selectedTimeline ~= nil then
                DebugText(me, "Starting Timeline")
                StartBehaviorDialog(selectedTimeline, sceneTrigger.Trigger, true, me, selectedChair)
            else
                Sleep(3.0)
            end

            DebugText(me, "Starting Sleep")
            readyToWrite = 0

        end,

        CanEnter = function()
            return readyToWrite == 1
        end,
    }

    nodes.WriterPause = Action{
        function()
            mod.util.SleepRandom(1.0, 3.0)
            DebugText(me, "Ending Sleep")
            readyToWrite = 1
        end,

        CanEnter = function()
            return readyToWrite == 0
        end,
    }
end
}