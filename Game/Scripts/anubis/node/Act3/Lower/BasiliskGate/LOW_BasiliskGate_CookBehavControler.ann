game.states.LOW_BasiliskGate_CookBehavControler = State{function ()
    description = [[Swicthes the between flee and random patrol based on a flag]] 

    params.spiceGrinding = {type = EParamType.State, required=true, help=[[...]]}
    params.meatChopping = {type = EParamType.State, required=true, help=[[...]]}

    local currentAction = "spiceGrinding"

    helpers.DebugTextMe = function(str)
        DebugText(me, tostring(str))
    end

    nodes.spiceGrinding = Proxy
    {
        params.spiceGrinding,
        Valid = function(node)
            return currentAction == "spiceGrinding"
        end,
        OnFinished = function()
            currentAction = "meatChopping"
            return
        end
    }
   
    nodes.meatChopping = Proxy
    {
        params.meatChopping,
        Valid = function(node)
            return currentAction == "meatChopping"
        end,
        OnFinished = function()
            currentAction = "spiceGrinding"
            return
        end
    }
end}
