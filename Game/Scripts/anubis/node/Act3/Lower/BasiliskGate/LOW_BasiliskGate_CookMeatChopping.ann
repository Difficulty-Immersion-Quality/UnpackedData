game.states.LOW_BasiliskGate_CookMeatChopping = State { function ()
    description = [[world behavior - a humanoid chops meat with a cleaver]]

    local behaviorTrigger = Entity("S_LOW_BasiliskGate_Cook_GrindSpice_TimelineTrigger_000_0ecbb931-0f46-44ae-819d-3498faa0145a")
    local behaviorDialog = Dialog("BHVR_WRLD_LOW_BasiliskGate_Cook_MeatChop_99643894-c9c1-e350-6330-3cca1098b61e")
    local meatItem = Entity("S_LOW_BasiliskGate_Cook_Meat_01_c4089357-6e9c-4fa4-a337-57f1c3412fbe")
    local cleaverItem = Entity("S_LOW_BasiliskGate_Cook_Cleaver_01_2b5aa347-2838-4e88-90d7-a7e1b4bb98c3")
    
    nodes.PlayWorldbehaviorAnimation = Action{function()
        DebugText(me,"Trying MeatChop")
        try
            StartBehaviorDialog(behaviorDialog, behaviorTrigger.Trigger, true, me, cleaverItem, meatItem)
        catch e then
            DebugText(me,"Error: [1]",e)
        end

        Sleep(2.0)
    end
    }

    --fallback
    nodes.Sleep = Action{function()
        WaitForInterrupt()
    end
    }
end}