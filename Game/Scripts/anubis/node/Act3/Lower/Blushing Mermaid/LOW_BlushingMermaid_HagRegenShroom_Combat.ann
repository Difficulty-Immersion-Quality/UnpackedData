game.states.LOW_BlushingMermaid_HagRegenShroom_Combat = State{function()

        self.Valid = function()
            return me.IsInCombat
        end

        nodes.EndTurn = Action{
            CanEnter = function()
                return me.CanActInCombatTeamTurn
            end,

            function()
                Sleep(1.0)
                EndTurn(me)
            end
        }

        nodes.DefaultCombat = Proxy{
            game.states.DefaultItemCombat
        }
    end
}