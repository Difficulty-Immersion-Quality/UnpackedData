
game.states.LOW_TadpoleTransport_PatrollingSteelwatcher = State{
    function()

        local patrolSpline = Spline("S_LOW_TadpoleTransport_Patrol_7ff55f7c-f394-4136-bc40-556b34f02bf2")

        nodes.Patrol = Action{
            function()
                DoPatrol(patrolSpline, false, MovementSpeed.Walk)
            end,

            Valid = function()
                return patrolSpline ~= nil
            end
        }
    end
}
