game.states.LOW_CountingHouse_Clerk = State{function()
    
    modules = {"shared.dialog", "shared.util"}

    params.idleAD = {type = EParamType.String, required=false, help=[[Idle AD to play.]]}
    params.idleAnimation = {type = EParamType.String, required=false, help=[[Idle animation to play.]]}
    params.idleTrigger = {type = EParamType.String, required=false, help=[[Idle trigger to stand at.]]}
    params.ADPartner = {type = EParamType.String, required=false, help=[[2nd character for the idle AD.]]}    
    params.escapeTrigger = {type = EParamType.String, required=false, help=[[Trigger to which the clerk will run in case of combat or alarm.]]}
    params.panicFlag = {type = EParamType.String, required=false, help=[[Flag that enables panic state on clerks.]]}

    params.behaviorDialog = {type = EParamType.String, required=false, help=[[Accounting wold beahvior.]]}
    local behaviorDialog = Dialog(params.behaviorDialog)

    params.sceneTrigger = {type = EParamType.String, required=false, help=[[Scene trigger for accounting world behavior.]]}
    local sceneTrigger = Entity(params.sceneTrigger)

    local idleTriggerString = params.idleTrigger
    local idleTrigger

    local idleAnimation = Animation(params.idleAnimation)
    local idleAD = Dialog(params.idleAD)
    local ADPartner = Entity(params.ADPartner)

    local panicFlag = Flag(params.panicFlag)

    local ledgerMovedFlag = Flag("LOW_CountingHouse_State_ClerksLedgerMoved_25435935-cd35-4866-8ecc-c56c0c088728")

    self.OnInit = function()
        idleTrigger = Entity(params.idleTrigger)
    end

    nodes.Panic = Proxy {
        CanEnter = function()
            return GetFlag(panicFlag)
        end,
        game.states.LOW_CountingHouse_Clerk_Cower,
        params = {
            escapeTrigger = params.escapeTrigger,
            panicFlag = params.panicFlag
        }
    }
      
    nodes.Idle = Action{        
        function()
            LookFrom(idleTrigger)
            Sleep(math.random(1.0,3.0))
            if(idleAD ~= nil) then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    idleAD,
                    {
                        waitForCompletion = false,
                        minDelay = 10 + math.random(1,2),
                        allowNilSpeakers = true
                    },
                    me,
                    ADPartner
                )
            end
            Sleep(math.random(1.0,3.0))
            if(behaviorDialog ~= nil and sceneTrigger ~= nil and not GetFlag(ledgerMovedFlag,me)) then
                try
                    StartBehaviorDialog(behaviorDialog, sceneTrigger.Trigger, true, me)
                catch e if ls.CheckType(e, error.BehaviorDialogStartFailed) then
                    DebugText(me,"BehaviorDialogStartFailed on [1]", me.Name)
                end
            else
                PlayAnimation(idleAnimation,false,false)
            end
        end,

        Valid = function()
            return GetDistanceTo(me, idleTrigger) <= 2.0
        end,

        OnLeave = function()
            StopAnimation(me)
        end
    }

    nodes.StandAtTrigger = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = idleTriggerString,
            acceptanceRadius = 1.0
        }
    }

    events.FlagSet = function(e)
        if e.Flag == ledgerMovedFlag.Guid then
            --BehaviorDialogRequestGracefulStop(me,true,behaviorDialog)
            DialogRequestStop(me,behaviorDialog)
            Interrupt()
        end
    end
end}

game.states.LOW_CountingHouse_Clerk_Cower = State{function ()

    modules = {"shared.moveto"}

    params.panicFlag = {type = EParamType.String, required=false, help=[[Flag that enables panic state on clerks.]]}
    params.escapeTrigger = {type = EParamType.String, required=false, help=[[Trigger to which the clerk will run in case of combat or alarm.]]}
    
    local escapeTrigger = Entity(params.escapeTrigger)
    local escapeTriggerString = params.escapeTrigger

    local panicFlag = Flag(params.panicFlag)

    self.OnEnter = function()
        SetUnicastEntityEvent(me, "ClearPeaceReturn")
        ApplyStatus(me, "ANIM_COWER")
    end

    nodes.RunInBackroom = Action{
        function()
            -- The flag is set in Osiris
            if(GetFlag(panicFlag)) then
                mod.moveto.MoveToPoint(escapeTrigger, MovementSpeed.Run, me, 0.5)
            else
                Sleep(2.0)
            end
        end,

        Valid = function()
            return GetDistanceTo(me, escapeTrigger) > 1.0
        end
    }

    nodes.CowerInBackroom = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = escapeTriggerString
        }
    }

    self.OnLeave = function()
        RemoveStatus(me, "ANIM_COWER")
    end
end}