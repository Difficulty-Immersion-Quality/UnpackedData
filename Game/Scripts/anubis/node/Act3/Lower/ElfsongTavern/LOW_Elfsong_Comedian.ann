game.states.LOW_Elfsong_Comedian = State{function ()

    --------------------------------Description--------------------------------
    description = [[Behavior of the main comedian at Elfsong Tavern.]]

    --------------------------------Modules--------------------------------

    modules = {"shared.dialog"}

    --------------------------------Variables--------------------------------

    local localAD = nil
    local steerPoint = nil
    local drinkAnimation = nil

    --------------------------------Nodes--------------------------------

    self.OnInit = function()
            localAD = Dialog("LOW_Elfsong_AD_HarvardWilloughby_50009fe8-791d-467e-ad20-0156d59c79b4")
            steerPoint = Entity("S_LOW_Elfsong_ComedyShow_Anchor_001_c7d602aa-393f-4bbe-80f1-ac550238e40b")
            drinkAnimation = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")
    end

    nodes = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.TellingJoke = Action {
        function()
            mod.dialog.StartCheckedAutomatedDialog(
            localAD,
            {
                waitForCompletion = true
            },
            me
        )

        end
    }
    nodes.Drinking = Action {
        function()
            try
                SteerTo(steerPoint)
                PlayAnimation(drinkAnimation)
            catch e if ls.CheckType(e, error.PlayAnimationFailed) then
                DebugText("Drinking animation is not working")
            end
        end
    }


end
}