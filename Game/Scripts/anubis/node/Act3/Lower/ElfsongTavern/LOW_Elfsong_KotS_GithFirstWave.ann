game.states.LOW_Elfsong_KotS_GithFirstWave = State{function ()

    --------------------------------Params and modules--------------------------------

    modules = {"shared.moveto"}

    params.DestinationPoint = {type = EParamType.String, help = [[Destination point of the character]], required = false, default = "S_LOW_Elfsong_Basement_PortalPoint_004_b698f739-cc86-4d76-a499-7af58571e831" }
    params.EventFlag = {type = EParamType.String, help = [[Flag to start the movement]], required = false, default = "LOW_Elfsong_KotS_MoveToPosition_fde28148-eff7-4014-a71d-9880ce812d61"}
    params.WanderZone = {type = EParamType.String, help = "[[Wander Zone]]", required = false, default = "S_LOW_KotS_TemplarWander_b94f4661-9161-4674-aa8e-90bce5f36569"}
    --------------------------------Variables--------------------------------

    --------------------------------Nodes and events--------------------------------

    nodes.MoveToPoint = Action {
        function()
            if mod.moveto.MoveToPoint(Entity(params.DestinationPoint), MovementSpeed.Walk, me) then
                ClearFlag(Flag(params.EventFlag), me)
                SetEntityEvent(me, "LOW_KnightsOfTheShield_FirstWave")
            end
        end,
        CanEnter = function()
            return GetFlag(Flag(params.EventFlag), me)
        end
    }

    nodes.Wander = Proxy {
        game.states.GEN_Wander,
        params = {
            trigger = params.WanderZone,
            wanderMin = 3,
            wanderMax = 5,
            sleepMin = 5,
            sleepMax = 8},
    }

    nodes.Idle = Action {
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return not GetFlag(Flag(params.EventFlag), me)
        end
    }
end
}