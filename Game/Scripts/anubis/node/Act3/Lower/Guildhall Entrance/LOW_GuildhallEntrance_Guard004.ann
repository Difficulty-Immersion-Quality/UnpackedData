game.states.LOW_GuildhallEntrance_Guard004Idle = State{

    function()
        modules = {"shared.dialog"}

        local SoloAD = Dialog("LOW_UndercellarEntrance_AD_Idle_Guard004_131aac6b-6e4d-6714-2a43-4fec87d98964")
        local ReadingAnim = Animation("CUST_Reading_Book_01_c3af4377-7383-4aeb-a067-d8c36e82f716")
        local GuardPosition = Entity("S_LOW_GuildhallEntrance_Guard004_326fa10d-63c1-4634-9395-3eb1e8f6b534")
        
        nodes.Idle = Action {
            function()
                    LookFrom(GuardPosition)
                    Sleep(math.random(1,6))
                    PlayAnimation(ReadingAnim,false,false)
                    mod.dialog.StartCheckedAutomatedDialogRateLimited(
                        SoloAD,
                        {
                            waitForCompletion = true,
                            checkSight = true,
                            minDelay = 10 + math.random(1,2),
                            
                        },
                        me)
                    Sleep(math.random(16.2, 23.8))
                    
                    
                
                
            end
        }
        end
    }