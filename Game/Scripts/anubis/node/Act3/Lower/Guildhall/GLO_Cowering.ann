game.states.GLO_Cowering = State { function ()
    description = [[ Character cowers in place. ]]

    nodes.Cowering = Proxy {
        game.states.Dummy,
        OnEnter = function() 
            ApplyStatus(me, "ANIM_COWER")
        end,
        OnLeave = function()
            RemoveStatus(me, "ANIM_COWER")
        end
    }
end}