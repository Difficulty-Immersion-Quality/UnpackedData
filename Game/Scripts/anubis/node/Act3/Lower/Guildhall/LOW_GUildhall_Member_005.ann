game.states.LOW_Guildhall_Member_005 = State{function ()
    
    local RummagingAnim_Start = Animation("CUST_Rummaging_01_Start_9cbe5deb-4a3c-4e2a-b0a3-b0dc88a5a85d")
    local RummagingAnim_Loop = Animation("CUST_Rummaging_01_Loop_2204d382-eb48-4b00-a1fc-5d956ef4ccb0")
    local RummagingAnim_End = Animation("CUST_Rummaging_01_End_2e6c360a-76c4-4582-889f-d92e74c34b66")

    local DoozyLeftFlag = Flag("LOW_Guildhall_Event_Member_005_Leaves_809e7412-ec2d-55dc-ace8-037be33e35a3")
    local ExitPoint = Entity("S_LOW_Guildhall_Bursar_Guard_002_CombatStartPoint_c5e78a5c-faee-4bc3-90fd-1b0c6815cb37")

    nodes.RummagingThroughMud = Action {
        function()
            PlayLoopingAnimation(RummagingAnim_Start, {RummagingAnim_Loop}, RummagingAnim_End)
            Sleep(5.0)
        end,
        CanEnter = function()
            return not GetFlag(DoozyLeftFlag)
        end
    }

    nodes.RunningAway = Action {
        function()
            MoveTo(ExitPoint, MovementSpeed.Run, false, false, 0.5, 2.0, false)
            Sleep(5.0)
        end,
        CanEnter = function()
            return GetFlag(DoozyLeftFlag)
        end
    }
end}