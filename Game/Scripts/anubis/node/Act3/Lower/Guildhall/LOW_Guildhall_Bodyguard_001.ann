game.states.LOW_Guildhall_Bodyguard_001 = State{function ()
    local trigger = Entity([[S_LOW_Guildhall_LeaderGuard_003_b343bd19-65cb-4ad4-9b82-2a1c88aeffca]])
    local checkZhentPos = Entity("S_LOW_Guildhall_Bodyguard_001_PatrolPoint_65d41b20-131b-4e86-8746-24d66eda106b")


    local anim_Start = Animation("CUST_ArmsCrossed_01_Start_dafd0bbc-012a-403c-aabe-4963aca9cf25")
    local anim_Loop = Animation("CUST_ArmsCrossed_01_Loop_e6c49668-99b1-41d6-8daa-7ed6864b4e71")
    local anim_End = Animation("CUST_ArmsCrossed_01_End_ae43ea68-fc1b-456a-88ce-0e1d504e1d40")

    modules = {"shared.moveto"}

    --------------------------------Nodes--------------------------------
    nodes.PreCoup = Selector{
        function(nodes)
            return FindFirstSelectable(nodes)
        end
    }

    nodes.PreCoup.CheckZhent = Action {
        function()
            if mod.moveto.MoveToPoint(checkZhentPos,MovementSpeed.Walk,me) then
                PlayLoopingAnimation(anim_Start, {anim_Loop}, anim_End)
                Sleep(13.0 + 3.0 * math.random())
            else
                Sleep(6.0)
                DebugText(me,"MoveTo call failed")
            end

            if mod.moveto.MoveToPoint(trigger,MovementSpeed.Walk,me) then
                LookFrom(trigger)
            else
                Sleep(6.0)
                DebugText(me,"MoveTo call failed")
            end
        end,

        OnLeave = function()
            Sleep(25.0)
        end
    }

    nodes.FallbackIdle = Action {
        function()
            WaitForInterrupt()
        end
    }
    
end
}