game.states.LOW_Guildhall_Civilian = State{function ()
    
    modules = { "shared.dialog" }

    params.Default_State = {type = EParamType.State, default = StateRef{game.states.Dummy},
        help = [[
            Behaviour to perform during PreCoup state in Guildhall
        ]]
    }
    params.DuringCoup_State = {type = EParamType.State, default = StateRef{game.states.GLO_Cowering},
        help = [[
            Behaviour to perform during DuringCoup state in Guildhall, if nil, character will cower in place
        ]]
    }

    local DuringCoup = Flag("LOW_Guildhall_State_DuringCoup_6dba56a5-8220-41f4-8849-085e38b80d4e")

    self.OnInit = function()
        
    end

    nodes.State_DuringCoup = 
    ImmediateSelector {
        Valid = function(nodes)
            return GetFlag(DuringCoup)
        end
    }

    nodes.State_DuringCoup.State = Proxy {
        params.DuringCoup_State
    }

    nodes.Default_State = 
    ImmediateSelector {
        Valid = function(nodes) 
            return not GetFlag(DuringCoup)
        end
    }

    nodes.Default_State.Action = Proxy {
        params.Default_State
    }
end}