game.states.LOW_Guildhall_FetchersBrat_003 = State { function ()
    description = [[ A kid who rummages the waters for the Fetchers in the Guildhall. ]]
    modules = {"shared.moveto"}

--------------------------------Variables--------------------------------
    local rummageTrigger = Entity([[S_LOW_Guildhall_Point_FetchersBrat_003_Rummage_fe5d2575-7f52-4135-a920-75ffb8f194d0]])
    local standTrigger = [[S_LOW_Guildhall_Point_FetchersBrat_003_6981e476-390d-4d7b-9da8-797ef242f0c9]]

    local canRummage = true
    local RummagingAnim_Start = Animation("CUST_Rummaging_01_Start_9cbe5deb-4a3c-4e2a-b0a3-b0dc88a5a85d")
    local RummagingAnim_Loop = Animation("CUST_Rummaging_01_Loop_2204d382-eb48-4b00-a1fc-5d956ef4ccb0")
    local RummagingAnim_End = Animation("CUST_Rummaging_01_End_2e6c360a-76c4-4582-889f-d92e74c34b66")

    --------------------------------Nodes--------------------------------

    nodes.Rummage = Action {
        function()
            if mod.moveto.MoveToPoint(rummageTrigger,MovementSpeed.Stroll,me) then
                PlayLoopingAnimation(RummagingAnim_Start, {RummagingAnim_Loop}, RummagingAnim_End)
                Sleep(12.0 + 6.0 * math.random())
                    if mod.moveto.MoveToPoint(Entity(standTrigger),MovementSpeed.Stroll,me) then
                        LookFrom(Entity(standTrigger))
                    else
                        DebugText(me,"MoveTo call failed")
                        SteerTo(Entity(standTrigger))
                        Sleep(6.0)
                    end
            else
                DebugText(me,"MoveTo call failed")
                SteerTo(rummageTrigger)
                Sleep(6.0)
            end
        end,

        OnLeave = function()
            Sleep(24.0 + 6.0 * math.random())
        end
    }
--------------------------------Fallback--------------------------------
    nodes.Action_StandAtTrigger = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = standTrigger
        },
    }
end}