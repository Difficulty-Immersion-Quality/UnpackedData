game.states.LOW_HouseOfHope_FireDebtor01 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Point1 = Entity("S_LOW_HouseOfHope_FireDebtor01_Point1_e09175a6-f662-4f31-bc68-55c50247d9ad"),
        Point2 = Entity("S_LOW_HouseOfHope_FireDebtor01_Point2_a4872261-e5d4-4d25-9ec0-2762922c45e9"),
        Point3 = Entity("S_LOW_HouseOfHope_FireDebtor01_Point3_ac0b3412-c2b7-4b1b-9f13-ce8d6922125a"),
        Point4 = Entity("S_LOW_HouseOfHope_FireDebtor01_Point4_289820d6-2328-4f31-80cd-b2ac02d046d9"),
    }
    
    local warm = Animation("CUST_UncomfortablyWarm_01_02efe31d-4cdd-45d4-b23f-104c24790437")
    local catchingBreath = Animation("CUST_CatchingBreath_01_44b024b3-4e93-4270-993d-41a21a2befe7")
    local sweeping = Animation("CUST_SweepBroom_01_74d09877-6b18-451a-8128-377a293b8bd0")
    
    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")


    --------------------------------Nodes--------------------------------
    
    nodes.Act = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)


        end,
        Valid = function()
            return not GetFlag(alarmFlag) 
        end
    }

    nodes.Act.Point1 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point1, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point1, MovementSpeed.Stroll)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(warm)
            Sleep(math.random(10,15))
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }
    
    nodes.Act.Point2 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point2, me.Character) then
                Sleep(5)
                return
            end
            MoveTo()
            local moveResult = MoveTo(points.Point2, MovementSpeed.Stroll)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(warm)
            Sleep(math.random(10,15))
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }

    nodes.Act.Point3 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point3, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point3, MovementSpeed.Stroll)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(sweeping, true, false)
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }

    nodes.Act.Point4 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point4, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point4, MovementSpeed.Stroll)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(sweeping, true, false)
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }


    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}