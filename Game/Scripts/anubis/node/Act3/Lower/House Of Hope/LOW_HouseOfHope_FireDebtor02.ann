game.states.LOW_HouseOfHope_FireDebtor02 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Entity("S_LOW_HouseOfHope_FireDebtor02_Point1_18254cd6-bc04-4c80-a691-f0f50bfd34a8"),
        Entity("S_LOW_HouseOfHope_FireDebtor02_Point2_fc88e717-3613-4197-8eb5-1f44c4b1fe04"),
        Entity("S_LOW_HouseOfHope_FireDebtor02_Point3_744a8125-b85c-4e6e-b3e2-8906b1819aea"),
        Entity("S_LOW_HouseOfHope_FireDebtor02_Point4_1048aa41-3fa5-4017-847b-46c6eb4981e7"),
    }
    
    local sweeping = Animation("CUST_SweepBroom_01_74d09877-6b18-451a-8128-377a293b8bd0")

    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")
    
    local currentIndex = 0
    --------------------------------Nodes--------------------------------
    
    nodes.Act = Action {
        function()
            local index = currentIndex
            while currentIndex == index do
                index = math.random(1,#points)
            end
            currentIndex = index
            if IsInDangerousSurfaceFor(points[index], me.Character) then
                SteerTo(points[index])
                Sleep(math.random(10,15))
                return
            end
            local moveResult = MoveTo(points[index], MovementSpeed.Walk)
            if moveResult ~= error.MovementError.None then
                SteerTo(points[index])                
                Sleep(math.random(10,15))
                return
            end
            LookFrom(points[index])
            PlayAnimation(sweeping, true, false)
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }


    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}