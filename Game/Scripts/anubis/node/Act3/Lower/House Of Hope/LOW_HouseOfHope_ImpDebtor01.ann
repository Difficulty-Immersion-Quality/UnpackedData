game.states.LOW_HouseOfHope_ImpDebtor01 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Entity("S_LOW_HouseOfHope_ImpDebtor01_Point1_8506abe8-d9fa-4c2a-afea-267d2b861fff"),
        Entity("S_LOW_HouseOfHope_ImpDebtor01_Point2_4c64e189-abfd-4fc5-bf13-32e6bfaec879"),
        Entity("S_LOW_HouseOfHope_ImpDebtor01_Point3_715296ba-a486-4d9d-bb3e-feaee656c911"),
        Entity("S_LOW_HouseOfHope_ImpDebtor01_Point4_bfdf8f34-e7a3-4319-b8b3-fb533919f6f2"),
    }
    
    local dance = Animation("CUST_Dancing_01_6e23855c-4845-4301-bcf8-9c04f5a782c1")
    local warm = Animation("CUST_UncomfortablyWarm_01_02efe31d-4cdd-45d4-b23f-104c24790437")

    local guardAnim = Animation("CUST_GuardNervous_01_add51b30-ef5b-11e9-81b4-2a2ae2dbcce4")
    

    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")

    local index = 0
    local rightDirection = true
    --------------------------------Nodes--------------------------------
    
    nodes.Act = Action {
        function()            
            if (rightDirection) then
                index = index + 1
                if index >= #points then 
                    rightDirection = false 
                    index = #points
                end
            else
                index = index - 1
                if index <= 1 then 
                    rightDirection = true 
                    index = 1
                end
            end
            if IsInDangerousSurfaceFor(points[index], me.Character) then
                SteerTo(points[index])
                Sleep(math.random(10,15))
                return
            end
            local moveResult = MoveTo(points[index], MovementSpeed.Stroll)
            if moveResult ~= error.MovementError.None then
                SteerTo(points[index])
            end
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }


    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}