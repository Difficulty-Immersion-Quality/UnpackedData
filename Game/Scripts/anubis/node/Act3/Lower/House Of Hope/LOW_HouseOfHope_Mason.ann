game.states.LOW_HouseOfHope_Mason = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Point1 = Entity("S_LOW_HouseOfHope_Debtor_Mason_Point1_f4d3c103-79f7-416c-8918-fa83b7689837"),
        Point2 = Entity("S_LOW_HouseOfHope_Debtor_Mason_Point2_74479d9f-2bcd-4e66-9172-b1e6a90ed8df"),
        Point3 = Entity("S_LOW_HouseOfHope_Debtor_Mason_Point3_4640daa6-6bb3-4c50-bea8-cf04ad92aef6"),
        Point4 = Entity("S_LOW_HouseOfHope_Debtor_Mason_Point4_6f89bfc3-1efc-4f13-93ba-bbd3686d0bd9"),
    }
    
    local lookingForValuables = Animation("CUST_LookingForValuables_01_eab8704c-97f7-4124-bab1-55deeadff528")
    local pokeFire = Animation("CUST_PokeFire_01_430ac587-588c-4200-a6ea-7113412d2cb3")
    local sweep = Animation("CUST_SweepBroom_01_74d09877-6b18-451a-8128-377a293b8bd0")
    local lookAround = Animation("CUST_Investigating_LookingAround_01_dfbe749c-d0c2-4f4f-91cf-f1caaec3f3bf")


    --------------------------------Nodes--------------------------------
    
    nodes.Act = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)
        end
    }

    nodes.Act.Fireplace = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point1, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point1, MovementSpeed.Walk, true, true, 0.5, 1.0, false, PathClimbingMode.Disabled)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            LookFrom(points.Point1)
            PlayAnimation(pokeFire, true, false)
            Sleep(3)            
        end
    }
    
    nodes.Act.Table1 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point2, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point2, MovementSpeed.Walk, true, true, 0.5, 1.0, false, PathClimbingMode.Disabled)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(sweep, true, false)
            Sleep(3)
        end
    }

    nodes.Act.Table2 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point3, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point3, MovementSpeed.Walk, true, true, 0.5, 1.0, false, PathClimbingMode.Disabled)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(sweep, true, false)
            Sleep(3)
        end
    }

    nodes.Act.LookAround = Action {
        function()
            if IsInDangerousSurfaceFor(points.Point4, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Point4, MovementSpeed.Walk, true, true, 0.5, 1.0, false, PathClimbingMode.Disabled)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            PlayAnimation(sweep, true, false)
            Sleep(3)
        end
    } 


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}