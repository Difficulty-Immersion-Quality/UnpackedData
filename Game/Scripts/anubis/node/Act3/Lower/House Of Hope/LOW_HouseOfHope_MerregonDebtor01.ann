game.states.LOW_HouseOfHope_MerregonDebtor01 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Pray1 = Entity("S_LOW_HouseOfHope_MerregonDebtor01_PrayingPoint01_9db519c9-2de6-4786-aa3a-8dfea77fa27a"),
        Guard2 = Entity("S_LOW_HouseOfHope_MerregonDebtor01_GuardingPoint02_07f7ee71-9c52-46ac-b161-9a6d04a88e46"),
        Pray2 = Entity("S_LOW_HouseOfHope_MerregonDebtor01_PrayingPoint02_77cc67d6-0f45-4628-a827-5dd5a0f5cd9c"),
    }
    
    local prayAnim = Animation("CUST_Praying_01_7f50198e-dda0-4763-a217-0935865ce76c")
    

    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")


    --------------------------------Nodes--------------------------------
    
    nodes.Act = Selector {
        function(nodes)
            return FindDifferentRandomSelectable(nodes)


        end,
        Valid = function()
            return not GetFlag(alarmFlag) 
        end
    }

    nodes.Act.Pray1 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Pray1, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Pray1, MovementSpeed.Walk, true, true, 0.5, 1.0, false, PathClimbingMode.Disabled)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            LookFrom(points.Pray1)
            PlayAnimation(prayAnim, true, false)
            Sleep(math.random(3,8))
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end,
        OnLeave = function()
            StopAnimation(me, false)
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }
    
    nodes.Act.Pray2 = Action {
        function()
            if IsInDangerousSurfaceFor(points.Pray2, me.Character) then
                Sleep(5)
                return
            end
            local moveResult = MoveTo(points.Pray2, MovementSpeed.Walk, true, true, 0.5, 1.0, false, PathClimbingMode.Disabled)
            if moveResult ~= error.MovementError.None then
                Sleep(5)
                return
            end
            LookFrom(points.Pray2)
            PlayAnimation(prayAnim, true, false)
            Sleep(math.random(3,8))
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end,
        OnLeave = function()
            StopAnimation(me, false)
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }

    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}
