game.states.LOW_HouseOfHope_MerregonDebtor02 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Entity("S_LOW_HouseOfHope_MerregonDebtor02_Point1_37b143f5-983c-48be-ab3f-69c5916bffd5"),
        Entity("S_LOW_HouseOfHope_MerregonDebtor02_Point2_f3028e8d-aece-457b-9c2e-c07688eb8dd2"),
        Entity("S_LOW_HouseOfHope_MerregonDebtor02_Point3_9c091762-1490-47c9-a093-268a5b5e264d"),
        Entity("S_LOW_HouseOfHope_MerregonDebtor02_Point4_6fad9e56-0a53-4624-9cb2-35c62eb55daf"),
    }    

    local potAnim = Animation("CUST_PotDebtor_SmellChamberPot_01_729c012b-1653-47e8-9fd7-f18bd91d1f2f")   

    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")

    local currentIndex = 0
    --------------------------------Nodes--------------------------------
    
    nodes.Act = Action {
        function()
            local index = currentIndex
            while currentIndex == index do
                index = math.random(1,#points)
            end
            currentIndex = index
            if IsInDangerousSurfaceFor(points[index], me.Character) then
                SteerTo(points[index])
                Sleep(math.random(10,15))
                return
            end
            local moveResult = MoveTo(points[index], MovementSpeed.Walk)
            if moveResult ~= error.MovementError.None then
                SteerTo(points[index])
                Sleep(math.random(10,15))
                return
            end
            LookFrom(points[index])
            PlayAnimation(potAnim, true, false)
            Sleep(math.random(5,10))
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }


    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}