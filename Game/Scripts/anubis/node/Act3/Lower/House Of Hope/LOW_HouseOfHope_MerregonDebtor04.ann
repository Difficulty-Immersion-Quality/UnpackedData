game.states.LOW_HouseOfHope_MerregonDebtor04 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = Entity("S_LOW_HouseOfHope_MerregonDebtor04_Point1_cbca79d2-5c7f-4b48-8d72-125755a1c0c2")
    
    local fear = Animation("CUST_KneelFlailingSelf_01_da880601-0edd-435c-ba05-7ec71f60b8e1")

    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")


    --------------------------------Nodes--------------------------------
    nodes.Flail = Action {
        function()            
            LookFrom(points.Pray1)
            PlayLoopingAnimation(fear)
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end,
        OnLeave = function()
            StopAnimation(me)
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }
    
    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}