game.states.LOW_HouseOfHope_MerregonDebtor05 = State{function ()

    --------------------------------Params and modules--------------------------------
    modules = {"shared.dialog", "shared.moveto"}

    --------------------------------Flags and variables--------------------------------

    local points = {
        -- key = value
        Entity("S_LOW_HouseOfHope_MerregonDebtor05_Point2_c3231764-8105-48a3-8481-3bad813e1993"),
        Entity("S_LOW_HouseOfHope_MerregonDebtor05_Point1_201ac9d7-8152-43ef-b57e-420d8d0c3b70"),
        Entity("S_LOW_HouseOfHope_MerregonDebtor05_Point3_705b82aa-1eaf-4b88-848b-2a479dd0cd7a"),
        Entity("S_LOW_HouseOfHope_MerregonDebtor05_Point4_b10bd9a6-8e97-4e64-8d6a-377a4a437590"),
    }
    
    local scrub = Animation("CUST_ScrubFloor_01_358b434f-3c05-4e7a-9635-51aaf726aa44")
    local ad = Dialog("LOW_HouseOfHope_AD_MerregonDebtor05_Idle_e165e59e-fd0d-82b9-048d-e2c35d2f40a6")

    local alarmFlag = Flag("LOW_HouseOfHope_State_RaphaelAlerted_f83c3d6b-d6cf-41a1-a03d-c31df5ea44fe")

    local currentIndex = 0
    local action = 0
    --------------------------------Nodes--------------------------------


    nodes.Act = Action {
        function()
            local index = currentIndex
            while currentIndex == index do
                index = math.random(1,#points)
            end
            currentIndex = index
            if IsInDangerousSurfaceFor(points[index], me.Character) then
                SteerTo(points[index])
                Sleep(math.random(10,15))
                return
            end
            local moveResult = MoveTo(points[index], MovementSpeed.Walk)
            if moveResult ~= error.MovementError.None then
                SteerTo(points[index])
            end
            StartAutomatedDialog(ad, false, me)
            PlayAnimation(scrub, true, false)            
            Sleep(math.random(5,10))
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }


    nodes.StayingInAmbush = Action{
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return not GetFlag(alarmFlag) 
        end
    }   


    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }


        --------------------------------Events--------------------------------
   
end}