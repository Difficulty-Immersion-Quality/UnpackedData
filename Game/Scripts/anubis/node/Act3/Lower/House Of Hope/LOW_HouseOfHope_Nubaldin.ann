game.states.LOW_HouseOfHope_Nubaldin = State{function ()

    --------------------------------Description--------------------------------
    description = [[Overseer in House of Hope that is angry that his "slave" kids do not work (because they are too tired).]]

    --------------------------------Modules--------------------------------

    modules = {"shared.dialog"}

    --------------------------------Variables--------------------------------

    --------------------------------Nodes--------------------------------

    local points = {
        Entity("S_LOW_HouseOfHope_NubaldinSpot01_c0738cca-7f05-4c98-9410-8a45b36f3e9d"),
        Entity("S_LOW_HouseOfHope_NubaldinSpot02_d4bdcd12-86ba-480e-9b4b-01386cb6a471"),
        Entity("S_LOW_HouseOfHope_NubaldinSpot03_b185aec8-122d-4be8-95e5-b5e4416246e4"),
    }
    
    local scrubAnim = Animation("CUST_ScrubFloor_01_358b434f-3c05-4e7a-9635-51aaf726aa44")

    local currentAction = 1

    --------------------------------Nodes--------------------------------
    
    nodes.NubaldinWorks = Action {
        function()
            if currentAction > #points then currentAction = 1 end
            if IsInDangerousSurfaceFor(points[currentAction], me.Character) then
                Sleep(math.random(10,15))
                return
            end
            local moveResult = MoveTo(points[currentAction], MovementSpeed.Stroll)
            if moveResult == error.MovementError.None then
                LookFrom(points[currentAction])
                PlayAnimation(scrubAnim, true, false)
                Sleep(3)
                currentAction = currentAction + 1
            end
        end,
        Valid = function()               
            return true
        end
    }

    nodes.IdleFallback = Action {
        function()
            WaitForInterrupt()
        end
    }

end
}