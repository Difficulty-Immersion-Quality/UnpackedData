game.states.LOW_KurwinCoffin_BereavedMother = State{
    function()
        modules = {"shared.util", "shared.dialog"}

        local SolvedAD = Dialog("LOW_KurwinCoffin_AD_BereavedCoupleSolved_56982e0c-2e88-732e-a5f8-7c1056a99e55")
        local UnsolvedAD = Dialog("LOW_KurwinCoffin_AD_BereavedCoupleUnsolved_dbdd3285-b7b3-6590-15e2-42eabafc46f9")
        local SadAnim = Animation ("CUST_Sad_01_8029ec3b-d903-45b0-9078-fe581c34cbc9")
        local convoPartnerElias = Entity("S_LOW_BereavedFather_42023010-c670-4885-addf-23e9bb31af32")
        local trigger = Entity("LOW_KurwinCoffin_BereavedMotherTrigger_2b2d479a-329e-4cc5-9338-ce7ebafdd712")

        local SolvedBereavedCouple = Flag("LOW_KurwinCoffin_State_HelpedBereavedCouple_4d3baf56-a815-457b-8465-62e03a70fe9c")
        


        nodes.Idle = Action {
            function()
                if GetFlag(SolvedBereavedCouple) == false then
                    LookAtEntity(convoPartnerElias)
                    Sleep(math.random(4,8.2))
                    PlayAnimation(SadAnim,false,false)
                    if(convoPartnerElias ~= nil and mod.dialog.IsSpeakerAvailable(convoPartnerElias)) then
                        mod.dialog.StartCheckedAutomatedDialogRateLimited(
                            UnsolvedAD,
                            {
                                waitForCompletion = true,
                                checkSight = true,
                                minDelay = 10 + math.random(1,2),
                            
                            },
                            convoPartnerElias,
                            me
                            )
                        else
                            Sleep(mod.math.random(12.1, 14.4))
                        end
                        Sleep(math.random(0.5, 1.2))
                else
                    if(convoPartnerElias ~= nil and mod.dialog.IsSpeakerAvailable(convoPartnerElias)) then
                        LookAtEntity(convoPartnerElias)
                        Sleep(math.random(1,6))
                        PlayAnimation(SadAnim,false,false)
                        mod.dialog.StartCheckedAutomatedDialogRateLimited(
                            SolvedAD,
                            {
                                waitForCompletion = true,
                                checkSight = true,
                                minDelay = 10 + math.random(1,2),
                            
                            },
                            convoPartnerElias,
                            me
                            )   
                        else
                            Sleep(mod.math.random(12.1, 14.4))
                        end
                        Sleep(math.random(0.5, 1.2))
                    end
                end
            }
        end
}