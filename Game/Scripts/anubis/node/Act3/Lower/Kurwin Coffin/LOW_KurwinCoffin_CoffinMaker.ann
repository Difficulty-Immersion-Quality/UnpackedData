game.states.LOW_KurwinCoffin_CoffinMaker = State{
    function()
        modules = {"shared.util", "shared.dialog", "shared.moveto"}

        local firstPointAnim = Animation("CUST_Thinking_01_97588786-d9bf-4d18-879b-1bd3dcaa62ba")
        local secondPointAnim = Animation("CUST_Thinking_02_43a70168-2f92-42e5-bfc2-845adf4013f6")
        local thirdPointAnim = Animation("CUST_Thinking_03_9407dc5c-7155-40a6-a2ef-43ec37b0eda0")

        local firstPoint = Entity("S_LOW_KurwinCoffin_CoffinMakerSpot1_56f14ab7-a8e0-4452-aaad-26dc8e8ee940")
        local secondPoint = Entity("S_LOW_KurwinCoffin_CoffinMakerSpot2_d0c804c7-7d73-46d2-a120-39053b1ef0fa")
        local thirdPoint = Entity("S_LOW_KurwinCoffin_CoffinMakerSpot3_2cd7195d-1457-448e-8030-3540daef2199")
        
        local nextPosition = 1
        
        helpers.action.PlayAnimationAt = function(pos, animation)
            if pos ~= nil then
                if mod.moveto.MoveToPoint(pos, MovementSpeed.Run, me, 0.5, false) then
                    LookFrom(pos)
                    PlayAnimation(animation)
                    StopAnimation(me)
                    mod.util.SleepRandom(1.0,2.0)
                end
            end
        end

        
        nodes.IdleRunAround1 = Action {
            Valid = function()
                return nextPosition == 1
            end,
            function()
                helpers.PlayAnimationAt(firstPoint, firstPointAnim)
                nextPosition = 2
            end,
        }

        nodes.IdleRunAround2 = Action {
            Valid = function()
                return nextPosition == 2
            end,
            function()
                helpers.PlayAnimationAt(secondPoint, secondPointAnim)
                nextPosition = 3
            end,
        }

        nodes.IdleRunAround2 = Action {
            Valid = function()
                return nextPosition == 3
            end,
            function()
                helpers.PlayAnimationAt(thirdPoint, thirdPointAnim)
                nextPosition = 1
            end,
        }
    end
}

