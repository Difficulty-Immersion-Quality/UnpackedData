game.states.LOW_CartLoading_Porter_01 = State { function () 

    modules = {"shared.dialog"}

    local wineAD = Dialog([[LOW_CartLoading_AD_Porter_01_Porter_02_74404cd4-1326-40a7-217c-e207619fb862]])
    local partner = Entity([[S_LOW_CartLoading_Porter_02_a6d25463-3e06-4f24-abd0-d5f3b2c393c0]])
    local posTrigger = [[S_LOW_CartLoading_Porter_01_Trigger_Patched_5f79fd76-5769-4110-9e88-329ef1280b80]]
    local posTriggerEntity = Entity([[S_LOW_CartLoading_Porter_01_Trigger_Patched_5f79fd76-5769-4110-9e88-329ef1280b80]])
    local drinkingAnim = Animation([[CUST_DrinkWine_01_9bb9efaf-7f30-42c3-8015-972f2ffa35c7]])
    local delayAD = 15.0
   

    nodes.Idle = Action {
        function()
            Sleep(2.0)
            PlayAnimation(drinkingAnim, false, false)
            Sleep(2.0)
          
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                wineAD,
                { maxDistance = 10.0,
                checkSight = false,
                waitForCompletion = true,
                minDelay = delayAD,},
                me, partner)

            Sleep(math.random(10.0, 13.0))
        end,
        CanEnter = function()
            return GetDistanceTo(me, posTriggerEntity) <= 2.0
        end
    }
    
    nodes.Fallback = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = posTrigger
        },
    }

end}