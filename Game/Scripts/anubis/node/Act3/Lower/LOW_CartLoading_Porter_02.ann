game.states.LOW_CartLoading_Porter_02 = State { function () 

    local drinkingAnim = Animation([[CUST_DrinkWine_01_9bb9efaf-7f30-42c3-8015-972f2ffa35c7]])
    local posTrigger = ([[S_LOW_CartLoading_Porter_02_Trigger_7638005a-6737-448f-84de-90cc3a729bd8]])
    local posTriggerEntity = Entity([[S_LOW_CartLoading_Porter_02_Trigger_7638005a-6737-448f-84de-90cc3a729bd8]])

    nodes.Idle = Action {
        function()
            Sleep(2.0)
            PlayAnimation(drinkingAnim, false, false)
            Sleep(math.random(10.0, 13.0))
        end,
        CanEnter = function()
            return GetDistanceTo(me, posTriggerEntity) <= 2.0
        end
    }

    nodes.Fallback = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = posTrigger
        },
    }
    
end}