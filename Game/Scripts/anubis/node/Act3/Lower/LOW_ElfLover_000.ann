game.states.LOW_ElfLover_000 = State { function () 

    modules = {"shared.dialog"}

    local posTrigger = [[S_LOW_ElfLover_000_Pos_3f688689-c1fb-4c59-8ad0-21c27b16d25f]]
    local bhvrTrigger = Entity([[S_BHVR_WRLD_LOW_CoupleStand_61621764-9e2e-4e88-a44d-34fa53eef2c2]])
    local partner = Entity([[S_LOW_ElfLover_001_47437f3d-70c5-4b88-a276-9a498280dc04]])
    local bhvrDialog = Dialog([[BHVR_WRLD_LOW_CoupleStand_564a1449-16a4-26de-6e62-13e8d0275a58]])

    --------------------------------NODES--------------------------------
    nodes.CoupleStand = Action {
        function()
            try
                StartBehaviorDialog(bhvrDialog, bhvrTrigger.Trigger, true, me, partner)
                WaitForInterrupt()
            catch e if ls.CheckType(e, error.BehaviorDialogStartFailed) then
                DebugText(me, "Failed to start wrld bhvr [2]: Error [1]", tostring(e), tostring(bhvrDialog.Guid))
                Sleep(6.0 + 6.0 * math.random())
            end
            
        end,
        CanEnter = function()
            return mod.dialog.IsSpeakerAvailable(partner)
        end
    }

    nodes.Fallback = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = posTrigger
        },
    }

    --------------------------------EVENTS--------------------------------
    events.DialogEnded = function(e)
        if e.Instance.DialogUUID == bhvrDialog.Guid then
            Interrupt()
        end
    end

end}