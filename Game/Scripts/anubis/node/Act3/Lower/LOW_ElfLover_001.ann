game.states.LOW_ElfLover_001 = State { function () 
   
    local posTrigger = [[S_LOW_ElfLover_001_Pos_a741596c-e907-4315-b8a0-46a36eb3c7c6]]
    local areaTrigger = Entity([[S_LOW_ElfLover_AreaTrigger_c80fa59e-c0cf-46bd-a9e7-f697bb530d3d]]) 
    local bhvrDialog = Dialog([[BHVR_WRLD_LOW_CoupleStand_564a1449-16a4-26de-6e62-13e8d0275a58]])
    -- bhvrDialog triggered from S_LOW_ElfLover_001_47437f3d-70c5-4b88-a276-9a498280dc04

    --------------------------------NODES--------------------------------
    nodes.CoupleStand = Action {
        function()
            WaitForInterrupt()
        end,
        CanEnter = function()
            return IsInTrigger(me, areaTrigger.Trigger)
        end
    }

    nodes.Fallback = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = posTrigger
        },
    }

    --------------------------------EVENTS--------------------------------
    events.DialogEnded = function(e)
        if e.Instance.DialogUUID == bhvrDialog.Guid then
            Interrupt()
        end
    end
end}