game.states.LOW_FishAndGrime_Sailor_01 = State { function () 

    local fishAD = Dialog([[LOW_FishAndGrime_AD_Sailor_01_Sailor_02_9cff6514-9f6b-ae78-ad44-b4fec4c77d4c]])
    local partner = Entity([[S_LOW_FishAndGrime_Sailor_02_b72a36b1-20da-47a7-8e58-b6b53a7f23e7]])
    local posTrigger = [[S_BHVR_WRLD_LOW_SmellyFish_Dragonborn_71c3b755-f668-4651-8131-a5773e0ccf8d]]
    local bhvrDialog = Dialog([[BHVR_WRLD_LOW_SmellyFish_DGB_M_fccba644-2eb7-b6b6-3765-4e277bb401bc]])
    local bhvrTrigger = Entity([[S_BHVR_WRLD_LOW_SmellyFish_Dragonborn_71c3b755-f668-4651-8131-a5773e0ccf8d]])

    local delayAD = 5.0

    --------------------------------NODES--------------------------------
    
    nodes.BHVRSmellFish = Action {
        function()
            Sleep(math.random(2.0,5.0))
            StartAutomatedDialogRateLimited(fishAD, delayAD, 5.0, false, me, partner)   
            try 
                StartBehaviorDialog(bhvrDialog, bhvrTrigger.Trigger, true, me)
            catch e if ls.CheckType(e, error.BehaviorDialogStartFailed) then
                DebugText(me, "Error [1] on wlrd bhvr: [2]", tostring(e), tostring(bhvrDialogbhvrDialog.Guid))
                Sleep((6.0))
            end
        end,
        
        CanEnter = function()
            return (GetDistanceTo(me, bhvrTrigger) < 2.0)
        end
    }

    nodes.Fallback = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = posTrigger
        },
    }

end}