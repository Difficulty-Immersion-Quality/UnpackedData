game.states.LOW_MinscHideout_GossipGuard = State{function()
    description = [[Sluice gate guard that initiates gossip with one of the other guards]]

    modules = {"shared.dialog"}

    params.GossipPartner = {type = EParamType.String, default = "",
        help = [[Other guard to gossip with]]}

    local gossipAD = nil
    local gossipPartner = Entity(params.GossipPartner)

    nodes.Idle = Action{
        function()
            -- TODO: Select which gossip AD to use
            if gossipAD ~= nil and gossipPartner ~= nil then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    gossipAD,
                    {
                        waitForCompletion = true,
                        minDelay = 30.0
                    },
                    me,
                    gossipPartner
                )
            end
        end
    }
end}