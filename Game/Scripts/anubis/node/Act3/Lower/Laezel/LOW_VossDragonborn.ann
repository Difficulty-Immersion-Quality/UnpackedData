game.states.LOW_VossDragonborn = State { function()

    description = [[ 
        Behaviour for Voss's Dragonborn when he is in the sewers in Lower City
    ]]

    local showedHammerToVoss = Flag("ORI_Laezel_State_ShowedVossTheHammer_5588f6a2-bb8c-4f91-a152-168492b9c09f")

    -- Nodes

    
    nodes.LeavingForEndgame = Action{
        function()            
            -- Voss and the Dragonborn will Poof away, perhaps with a Dimension Door effect
            WaitForInterrupt()
            Sleep(2.0)
        end,
        Valid = function()
            return GetFlag(showedHammerToVoss)
        end,
    }
    
    nodes.GatheredAlliesInSewers = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_LOW_VossDragonbornSewersPos_ed1ca25f-a5e3-4596-b0f5-76699077b18a"
        },    
        Valid = function()
            return not GetFlag(showedHammerToVoss)
        end
    }
end}