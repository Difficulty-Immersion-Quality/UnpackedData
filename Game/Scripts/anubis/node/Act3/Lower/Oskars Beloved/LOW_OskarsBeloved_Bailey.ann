game.states.LOW_OskarsBeloved_Bailey = State{function()
    description = [[High Servant with repeated AD solo or with a Servant depending on player interaction]]
    modules = {"shared.moveto", "shared.dialog", "shared.util"}

    --Flags
    local pickupFailAttempts = 0
    local pickedObject = Entity("S_LOW_DroppedCutlery_000_19220846-d7ef-4a08-ba2c-9a180e9490b9")    
    local savedFlag =  Flag("LOW_OskarsBeloved_Event_ServantSaved_7f61db94-aa04-4a9b-8c01-b8ea5c7198de")
    local wanderAnchor = Entity("S_LOW_BeratingServantTrigger_070baf4d-5a44-4c47-8090-e43aeb5a758a")
    local patrolingFlag = Flag("LOW_OskarsBeloved_Event_ServantStartPatrol_abc5886e-797a-427f-8cc9-a9d897f4eac5")
    -----------------------------------------
    -- Nodes


    nodes.Patrol= Action {


        OnEnter = function()

            if CanSee(me, pickedObject) and mod.moveto.MoveToPoint(pickedObject,MovementSpeed.Run, me) then
                PickUpItem(pickedObject)
            end
            Sleep(0.5)
        end,
        
        function()
            if CanSee(me, pickedObject) and mod.moveto.MoveToPoint(pickedObject,MovementSpeed.Run, me) then
                PickUpItem(pickedObject)
            end
            Sleep(1 + math.random(3,6))
            Wander(5.0, 4.0, MovementSpeed.Walk, wanderAnchor)
        end,
      
        Valid = function()
            return GetFlag(patrolingFlag,me)
        end
    }




    nodes.Sleep = Action {
        function()            
            WaitForInterrupt()

        end,        
        Valid = function()
            return not GetFlag(patrolingFlag,me)
        end

    }


end}