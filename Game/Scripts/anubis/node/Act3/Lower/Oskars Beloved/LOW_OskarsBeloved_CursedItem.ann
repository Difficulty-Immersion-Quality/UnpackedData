game.states.LOW_OskarsBeloved_CursedItem = State {

    function ()
        
    
        nodes.Sleep = Action{
            function()
                
                WaitForInterrupt()
            end,
    
            Valid = function()
                return true
            end
        }


        events.EntityEvent = function(e)
            if e.Event == "LOW_OskarsBeloved_CastThunderwave" and e.TargetEntity == me then
                ShootZone("Zone_LOW_OskarsBeloved_ObjectThunderwave", me, ls.math.Vector3(0, 0, 0),  me.ForwardDirection,me)
                if me.IsInCombat then
                    Sleep(2.0)
                    EndTurn(me)
                end
            end

        end
    
    end
}