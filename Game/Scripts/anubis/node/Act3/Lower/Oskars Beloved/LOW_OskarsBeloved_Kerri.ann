game.states.LOW_OskarsBeloved_Kerri = State {function ()

    local InBedroomWaiting = false
    local aggressiveAnimation = Animation("CUST_Idle_Still_Combat_01_590ea7e8-ae43-4307-916b-b1133ef47dfa")
    local oskarEntity =  Entity("S_GLO_DoubtingArtist_3ae152be-8ff6-420c-81a0-68d6a55cd5bd")

    nodes.Waiting = Action{

        function()
            WaitForInterrupt()

        end,
        Valid = function()
            return not InBedroomWaiting
        
        end
    }

    nodes.LookingAtOskar = Action{

        function()
            if CanSee(me, oskarEntity) then
                SteerTo(oskarEntity)
            end
            PlayAnimation(aggressiveAnimation,false,true)
            WaitForInterrupt()
        end,
        OnLeave = function()
            StopAnimation(me)
        end,
        Valid = function()
            return InBedroomWaiting
        end
    }

    events.EntityEvent = function(e)
        if e.Event == "LOW_OskarsBeloved_KerriInBedroom" then 
            InBedroomWaiting = true
        end
        if e.Event == "LOW_OskarsBeloved_KerriNextPhase" then 
            InBedroomWaiting = false
        end
    end

end}
