game.states.LOW_OskarsBeloved_Tarhun = State {function ()

    modules = {"shared.moveto","shared.util"}

    local stateFlag = Flag("LOW_OskarsBeloved_State_ArtistLeftHideout_76dca7be-5c6a-4444-afa4-3ae4b13d6315")
    local kitchenFlag = Flag("LOW_Tarhun_Event_ToTheKitchen_cd3872f1-5e33-4040-a457-c6caf10642a6")
    local kitchenTrigger = Entity("S_LOW_OskarsBeloved_TarhunKitchenTrigger_012fdc69-1756-41d2-9d96-6fd2c64efe51")



    nodes.Haunt_Kitchen = Action{

        function()
            if mod.moveto.MoveToPoint(kitchenTrigger,MovementSpeed.Walk, me, 5) then
            end
            Sleep(12 + math.random(3,6))
            Wander(6.0, 4.0, MovementSpeed.Walk, kitchenTrigger)

        end,
        Valid = function()
            return GetFlag(stateFlag) and GetFlag(kitchenFlag)
        
        end
    }

    nodes.StandAtTrigger = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_LOW_OskarsBeloved_TarhunPosTrigger_da1d27af-e491-49ae-85bc-f2a8ea6e3eb4"
        },
 
        Valid = function()
            return not (GetFlag(kitchenFlag) and GetFlag(stateFlag))
        end
    }

end}
