game.states.LOW_PhilgravesMansion_HeartJar = State {

    function ()
    
        modules = { "shared.dialog", "shared.util" }


         nodes.Sleep = Action {
                function()
                    WaitForInterrupt()                 
                end
    
        }
        
        events.EntityEvent = function(e)
            if e.TargetEntity == me then
                if e.Event == "LOW_PhilgravesMansion_ExplodeHeart" then
                    UseSpellImmediate(nil, "Shout_DestructiveWave_Necrotic", me.Position, nil, nil, nil)
                end
            end
        end

    end

}