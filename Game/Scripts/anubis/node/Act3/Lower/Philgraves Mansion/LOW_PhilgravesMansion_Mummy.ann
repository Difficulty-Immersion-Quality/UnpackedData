game.states.LOW_PhilgravesMansion_Mummy = State{

    
    function()

        modules = {"shared.util"}
        local inCoffin = true
        params.coffin =  {type=EParamType.String, required = false, help = [[coffin from which Mummy emerges]]}
        local coffin = Entity(params.coffin)

        nodes.PatrolSleep = Action{
            function()
                Sleep(math.random(15.0,20.0))
                Wander(2.0,2.0,MovementSpeed.Walk,coffin)
            end,
            CanEnter = function()
                return not inCoffin 
            end
        }
        nodes.InCoffin = Action{
            function()
                WaitForInterrupt()
            end,
            Valid = function()
                return inCoffin 
            end
        }

        events.Destroyed = function(e)
            if(e.Entity == coffin) then
                inCoffin = false
            end
        end
end
    }
