game.states.LOW_BasiliskGate_Caster = State { function ()
    description = [[Fist Eostre moves from point to point and compares the contents of crates to her ledger.]]

    modules = {"shared.moveto", "shared.util" }

    params.patrolPoints = {type=EParamType.String, arrayRange = "..", required = true, help=[[Set of patrol points.]]}

    local currentIndex = 1
    local lastIndex = -1

    local behaviorDialog = Dialog("BHVR_WRLD_LOW_BasiliskGate_Caster_ReadingLedger_9c31ec2b-9eb4-a288-4fed-b3ddb9c8309b")
    local AD = Dialog("LOW_BasiliskGate_Caster_AD_88382615-1b17-a10d-82ad-89f6a76b1eee")

    nodes.Patrol = Action{function()
        local dest = Entity(params.patrolPoints[currentIndex])
        if mod.moveto.MoveToPoint(dest, MovementSpeed.Walk, me, nil, nil) then
            LookFrom(dest)
            Sleep(1.0)
            StartBehaviorDialog(behaviorDialog, nil, false, me)
            Sleep(8.5)
            StartAutomatedDialog(AD, true, me)
            mod.util.SleepRandom(14.0, 19.0)
        else
            SteerTo(dest)
        end

        currentIndex = math.random(1, #params.patrolPoints)        
        if currentIndex == lastIndex then
            currentIndex = currentIndex + 1
        end
        if currentIndex > #params.patrolPoints then
            currentIndex = 1
        end
    end
    }
end}