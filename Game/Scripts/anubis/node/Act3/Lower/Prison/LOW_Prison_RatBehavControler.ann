game.states.LOW_Prison_RatBehavControler = State{function ()
    description = [[Swicthes the between flee and random patrol based on a flag]] 

    params.customFlee = {type = EParamType.State, required=true, help=[[...]]}
    params.normalBehavior = {type = EParamType.State, required=true, help=[[...]]}

    local fleeFlag = Flag("LOW_Prison_Rat01_Event_GoToHole_dc64e547-bbd1-c4d0-a7ed-cfedf3f10c85")
    local currentAction = "normalBehav"

    --Events
    events.FlagSet = function(e)
        if e.Flag == fleeFlag.Guid then
            currentAction = "customFlee"
        end
    end

    events.FlagCleared = function(e)
        if e.Flag == fleeFlag.Guid then
            currentAction = "normalBehav"
        end
    end

    nodes.normalBehavior = Proxy
    {
        params.normalBehavior,

        Valid = function(node)
            return currentAction == "normalBehav"
        end
    }
   
    nodes.customFlee = Proxy
    {
        params.customFlee,
        Valid = function(node)
            return currentAction == "customFlee"
        end,
        OnFinished = function()
            currentAction = "normalBehav"
            return
        end
    }
end}
