game.states.LOW_Prison_Rat_CustomFleeToHole = State { function ()
    description = [[Rat flees to hole when flagged]]

    modules = {"shared.moveto"}

    local holeTrigger = Entity("S_LOW_Prison_MouseHoleBurrowPoint_7a5d51a7-e984-428b-8fb4-5bdb6de38289")
    
    nodes.FleeToHoleAndGoOffStage = Action{function()
        local moveResult = mod.moveto.MoveToPoint(holeTrigger, MovementSpeed.Run, me, nil, nil)
        if not moveResult == error.MovementError.None then
            return
        end
        SetOnStage(me, false)
    end
    }

    --fallback
    nodes.Sleep = Action{function()
        WaitForInterrupt()
    end
    }
end}