game.states.LOW_HouseOfGrief_ConfusedMerchant = State {function ()
 
    modules = { "shared.dialog" }

    local MovedOutside = false
    
    local OutsidePoint = Entity("S_LOW_ConfusedMerchantOutsidePoint_d161df9c-6367-4241-9a50-1f85f0653656")

    local merchantAD = Dialog("LOW_HouseOfGrief_AD_SpotSquirrel_d2492695-020b-bed5-b3cb-0b0345f63ac1")

    nodes.MoveToOutside = Action {
        function()
            if not IsInDangerousSurfaceFor(OutsidePoint, me.Character) and GetDistanceTo(me,OutsidePoint) > 2 then
                local moveResult = MoveTo(OutsidePoint, MovementSpeed.Walk, false, true, 2.0, 3.0, false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                else
                    if mod.dialog.IsSpeakerAvailable(me) then
                        StartAutomatedDialog(merchantAD , true, me)
                        Sleep(3.0)
                    end
                    MovedOutside = true
                end
            end
            Sleep(4.0)
        end,
        Valid = function()
            return not MovedOutside
        end
    }

    nodes.Fallback = Action {
        function()
            Sleep(6.0)
        end
    }
    
end
}