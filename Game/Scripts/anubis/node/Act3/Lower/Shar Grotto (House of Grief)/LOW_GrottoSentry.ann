game.states.LOW_SharGrotto_GrottoSentry = State {function ()

    local PartyGreeted = Flag("LOW_SharGrotto_State_GreetedParty_12192fc3-0ad6-4da6-b41f-5a559135dbe2")
    
    local HallPoint = Entity("S_LOW_SentrySermonPoint_c3c240cd-c88c-4789-9256-431d00856f1f")

    local lookAtCenter = Entity("S_LOW_CenterPoint_80aff997-4f1c-4cd9-af23-092d32ae010a")

    nodes.MoveToHall = Action {
        function()
            Sleep(6.0)
            if not IsInDangerousSurfaceFor(HallPoint, me.Character) and GetDistanceTo(me, HallPoint) > 2 then
                local moveResult = MoveTo(HallPoint, MovementSpeed.Walk, false, true, 2.0, 3.0, false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                else
                    LookAtEntity(lookAtCenter, 3.0)
                end
            end
        end,
        Valid = function()
            return GetFlag(PartyGreeted)
        end
    }

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return not GetFlag(PartyGreeted) 
        end
    }
end
}