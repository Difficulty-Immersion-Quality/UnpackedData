game.states.LOW_SharGrotto_ShadowheartFriend = State {function ()

    local MovedToHall = false

    local FriendConvinced = Flag("LOW_SharGrotto_State_TraderJoiningCombat_c7308f7d-05c0-41f5-9489-35e1865b7920")
    
    local HallPoint = Entity("S_LOW_ShadowheartFriendPoint_78f1f67c-0c9a-4250-8012-ea935af194db")

    nodes.MoveToHall = Action {
        function()
            if not IsInDangerousSurfaceFor(HallPoint, me.Character) and GetDistanceTo(me, HallPoint) > 2 then
                local moveResult = MoveTo(HallPoint, MovementSpeed.Walk, false, true, 2.0, 3.0, false)
                if moveResult ~= error.MovementError.None then
                    DebugText(me, "Error: MoveTo failed")
                    Sleep(3.0)
                else
                    MovedToHall = true
                end
            end
            Sleep(4.0)
        end,
        Valid = function()
            return not MovedToHall and GetFlag(FriendConvinced)
        end
    }

    nodes.Fallback = Action {
        function()
            Sleep(6.0)
        end
    }
    
end
}