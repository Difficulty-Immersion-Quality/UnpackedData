game.states.LOW_SharGrotto_Viconia = State {function ()
    
    modules = { "shared.dialog" }

    local SermonStopped = Flag("LOW_SharGrotto_State_FinishedSermon_1ab561f3-1756-494a-bbbd-90580e530c36")
    local ViconiaDefeated = Flag("LOW_Grotto_State_ViconiaDefeated_8e27eb4e-8d52-4966-8aa4-e658ff595097")

    local SermonAD = Dialog("LOW_SharGrotto_AD_ViconiaSermon_6bbe45af-5b0f-da2d-ce43-506978bb8f63")

    local cultist1 = Entity("S_LOW_ViconiaCultist_000_73bbaf85-e889-48b8-81cd-f2350fa0802b")
    local cultist2 = Entity("S_LOW_ViconiaCultist_001_5ce3f68d-a9b4-4ae0-adae-26f84e20f39a")
    local cultist3 = Entity("S_LOW_SharranTrainee_002_37441df0-a3fa-4709-800f-a4cfcec2448d")
    local cultist4 = Entity("S_LOW_SharranTrainee_004_24498358-fc73-4e6f-bf64-466c8bb22fb8")
    local cultist5 = Entity("S_LOW_SharranTrainee_006_279da1af-4002-4add-af07-95a7f249aabd")
    local cultist6 = Entity("S_LOW_SwayedDarkJusticiar_0e473c58-f86f-4952-a8c8-73e8ffb348c6")

    nodes.ViconiaDefeated = Action {
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return GetFlag(ViconiaDefeated) or GetFlag(SermonStopped)
        end
    }
    
    nodes.SharranSermon = Action {
        function()
            if mod.dialog.IsSpeakerAvailable(me) then
                StartAutomatedDialog(SermonAD , true, me, cultist1, cultist2, cultist3, cultist4, cultist5, cultist6)
                Sleep(3.0)
            end
        end,
        Valid = function()
            return not GetFlag(ViconiaDefeated) and not GetFlag(SermonStopped)
        end
    }  
end
}