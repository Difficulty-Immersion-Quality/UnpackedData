game.states.LOW_SWS_AtWall_SW = State{function ()
    description = [[Steel Watcher from SWS booster at Wall, inspecting civilians]]

    local poses = {
        Entity("S_LOW_SWS_AtWall_Pos_SW_000_59b907aa-efab-46cf-be42-b30fb58a9a52"),
        Entity("S_LOW_SWS_AtWall_Pos_SW_001_cd1b7138-a2af-4e97-bd97-850fefa94526"),
        Entity("S_LOW_SWS_AtWall_Pos_SW_002_9ad1123b-a707-404a-85c7-d02f132d8ece")
    }

    local civs = {
        Entity("S_LOW_SWS_AtWall_Civ_000_c52676d4-1925-4124-8901-6f206c706199"),
        Entity("S_LOW_SWS_AtWall_Civ_001_9ae6229a-43f5-40f5-8912-98fc454114df"),
        Entity("S_LOW_SWS_AtWall_Civ_002_456748f3-6720-43b1-8819-c2f67919bfc2"),
    }

    nodes.Inspect = Action{
        function()
            for i, pos in ipairs(poses) do
                local civ = civs[i]
                if not civ.Character.IsDead and CanSee(me, civ) then
                    local res = MoveTo(pos, MovementSpeed.Stroll, false, false, 0.0, 0.1, false)
                    if res == error.MovementError.None then
                        SteerTo(civ)
                        Sleep(5.0)
                    end
                end
            end
            Sleep(1.0)
        end
    }
end}