game.states.LOW_SWS_BasiliskGate_Criminal = State{function()
    description = [[A beaten criminal at Basilisk gate]]

    local unconscious = Flag("LOW_SWS_BasiliskGate_CriminalKnockedOut_b9cf3fc2-de97-40c8-bbab-cd59b19337c1")
    local worried = Animation("CUST_Worried_01_a4616816-be6d-4fa1-a65a-2da057196af4")

    nodes.WokenUp = Action{
        CanEnter = function()
            return not GetFlag(unconscious)
        end,

        function()
            try
                PlayAnimation(worried, true, false)
            catch ex if ls.CheckType(ex, error.PlayAnimationFailed) then
                DebugText(me, "Worried animation")
            end
            mod.util.SleepRandom(5.0, 10.0)
        end
    }

    nodes.Default = Action{
        Valid = function()
            return GetFlag(unconscious)
        end,

        function()
            WaitForInterrupt()
        end
    }
end}
