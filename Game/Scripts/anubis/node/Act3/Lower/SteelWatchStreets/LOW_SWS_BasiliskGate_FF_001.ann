game.states.LOW_SWS_BasiliskGate_FF_001 = State{function ()
    description = [[A Flamin Fist at Basilisk gate. Sometimes kicks a criminal.]]

    modules = { "shared.math", "shared.util" }

    local pos = Entity("S_LOW_SWS_BasiliskGate_Pos_FF_001_2a0f2f0a-8e67-4916-a659-6447aec06849")
    local criminal = Entity("S_LOW_SWS_BasiliskGate_Criminal_c21a2d99-f10d-4211-8d6a-d04851bb177c")
    local kick = Animation("CUST_GroundKicking_01_cd29166e-3971-421a-b5d3-31b678c44277")
    local knocked_out = Flag("LOW_SWS_BasiliskGate_CriminalKnockedOut_b9cf3fc2-de97-40c8-bbab-cd59b19337c1")

    nodes.MoveTo = Action {
        CanEnter = function()
            return pos ~= nil and GetDistanceTo(me, pos) > 0.1
        end,

        function()
            local result = MoveTo(pos, MovementSpeed.Walk, false, false, 0.1, 1.0, false)
            if result == error.MovementFailed then
                SteerTo(pos)
                Sleep(1.0)
            else
                LookFrom(pos)
            end
        end
    }

    nodes.Kick = Action {
        CanEnter = function()
            return GetFlag(knocked_out)
        end,

        function()
            LookFrom(pos)
            if mod.math.CoinToss(0.3) and CanSee(me, criminal) and GetDistanceTo(me, criminal) < 1.0 then
                SteerTo(criminal)
                try
                    PlayAnimation(kick, true, false)
                catch ex if ls.CheckType(ex, error.PlayAnimationFailed) then
                    DebugText(me, "Kicking animation")
                end
            end
            mod.util.SleepRandom(10.0, 15.0)
        end
    }

    nodes.NoKick = Action {
        function()
            LookFrom(pos)
            mod.util.SleepRandom(10.0, 15.0)
        end
    }

end}