game.states.LOW_SWS_NearMermaid_FF_001 = State{function ()
    description = [[A Flaming Fist near Blushing Mermaid. Inspects traders goods.]]

    modules = { "shared.math", "shared.util" }

    local pos = Entity("S_LOW_SWS_NearMermaid_Pos_FF_001_f76caeb2-a69a-4fc3-bc7e-bb846969b156")
    local inspect = Animation("CUST_InspectingBasket_01_6b69a357-9f1d-448e-91b8-b2c26b2309e0")

    nodes.MoveTo = Action {
        CanEnter = function()
            return pos ~= nil and GetDistanceTo(me, pos) > 0.1
        end,

        function()
            local result = MoveTo(pos, MovementSpeed.Walk, false, false, 0.1, 1.0, false)
            if result == error.MovementFailed then
                SteerTo(pos)
                Sleep(1.0)
            else
                LookFrom(pos)
            end
        end
    }

    nodes.Inspect = Action {
        function()
            LookFrom(pos)
            try
                PlayAnimation(inspect, true, false)
            catch ex if ls.CheckType(ex, error.PlayAnimationFailed) then
                DebugText(me, "Inspecting animation")
            end
            mod.util.SleepRandom(3.0, 5.0)
        end
    }

end}