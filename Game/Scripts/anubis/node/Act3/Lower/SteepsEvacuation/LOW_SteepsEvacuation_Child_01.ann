game.states.LOW_SteepsEvacuation_Child_01 = State { function () 

    local originalTrigger = [[S_LOW_SteepsEvacuation_Child_01_Trigger_96c6c311-a2c5-48a4-8f98-80a0c3d5386d]]
    local boatTrigger = [[S_LOW_SteepsEvacuation_FamilyStand_002_Trigger_adf05a2a-c3d7-459a-bd47-ce6db5bfe328]]
    local captainConvincedFlag = Flag("LOW_Evacuation_HasMet_MadeDealWithSailor_76df3b6e-c3c2-f9b3-d6b6-7e1dd160725f")
    
    nodes.StandNearBoat = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = boatTrigger
        },
        CanEnter = function()
            return GetFlag(captainConvincedFlag)
        end,
    }
   
    nodes.StandOriginalPosition = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = originalTrigger
        }
    }	
end}