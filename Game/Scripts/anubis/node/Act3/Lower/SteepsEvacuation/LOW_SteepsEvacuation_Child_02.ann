game.states.LOW_SteepsEvacuation_Child_02 = State { function () 

    local originalTrigger = [[S_LOW_SteepsEvacuation_Child_02_Trigger_3a964e1a-1167-4d3d-93e0-e70f18cbe447]]
    local boatTrigger = [[S_LOW_SteepsEvacuation_FamilyStand_003_Trigger_90d7c200-bdf9-4602-8985-01347d71fe95]]
    local captainConvincedFlag = Flag("LOW_Evacuation_HasMet_MadeDealWithSailor_76df3b6e-c3c2-f9b3-d6b6-7e1dd160725f")
    
    nodes.StandNearBoat = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = boatTrigger
        },
        CanEnter = function()
            return GetFlag(captainConvincedFlag)          
        end,
    }
   
    nodes.StandOriginalPosition = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = originalTrigger
        }
    }	
end}