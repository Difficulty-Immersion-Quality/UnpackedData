game.states.LOW_SteepsEvacuation_Father = State { function () 

    local originalTrigger = [[S_LOW_SteepsEvacuation_Father_Trigger_fd5703f0-2f25-4065-90d3-7233594dd192]]
    local boatTrigger = [[S_LOW_SteepsEvacuation_FamilyStand_000_Trigger_875a0105-f43d-4a30-89fb-ec78b915c654]]
    local captainConvincedFlag = Flag("LOW_Evacuation_HasMet_MadeDealWithSailor_76df3b6e-c3c2-f9b3-d6b6-7e1dd160725f")
    
    nodes.StandNearBoat = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = boatTrigger
        },
        CanEnter = function()
            return GetFlag(captainConvincedFlag)
        end,
    }
   
    nodes.StandOriginalPosition = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = originalTrigger
        }
    }	
end}