game.states.LOW_SteepsEvacuation_Mother = State { function () 

    local originalTrigger = [[S_LOW_SteepsEvacuation_Mother_Trigger_2b2d665d-1553-490b-be91-2edac136743e]]
    local boatTrigger = [[S_LOW_SteepsEvacuation_FamilyStand_001_Trigger_55bf35f8-3e2d-4445-8e5b-d790fa8711f7]]
    local captainConvincedFlag = Flag("LOW_Evacuation_HasMet_MadeDealWithSailor_76df3b6e-c3c2-f9b3-d6b6-7e1dd160725f")
    
    nodes.StandNearBoat = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = boatTrigger
        },
        CanEnter = function()
            return GetFlag(captainConvincedFlag)
        end,
    }
   
    nodes.StandOriginalPosition = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = originalTrigger
        }
    }	
end}