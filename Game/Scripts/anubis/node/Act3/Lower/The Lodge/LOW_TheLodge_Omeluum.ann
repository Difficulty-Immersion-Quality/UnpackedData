game.states.LOW_TheLodge_Omeluum = State{function()
    
    modules = {"shared.dialog"}

    local triggerString = "S_LOW_TheLodge_OmeluumLodge_PointTrigger_5241331c-80ac-4f42-9c3f-0de39706f4da"
    local trigger

    local idleAnimation = Animation("CUST_ArcaneIncantations_01_a9f3f5c6-2ab5-410d-b5c2-be409aea0458")

    self.OnInit = function()
        trigger = Entity(triggerString)
    end

    nodes.Idle = Action{        
        function()
            LookFrom(trigger)
            PlayAnimation(idleAnimation)
            Sleep(mod.math.random(3, 13))
        end,

        Valid = function()
            return GetDistanceTo(me, trigger) <= 2.0
        end
    }

    nodes.StandAtTrigger = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = triggerString
        }
    }
end}