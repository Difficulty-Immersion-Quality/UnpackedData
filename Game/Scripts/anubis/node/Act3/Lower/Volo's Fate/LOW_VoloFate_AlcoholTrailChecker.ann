game.states.LOW_VoloFate_AlcoholTrailChecker = State{function()

    local alcoSurfaceRemoved = Flag("LOW_VoloFate_State_AlcoholTrailSurfaceRemoved_98974b7c-29e4-4345-887c-24a144a52213")
    local voloArrivedFlag = Flag("LOW_VoloFate_State_VoloArrivedInBG_5faacb8c-836d-4626-bb7d-418c643e494d")
    local executionSceneDoneFlag = Flag("LOW_VoloFate_State_ExecutionSceneDone_ef057af1-d080-4c75-b454-15f71f1f669a")

    local volosCart = Entity("S_LOW_VoloFate_ExecutionCart_f1ceb8d9-0122-8051-4345-e45bb5fa7664")
    
    nodes.CheckAlcoholTrail = Action {

        function()
            Sleep(1)
            -- The precise size of the alcohol trail can be check though Osiris with oe LOW_VoloFate_CheckCartSurfaceSize
            if(FindSurface(volosCart,0.0,0.5,SurfaceType.ALCOHOL,312) == nil) then
                DebugText(me,"The trail changed")
                SetFlag(alcoSurfaceRemoved, nil)
            else
                DebugText(me,"The trail's untouched")
            end
        end,

        Valid = function()
            return GetFlag(voloArrivedFlag) and not GetFlag(alcoSurfaceRemoved) and not GetFlag(executionSceneDoneFlag)
        end
    }

    nodes.Fallback = Action{
        function()
            WaitForInterrupt()
        end
    }
end}