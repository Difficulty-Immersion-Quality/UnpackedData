game.states.WYR_Jungle_Alioramus_04 = State { function ()

    description = [[ 
        Patroling jungle dino behaviour. 
    ]]

    modules = { "shared.util" }

    local readyForRoutine = false
    local eatingAnimLoop = { Animation("CUST_Eating_01_Loop_0dae0f54-095c-489e-b611-6c42302f96d8") }
    local eatingAnimStart = Animation("CUST_Eating_01_Start_06ea1c42-85d8-4476-a853-a5c0650189b5")
    local eatingAnimEnd = Animation("CUST_Eating_01_End_389e4e72-4755-4b4f-a749-4334cb6f0af1")

    nodes.WaitingBeforeRoutine = Action {
        function()
            PlayLoopingAnimation(eatingAnimStart, eatingAnimLoop, eatingAnimEnd)
        end,
        Valid = function()
            return not readyForRoutine
        end        ,
        OnLeave = function()
            StopAnimation(me)
        end
    }

    nodes.Routine = Proxy {
        game.states.WYR_Jungle_AlioramusRoutinePatrol,
        params = {
            patrolSpline = "S_WYR_Jungle_Alioramus_04_PatrolSpline_RoutineA_c542b5d7-d2fc-4a79-a29a-8ef1f2537083",
            movementSpeed = "Walk"
        },
        Valid = function()
            return readyForRoutine
        end
    }

    -- Events
    events.EntityEvent = function(e)
        if e.TargetEntity == me then
            if e.Event == "WYR_Jungle_Alioramus_04_Event_FinishIntro" then
                readyForRoutine = true
            end
        end
    end
end}