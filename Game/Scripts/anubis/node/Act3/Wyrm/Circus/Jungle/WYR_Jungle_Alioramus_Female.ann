game.states.WYR_Jungle_Alioramus_Female = State { function ()

    description = [[ 
        Patroling jungle dino behaviour of a female dino in the cave. 
    ]]

    modules = { "shared.util" }

    local eatingIntroFlag = Flag("WYR_Jungle_Event_StartFeedingIntro_e409feaa-398a-4c3a-b76b-59de927fb547")

    nodes.WaitingBeforeRoutine = Action {
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return not GetFlag(eatingIntroFlag)
        end
    }

    nodes.Routine = Proxy {
        game.states.WYR_Jungle_AlioramusRoutinePatrol,
        params = {
            patrolSpline = "S_WYR_Jungle_Alioramus_Female_PatrolSpline_RoutineA_5bf1d543-a8a3-4953-8b9c-27b504f09b1a",
            movementSpeed = "Stroll"
        },
        Valid = function()
            return GetFlag(eatingIntroFlag)
        end
    }
end}