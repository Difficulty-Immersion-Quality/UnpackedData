game.states.WYR_Circus_BackupPerformer_PreCombat = State { function ()
    
    description = [[ A behaviour for a circus performer entertaining the crowd. ]]

    modules = { "shared.moveto", "shared.math" }

    params.performAnim = {type = EParamType.String, required = false, help=[[
        Animation to play.
    ]]}

    params.homePosTrigger = {type = EParamType.String, required = false, help=[[
        The trigger at which the character stands.
    ]]}

    local cheerAnims = {
        Animation([[CUST_Cheering_01_bb17118b-9bdc-4003-b9ad-26eda135e1a0]]),
        Animation([[CUST_Cheering_02_5e23b082-f75a-4daa-86e1-ab73ec6d30b7]]),
        Animation([[CUST_Cheering_03_34ac373e-2928-4d83-8427-13f34573c64a]]),
    }
    local homePosTrigger = Entity(params.homePosTrigger)
    local performAnim = Animation(params.performAnim)

    -----------------------------------------
    -- Nodes
    
    nodes.Performing = Action {
        function()
            if mod.moveto.MoveToPoint(homePosTrigger, MovementSpeed.Stroll, me) then
                LookFrom(homePosTrigger)
                Sleep(mod.math.random(1, 3))
                PlayAnimation(performAnim)
                Sleep(mod.math.random(2, 4))
                PlayAnimation(cheerAnims[math.random(#cheerAnims)],true)
            end
        end
    }
end}

game.states.WYR_Circus_BackupPerformer_PostCombat = State { function ()
    
    description = [[ A behaviour for a circus performer after combat is done. ]]

    modules = { "shared.moveto", "shared.math" }

    params.worriedAnim = {type = EParamType.String, required = false, help=[[
        Animation to play when combat is over.
    ]]}

    params.homePosTrigger = {type = EParamType.String, required = false, help=[[
        The trigger at which the character stands.
    ]]}

    local worriedAnim = Animation(params.worriedAnim)
    local homePosTrigger = Entity(params.homePosTrigger)

    -----------------------------------------
    -- Nodes

    nodes.Idle = Action {
        function()
            if mod.moveto.MoveToPoint(homePosTrigger, MovementSpeed.Run, me) then
                LookFrom(homePosTrigger)
                PlayAnimation(worriedAnim)
            end
        end
    }
end}