game.states.WYR_Circus_Bard = State { function ()
    description = [[ A bard who performs a song in the Circus. ]]
    
    modules = { "shared.moveto", "shared.math" }

    params.performSpell = {type = EParamType.String, required=false, default = "Shout_Bard_Perform_BardDance_Flute", help=[[
       Performance spell to use.
    ]]}

    params.performTrigger = {type = EParamType.String, required = false, help=[[
        The trigger at which the character stands.
    ]]}

    local performTrigger = Entity(params.performTrigger)

    -----------------------------------------
    -- Nodes
    
    nodes.Playing = Action {
        function()
            if mod.moveto.MoveToPoint(performTrigger, MovementSpeed.Stroll, me) then
                LookFrom(performTrigger)
                if not me.Character.IsInteractionDisabled then
                    UseSpell(params.performSpell, me, nil, nil, nil, true, true)
                    WaitForInterrupt();
                else
                    Sleep(6.0)
                end
            else
                Sleep(6.0)
            end
        end
    }
end}