game.states.WYR_Circus_Base = State { function ()
    description = [[ Base state tree for the circus characters. ]]

    modules = { "shared.util" }

    params.preShowIdle = { type = EParamType.State, required = false, default = StateRef{game.states.Dummy}, help = [[
        Idle before the clown show ends.
    ]]}

    params.duringCombatIdle = { type = EParamType.State, required = false, default = StateRef{game.states.Dummy}, help = [[
        State that is played while the players are fighting with the fake clown.
    ]]}

    params.postCombatIdle = { type = EParamType.State, required = false, default = StateRef{game.states.Dummy}, help = [[
        State after fighting with Dribbles the clown.
    ]]}

    local postCombatFlag = Flag("WYR_Circus_State_PostCombat_ee4b2f6e-9d52-4bc5-bde6-bc0e1c015de4")
    local combatStartedFlag = Flag("WYR_Circus_Clown_State_Hostile_59c1f674-0985-4d4d-9679-b8a1e4982f45")

    nodes.PreShow = Proxy {
        params.preShowIdle,
        Valid = function()
            return not GetFlag(postCombatFlag) and not GetFlag(combatStartedFlag)
        end
    }

    nodes.DuringCombatIdle = Proxy {
        params.duringCombatIdle,
        Valid = function()
            return not GetFlag(postCombatFlag) and GetFlag(combatStartedFlag)
        end
    }

    nodes.PostCombat = Proxy {
        params.postCombatIdle,
        CanEnter = function()
            return GetFlag(postCombatFlag)
        end
    }
end}