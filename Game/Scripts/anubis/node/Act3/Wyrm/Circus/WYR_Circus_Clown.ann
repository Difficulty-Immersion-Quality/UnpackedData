game.states.WYR_Circus_Clown = State { function ()
    description = [[ Behaviour for the clown on the circus' stage. He just performs an animation. ]]

    modules = { "shared.math", "shared.moveto" }

    local homePosTrigger = Entity("S_WYR_Circus_Clown_PreShowPos_604e0de9-f034-4f98-aedf-3822dc777e8d")
    local performAnim = Animation("CUST_ClownPerforming_01_97ff18e4-1265-4a31-9b38-cb75aa1de411")

    nodes.PreShow =  Action {
        function()
            if mod.moveto.MoveToPoint(homePosTrigger, MovementSpeed.Stroll, me) then
                LookFrom(homePosTrigger)
                PlayAnimation(performAnim)
            end
        end
    }
end}