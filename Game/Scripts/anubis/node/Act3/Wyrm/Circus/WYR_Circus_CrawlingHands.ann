game.states.WYR_Circus_CrawlingHands = State { function()   
    description = [[ TODO ]]
    
    local anchor

    self.OnInit = function()
        anchor = me.Position
    end

    nodes = Selector {
        function(nodes)
            return FindWeightedRandomSelectable(nodes, {
                [nodes.Wander] = 2,
                [nodes.Idle] = 1
            })
        end
    }

    nodes.Wander = function()
        Wander(math.random(2,5), math.random(2,5), MovementSpeed.Run, anchor)
    end

    nodes.Idle = function()
        Sleep(math.random(1,10))
    end
end}