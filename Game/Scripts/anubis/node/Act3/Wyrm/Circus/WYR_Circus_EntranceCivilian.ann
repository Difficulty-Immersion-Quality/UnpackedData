game.states.WYR_Circus_EntranceCivilian = State { function ()
    description = [[ Config for the civilian who enters the circus with the player. ]]

    modules = { "shared.util" }

    local canEnterFlag = Flag("WYR_Circus_EntranceCivilian_Event_PlayerEntered_81faaf61-0a04-4b1b-9dbc-330e1d310a58")

    nodes.CircusIdle = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_Circus_EntranceCivilianCircusPos_6c2df7fd-be55-4d07-adeb-e05d6b025b02"
        },
        Valid = function()
            return GetFlag(canEnterFlag)
        end
    }
    
    nodes.EntranceIdle = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_Circus_EntranceCivilianPos_9de77c00-9334-4fcb-852b-050d8df3bf4e"
        },
        Valid = function()
            return not GetFlag(canEnterFlag)
        end
    }
end}