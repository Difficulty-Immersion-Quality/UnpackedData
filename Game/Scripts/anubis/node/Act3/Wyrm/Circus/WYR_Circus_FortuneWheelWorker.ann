game.states.WYR_Circus_FortuneWheelWorker = State { function ()
    description = [[ 
        Behaviour for the circus worker, standing near the wheel of fortune and attracting the customers via AD.
     ]]

    modules = { "shared.util" }

    params.wheelWorkingIdle = { type = EParamType.State, required = true, help = [[
        Idle to play AD attracting the customers.
    ]]}

    params.wheelStoppedIdle = { type = EParamType.State, required = true, help = [[
        Idle to play after the wheel is no longer works.
    ]]}

    local hasPrizesFlag = Flag("WYR_Circus_FortuneWheelWorker_State_HasPrizes_dcea2493-c33f-7d42-d348-90530855995f")
    local wonGrandPrizeFlag = Flag("WYR_Circus_FortuneWheelWorker_State_WonGrandPrize_70949ccb-0be4-d4a0-86b3-421939e1b17e")

    nodes.WheelWorkingIdle = Proxy {
        params.wheelWorkingIdle,
        Valid = function()
            return GetFlag(hasPrizesFlag) and not GetFlag(wonGrandPrizeFlag)
        end
    }

    nodes.WheelStoppedIdle = Proxy {
        params.wheelStoppedIdle,
        CanEnter = function()
            return not GetFlag(hasPrizesFlag) or GetFlag(wonGrandPrizeFlag)
        end
    }
end}