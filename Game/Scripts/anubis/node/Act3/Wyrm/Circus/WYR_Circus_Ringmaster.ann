game.states.WYR_Circus_Ringmaster = State { function ()
    description = [[ Behaviour for the circus leader after combat with Dribbles. ]]

    local gotQuestFlag = Flag("WYR_Circus_State_GotDribblesQuest_780f6847-84a7-ff3e-f8bb-670d625c1a87")

    modules = { "shared.util" }

    nodes.AfterCombat = Proxy {
        game.states.WYR_ADInTrigger,
        params = {
            AD = [[WYR_Circus_AD_Ringmaster_57a8297a-ed78-e0e5-3f1d-fadb64666245]],
            minDelay = 8,
            pauseBetweenChecks = 3,
            trigger = [[S_WYR_Circus_Ringmaster_PostCombatPos_fbd722db-155d-430a-96d6-b897cb798c4f]],
        },
        Valid = function()
            return not GetFlag(gotQuestFlag)
        end
    }

    nodes.AfterQuestGiven = Proxy {
        game.states.GLO_StandAtTriggerSplit,
        params = {
            trigger = "S_WYR_Circus_Ringmaster_PostQuestPos_758b43e1-e5ce-4aa8-b5ed-f94cd1a94313",
            animations = {
                "CUST_Bored_01_23588ba8-fafb-438c-9bc5-660ff6650aef",
                "CUST_Bored_02_7892cb3b-2935-4aa3-b65c-64d9664cbe75",
            },
        },
        Valid = function()
            return GetFlag(gotQuestFlag)
        end
    }
end}