game.states.WYR_Circus_Thug_02 = State { function ()
    description = [[ Thug who stands on a side near the dino cage and watches the crowd. ]]

    modules = { "shared.util", "shared.moveto" }

    local homePosTrigger = Entity("S_WYR_Circus_Thug_02_Pos_c6405918-9ad1-4169-86ab-a25edae2b6a5")
    local crossArmAnim = Animation("CUST_ArmsCrossed_01_Loop_e6c49668-99b1-41d6-8daa-7ed6864b4e71")

    nodes.NearCages = Action {
        function()
            if mod.moveto.MoveToPoint(homePosTrigger, MovementSpeed.Walk, me) then
                LookFrom(homePosTrigger)
                PlayAnimation(crossArmAnim, false, true)
            end
        end,
        OnLeave = function()
            StopAnimation(me)
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end
    }
end}