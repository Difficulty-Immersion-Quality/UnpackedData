game.states.WYR_DevilsAtTheGate_TieflingLeader = State{function()

    params.SharessCaressTrigger = { type = EParamType.String, required = true, help = [[
        The trigger at Sharess' Caress.
    ]]}

    params.AmbushMeetingTrigger = { type = EParamType.String, required = true, help = [[
        The trigger at the ambush meeting.
    ]]}

    params.ContingencyMeetingTrigger = { type = EParamType.String, required = true, help = [[
        The trigger at the ambush meeting.
    ]]}

    local readyForAmbushMeeting = Flag("WYR_DevilsAtTheGate_State_ZevlorReadyForAmbushMeeting_2577d752-3d0c-4a03-99c5-975fddd77221")
    local ambushMeetingOver = Flag("WYR_DevilsAtTheGate_State_AmbushMeetingOver_9e3fe33e-f8f4-3953-d3ca-5fc4aa0700fe")
    local readyForContingencyMeeting = Flag("WYR_DevilsAtTheGate_State_ZevlorReadyForContingencyMeeting_69a88fc7-7feb-4ca4-86fb-6eb338af999e")
    local contingencyMeetingOver = Flag("WYR_DevilsAtTheGate_State_ContingencyMeetingOver_2b414951-00ca-4b60-9953-8451e87c9960")

    nodes.AtAmbushMeetingTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.AmbushMeetingTrigger
        },
        Valid = function()
            return GetFlag(readyForAmbushMeeting) and not GetFlag(ambushMeetingOver)
        end
    }

    nodes.AtContingencyMeetingTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.ContingencyMeetingTrigger
        },
        Valid = function()
            return GetFlag(readyForContingencyMeeting) and not GetFlag(contingencyMeetingOver)
        end
    }

    nodes.AtSharessCaressTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.SharessCaressTrigger
        },
        Valid = function()
            return not (GetFlag(readyForAmbushMeeting) and not GetFlag(ambushMeetingOver)) and not (GetFlag(readyForContingencyMeeting) and not GetFlag(contingencyMeetingOver))
        end
    }
end}