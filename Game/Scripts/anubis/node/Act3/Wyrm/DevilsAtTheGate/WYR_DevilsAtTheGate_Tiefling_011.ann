game.states.WYR_DevilsAtTheGate_Tiefling_011 =
    State {
    function()
        params.RefugeeCampTrigger = {
            type = EParamType.String,
            required = true,
            help = [[
        The trigger at refugee camp.
    ]]
        }

        params.AmbushMeetingTrigger = {
            type = EParamType.String,
            required = true,
            help = [[
        The trigger at the ambush meeting.
    ]]
        }

        local readyForAmbushMeeting =
            Flag("WYR_DevilsAtTheGate_State_ZorruReadyForAmbushMeeting_6f06b832-6d97-4d88-8444-62b34c1118d1")
        local ambushMeetingOver =
            Flag("WYR_DevilsAtTheGate_State_AmbushMeetingOver_9e3fe33e-f8f4-3953-d3ca-5fc4aa0700fe")

        nodes.AtMeetingTrigger =
            Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.AmbushMeetingTrigger
            },
            Valid = function()
                return GetFlag(readyForAmbushMeeting) and not GetFlag(ambushMeetingOver)
            end
        }

        nodes.AtCampTrigger =
            Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.RefugeeCampTrigger
            },
            Valid = function()
                return not GetFlag(readyForAmbushMeeting) or GetFlag(ambushMeetingOver)
            end
        }
    end
}
