
game.states.WYR_FigaroSister_Carmen = State{function ()

    modules = { "shared.math", "shared.params", "shared.util" }

    -----------------------------------------
    -- Params

    -----------------------------------------
    -- Local variables
    
    local trigger001 = Entity("S_WYR_FigaroSister_Carmen_Point_001_8d2db404-2dd0-47b0-9ede-e820e70fd540")
    local trigger002 = Entity("S_WYR_FigaroSister_Carmen_Point_002_d9c78715-56a3-4730-922e-1a827ca23032")
    local trigger003 = Entity("S_WYR_FigaroSister_Carmen_Point_003_57bcd4c2-1cb8-43c5-8da6-3bbeabcb42ad")
    local trigger001_LookAt = Entity("S_WYR_FigaroSister_Carmen_Point_LookAt_001_cd5b2b56-b732-4188-9bfa-0cff72f61c10")
    local trigger002_LookAt = Entity("S_WYR_FigaroSister_Carmen_Point_LookAt_002_c11fea7c-59b0-49b8-a327-cc55ce35a832")
    local trigger003_LookAt = Entity("S_WYR_FigaroSister_Carmen_Point_LookAt_003_99c749d8-e5e9-4df0-95ca-b7efb8ba5ba6")
    
    local atTrigger2=Flag("WYR_FigaroSister_State_Carmen_AtTrigger2_72a02d93-9390-45e5-808a-a72f604d7103")
    local atTrigger3=Flag("WYR_FigaroSister_State_Carmen_AtTrigger3_9e3f0a10-2666-4785-aa8f-14d1f3c3cd38")

    local materialsDialog=Dialog("WYR_FigaroSister_AD_Carmen_LookAtMaterials_c15ade35-cf6d-de88-3caf-3bf299e6857a")

    local inspectFabricAnim = Animation("CUST_InspectFabric_01_47249e0f-20b7-43ed-8853-029badd0587e")

    -----------------------------------------
    -- Nodes

    nodes.AtShop = Action {
        function()
            if GetFlag(atTrigger3,me) then
                DebugText(me,"Moving to trigger003")
                local moveResult = MoveTo(trigger003,MovementSpeed.Stroll,true,false)
                if moveResult == error.MovementError.None then
                    SteerTo(trigger003_LookAt)
                    Sleep(1.0)
                    --the atTrigger3 flag being set will play the right-side nodes in the AD
                    StartAutomatedDialogRateLimitedImmediate(materialsDialog,0.0,8.0,me)
                    PlayAnimation(inspectFabricAnim,true)
                    Sleep(2.0)
                    ClearFlag(atTrigger3,me)
                end
            elseif GetFlag(atTrigger2,me) then
                DebugText(me,"Moving to trigger002")
                local moveResult = MoveTo(trigger002,MovementSpeed.Stroll,true,false)
                if moveResult == error.MovementError.None then
                    SteerTo(trigger002_LookAt)
                    Sleep(1.0)
                    --the atTrigger3 flag not being set will play the left-side nodes in the AD
                    StartAutomatedDialogRateLimitedImmediate(materialsDialog,0.0,8.0,me)
                    PlayAnimation(inspectFabricAnim,true)
                    Sleep(2.0)
                    SetFlag(atTrigger3,me)
                    ClearFlag(atTrigger2,me)
                end
            else
                DebugText(me,"Moving to trigger001")
                local moveResult = MoveTo(trigger001,MovementSpeed.Stroll,true,false)
                if moveResult == error.MovementError.None then
                    SteerTo(trigger001_LookAt)
                    Sleep(35.0)
                    SetFlag(atTrigger2,me)
                end
            end
        end
    }

end}