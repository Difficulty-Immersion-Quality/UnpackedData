game.states.WYR_IronhandGnome = State{function()
    description = [[Common state for those Ironhand gnome that might take part in South checkpoint scene]]

    params.hideoutState = {type = EParamType.State, required = true,
        help=[[State inside hideout]]}

    local atCheckpoint = Flag("WYR_Ironhand_State_AtCheckpoint_fbba9492-5888-4f04-8be7-b6af11ab5463")

    nodes.BeforeHideout = Action {
        function()
            WaitForInterrupt()
        end,
        Valid = function()
            return GetFlag(atCheckpoint, me)
        end
    }

    nodes.AtHideout = Proxy {
        params.hideoutState,
    }
end}