game.states.WYR_Ironhand_ArtificerExtra_001 = State{function()
    description = [[Extra addition gnome. Can take role of HiddenGnome or GnomeWorkerDaffy: at workbench or guarding at ladder]]

    local replaceGnome1 = Flag("WYR_Ironhand_ReplaceGnome_1_ef6260ad-61c0-4dd3-b505-1a30bf773b4f")
    local patrolSpline = "S_WYR_Ironhand_LadderGuardSpline_6dcdd4b7-963b-4267-886d-3ba3acbfe8ef"

    nodes.Workbench = Proxy {
        game.states.WYR_HiddenGnome,

        CanEnter = function()
            return GetFlag(replaceGnome1, me)
        end
    }

    nodes.Default = Proxy {
        game.states.GEN_Patrol,
        params = {
            patrolSpline = patrolSpline,
            patrolSpeed = "Stroll",
        }
    }
end}
