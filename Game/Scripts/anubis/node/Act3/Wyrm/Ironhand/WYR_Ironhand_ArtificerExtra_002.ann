game.states.WYR_Ironhand_ArtificerExtra_002 = State{function()
    description = [[Extra addition gnome. Can take role of InjuredGnome or Prisoner_001: at chemlab or at whetstone]]

    local replaceGnome1 = Flag("WYR_Ironhand_ReplaceGnome_1_ef6260ad-61c0-4dd3-b505-1a30bf773b4f")

    nodes.Chemistry = Proxy {
        game.states.WYR_ChemistryGnome,

        CanEnter = function()
            return GetFlag(replaceGnome1, me)
        end
    }

    nodes.Chemistry = Proxy {
        game.states.WYR_GnomePrisoner_001
    }
end}
