game.states.WYR_MerchantsHouse_Refugee = State { function ()
    description = [[ TODO ]]

    params.conflictIdle = { type = EParamType.State, required = true, help = [[
        The idle during the conflict scene, before situation has been resolved.
    ]]}

    params.housedIdle = { type = EParamType.State, required = true, help = [[
        Idle state after the refugees has been housed.
    ]]}

    local housedFlag = Flag("WYR_MerchantsHouse_Refugees_State_Housed_0481d093-1539-1a06-b3b2-246270b82a12")
    local merchantIntimidatedFlag = Flag("WYR_MerchantsHouse_Merchant_State_Intimidated_74338e62-6273-1d74-5609-90c9eccdabcc")
    local merchantGoneFlag = Flag("WYR_MerchantsHouse_Merchant_State_GoneFromHouse_5e40419b-d67c-4bde-8b91-bdace8bad309")
    local knowsRefugeesFlag = Flag("WYR_MerchantsHouse_Knows_Refugees_8e235664-43aa-304d-1a1f-839214b598d6")

    helpers.CanGoInsideHouse = function()
        return GetFlag(housedFlag) or 
            (GetFlag(knowsRefugeesFlag) and (GetFlag(merchantIntimidatedFlag) or GetFlag(merchantGoneFlag)))
    end

    nodes.ConflictIdle = Proxy {
        params.conflictIdle,
        Valid = function()
            return not helpers.CanGoInsideHouse()
        end
    }

    nodes.HousedIdle = Proxy {
        params.housedIdle,
        CanEnter = function()
            return helpers.CanGoInsideHouse()
        end
    }
end}