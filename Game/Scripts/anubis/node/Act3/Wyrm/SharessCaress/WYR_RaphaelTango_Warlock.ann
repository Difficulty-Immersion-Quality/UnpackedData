game.states.WYR_RaphaelTango_Warlock = State { function ()
    
    description = [[ 
        Behaviour for Korrilla while she's in Sharess Caress'.
    ]]

    modules = { "shared.dialog", "shared.util" }  

    local AD = Dialog("WYR_SharessCaress_AD_WarlockBartender_ae67f930-21d0-9de5-4224-129782c97e02")
    local bartender = Entity("S_WYR_SharessCaress_Bartender_ab24945c-268d-4f90-b8ea-bbb11cd50157")
    local drinkAnim = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")

    nodes.Taproom = Action {
        function()
            PlayAnimation(drinkAnim, false)
            mod.util.SleepRandom(2.0, 4.0)
            if mod.dialog.IsSpeakerAvailableAndNear(bartender, me, 10.0, false, false) then
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    AD,
                    {
                        checkSight = false,
                        waitForCompletion = true,
                        minDelay = 15.0
                    },
                    me,
                    bartender
                )
            else
                Sleep(3.0)
            end            
        end
    }
end}