game.states.WYR_SharessCaress_BoastingCrooks_Zhent = State{ function()

modules = {"shared.dialog"}

--local chair = Entity("S_WYR_SharessCaress_BoastingCrooks_ZhentChair_94f71c4c-ebc7-4c69-962c-3a03991ebaf1")
local companion = Entity("S_WYR_SharessCaress_BoastingCrooks_RivingtonRat_59f97331-f6bc-45b5-bf21-03ea4341e99e")
local AD = Dialog("WYR_SharessCaress_BoastingCrooks_AD_d5285158-d5bd-2e43-646d-61bb687525e4")


nodes.PlayAD = Action{
    function()
        mod.dialog.StartCheckedAutomatedDialogRateLimited(
            AD,
            {
                waitForCompletion = true,
                minDelay = 24,
                checkSight = false,
                cullingDistance = 15.0
            },
                me,
                companion
            )
    end,
    CanEnter = function()
        return not companion.Character.IsDead
    end
}

nodes.Fallback = Action{
    function()
        WaitForInterrupt()
    end,
    CanEnter = function()
        return true
    end

}

end
}





