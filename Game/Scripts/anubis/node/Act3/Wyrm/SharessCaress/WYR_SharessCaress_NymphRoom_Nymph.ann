game.states.WYR_SharessCaress_NymphRoom_Nymph = State { function ()
    
    description = [[ 
        Behaviour the Nymph in the Sharess Caress' Nymph's Grotto room.
    ]]

    modules = { "shared.moveto", "shared.math" }  
    
    local transformedFlag = Flag("WYR_SharessCaress_NymphRoom_State_Transformed_d3eb0659-c71c-4d59-88fb-e70c68495fb3")

    nodes.BeforeTransformation = Proxy {
        game.states.WYR_PairedADInTrigger,
        params = {
            trigger = "S_WYR_SharessCaress_NympRoom_PreCombatPos_2b4a26d1-02ed-449f-8d2a-a40e50452f92",
            pairNPCs = { "S_WYR_SharessCaress_NymphRoom_FlamingFist_b5cb7f36-6ab8-48fb-9ddb-0bcb67807e44" },
            AD = "WYR_SharessCaress_NymphRoom_AD_NymphFlamingFist_7b44f9c1-8152-cc68-b4f5-33940c9bc64f"
        }, 
        Valid = function()
            return not GetFlag(transformedFlag)
        end
    }

    nodes.PostCombat = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_SharessCaress_NympRoom_PostCombatPos_f8326052-93aa-4960-93c9-ef50763c50c2",
        }, 
        Valid = function()
            return GetFlag(transformedFlag)
        end
    }
end}