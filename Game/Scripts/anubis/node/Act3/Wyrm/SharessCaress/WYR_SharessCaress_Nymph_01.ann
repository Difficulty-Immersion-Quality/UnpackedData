game.states.WYR_SharessCaress_Nymph_01 = State { function ()
    
    description = [[ 
        Behaviour for the Nymph in the taproom at the bar of Sharess Caress'.
    ]]

    modules = { "shared.dialog", "shared.moveto", "shared.util" }  
    
    local fistLeftFlag = Flag("WYR_SharessCaress_State_NymphFlamingFistLeft_798c8029-9b0e-4f1e-d4f9-0282b5366bd1")
    local drinkingAnim = Animation("CUST_Drinking_01_Drink_Wine_Glass_A_3f6ab5b5-6c83-456d-932e-23a260378b6b")
    local trigger = Entity("S_WYR_SharessCaress_Nymph_01_TaproomPos_62e28e0f-10d9-44a0-b691-bbb9558ee96b")
    local fist = Entity("S_WYR_SharessCaress_FlamingFist_01_350212e9-a8d6-43aa-8595-61e0d69b46f1")
    local AD = Dialog("WYR_SharessCaress_AD_NymphDrunkFist_aee5b384-40ba-a535-c9b3-51a545fb1813")

    nodes.WithFist = Action {
        function()
            if mod.moveto.MoveToPoint(trigger, MovementSpeed.Walk, me) then
                LookAtEntity(fist, 3.0)
                PlayAnimation(drinkingAnim)
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    AD,
                    {
                        waitForCompletion = true,
                        minDelay = 50.0,
                        cullingDistance = 7.0,
                        checkSight = false
                    },
                    me,
                    fist
                )
            end
        end,
        Valid = function()
            return not GetFlag(fistLeftFlag)
        end
    }

    nodes.FistLeft = Proxy {
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_SharessCaress_Nymph_01_TaproomPos_62e28e0f-10d9-44a0-b691-bbb9558ee96b",
        }, 
        Valid = function()
            return GetFlag(fistLeftFlag)
        end
    }
end}