game.states.WYR_SmugglersCave_Attacker_Base = State { function ()
    description = [[ TODO ]]

    modules = { "shared.util" }

    params.preShowIdle = { type = EParamType.State, required = true, help = [[
        Idle before the combat begins.
    ]]}

    params.postCombatIdle = { type = EParamType.State, required = true, help = [[
        State after fighting and winning against the Smugglers.
    ]]}

    local postCombatFlag = Flag("WYR_SmugglersCave_Event_PostCombat_67b3c231-5dc4-4bb8-9fee-02d7d1074da3")

    nodes.PreShow =  Proxy {
        params.preShowIdle,
        Valid = function()
            return not GetFlag(postCombatFlag)
        end
    }

    nodes.PostCombat =  Proxy {
        params.postCombatIdle,
        CanEnter = function()
            return GetFlag(postCombatFlag)
        end
    }
end}