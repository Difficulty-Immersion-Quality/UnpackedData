game.states.WYR_SmugglersCave_SmugglerLeader = State{function()
    description = [[Behavior of smugglers in Smuggler's Cave:
        - after combat they run around as if unloading the ship
    ]]

    modules = { "shared.moveto", "shared.params", "shared.util" }

    local postCombat = Flag("WYR_SmugglersCave_Event_PostCombat_67b3c231-5dc4-4bb8-9fee-02d7d1074da3")


    nodes.PreCombat = Proxy{
        Valid = function()
            return not GetFlag(postCombat)
        end,

        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_Smugglers_SmugglersLeader_Pos_600ce497-1e01-43b0-a089-7a2a031c1c1f",
        }
    }

    nodes.PostCombat = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_Smugglers_SmugglersLeader_PostCombatPos_99328503-72d0-44fc-bdc9-9b8727baecac",
        }
    }
end}
