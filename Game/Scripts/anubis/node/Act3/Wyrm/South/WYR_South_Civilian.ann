game.states.WYR_South_Civilian = State{function()
    description = [[Civilian at WYR south checkpoint]]

    params.position = { type = EParamType.String, required = true, help = [[
        Trigger to stand at
    ]]}

    nodes.StandAtTrigger = Proxy{
        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.position
        }
    }
end}
