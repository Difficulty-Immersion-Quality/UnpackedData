game.states.WYR_South_Guard_002 = State{function()
    description = [[Guard at WYR south checkpoint talking to refugees]]

    modules = { "shared.dialog" }

    local pos1 = Entity("S_WYR_South_GuardPos_002_2_825c3d29-81bf-4b5e-ba21-694bc1799a6c")
    local pos2 = Entity("S_WYR_South_GuardPos_002_ad84e12f-9ca2-4b7b-b3cb-bdf6a7a739a5")

    local refugeesLeft = Flag("WYR_South_RefugeesLeft_e3945f51-32da-42f4-ab06-f58e61f55dbc")

    local dialog = Dialog("WYR_South_AD_Refugees_33082383-b68c-7bb0-093b-732a3b78d597")
    local partners = {
        Entity("S_WYR_South_Guard_003_e93fa1a6-9999-45a9-9a91-3e7dc00908c1"),
        Entity("S_WYR_South_Civilian_000_fac3ed5f-b71b-4285-b05a-1d504c06666e"),
        Entity("S_WYR_South_Civilian_001_4134d7c5-e8ba-4123-bd25-32094a9c3701"),
    }

    nodes.RefugeesLeft = Proxy{
        CanEnter = function()
            return GetFlag(refugeesLeft)
        end,

        game.states.GLO_StandAtTriggerSplit,
        params = {
            trigger = "S_WYR_South_GuardPos_002_ad84e12f-9ca2-4b7b-b3cb-bdf6a7a739a5",
            animations = {
                "CUST_Bored_01_23588ba8-fafb-438c-9bc5-660ff6650aef",
                "CUST_Bored_02_7892cb3b-2935-4aa3-b65c-64d9664cbe75",
            },
        }
    }

    nodes.StandAtTrigger = Proxy{
        CanEnter = function()
            return GetDistanceTo(me, pos1) > 0.5
        end,

        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_South_GuardPos_002_2_825c3d29-81bf-4b5e-ba21-694bc1799a6c"
        }
    }

    nodes.TalkToRefugees = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(dialog, { minDelay = 30.0 }, me, table.unpack(partners))
            Sleep(2.0)
        end
    }

    nodes.Fallback = Action{
        function()
            Sleep(2.0)
        end
    }
end}
