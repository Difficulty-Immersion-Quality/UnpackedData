game.states.WYR_South_Guard_003 = State{function()
    description = [[Guard at WYR south checkpoint talking to refugees]]

    local pos1 = Entity("S_WYR_South_GuardPos_003_2_e5ad6cfc-e898-49da-a61f-1b92086228b8")
    local pos2 = Entity("S_WYR_South_GuardPos_003_73b1b206-2295-493b-b1f2-5ed0d1265c55")

    local refugeesLeft = Flag("WYR_South_RefugeesLeft_e3945f51-32da-42f4-ab06-f58e61f55dbc")

    nodes.RefugeesLeft = Proxy{
        CanEnter = function()
            return GetFlag(refugeesLeft)
        end,

        game.states.GLO_StandAtTriggerSplit,
        params = {
            trigger = "S_WYR_South_GuardPos_003_73b1b206-2295-493b-b1f2-5ed0d1265c55",
            animations = {
                "CUST_Bored_01_23588ba8-fafb-438c-9bc5-660ff6650aef",
                "CUST_Bored_02_7892cb3b-2935-4aa3-b65c-64d9664cbe75",
            },
        }
    }

    nodes.StandAtTrigger = Proxy{
        CanEnter = function()
            return GetDistanceTo(me, pos1) > 0.5
        end,

        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_South_GuardPos_003_2_e5ad6cfc-e898-49da-a61f-1b92086228b8"
        }
    }

    nodes.TalkToRefugees = Action{
        function()
            Sleep(1.0)
        end
    }
end}
