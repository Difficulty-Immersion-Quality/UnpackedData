game.states.WYR_South_Guard_004 = State{function()
    description = [[Behavior of a guard at WYR South checkpoint. Main checkpoint guard.
        Walks one way then the other in front of the checkpoint]]

    modules = { "shared.math" }

    local spline = Spline("S_WYR_South_Guard_Patrol_004_e1f6ccd8-8583-414b-94d9-bfd733ebdfc1")
    local reversed = false
    local rest = false

    nodes.Rest = Action{
        Valid = function()
            return rest
        end,

        function()
            LookFrom(spline)
            Sleep(1.0)
        end
    }

    nodes.Stroll = Action{
        function()
            DoPatrol(spline, reversed, MovementSpeed.Stroll, -1, false)
        end
    }


    events.SplineControlPointReached = function(ev)
        if ev.EndReached then
            rest = true
            reversed = not reversed
            StartTimer(me, "Timer_WYR_South_Guard_004_ContinuePatrol", mod.math.random(5.0, 25.0), 0)
        end
    end

    events.TimerFinished = function(ev)
        if ev.TimerName == "Timer_WYR_South_Guard_004_ContinuePatrol" then
            rest = false
        end
    end
end}
