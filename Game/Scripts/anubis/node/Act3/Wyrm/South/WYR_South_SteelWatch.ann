game.states.WYR_South_SteelWatch = State{function()
    description = [[Steel Watcher at WYR South checkpoint]]

    modules = { "shared.dialog" }

    local malfunctionTag = Tag("STEEL_WATCHER_MALFUNCTION_62b8df63-c303-4956-97a9-5c9c97520ebf")
    local malfunctionAD = Dialog("GLO_SteelWatcher_AD_Malfunction_6b4fb4c5-b34f-f10f-d035-9f3a8ec5a0b2")

    nodes.Malfunction = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(malfunctionAD, {
                waitForCompletion = true,
                minDelay = 40.0 },
                me)
            Sleep(5.0)
        end,

        Valid = function()
            return IsTagged(me, malfunctionTag)
        end
    }

    nodes.Default = Action{
        function()
            Sleep(1.0)
        end
    }
end}
