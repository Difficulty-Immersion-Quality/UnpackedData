game.states.WYR_Flophouse_Cook = State{

    function()

        modules = {"shared.util","shared.math"}

        local choppingPos = Entity("S_WYR_Flophouse_Cook_ChoppingPos_1253fa31-a02d-41a0-a9d1-577101f597fc")
        local choppingAnim = Animation("CUST_ChoppingLeaves_01_e87e9e8c-81e4-4c03-a890-c8394a323a7f")

        local warmPos = Entity("S_WYR_Flophouse_Cook_WarmPosition_143ea579-761d-478a-b129-9789149b1261")
        local warmAnim = Animation("CUST_UncomfortablyWarm_01_02efe31d-4cdd-45d4-b23f-104c24790437")

        local organizingPos = Entity("S_WYR_Flophouse_Cook_OrganizingPos_415da838-9c5e-4e68-a6eb-85541db1901b")
        local organizingAnim = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")

        local inspectPos = Entity("S_WYR_Flophouse_Cook_InspectClose_c37b5216-76e9-4076-ad29-87c50916c00f")
        local inspectAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")

        nodes.DefaultBehavior = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
        }

        nodes.DefaultBehavior.Chopping = Action {
            function()
                if GetDistance2DTo(me, choppingPos) > 0.25 then
                    local moveResult = MoveTo(choppingPos, MovementSpeed.Walk, false, false, 0.1, 0.25, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(choppingPos)
                        PlayAnimation(choppingAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

        nodes.DefaultBehavior.Warm = Action {
            function()
                if GetDistance2DTo(me, warmPos) > 0.5 then
                    local moveResult = MoveTo(warmPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(warmPos)
                        PlayAnimation(warmAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

        nodes.DefaultBehavior.Organizing = Action {
            function()
                if GetDistance2DTo(me, organizingPos) > 0.5 then
                    local moveResult = MoveTo(organizingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(organizingPos)
                        PlayAnimation(organizingAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

        nodes.DefaultBehavior.Inspecting = Action {
            function()
                if GetDistance2DTo(me, inspectPos) > 0.5 then
                    local moveResult = MoveTo(inspectPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(inspectPos)
                        PlayAnimation(inspectAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

    end
}