game.states.WYR_Flophouse_Guest_002 = State {

    function()

        modules = { "shared.dialog" }

        local repeatedAD = Dialog("WYR_Flophouse_AD_Guest_002_02eb79cf-cab4-d907-18f7-3aeebf35043d")

        nodes.Talk = Action{
            function()
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me
                )
				Sleep(6.0)
            end
        }

        nodes.Fallback = Action{
            function()
                Sleep(6.0)
            end
        }

    end
}