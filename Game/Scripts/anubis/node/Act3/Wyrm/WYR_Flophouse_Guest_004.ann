game.states.WYR_Flophouse_Guest_004 = State {

    function()

        modules = { "shared.dialog" }

        local repeatedAD = Dialog("WYR_Flophouse_AD_Guest_004_d6ddb923-0109-af2f-5d8d-e2472e5da88f")

        nodes.Talk = Action{
            function()
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me
                )
				Sleep(6.0)
            end
        }

        nodes.Fallback = Action{
            function()
                Sleep(6.0)
            end
        }

    end
}