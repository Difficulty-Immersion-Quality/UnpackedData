game.states.WYR_Flophouse_Janitor = State{

    function()

        modules = {"shared.util","shared.math"}

        local thinkingPos = Entity("S_WYR_Flophouse_Janitor_ThinkingPos_e911977b-4207-43f3-9445-a392954e4048")
        local thinkingAnim = Animation("CUST_Thinking_01_97588786-d9bf-4d18-879b-1bd3dcaa62ba")

        local drinkingPos = Entity("S_WYR_Flophouse_Janitor_DrinkingPos_f7895c0a-c247-435f-a00a-9228bf98b022")
        local drinkingAnim = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")

        local organizingPos = Entity("S_WYR_Flophouse_Janitor_OrganizingPos_b1da7780-ed54-40a6-b2c1-87d398922ff1")
        local organizingAnim = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")

        local standingPos = Entity("S_WYR_Flophouse_Janitor_StandingPos_0695c290-4763-4cbf-91bd-bb2b63e00cab")

        nodes.DefaultBehavior = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
        }

        nodes.DefaultBehavior.Thinking = Action {
            function()
                if GetDistance2DTo(me, thinkingPos) > 0.5 then
                    local moveResult = MoveTo(thinkingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(thinkingPos)
                        PlayAnimation(thinkingAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

        nodes.DefaultBehavior.Drinking = Action {
            function()
                if GetDistance2DTo(me, drinkingPos) > 0.5 then
                    local moveResult = MoveTo(drinkingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(drinkingPos)
                        PlayAnimation(drinkingAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

        nodes.DefaultBehavior.Organizing = Action {
            function()
                if GetDistance2DTo(me, organizingPos) > 0.5 then
                    local moveResult = MoveTo(organizingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(organizingPos)
                        PlayAnimation(organizingAnim, true)
                    end
                end
                Sleep(math.random(2, 4))
            end
        }

        nodes.DefaultBehavior.Standing = Action {
            function()
                if GetDistance2DTo(me, standingPos) > 0.5 then
                    local moveResult = MoveTo(standingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(standingPos)
                    end
                end
                Sleep(math.random(6, 9))
            end
        }

    end
}