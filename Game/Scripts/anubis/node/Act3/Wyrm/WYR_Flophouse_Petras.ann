game.states.WYR_Flophouse_Petras = State {

    function()

        modules = { "shared.dialog" }

        local repeatedAD = Dialog("WYR_VampireSpawns_AD_DalyriaAndPetras_e346aaa1-ad08-43c5-df09-f5baec1eb75f")
        local partner = Entity("S_WYR_VampireSpawns_Dalyria_204a74d2-e6ad-4e9b-a275-f03cb5f3d975")
        local sentToPalace = Flag("LOW_CazadorsPalace_State_SentToPalace_df019be0-deac-4302-a3a6-018fb985c705")

        nodes.Talk = Action{
            function()
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me,
                    partner
                )
				Sleep(6.0)
            end,
            Valid = function()
                return not GetFlag(sentToPalace, me)
            end
        }

        nodes.Fallback = Action{
            function()
                Sleep(6.0)
            end
        }

    end
}