game.states.WYR_GurCamp_GurLeader = State {

    function()

        modules = { "shared.dialog" }

        local repeatedAD = Dialog("WYR_GurCamp_AD_GroupADWithGurLeader_f0bd285a-d183-e7ff-11aa-192b0d6b98c9")
        local speaker_002 = Entity("S_WYR_GurCamp_Hunter_002_630d63de-ae45-4649-8cbd-563b6d3055ae")
        local speaker_003 = Entity("S_WYR_GurCamp_Hunter_005_afbb70d4-5cc4-444f-90b6-0d243b6418c3")
        local inDungeon = Flag("LOW_GurFollowUp_State_InDungeon_1f27517e-bbdf-4b45-8ab4-2c612650311e")

        nodes.Talk = Action{
            function()
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me,
                    speaker_002,
                    speaker_003
                )
                Sleep(6.0)
            end,
            Valid = function()
                return not GetFlag(inDungeon)
            end
        }

        nodes.Fallback = Action{
            function()
                Sleep(6.0)
            end
        }

    end

}