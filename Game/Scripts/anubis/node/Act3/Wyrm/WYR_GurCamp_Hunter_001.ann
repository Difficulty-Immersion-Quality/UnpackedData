game.states.WYR_GurCamp_Hunter_001 = State {

    function()

        modules = { "shared.dialog" }

        local repeatedAD = Dialog("WYR_GurCamp_AD_GroupDialogBetweenHunters_890146c7-e040-2b23-4052-1837b3a7c92f")
        local speaker_002 = Entity("S_WYR_GurCamp_Hunter_003_8948bd61-52a0-41a0-99b8-bb6d4c301255")
        local speaker_003 = Entity("S_WYR_GurCamp_Hunter_006_4c42f14a-c99a-4ba0-891c-136bf7ed38bb")
        local inDungeon = Flag("LOW_GurFollowUp_State_InDungeon_1f27517e-bbdf-4b45-8ab4-2c612650311e")

        nodes.Talk = Action{
            function()
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me,
                    speaker_002,
                    speaker_003
                )
                Sleep(6.0)
            end,
            Valid = function()
                return not GetFlag(inDungeon)
            end
        }

        nodes.Fallback = Action{
            function()
                Sleep(6.0)
            end
        }

    end

}