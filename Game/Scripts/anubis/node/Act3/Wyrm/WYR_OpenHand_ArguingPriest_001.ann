game.states.WYR_OpenHand_ArguingPriest = State {

    function()

        modules = { "shared.dialog" }

        local repeatedAD = Dialog("WYR_OpenHand_AD_ArguingPriests_2d88140f-2919-b10c-0f94-1327570f97a9")
        local partner = Entity("S_WYR_OpenHand_ArguingPriest_002_888f7b75-bae2-487b-a631-aad7be93a29b")

        nodes.Talk = Action{
            function()
                mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me,
                    partner
                )
				Sleep(6.0)
            end
        }

        nodes.Fallback = Action{
            function()
                Sleep(6.0)
            end
        }

    end
}