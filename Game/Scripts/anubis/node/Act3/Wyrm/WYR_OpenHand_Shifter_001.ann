game.states.WYR_OpenHand_Shifter_001 = State{function()    

    modules = {"shared.dialog"}
    
    local defaultAD = Dialog("WYR_OpenHand_AD_ShiftersIdle_0adce919-609a-c03e-177a-1b61366a9ee3")
    local shifter002 = Entity("S_WYR_OpenHand_Shifter_002_076ff51e-5710-409e-b1d3-a4b0dcec1e4f")
    local shifter003 = Entity("S_WYR_OpenHand_Shifter_003_83bbacf9-5395-4420-b5de-5a112d598840")
    
    nodes.DefaultAD = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    defaultAD,
                    {
                        waitForCompletion = true,
                        minDelay = 6.0,
                    },
                    me,
                    shifter002,
                    shifter003
                )            
        end,

    }

    nodes.Fallback = Action {
        function()
            Sleep(6.0)
        end
    }

end}