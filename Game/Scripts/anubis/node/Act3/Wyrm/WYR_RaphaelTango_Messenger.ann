game.states.WYR_RaphaelTango_Messenger = State{function ()

    modules = { "gustav.Act1.Underdark" }
    -----------------------------------------
    -- Params

    -----------------------------------------
    -- Local variables

    -----------------------------------------
    -- State nodes

    self.Valid = function()
        return true
    end
    -----------------------------------------
    -- Nodes

    nodes.Action_Gaze = Action{
        function()
            local Character = mod.Underdark.FindClosestActiveCharacter(me.Position,10.0,true)
            if Character ~= nil then
                SteerTo(Character)                       
                
            end
        end
    }

    -----------------------------------------
    -- Events

end}