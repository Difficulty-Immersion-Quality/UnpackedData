game.states.WYR_Sleeper = State{function ()

    description = [[Behaviour for the character that has a fallback behaviour when we interrupt the sleeping (sitting)]]

    params.seat = {type = EParamType.String, required=false, help=[[
        Item to lie on
    ]]}

    params.wokeUpIdle = { type = EParamType.State, required = true, help = [[
        Idle after waking up.
    ]]}

    local stopSitting = false

    nodes.Sit = Proxy {
        game.states.Sit,
        params = {
            seat = params.seat
        },
        CanEnter = function()
            return not stopSitting
        end
    }

    nodes.Idle =  Proxy {
        params.wokeUpIdle
    }

    events.EntityEvent = function(e)
        if(e.TargetEntity == me) then
            if e.Event == "GLO_Sit_ManualInterrupt" then
                stopSitting = true
            end
        end
    end
end}