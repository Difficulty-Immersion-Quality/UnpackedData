game.states.WYR_Smugglers_Trap_Blast = State{function()

    modules = { "shared.math" }

    params.spell = { type=EParamType.String, required = true }

    params.trigger = { type=EParamType.String, required = true }

    local trigger = Entity(params.trigger)

    helpers.Shoot = function(spell, target)
        ShootZone(spell, me, ls.math.Vector3(0, 0, 0), me.ForwardDirection)
    end

    self.OnInit = function()
    end

    nodes.Default = Action{
        function()
            WaitForInterrupt()
        end
    }


    events.EnteredTrigger = function(ev)
        if ev.Trigger == trigger and ev.Trigger.Trigger.IsEventTrigger and ev.Trigger.Trigger.EnterEvent == "Trap_Activate" then
            helpers.Shoot(params.spell, me)
        end
    end

    events.AttemptedDisarm = function(ev)
        if ev.Trap == me and ev.Success == true then
            SetCanInteract(me.Item, false)
            --Die(me, DeathType.DOT, ev.Disarmer, false, true)
        end
    end
end}
