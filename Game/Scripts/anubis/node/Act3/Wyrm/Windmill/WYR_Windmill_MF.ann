game.states.WYR_Windmill_MF = State {
    function()

        modules = { "shared.dialog" }

        local windmillBasementTrigger = [[S_WYR_Windmill_Point_MF_a466e578-63a1-4692-a22c-810b3f112b8a]]
        local mindflayerHuntsFlag = Flag([[WYR_Windmill_State_MindflayerHunts_52f1c3c5-a312-b0ae-c3a6-25785b0ad7d1]])
        local windmillFrontTrigger = [[S_WYR_Windmill_Point_Front_9616c2dc-0ea7-4068-8399-ab9ee4b5e92c]]
        local mindflayerFedFlag = Flag([[WYR_Windmill_State_MindflayerFedAndGone_562bd3e4-b70f-4107-b8f7-b171f7ee42c5]])
        local houseTrigger = [[S_LOW_WindmillMindflayerFollowup_MF_Spot_91ea4881-9165-4efb-bdee-1c21c95544d6]]

        nodes.StandAtBasement = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = windmillBasementTrigger
            },
            CanEnter = function()
                return not GetFlag(mindflayerHuntsFlag) and not GetFlag(mindflayerFedFlag)
            end
        }

        nodes.StandAtWindmill = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = windmillFrontTrigger
            },
            CanEnter = function()
                return GetFlag(mindflayerHuntsFlag) and not GetFlag(mindflayerFedFlag)
            end
        }

        nodes.StandAtHouse = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = houseTrigger
            },
            CanEnter = function()
                return GetFlag(mindflayerFedFlag)
            end
        }
    end
}