game.states.WYR_Florrick = State{function()

    description = [[Behavior of Florrick in Wyrm Rock prison]]

    local cellZone = Entity("S_WYR_WyrmRockPrison_FlorricksCell_db3096d9-3177-4245-93a6-f01c8bb6889f")

    nodes.InCell = Proxy{
        CanEnter = function()
            return IsInTrigger(me, cellZone.Trigger)
        end,

        game.states.GLO_StandAtTrigger,
        params = {
            trigger = "S_WYR_WyrmRockPrison_FlorrickDefaultPos_3f08f866-66e5-4fce-9113-8ed8bd2e2207",
        }
    }

    nodes.OutOfCell = Action{
        function()
            Sleep(1.0)
        end
    }

end}