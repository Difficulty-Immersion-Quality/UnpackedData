game.states.WYR_Fortress_FlamingFist001_Vignette = State{function()
    description = [[State for a flaming fist inside Wyrm's rock main hallway.
        Is supposed to be a vingette character, but has to participate in Battle Stations, hence the complications of its Anubis.
        Pure Vignette characters do not go back to their trigger positions if they moved away.
        This script does that.]]

    params.ADState = { type=EParamType.State, required = false, default = nil, help=[[AD State.]] }
    params.trigger = {type = EParamType.String, help=[[
        The trigger at which the character stands.
    ]]}

    local trigger = Entity(params.trigger)

    nodes.ADState = Proxy{
        Valid = function()
            return GetDistanceTo(me, trigger) <= 1.1
        end,

        params.ADState
    }

    nodes.MoveToPoint = Proxy{
        Valid = function()
            return GetDistanceTo(me, trigger) > 1.0
        end,

        game.states.GLO_StandAtTrigger,
        params = {
            trigger = params.trigger,
        }
    }
end}