game.states.WYR_KillDirectorGortash_CoronationWitness_Stand = State {

    function()

        params.beforeCeremonyPos = {
            type = EParamType.String,
            required = true,
        }

        params.afterCeremonyPos = {
            type = EParamType.String,
            required = true,
        }

        local afterCeremony = Flag("WYR_KillDirectorGortash_State_AfterCeremony_a05a6945-21ad-400d-80bc-7b4934571c57")

        nodes.AfterCeremony = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.afterCeremonyPos
            },
            Valid = function()
                return GetFlag(afterCeremony)
            end
        }

        nodes.BeforeCeremony = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.beforeCeremonyPos
            }
        }

    end
}