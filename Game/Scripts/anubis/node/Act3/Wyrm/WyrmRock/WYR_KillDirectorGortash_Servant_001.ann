game.states.WYR_KillDirectorGortash_Servant_001 = State{

    function()

        modules = { "shared.math" }

        local cleaningPos = Entity("S_WYR_KillDirectorGortash_Servant_001_CleaningTablePos_07fff651-a462-4158-aaa1-4cecc2c5a005")
        local inspectingPos = Entity("S_WYR_KillDirectorGortash_Servant_001_InspectingTable_b5b596fe-32fb-45a5-a299-e278a7ee1797")
        local writingPos = Entity("S_WYR_KillDirectorGortash_Servant_001_Writing_4c01f472-64a2-43e9-bcb9-da27f9bef448")

        local cleaningAnim = Animation("CUST_CleaningTable_01_e868c41d-6ff9-41c4-8b48-4d06708f735e")
        local inspectingAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
        local writingAnim = Animation("CUST_Writing_01_98fe16cb-1bbe-4046-bede-5d2336962b63")


        nodes.AfterCeremony = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
        }

        nodes.AfterCeremony.Cleaning = Action {
            function()
                if GetDistance2DTo(me, cleaningPos) > 0.5 then
                    local moveResult = MoveTo(cleaningPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(cleaningPos)
                        PlayAnimation(cleaningAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.AfterCeremony.Inspecting = Action {
            function()
                if GetDistance2DTo(me, inspectingPos) > 0.5 then
                    local moveResult = MoveTo(inspectingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(inspectingPos)
                        PlayAnimation(inspectingAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.AfterCeremony.Organizing = Action {
            function()
                if GetDistance2DTo(me, writingPos) > 0.5 then
                    local moveResult = MoveTo(writingPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(writingPos)
                        PlayAnimation(writingAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

    end
}