game.states.WYR_KillDirectorGortash_Servant_002 = State{

    function()

        modules = { "shared.math" }

        local pos_001 = Entity("S_WYR_KillDirectorGortash_Servant_002_AfterCeremonyPos_001_cf4f8536-9502-4d2a-a3f5-101f8894b25b")
        local pos_002 = Entity("S_WYR_KillDirectorGortash_Servant_002_AfterCeremonyPos_002_96ef0b34-bb67-4d7b-b64b-f6b09f58dc6c")
        local pos_003 = Entity("S_WYR_KillDirectorGortash_Servant_002_AfterCeremonyPos_003_02bcc8a5-bffe-4a76-8215-a19e747a41f8")

        local inspectingAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
        local organizingAnim = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")

        nodes.AfterCeremony = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
        }

        nodes.AfterCeremony.MoveToPos_001 = Action {
            function()
                if GetDistance2DTo(me, pos_001) > 1.0 then
                    local moveResult = MoveTo(pos_001, MovementSpeed.Walk, false, false, 0.5, 1.0, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(pos_001)
                        PlayAnimation(organizingAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.AfterCeremony.MoveToPos_002 = Action {
            function()
                if GetDistance2DTo(me, pos_002) > 1.0 then
                    local moveResult = MoveTo(pos_002, MovementSpeed.Walk, false, false, 0.5, 1.0, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(pos_002)
                        PlayAnimation(inspectingAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.AfterCeremony.MoveToPos_003 = Action {
            function()
                if GetDistance2DTo(me, pos_003) > 1.0 then
                    local moveResult = MoveTo(pos_003, MovementSpeed.Walk, false, false, 0.5, 1.0, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(pos_003)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

    end
}