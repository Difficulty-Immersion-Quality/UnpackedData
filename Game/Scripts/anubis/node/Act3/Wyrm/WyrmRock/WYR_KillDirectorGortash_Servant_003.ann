game.states.WYR_KillDirectorGortash_Servant_003 = State{

    function()

        modules = { "shared.math" }

        local pos_001 = Entity("S_WYR_KillDirectorGortash_Servant_003_AfterCeremonyPos_001_c9c6883e-627b-420c-bc5c-0e6172ed7718")
        local pos_002 = Entity("S_WYR_KillDirectorGortash_Servant_003_AfterCeremonyPos_002_f1723f92-872d-4b20-a2b3-dfd787640ff9")
        local pos_003 = Entity("S_WYR_KillDirectorGortash_Servant_003_AfterCeremonyPos_003_712ea817-fbd3-49fe-ab67-457a3ed5e91d")

        local inspectingAnim = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
        local organizingAnim = Animation("CUST_Organizing_01_0e82e372-b47d-4d62-933b-068725cdfd06")

        nodes.AfterCeremony = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
        }

        nodes.AfterCeremony.MoveToPos_001 = Action {
            function()
                if GetDistance2DTo(me, pos_001) > 0.5 then
                    local moveResult = MoveTo(pos_001, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(pos_001)
                        PlayAnimation(organizingAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.AfterCeremony.MoveToPos_002 = Action {
            function()
                if GetDistance2DTo(me, pos_002) > 0.5 then
                    local moveResult = MoveTo(pos_002, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(pos_002)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.AfterCeremony.MoveToPos_003 = Action {
            function()
                if GetDistance2DTo(me, pos_003) > 0.5 then
                    local moveResult = MoveTo(pos_003, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(pos_003)
                        PlayAnimation(inspectingAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

    end
}