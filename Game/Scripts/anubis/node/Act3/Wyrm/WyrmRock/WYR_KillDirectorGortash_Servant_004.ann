game.states.WYR_KillDirectorGortash_Servant_004 = State{

    function()

        modules = { "shared.math" }

        local beforeCeremonyPos = Entity("S_WYR_KillDirectorGortash_Servant_004_DefaultPos_68f96960-3988-4a86-9bb5-f7eb2927a5a1")
        local posGortashArchDuke = Entity("S_WYR_KillDirectorGortash_Servant_004_AfterCeremonyPos_43274139-4143-4fb3-9d55-55c6bf637ccc")

        local boredAnim_001 = Animation("CUST_Bored_01_23588ba8-fafb-438c-9bc5-660ff6650aef")
        local boredAnim_002 = Animation("CUST_Bored_02_7892cb3b-2935-4aa3-b65c-64d9664cbe75")
        local lookingAroundAnim = Animation("CUST_LookingAround_63bcacef-5631-4ab3-9400-81b23cb18ca7")

        local boredPos_001 = Entity("S_WYR_KillDirectorGortash_Servant_004_BoredPos_001_68f96960-3988-4a86-9bb5-f7eb2927a5a1")
        local boredPos_002 = Entity("S_WYR_KillDirectorGortash_Servant_004_BoredPos_002_4ca3e267-416b-4a99-ad99-391327a3bc13")
        local lookingAroundPos = Entity("S_WYR_KillDirectorGortash_Servant_004_LookingAroundPos_78b3500f-87fc-4b1e-a012-fe0e0413f71e")

        local archDukeFlag = Flag("WYR_KillDirectorGortash_State_GortashBecameArchduke_b91a5012-d49b-429d-9b86-b75686fa7582")

        nodes.AfterCeremony = Action {
            function()
                if GetDistance2DTo(me, posGortashArchDuke) > 1.5 then
                    local moveResult = MoveTo(posGortashArchDuke, MovementSpeed.Walk, false, false, 0.5, 1.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(posGortashArchDuke)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end,
            Valid = function()
                return GetFlag(archDukeFlag)
            end
        }

        nodes.BeforeCeremony = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
            Valid = function()
                return not GetFlag(archDukeFlag)
            end
        }

        nodes.BeforeCeremony.Bored_001 = Action {
            function()
                if GetDistance2DTo(me, boredPos_001) > 0.5 then
                    local moveResult = MoveTo(boredPos_001, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(boredPos_001)
                        PlayAnimation(boredAnim_001, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.BeforeCeremony.Bored_002 = Action {
            function()
                if GetDistance2DTo(me, boredPos_002) > 0.5 then
                    local moveResult = MoveTo(boredPos_002, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(boredPos_002)
                        PlayAnimation(boredAnim_002, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.BeforeCeremony.LookingAround = Action {
            function()
                if GetDistance2DTo(me, lookingAroundPos) > 0.5 then
                    local moveResult = MoveTo(lookingAroundPos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(lookingAroundPos)
                        PlayAnimation(lookingAroundAnim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

    end
}