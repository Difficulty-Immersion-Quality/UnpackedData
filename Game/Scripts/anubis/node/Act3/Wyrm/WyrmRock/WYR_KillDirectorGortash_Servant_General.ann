game.states.WYR_KillDirectorGortash_Servant_General = State{

    function()

        params.afterCeremonyBehavior = {   type = EParamType.State, required = false, default = nil, help = [[Custom Behavior state for a servant]] }

        nodes.AfterCeremony = Proxy {
            params.afterCeremonyBehavior
        }

        nodes.Fallback = Action {
            function()
                Sleep(6.0)
            end
        }

    end
}