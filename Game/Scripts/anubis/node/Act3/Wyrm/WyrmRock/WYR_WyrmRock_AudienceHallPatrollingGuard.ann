game.states.WYR_WyrmRock_AudienceHallPatrollingGuard = State{

    function()

        params.patrolSpline = {
            type = EParamType.String,
            required = true,
        }

        params.ceremonyPos = {
            type = EParamType.String,
            required = true,
        }

        local steelWatchersDisabled = Flag("GLO_Foundry_State_ControlCentreDestroyed_456906c5-40a6-429e-8e1c-7120a2ef631b")
        local ceremonyEnded = Flag("WYR_KillDirectorGortash_State_CeremonyEnded_9aeab401-c087-4f2e-9894-859df23680dc")

        -- If Steel Watchers are Disabled and Ceremony is in progress - guard the ceremony area
        nodes.StandAtCeremony = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.ceremonyPos
            },
            Valid = function()
                return GetFlag(steelWatchersDisabled) and not GetFlag(ceremonyEnded)
            end
        }

        -- otherwise - patrol the area
        nodes.Patrol = Proxy{
            game.states.GEN_Patrol,
            params = {
                patrolSpline = params.patrolSpline
            }
        }

    end
}
