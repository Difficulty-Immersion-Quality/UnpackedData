game.states.WYR_WyrmRock_AudienceHallStandingGuard = State{

    function()

        params.defaultPos = {
            type = EParamType.String,
            required = true,
        }

        params.ceremonyPos = {
            type = EParamType.String,
            required = true,
        }

        local steelWatchersDisabled = Flag("GLO_Foundry_State_ControlCentreDestroyed_456906c5-40a6-429e-8e1c-7120a2ef631b")

        -- If Steel Watchers are Active - guard one of the entrances
        nodes.StandAtEntrance = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.defaultPos
            },
            Valid = function()
                return not GetFlag(steelWatchersDisabled)
            end
        }

        -- otherwise - guard the ceremony area
        nodes.StandAtCeremony = Proxy {
            game.states.GLO_StandAtTrigger,
            params = {
                trigger = params.ceremonyPos
            }
        }

    end
}
