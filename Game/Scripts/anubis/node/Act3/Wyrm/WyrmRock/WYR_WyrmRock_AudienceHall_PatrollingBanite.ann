game.states.WYR_WyrmRock_AudienceHall_PatrollingBanite = State{

    function()

        params.patrolSpline = {
            type = EParamType.String,
            required = true,
        }

        nodes.Patrol = Proxy{
            game.states.GEN_Patrol,
            params = {
                patrolSpline = params.patrolSpline,
                patrolSpeed = "Stroll",
            }
        }

    end
}
