game.states.WYR_WyrmRock_FFOfficeGuard_001 = State{

    function()

        modules = { "shared.math" }

        local think_anim = Animation("CUST_Pondering_01_c2a68c82-1b0b-4d0c-8f1a-c9f14984a5fb")
        local think_pos = Entity("S_WYR_WyrmRock_FFOfficeGuard_001_ThinkPos_277aedc8-4a50-4fbd-bcd4-262f570fc10c")

        local inspect_anim = Animation("CUST_InspectWork_01_c3ade1d7-2469-4f1f-b8c4-4848e40c9ffc")
        local inspect_pos = Entity("S_WYR_WyrmRock_FFOfficeGuard_001_InspectPos_6206da71-6955-4252-a2ed-2f9d18914cb5")

        local drink_anim = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")
        local drink_pos = Entity("S_WYR_WyrmRock_FFOfficeGuard_001_DrinkPos_3909b98e-11a7-4e26-988d-c11c413a5107")

        nodes.Default = Selector {
            function(nodes)
                return FindDifferentRandomSelectable(nodes)
            end,
        }

        nodes.Default.Think = Action {
            function()
                if GetDistance2DTo(me, think_pos) > 0.5 then
                    local moveResult = MoveTo(think_pos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(think_pos)
                        PlayAnimation(think_anim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.Default.Inspect = Action {
            function()
                if GetDistance2DTo(me, inspect_pos) > 0.5 then
                    local moveResult = MoveTo(inspect_pos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(inspect_pos)
                        PlayAnimation(inspect_anim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.Default.Drink = Action {
            function()
                if GetDistance2DTo(me, drink_pos) > 0.5 then
                    local moveResult = MoveTo(drink_pos, MovementSpeed.Walk, false, false, 0.1, 0.5, false)
                    if moveResult == error.MovementError.None then
                        LookFrom(drink_pos)
                        PlayAnimation(drink_anim, true)
                    end
                end
                Sleep(math.random(3.0, 9.0))
            end
        }

        nodes.Default.Wander = Proxy {
            game.states.GEN_Wander,
            params = {
                trigger = [[S_WYR_WyrmRock_FFOfficeGuard_001_WanderArea_9fd77efb-db71-4a80-844b-048ed1884468]],
                wanderMin = 6,
                wanderMax = 9,
                sleepMin = 3,
                sleepMax = 9},
        }

    end
}