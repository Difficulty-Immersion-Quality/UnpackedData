game.states.WYR_WyrmRock_FFOfficeGuard_002 = State{

    function()

        modules = { "shared.math" }

        local writing_behavior = Dialog("BHVR_WRLD_SitAndWrite_HUM_F_9bb11294-0627-cf49-8099-d9f859034a46")
        local writing_trigger = Entity("S_WYR_WyrmRock_FFOfficeChair_Zone_002_61178181-ada5-490d-9091-e7e30d00d300")
        local writing_chair = Entity("S_WYR_WyrmRock_FFOfficeChair_002_2dde8a28-5953-419b-aa4d-e0ee3f26c379")

        local writing_blockbehavior_flag = Flag("WYR_WyrmRock_State_FFOfficeGuard_002_BlockBehavior_ecde4ddf-3873-4e41-b554-bfe44218865a")

        nodes.Default = Selector {
            function(nodes)
                if GetFlag(writing_blockbehavior_flag) then
                    return nodes.Wait
                else
                    return FindDifferentRandomSelectable(nodes)
                end
            end,
        }

        nodes.Default.Write = Action {
            function()
                try
                    StartBehaviorDialog(writing_behavior, writing_trigger.Trigger, true, me, writing_chair)
                    Sleep(math.random(3.0, 9.0))
                catch e then
                    DebugLog("WYR_WyrmRock_FFOfficeGuard_002: "..tostring(e))
                    WaitForInterrupt()
                end  
            end
        }

        nodes.Default.Wait = Action {
            function()
                Sleep(math.random(3.0, 9.0))
            end
        }

    end
}