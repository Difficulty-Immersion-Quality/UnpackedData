game.states.WYR_WyrmRock_MessHallBodyguard_EatingAndDrinking = State {

    function()

        modules = { "shared.util" }

        local drinkingAnimation = Animation("CUST_Drinking_01_fab141d9-e068-4f2e-ba44-699b6d9b3636")

        nodes.StandAtDefaultPos = Action {
            function()
                mod.util.SleepRandom(3.0, 9.0)
                PlayAnimation(drinkingAnimation, true)
            end
        }

    end

}