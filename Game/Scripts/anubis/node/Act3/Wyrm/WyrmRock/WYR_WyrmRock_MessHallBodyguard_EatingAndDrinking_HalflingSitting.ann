        local seat = Entity("S_WYR_WyrmRock_MessHallBench_004_de7563e8-8155-46de-a114-6e9e5ea3ca6b")

        nodes.Default = Action {
            function()
                Sleep(2.0)
                StartBehaviorDialog(drinkingDialog, nil, true, me, seat)
                Sleep(5.0 + 8.0 * math.random())
            end
        }

    end

}