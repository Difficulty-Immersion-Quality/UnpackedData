game.states.WYR_WyrmRock_Quartermaster = State{function()

    modules = {"shared.dialog"}

    local AD = Dialog("WYR_WyrmRock_AD_Quartermaster_37e1f7a7-3be1-ece0-88a9-36a80d3a30dd")

    nodes.Talking = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                AD,
                {
                    waitForCompletion = true,
                    minDelay = 8.0,
                },
                me
            )
        end,
    }

    nodes.Fallback = Action{
        function()
            Sleep(6.0)
        end
    }
end
}
