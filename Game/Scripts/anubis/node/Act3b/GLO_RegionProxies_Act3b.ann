game.states.GLO_RegionProxies_Act3b = State { function ()

    local inCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")

    description = [[Contains a proxy for each region in Act3b. To be used on global entities in this Act only.]]

    params.CAMP = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in the campsite.]]
    }
    params.LOW = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only on the Lower City.]]
    }
    params.act3b = { type = EParamType.State,
        required = false, default = nil,
        help = [[State to be active only in CTY_Main_A.]]
    }

    nodes = ImmediateSelector {}

    nodes.CAMP = Proxy {
        params.CAMP,
        Valid = function()
            return GetFlag(inCamp,me)
        end
    }

    nodes.Act3b = ImmediateSelector {
        Valid = function(node)
            return CheckCurrentGameLevel("CTY_Main_A") and CheckAnySelectable(node)
        end
    }
    nodes.Act3b.LOW = Proxy {
        params.LOW
    }
    nodes.Act3b.Main = Proxy {
        params.act3b
    }

    nodes.Fallback = Action {
        function()
            WaitForInterrupt()
        end
    }
end}