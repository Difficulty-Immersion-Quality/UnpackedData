game.states.LOW_SteelWatchFoundry_BaneiteOfficer_PostIRN01 = State{function()
    description = [[BaneiteOfficer_PostIRN01's (baneite officer that appears after the Iron throne is destroyed) behaviours]]
    modules = {"shared.dialog", "shared.util"}

    ------------------------------------------------
    -- Params

    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables

    ------------------------------------------------ 
    local ironThroneDestroyed = Flag("IRN_IronThrone_State_Destroyed_91795368-af06-4b56-9ac1-b78995aa9ea9")
    local ad = Dialog("LOW_SteelWatchFoundry_AD_BeforeConfrontation_eed396fc-e6e5-46f1-9b62-4667f115fddb")
    local toobin = Entity("S_LOW_GondianWorker08_Leader_3607ec31-f939-41aa-a7d2-e32f8c46979d")
    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    -- While he is working in the office he walks around and speakd ADs
    nodes.Action_TalkingWithToobin = Action
    {
        function ()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                ad,
                    {                        
                        minDelay = math.random(5.0, 10.0),
                        cullingDistance = 20.0,
                        waitForCompletion = false
                    },
                    me, toobin)            
        end,

        Valid = function()
            return GetFlag(ironThroneDestroyed)
        end
    }



    -- Action - fallback
    nodes.Action_Fallback = Action{
        function()
            WaitForInterrupt()
        end,
    }
end}