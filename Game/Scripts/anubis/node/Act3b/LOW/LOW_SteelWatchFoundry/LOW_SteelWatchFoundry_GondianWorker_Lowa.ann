game.states.LOW_SteelWatchFoundry_GondianWorker_Lowa = State{function()
    description = [[Gondian Worker Lowa's behaviours]]
    modules = {"shared.dialog", "shared.util"}

    ------------------------------------------------
    -- Params

    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables

    --Status flags
    local postIRNWorkroomBaneitesDead = Flag("LOW_SteelWatchFoundry_State_PostIRNWorkroomBaneitesDefeated_1c0a4b23-9bc2-4d25-9c89-c066ee42f6c7")
    local working = Flag("LOW_SteelWatchFoundry_State_LowaWorking_2194447d-7b32-44c3-a760-2afcb95e26de")
    local doAlternateWork = Flag("LOW_SteelWatchFoundry_State_AlternateWorkBehaviour_1cbf2ff3-53d9-48bb-b634-5d9c259b8056")
    local ironThroneDestroyed = Flag("IRN_IronThrone_State_Destroyed_91795368-af06-4b56-9ac1-b78995aa9ea9")

    --working
    params.workPositions = {type = EParamType.String, arrayRange = "1..", required = false, default = nil, help=[[Positions to work at.]]}
    params.workAD = {type = EParamType.String, required = false, default = nil, help = [[AD to play while working]]}
    params.alternateWorkAD = {type = EParamType.String, required = false, default = nil, help = [[alternate AD to play while working]]}
    params.workAnimations = {type = EParamType.String, arrayRange = "1..", required = false, default = nil, help=[[Work animations to play.]]}
    params.workTargets = {type = EParamType.String, arrayRange = "1..", required = false, default = nil, help=[[Things to look at while working (match the index of positions)]]}
    params.workBhvrs = {type = EParamType.String, arrayRange = "1..", required = false, default = nil, help=[[Work world behaviours to play (match the index of positions).]]}
    params.isWrldBhvr = {type = EParamType.Bool, arrayRange = "1..", required = false, default = nil, help=[[Set to true if the animation is a World Behaviour.]]}

    --player murdered Baneites
    local panicAD = Dialog(params.alternateWorkAD)
    local deadBaneite = Entity("S_LOW_BaneiteOfficer02_de084b09-99c6-426e-9159-f692d180d418")

    --Back-and-forth with Baneite
    local arguingAD = Dialog("LOW_SteelWatchFoundry_AD_BeforeWorkroomEncounter_82be1ba8-c32a-d750-81d0-1b0d8f666955")
    local baneite = Entity("S_LOW_BaneiteOfficer02_de084b09-99c6-426e-9159-f692d180d418")
    
    --BeggingforLife
    params.beggingAnimation = {type = EParamType.String, required = false, default = nil, help=[[Begging animation]]}
    local beggingAnimation = Animation("CUST_Begging_01_ea750351-2f98-473c-9890-918abd808c73") 
    params.beggingTarget = {type = EParamType.String, required = false, default = nil, help = [[The Baneite to beg towards.]]}
    local beggingTarget
    local liberated = Flag("LOW_SteelWatchFoundry_State_WorkerLiberated_32da4560-217f-41d3-b5bb-526e2665a83d")
    
    --Liberated
    local escapeLocation = Entity("S_LOW_GenericGondianEscapeLocation_f4dfa967-c92b-400b-a0d1-af50dc4aa3fd")
    
    local ignoreDangerousSurfacesTag = Tag("IGNORE_DANGEROUS_SURFACES_bbf62461-4af4-4631-807a-eb0bd988d9a6")

    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes
    self.OnInit = function()
        --beggingAnimation = Animation(params.beggingAnimation)
        beggingTarget = FindEntity(params.beggingTarget)
        --panicAD = Dialog(params.alternateWorkAD)
    end

    --arguing with Overseer
    nodes.Arguing = Action
    {
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                arguingAD,
                    {                        
                        minDelay = math.random(20.0, 30.0),
                        cullingDistance = 20.0,
                        waitForCompletion = true
                    },
                    baneite,
                    me)
                    Sleep(3.0)
        end,
        Valid = function()
            return (not GetFlag(ironThroneDestroyed))
            and (not GetFlag(working))
        end
    }

    --Default Working
    nodes.Work = Proxy{
        game.states.LOW_SteelWatchFoundry_GondianWorking,
        params = {
            workPositions = params.workPositions,
            workAD = params.workAD,
            workAnimations = params.workAnimations,
            workTargets = params.workTargets,
            workBhvrs = params.workBhvrs,
            isWrldBhvr = params.isWrldBhvr
        },
    
        Valid = function()
            return (not GetFlag(ironThroneDestroyed))
            and not (GetFlag (doAlternateWork, me))
        end
    }

    --Simple behaviour if the doAlternateWork flag is set on this gondian - this plays after the player kills the Baneites in the workroom - the gondians walk around palying panicing ADs
    nodes.Action_MurderPanic = Action{
        function()
            DebugText(me,"playing panic AD")
            mod.util.SleepRandom(0.1,2.0)
            if panicAD ~= nil and panicAD ~= "" then
                StartAutomatedDialog(panicAD, false,me)
            end
            if GetDistanceTo(deadBaneite,me)>10.0 then
                try
                    MoveTo(deadBaneite, MovementSpeed.Run, true, true, 0.1, 0.5, false)
                catch e if ls.CheckType(e, error.MovementFailed) then
                    SteerTo(deadBaneite)
                    Sleep(2.0)
                end
            else
                local wanderAnchor = deadBaneite.Position
                Wander(10.0, 3.0, MovementSpeed.Stroll, deadBaneite)
            end
            SteerTo(deadBaneite)
            Sleep(5.0)
        end,
    
        Valid = function()
            return (not GetFlag(ironThroneDestroyed))
            and GetFlag (doAlternateWork, me)
        end
    }

    --begging behaviour after the player returns from IRN
    nodes.Action_BeggingForLife = Action
    {
        function ()
            LookAtEntity(beggingTarget, 5.0)
            PlayAnimation(beggingAnimation,false, true)
            Sleep(5.0)
        end,

        OnLeave = function()
            StopAnimation(me)
        end,

        Valid = function()
            return GetFlag(ironThroneDestroyed)
            and (not GetFlag(liberated, me))
        end
    }

    --actions after the palyer frees her
    nodes.Action_Liberated = Action 
    {
        function ()
            mod.util.SleepRandom(5.0,20.0)
            if not IsInDangerousSurfaceFor(escapeLocation, me.Character) or IsTagged(me, ignoreDangerousSurfacesTag) then
                if GetDistanceTo(me, escapeLocation) > 0.5 then
                    try
                        MoveTo(escapeLocation, MovementSpeed.Run, true, true, 0.1, 0.5, false)
                    catch e if ls.CheckType(e, error.MovementFailed) then
                        SteerTo(escapeLocation)
                        Sleep(2.0)
                    end
                else
                    LookFrom(escapeLocation)
                end
            else
                SteerTo(escapeLocation)
            end
            Sleep(2.0)
        end,
        Valid = function()
            return GetFlag(ironThroneDestroyed)
            and GetFlag(liberated, me)
        end
    }

    -- Action - fallback
    nodes.Action_Fallback = Action{
        function()
            WaitForInterrupt()
        end,
    }

    events.SavegameLoaded = function(ev)
        beggingAnimation = Animation("CUST_Begging_01_ea750351-2f98-473c-9890-918abd808c73")
    end
end}