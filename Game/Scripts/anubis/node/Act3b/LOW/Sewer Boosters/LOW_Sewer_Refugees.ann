game.states.LOW_Sewer_Refugees = State{
    function()

    modules = {"shared.math", "shared.dialog", "shared.util"}
    description = [[Behaviour of the Refugess in the Sewers, getting shot at by Bhaal cultists.]]

    params.AD = {type = EParamType.String, required = false, default = nil, help = [[AD that may be played after shooting]]}


    local cultistsDead = Flag("LOW_Sewer_State_BaahlShootersDefeated_deb6b4eb-4b04-40c3-9749-e42003d77b88")
    local shouldSpeak = Flag("LOW_Sewer_State_ShootingPracticeAD_ShouldSpeak_c7b48cbd-77a9-4a42-818b-bd1db1ee44fe")
    local AD = Dialog(params.AD)

    self.OnInit = function()
        mod.util.SleepRandom(0.0, 0.5)
        ApplyStatus(me, "ANIM_COWER")
    end

    nodes.Cowering = Action{
        function()
            if GetFlag(shouldSpeak, me) and AD ~= nil then
                StartAutomatedDialog(AD, true, me)
            end
            ClearFlag(shouldSpeak, me)

            mod.util.SleepRandom(1.5,4.0)
        end,

        Valid = function()
            return not GetFlag(cultistsDead)
        end
    }

    nodes.Idle = Action{
        function()
            WaitForInterrupt()
        end
    }


end}