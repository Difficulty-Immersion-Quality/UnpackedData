game.states.LOW_CellarWaveservants_Entrance = State{function()
    description = [[Cellar waveservants at the entrance behavior]]
    modules = {"shared.dialog"}

    ------------------------------------------------
    -- Params
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    local repeatedAD = Dialog("LOW_WaterQueensHouse_AD_CellarWaveservantsChat_f641fc5a-f467-53c7-4120-8a36fb69688e")
    local secondNPC = Entity("S_LOW_CellarWaveservant02_22aaad49-98de-43a2-ab2f-c7ab9a8df922")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    -- Unless killed, the cellar waveservants at the entrance keep talking with a rate limited AD
    nodes.Action_ADLoop = Action{
        function()
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                    repeatedAD,
                    {
                        waitForCompletion = true,
                        minDelay = 12.0,
                    },
                    me,
                    secondNPC
                )
        end,

        Valid = function()
            return true
        end
    }

    ------------------------------------------------
    
    ------------------------------------------------
    -- Events
    ------------------------------------------------

end
}