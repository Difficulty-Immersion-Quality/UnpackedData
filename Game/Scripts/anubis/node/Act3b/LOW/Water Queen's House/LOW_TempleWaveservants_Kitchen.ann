game.states.LOW_TempleWaveservants_Kitchen = State{function()
    description = [[Kitchen waveservants behavior]]
    modules = {"shared.moveto"}
    ------------------------------------------------
    -- Params
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    ------------------------------------------------ 
    local standTrigger = Entity("S_LOW_KitchenWaveservant01_Stand_589274f1-ba39-4e85-b514-80fa315432bf")    
    local stand2Trigger = Entity("S_LOW_KitchenWaveservant02_Stand_b5954dbc-9ae2-47cd-a32e-80edb40896d6")
    local anim = Animation("CUST_Thinking_01_97588786-d9bf-4d18-879b-1bd3dcaa62ba")
    local anim2 = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    -- Unless killed, the kitchen waveservants keep talking with a rate limited AD
    nodes.Wait = Action{
        function()
            if mod.moveto.MoveToPoint(standTrigger, MovementSpeed.Walk, me) then
                LookFrom(standTrigger)                
                PlayAnimation(anim, true, false)
            end
            if mod.moveto.MoveToPoint(stand2Trigger, MovementSpeed.Walk, me) then
                LookFrom(stand2Trigger)                
                PlayAnimation(anim2, true, false)
            end
        end
    }

    ------------------------------------------------
    
    ------------------------------------------------
    -- Events
    ------------------------------------------------

end
}