game.states.LOW_TempleWaveservants_Kitchen02 = State{function()
    description = [[Kitchen waveservants behavior]]
    modules = {"shared.dialog", "shared.moveto"}

    ------------------------------------------------
    -- Params
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    local repeatedAD = Dialog("LOW_WaterqueensHouse_AD_KichenWaveservantsChat_68f22735-17c8-4003-012a-d513bd61fc8b")
    local firstNPC = Entity("S_LOW_KitchenWaveservant01_582e2859-3602-4243-b7ec-c7d51d9c3b4a")

    local shelfTrigger = Entity("S_LOW_KitchenWaveservant02_StudyShelf_626e9441-b919-43b3-9599-81cd6055601e")
    local shelfAnim = Animation("CUST_StudyingShelves_01_33ab0976-2071-4b53-a2c4-c5c958acb85f")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    -- Unless killed, the kitchen waveservants keep talking with a rate limited AD

    nodes.Act = Action{
        function()
            if mod.moveto.MoveToPoint(shelfTrigger, MovementSpeed.Walk, me) then
                LookFrom(shelfTrigger)
                PlayAnimation(shelfAnim, true, false)
            else
                SteerTo(shelfTrigger)
                Sleep(5)
            end
            mod.dialog.StartCheckedAutomatedDialogRateLimited(
                repeatedAD,
                {
                    waitForCompletion = true,
                    minDelay = 10.0,
                },
                firstNPC,
                me
            )
        end,
        OnEnter = function()
            SetDoNotFace(me, true)
            SetDoNotFace(firstNPC, true)
        end,
    }

    ------------------------------------------------
    
    ------------------------------------------------
    -- Events
    ------------------------------------------------

end
}