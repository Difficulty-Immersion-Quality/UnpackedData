game.states.LOW_UmberleeFollower04 = State{function()
    description = [[UmberleeFollower04 behavior]]
    modules = {"shared.moveto"}
    ------------------------------------------------
    -- Params
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    local animStart = Animation("CUST_Pondering_01_Start_2d14e6a9-d3a3-4f98-9031-22831546c392")
    local animLoop = Animation("CUST_Pondering_01_Loop_a47454a1-05a2-4153-bdfe-7a0500fa62d0")
    local animEnd = Animation("CUST_Pondering_01_End_e15cc480-7f1a-4ed4-8a3c-36355a37c644")

    local startRoutine = Flag("LOW_WaterQueensHouse_Event_TalkedToUmberleeFollower04_58c5d102-37e5-49dc-ad36-88ae359d5947")
    local offeringsChest = Entity("S_LOW_WaterQueensHouse_OfferingsChest_9f1a218c-c8ba-42da-8370-51e723052dbc")
    local finishOfferings = false

    local spotTrigger = Entity("S_LOW_UmberleeFollower04_Spot_ed4468fc-aabe-4728-8b4f-91135e697f3c")

    local waitForOfferings = Flag("LOW_VaultWaveservant_State_WaitingForOfferings_2ab70a62-99ae-4f13-8c88-b582d9d0f214")

    local offeringsGone = Flag("LOW_WaterQueensHouse_State_OfferingsAreGone_7b4a853d-fff5-4faa-82b6-2e3829eb2851")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    nodes.Action_Idle = Action{
        function()
            if mod.moveto.MoveToPoint(spotTrigger, MovementSpeed.Walk, me) then
                --PlayLoopingAnimation(animStart, {animLoop}, animEnd)
                WaitForInterrupt()
            else
                Sleep(5)
                return
            end
        end,
        -- OnInterrupt = function()
        --     StopAnimation(me, false)
        -- end,
        -- OnLeave = function()
        --     StopAnimation(me, false)
        -- end,

        Valid = function()
            return not GetFlag(startRoutine) or finishOfferings
        end
    }

    nodes.OfferingsRoutine = Action{
        function()         
            if not offeringsChest.Item.IsOpened and not offeringsChest.Item.IsLocked then          
                UseItem(offeringsChest.Item)                
                MoveAllItemsTo(me, offeringsChest, 0, 0, true)  
                Sleep(1)            
                if offeringsChest.Item.IsOpened then        
                    UseItem(offeringsChest.Item)
                end
                finishOfferings = true
                ApplyStatus(me, "BLESS", true, -1, offeringsChest)            
            else
                Sleep(5)
            end
        end,

        Valid = function()
            return GetFlag(startRoutine) and not finishOfferings and not IsInDialog(me, true) and not offeringsChest.Item.IsDestroyed and not offeringsChest.Item.IsLocked and not GetFlag(offeringsGone)
        end
    }

    nodes.Fallback = Action{
        function()
            finishOfferings = true
        end,
    }

    ------------------------------------------------
    
    ------------------------------------------------
    -- Events

    events.FlagSet = function(e)
        if e.Flag == waitForOfferings.Guid then
            SetFlag(startRoutine)
        end
    end


    ------------------------------------------------

end
}