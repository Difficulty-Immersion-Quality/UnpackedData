game.states.LOW_VaultGuardWaveservant02 = State{function()
    description = [[VaultGuardWaveservant02]]

    
    ------------------------------------------------
    -- Params
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    

    local spot1 = Entity("S_LOW_WaterQueensHouse_GuardSpot01_d06f30fe-14bb-4e1c-927d-1e027ebe013f")
    local spot2 = Entity("S_LOW_WaterQueensHouse_GuardSpot02_69ff94a7-d1ff-4dd3-adcd-93f7fee137b4")

    local anim = Animation("CUST_LookingAround_63bcacef-5631-4ab3-9400-81b23cb18ca7")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action

    nodes.Guard = Action {
        function()
            if IsInDangerousSurfaceFor(spot1, me.Character) then
                SteerTo(spot1)
                Sleep(2)
                return
            end
            local moveResult = MoveTo(spot1, MovementSpeed.Walk)
            if moveResult ~= error.MovementError.None then
                SteerTo(spot1) 
                Sleep(2)
                return
            end
            LookFrom(spot1)
            PlayLoopingAnimation(startAnim, loopAnim, endAnim)
            WaitForInterrupt()
        end,       

        OnInterrupt = function()
            StopAnimation(me)
        end,
        OnLeave = function()
            StopAnimation(me)
        end,
    }

    ------------------------------------------------
    
    ------------------------------------------------
    -- Events
    ------------------------------------------------
    

end
}