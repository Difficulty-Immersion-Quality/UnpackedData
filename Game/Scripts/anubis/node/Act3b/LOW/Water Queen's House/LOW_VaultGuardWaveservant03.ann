game.states.LOW_VaultGuardWaveservant03 = State{function()
    description = [[VaultGuardWaveservant03]]

    
    ------------------------------------------------
    -- Params
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    
    local stool = Entity("FUR_Smith_Stool_Wood_A_000_5da64ce4-da24-46f8-ab28-23fbe1bb0a9d")
    local guardSpot = Entity("S_LOW_WaterQueensHouse_GuardSpot03_6487a04f-b9a1-4b6f-8ffa-5a9018551ab0")

    local startAnim = Animation("CUST_ArmsCrossed_01_Start_dafd0bbc-012a-403c-aabe-4963aca9cf25")
    local loopAnim = { Animation("CUST_ArmsCrossed_01_Loop_e6c49668-99b1-41d6-8daa-7ed6864b4e71") }
    local endAnim = Animation("CUST_ArmsCrossed_01_End_ae43ea68-fc1b-456a-88ce-0e1d504e1d40")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action


    nodes.Guard = Action {
        function()
            if IsInDangerousSurfaceFor(guardSpot, me.Character) then
                SteerTo(guardSpot)
                Sleep(2)
                return
            end
            local moveResult = MoveTo(guardSpot, MovementSpeed.Walk)
            if moveResult ~= error.MovementError.None then
                SteerTo(guardSpot)
                Sleep(2)
                return
            end
            LookFrom(guardSpot)
            PlayLoopingAnimation(startAnim, loopAnim, endAnim)
            WaitForInterrupt()
        end,
        OnInterrupt = function()
            StopAnimation(me)
        end,
        OnLeave = function()
            StopAnimation(me, false)
        end,
    }

    ------------------------------------------------
    
    ------------------------------------------------
    -- Events
    ------------------------------------------------
    

end
}