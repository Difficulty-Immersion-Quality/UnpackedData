game.states.IRN_IronThrone_HostageAnimationLoop = State 
{
    function()
    description = [[Looping Animation for hostages]]
    modules = {"shared.dialog", "shared.util"}

    ------------------------------------------------
    -- Params

    params.LoopingAnimStart = {type = EParamType.String, required = true, help=[[
        Looping animation for character
    ]]}

    params.LoopingAnimLoop = {type = EParamType.String, required = true, help=[[
        Looping animation for character
    ]]}

    params.LoopingAnimEnd = {type = EParamType.String, required = true, help=[[
        Looping animation for character
    ]]}

    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    local startAnim = Animation(params.LoopingAnimStart)
    local loopAnim = {Animation(params.LoopingAnimLoop)}
    local endAnim = Animation(params.LoopingAnimEnd)

    local freedFlag = Flag("IRN_IronThrone_State_IndividualPrisonerFree_4c120f58-ad6c-438a-b35b-1bb3d4ed5e87")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    
    nodes.Action_HostageAnimationLoop = Action
    {
        function ()
            PlayLoopingAnimation(startAnim, loopAnim, endAnim)
            Sleep(3.0) --Not sure if needed. Some of those should loop without interruption, will check once the animations work
        end
    }
    --------------------------------

    events.EntityEvent = function(e)
        if e.TargetEntity == me and e.Event == "IRN_IronThrone_PrisonerFreed" then
            StopAnimation(me, false)
        end
    end

end
}