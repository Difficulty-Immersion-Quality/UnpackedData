game.states.LOW_IronThrone_HostageAfterReturning = State 
{
    function()
    description = [[Hostages after returning from Iron Throne]]
    modules = {"shared.dialog", "shared.util"}

    ------------------------------------------------
    -- Params

    params.InSubmersibleState = {type = EParamType.State, required = true, help=[[
        State which the character is while they are in the submersible after returning
    ]]}

    params.InBasementState = {type = EParamType.State, required = true, help=[[
        State which the character is in while in the basement, after exiting the submersible
    ]]}
    ------------------------------------------------

    ------------------------------------------------
    -- Local State variables
    local reachedBasementFlag = Flag("IRN_IronThrone_State_IndividualPrisonerReachedBasement_7afcb442-1ae5-440c-89fe-7205c27f18c6")
    local basementFinished = Flag("IRN_IronThrone_State_BasementFinished_febdf850-3d7a-45f7-b822-d713232d166d")
    ------------------------------------------------ 

    ------------------------------------------------
    -- Helper functions
    ------------------------------------------------
 
    ------------------------------------------------
    -- State (self) node functions
    ------------------------------------------------
    
    ------------------------------------------------
    -- Nodes

    -- Action
    
    -- Either sitting on chairs or looping animations ir sitting on ground

    nodes.Action_Finished = Proxy {
        game.states.Dummy,
        Valid = function ()
            return GetFlag(basementFinished)
        end
    }

    nodes.Action_InBasement = Proxy {
        params.InBasementState,
        Valid = function()
            return GetFlag(reachedBasementFlag, me)
        end
    }

    -- Combat takes over during the escape
    nodes.Action_InSubmersible = Proxy {
        params.InSubmersibleState,
        Valid = function()
            return not GetFlag(reachedBasementFlag, me)
        end
    }

    nodes.Action_Fallback = Proxy {
        game.states.Dummy,
        Valid = function()
            return true
        end
    }
    --------------------------------
end
}