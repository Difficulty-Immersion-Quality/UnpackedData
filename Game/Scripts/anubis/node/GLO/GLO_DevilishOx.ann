game.states.GLO_DevilishOx = State{function()
    description=[[Behaviours for the phasm masquerading as an OX]]
    
    ------------------------------------------------
    -- Local State variables
    ------------------------------------------------
    local idleAnim = Animation("CUST_Strange_01_7819852c-d8b9-4ec5-8e44-330814c933fc")

    ------------------------------------------------ 
    -- Actions
    ------------------------------------------------

    nodes.InStable = Action
    {
        function()
            PlayAnimation(idleAnim, false, true)
        end,

        OnInterrupt = function()
            StopAnimation(me)
        end,

        OnLeave = function()
            StopAnimation(me)
        end
    }
end}