-- Collection of states for Gale

game.states.Gale_Unrecruited = State {
    function ()
        description = [[Gale is not recruited yet]]
        local CHA_WaypointShrine_Top = Entity("S_CHA_WaypointShrine_Top_8ebd584c-97e3-42fd-b81f-80d7841ebdf3")
        local ORI_Gale_State_WasRecruited = Flag("ORI_Gale_State_WasRecruited_a56d3a51-2983-5f82-25f4-ad142948b133")
        local Avatar = Tag("AVATAR_306b9b05-1057-4770-aa17-01af21acd650")
        local CUST_InspectClose_01 = Animation("CUST_InspectClose_01_25631e14-916d-4d91-8b59-094122d78cd0")
        local CAMP_GLO_State_InCamp = Flag("CAMP_GLO_State_InCamp_161b7223-039d-4ebe-986f-1dcd9a66733f")

        nodes.AtWayPoint = Action {
            function()
                if GetDistanceTo(me, CHA_WaypointShrine_Top) > 8.5 then
                    local moveSuccess = MoveTo(CHA_WaypointShrine_Top,MovementSpeed.Stroll, false, true, 4.0, 6.0, false)
                    if moveResult ~= error.MovementError.None then
                        Sleep(3.0)
                    end
                else
                    SteerTo(CHA_WaypointShrine_Top)
                    Sleep(3.0 + 3.0*math.random())
                    PlayAnimation(CUST_InspectClose_01)
                end
            end
        }

        self.Valid = function()
            return not GetFlag(ORI_Gale_State_WasRecruited, nil) and
                   not IsTagged(me, Avatar) and
                   not GetFlag(CAMP_GLO_State_InCamp, me)
        end
    end
}