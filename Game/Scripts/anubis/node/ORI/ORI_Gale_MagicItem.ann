game.states.ORI_Gale_MagicItem = State{
    function()
        description = [[Sight check for any item that Gale needs.]]

        ---------------------------------------------
        -- Local params
        params.maxDistance = {type = EParamType.Number, required=false, default=3.0, help=[[
            maximum distance that players are required to be in
        ]]}
        ---------------------------------------------

        ---------------------------------------------
        -- Local values
        local seen = false
        ---------------------------------------------

        ---------------------------------------------
        -- Nodes
        nodes.Idle = Action{
            function()
                WaitForInterrupt()
            end
        }
        ---------------------------------------------

        ---------------------------------------------
        -- Events
        events.Activated = function()
            if not seen then
                StartTimer(me, "CheckSight", 0.5, -1)
            end
        end

        events.Deactivated = function()
            if not seen then
                StopTimer(me, "CheckSight")
            end
        end

        events.TimerFinished  = function(e)
            DebugText(me, "CheckSight")
            if e.TimerName == "CheckSight" then
                local actives = GetActiveCharacters(me, params.maxDistance)
                for _,char in pairs(actives) do
                    if char.Character.IsPlayer and CanSee(char, me) then
                        seen = true
                        SetEntityEvent(char, "ORI_Gale_MagicItemSeen", me)
                        StopTimer(me, "CheckSight")
                    end
                end
            end
        end

        events.Destroyed = function(e)
            if e.Entity == me and not seen then
                StopTimer(me, "CheckSight")
            end
        end
        ---------------------------------------------
    end
}