game.states.Hireling = State{function()
    description = [[Default generic state for hirelings]]

    params.camp = { type = EParamType.State, required = true,
        help = [[State for being in camp]] }

    params.default = { type = EParamType.State, required = true,
        help = [[Default state not in camp]] }

    nodes.Camp = Proxy {
        params.camp
    }

    nodes.Default = Proxy {
        params.default
    }
end}
