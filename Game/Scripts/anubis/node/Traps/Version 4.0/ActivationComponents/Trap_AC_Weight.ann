game.expressions.Trap_AC_Weight = Expression{

    ttl = 0.1,

    function(weightMax) -- Evaluator function
        if not me.OnStage then
            return false
        end
        local objects = GetEntitiesOn(me)
        local weight = 0

        for _, object in ipairs(objects) do
            weight = weight + object.Weight    
        end
        local weightString = tostring(weight)
        local weightMaxString = tostring(weightMax)
        --DebugLog("Mine: My weight is "..weightString..", max weight is "..weightMaxString)
        return weight >= weightMax
    end,
    -- Argument types, must be exactly the number of arguments in the evaluator function, where ... is counted as
    -- one argument (all params to be plugged into those args should have this type)
    args = {EParamType.Number},
    -- Result type
    --
    -- Will be validated in run-time, so choose wisely
    --
    -- Optional. EParamType.Bool by default
    result = EParamType.Bool
}
