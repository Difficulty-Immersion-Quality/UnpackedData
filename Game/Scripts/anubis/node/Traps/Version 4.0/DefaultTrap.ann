-- luacheck: globals socket Input EType Output

game.roots.DefaultTrap_Old = State{function()
   
    params.perceptionComponent = {type = EParamType.State, required=false, default=nil, help="Component that determines if the object is hidden and what reveals it."}

    params.logicComponent = {type = EParamType.State, help="Component that contains trap logic"}

    nodes = ImmediateSelector {}

    nodes.LogicComponent = Proxy{
        params.logicComponent,
    }

    nodes.Idle = Action{function()
        WaitForInterrupt()
    end}

    nodes.PerceptionComponent = Proxy{
        params.perceptionComponent
    }

end
}

