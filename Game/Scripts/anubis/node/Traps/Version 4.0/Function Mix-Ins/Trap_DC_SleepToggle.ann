-- luacheck: globals socket Input EType Output
game.states.Trap_DC_SleepToggle =  State{function ()

    params.activeFunctionComponent = {type = EParamType.State, required=false, default=StateRef{game.states.Trap_FC_TrapSleep}, help=[[
        What to do while shooting
    ]]}

    params.sleepFunctionComponent = {type = EParamType.State, required=false, default=StateRef{game.states.Trap_FC_TrapSleep}, help=[[
        What to do between shots
    ]]}

    local slept = true

    self.OnLeave = function()
        slept = true
    end

    nodes.Selector = Selector{function(nodes)
        if slept then
            slept = false
            return nodes.Act
        else
            slept = true
            return nodes.Sleep
        end
    end
    }

    nodes.Selector.Act = Proxy{
        params.activeFunctionComponent
    }

    nodes.Selector.Sleep = Proxy{
        params.sleepFunctionComponent
    }

end
}