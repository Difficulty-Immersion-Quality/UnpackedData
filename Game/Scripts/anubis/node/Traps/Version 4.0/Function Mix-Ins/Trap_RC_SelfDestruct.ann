-- luacheck: globals socket Input EType Output
game.states.Trap_RC_SelfDestruct = State{function()

    params.action = {type = EParamType.State, required=false, default=nil, help=[[
        What the trap does when it activates. Leave as nil to do nothing.
    ]]}


    local activatedOnce = false --Activate once on launch, then sleep.


    nodes.repetitionSelector = Selector{function(nodes)
    
        if not activatedOnce then
            activatedOnce = true
            return nodes.Action
        else
            return nodes.SelfDestruct
        end    
    end
    }

    nodes.repetitionSelector.SelfDestruct = Action{function()
        Sleep(0.5)
        Die(me, DeathType.DOT, me)
    end
    }

    nodes.repetitionSelector.Action = Proxy{
        params.action,
    }
end
}