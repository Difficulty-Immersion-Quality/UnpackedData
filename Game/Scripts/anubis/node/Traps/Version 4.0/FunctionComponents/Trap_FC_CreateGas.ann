game.states.Trap_FC_CreateGas = State{function ()

    description = [[This action spawns gas with an optional growing radius]]

    params.surface = {type = EParamType.String, help=[[Surface]]}
    params.radius = {type = EParamType.Number, required=false, default = 3.0, help=[[Surface radius]]}
    params.lifetime = {type = EParamType.Number, required=false, default = -1, help=[[Surface Lifetime]]}
    params.radiusStep = {type = EParamType.Number,  required=false, default = 0.0,  help=[[Radius Growth Step]]}

    local currentRadius = -1
    local surface

    self.OnInit = function()
        if params.radiusStep ~= 0.0 then
            currentRadius = 0.0
        else
            currentRadius = params.radius
        end
    end

    nodes.Act = function()
        if currentRadius <= params.radius then
            currentRadius = currentRadius + params.radiusStep
            if currentRadius >= params.radius then
                currentRadius = params.radius
            end
        else
            currentRadius = 0
        end
        if currentRadius > 0 then
            CreateSurfaceAt(me, SurfaceType[params.surface], currentRadius, params.lifetime)
        end
    end
end}