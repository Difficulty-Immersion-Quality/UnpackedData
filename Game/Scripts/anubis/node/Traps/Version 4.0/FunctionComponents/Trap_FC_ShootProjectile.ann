game.states.Trap_FC_ShootProjectile = State{function ()
    description = [[This action shoots a projectile]]

    params.projectile =  {type = EParamType.String, help=[[Projectile to Fire]]}
    params.offSet = {type = EParamType.Vector3, required=false, help = [[Offset where the projectile starts from]]}
    params.direction = {type = EParamType.Vector3, required = false, help = [[Direction the projectile travels in]]}
    params.range = {type = EParamType.Number, required = false, default = 1000.0, help = [[Distance the projectile travels]]}

    local direction

    self.OnInit = function()
        direction = params.direction or me.ForwardDirection
    end

    nodes.Act = Action{
        function()
            ShootProjectileAt(params.projectile, me, params.offSet, me.Position + params.offSet + (direction * params.range))
        end,
    }
end
}