context = ...

local helpers = ls.cinematicthoth.helpers
local ConditionResult = ls.thoth.shared.ConditionResult

if helpers.ShouldIgnore() then
    return ConditionResult(false)
end

return ls.thoth.shared.ConditionResult(helpers.IsSpellWithId('GOB_GoblinPriest_Statue_03') and helpers.IsControlledByLocalPlayer(context.Source))
