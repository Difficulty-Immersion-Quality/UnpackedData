context = ...

local helpers = ls.cinematicthoth.helpers
local ConditionResult = ls.thoth.shared.ConditionResult

if helpers.ShouldIgnore() then
    return ConditionResult(false)
end

local targetGUID = ls.core.Guid("c457d064-83fb-4ec6-b74d-1f30dfafd12d")

return ConditionResult(helpers.GetEntityUUID(context.Target) == targetGUID and helpers.GetEntityUUID(context.Source) == targetGUID and helpers.IsSpellWithId('Shout_HAG_SpawnDoubles_Phase1')) 
