context = ...

local helpers = ls.cinematicthoth.helpers
local ConditionResult = ls.thoth.shared.ConditionResult

local sourceIsPlayer = helpers.IsControlledByLocalPlayer(context.Source)
local spellFilter = helpers.IsSpellWithContainerId('Target_RangersCompanion')
return ls.thoth.shared.ConditionResult(not helpers.ShouldIgnore() and sourceIsPlayer and spellFilter)
