context = ...

local helpers = ls.cinematicthoth.helpers
local ConditionResult = ls.thoth.shared.ConditionResult

if helpers.ShouldIgnore() then
    return ConditionResult(false)
end

local tagetIsSource = context.Target == context.Source
local spellFilter = helpers.IsSpellWithId('Shout_WildShape_Dismiss')
return ls.thoth.shared.ConditionResult(tagetIsSource and spellFilter)
