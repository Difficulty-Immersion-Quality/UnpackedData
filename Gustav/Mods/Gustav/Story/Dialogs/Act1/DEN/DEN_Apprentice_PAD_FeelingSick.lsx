	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="|The player has the status DEN_APPRENTICE_THORN on them. This status has 3 stages leading to death. The player is slowly dying.&#xD;&#xA;The first stage is right after being stung by Nettie in the situation Halsin's Apprentice (the reaction of the player is covered in the dialog DEN_Apprentice_Cyanide).&#xD;&#xA;This PAD plays after a long rest: the player rested but the status is worsening. The status is getting to stage 2 and then to stage 3, each time having worse gameplay effects.&#xD;&#xA;After stage 3, the status kills the player; the PAD DEN_Apprentice_PAD_Dying plays in that case.|" />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
