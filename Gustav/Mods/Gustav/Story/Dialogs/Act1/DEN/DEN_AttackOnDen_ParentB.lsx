			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="114" />
			<attribute id="synopsis" type="LSString" value="Marricko is hidden away as the attack appraoches. She's afraid, but determined to keep it together.If her daughter is alive, she's worried about her but also knows she can take care of herself if needs be.&#xD;&#xA;&#xD;&#xA;If her child is bad, she laments when she even survived. She is despondant and grieving. " />
