	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Repro steps:&#xD;&#xA;1. Start the game&#xD;&#xA;2. loadlevel WLD_Main_A&#xD;&#xA;3. oe readyattackonden&#xD;&#xA;4. Blow the horn and side wit the goblin (kill all tieflings at the gate).&#xD;&#xA;5. goto 175.70, 21.56, 529.96&#xD;&#xA;6. Kill all tieflings.&#xD;&#xA;7. goto 258.42, 14.76, 525.52&#xD;&#xA;8. Kill all druids.&#xD;&#xA;9. Follow the goblins to 285.38, 1.25, 470.33&#xD;&#xA;10. Talk with Goblin Sharp-eye&#xD;&#xA; " />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="6" />
			<attribute id="synopsis" type="LSString" value="A goblin raider celebrates upon having successfully destroyed a shelter full of refugees. Jubilant and nasty." />
