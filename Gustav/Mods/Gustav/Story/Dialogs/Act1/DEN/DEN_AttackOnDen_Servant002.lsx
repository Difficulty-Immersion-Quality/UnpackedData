	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Be far away from Den, then use: oe readyattackonden&#xD;&#xA;- Activate the horn above Den gate to trigger Goblin raid&#xD;&#xA;- Side with Zevlor in dialogue and kill all goblins. &#xD;&#xA;(CTRL + Shift + K) or “killcombat”command is useful here &#xD;&#xA;- Talk to Marcoryl (ServantIntolerent002) down in the druid's underground Den at X:-470 Y:-11" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="129" />
			<attribute id="synopsis" type="LSString" value="Marcoryl spent the attack hiding in the lair, refusing us access. Now the attack has been repelled he's opened it up and is keen to see the tieflings gone. A sanctimonious and unrepentant bad host to those in need." />
			<children>
