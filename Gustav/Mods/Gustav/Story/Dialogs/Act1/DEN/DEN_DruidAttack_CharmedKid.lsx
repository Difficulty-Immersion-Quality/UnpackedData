	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="select player character&#xD;&#xA;in reCon: addTag BARBARIAN&#xD;&#xA;teleport S_DEN_CharmedKid&#xD;&#xA;trigger dialogue DEN_HarpyMeal_CharmedVictim&#xD;&#xA;go through these choices&#xD;&#xA;- You shouldn't be standing out in the water. It's dangerous.&#xD;&#xA;-  Focus and try to hear what he hears.&#xD;&#xA;-  Struggle against the music's pull. (roll amazing)&#xD;&#xA;- Roar at the top of your lungs to overpower the voice.&#xD;&#xA;dialogue exits&#xD;&#xA;killcombat&#xD;&#xA;click through next dialogue (spacebar all the way)&#xD;&#xA;oe startdruidattack&#xD;&#xA;teleport S_DEN_CharmedKid" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="14" />
			<attribute id="synopsis" type="LSString" value="Two states: one where the child is about to get attacked by the druids and is panicking, and one where the player has saved him and he's grateful." />
