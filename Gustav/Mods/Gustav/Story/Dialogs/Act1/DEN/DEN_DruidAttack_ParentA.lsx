		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Repro steps:&#xD;&#xA;1. Start the game&#xD;&#xA;2. oe startdruidattack&#xD;&#xA;3. oe druidattackkilldruids&#xD;&#xA;4. goto -43 77&#xD;&#xA;5. Talk to Locke" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="26" />
			<attribute id="synopsis" type="LSString" value="Locke is hidden alongside multiple other tieflings as the druids attack the grove. In his post attack lines he is grim and depressed if his daughter is dead (even as he thanks the player.) If his daughter is alive, he is saddened that violence occured but thankful the player was there to help. " />
