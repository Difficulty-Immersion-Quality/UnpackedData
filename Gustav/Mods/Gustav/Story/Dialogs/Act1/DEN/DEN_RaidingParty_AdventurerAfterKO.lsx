		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Repro Steps:&#xD;&#xA;1. Start the game.&#xD;&#xA;2. loadlevel WLD_Main_A&#xD;&#xA;3. goto 212.35, 26.28, 400.38&#xD;&#xA;4. Advance towards the gate to trigger Attack on Den cinematic.&#xD;&#xA;5. killcombat&#xD;&#xA;6. Advance into the Grove.&#xD;&#xA;7. KO or let Zevlor KO Aradin.&#xD;&#xA;8. Talk with Aradin" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="565" />
			<attribute id="synopsis" type="LSString" value="After the main confrontation dialogue, one leader may attack the other. This dialogue the plays if the Adventurer Leader is the sole survivor regardless of who attacked who." />
