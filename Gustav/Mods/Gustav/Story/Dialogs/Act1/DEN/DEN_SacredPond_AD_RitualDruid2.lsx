		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="17" />
			<attribute id="synopsis" type="LSString" value="This AD has two phases: the first plays if a druid ritual Kerrick was part of was stopped because their leader was exposed as a shadow druid. In this state, Kerrick feels angry and betrayed - he thought he was part of something good when really he was being used.&#xD;&#xA;The second state plays once the goblins that threatened the grove - and necessitated the ritual - have been dealt with. In this state, Kerrick is reflective and calm. The threat is gone, but there's much to be learned from it." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
