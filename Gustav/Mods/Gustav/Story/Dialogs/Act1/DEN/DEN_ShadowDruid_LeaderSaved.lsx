			<attribute id="synopsis" type="LSString" value="Kagha's dialog after the Celebration (post-AttackOnDen or post-GoblinHunt), if the scene with the parents occured and the player saved her.&#xD;&#xA;CAMP_GoblinHuntCelebration_Event_SavedKagha = true" />
