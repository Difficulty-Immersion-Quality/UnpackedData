	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- goto -73, 16, 356&#xD;&#xA;- Use your Illithid powers on the goblin to gain entry&#xD;&#xA;- goto 333, 41, -34, pass Charisma Check with Spike to make him leave&#xD;&#xA;- Destroy the 'Torture Rack' with Ctrl+Shift+K&#xD;&#xA;- Talk to Liam and have him return to the Druid's Den&#xD;&#xA;- Trigger and complete 'Plea at the Gate' at (217, 32, 411) using the ReCon command &quot;killcombat&quot;&#xD;&#xA;- Speak with Liam at (171, 20, 547)" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="52" />
			<attribute id="synopsis" type="LSString" value="Small dialogue when you find Liam sleeping in the den after freeing him in the goblin camp." />
