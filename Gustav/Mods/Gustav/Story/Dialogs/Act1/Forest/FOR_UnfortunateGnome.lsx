	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="repro steps:&#xD;&#xA;1. Start the game.&#xD;&#xA;2. loadlevel WLD_Main_A&#xD;&#xA;3. goto 0.60, 36.99, 424.64&#xD;&#xA;4. Resolve the dialog with goblin or kill everyone.&#xD;&#xA;5. go to the lever in the windmill and choose the &quot;brake&quot; one.&#xD;&#xA;6. Talk to Barcus and choose to free him." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2515" />
			<attribute id="synopsis" type="LSString" value="The player speaks to a deep gnome after freeing him from some goblins, who'd had him tied to the sail of a windmill. The player discovers that the deep gnome travelled to the region as he learned his old friend is in danger. By way of thanks, he provides the player with the means to craft smokepowder, an explosive item. He then leaves for the Underdark in search of his friend. There, the player may encounter him again." />
			<children>
				<node id="defaultAttitudes" />
