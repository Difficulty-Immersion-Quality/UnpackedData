	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- loadmodule Gustav WLD_Main_A&#xD;&#xA;- god&#xD;&#xA;- roll amazing&#xD;&#xA;- create OBJ_BasicPoison&#xD;&#xA;- goto -94.25, 9.78, 442.25&#xD;&#xA;- Use the Booze Tub nearby.&#xD;&#xA;- Combine Basic Poison with Booze Tub.&#xD;&#xA;- You will be spotted. Choose dialogue option: 2 &gt; 1 &gt; 3 &gt; 2&#xD;&#xA;- Wait until some of the goblins die to poison.&#xD;&#xA;- GOB_GoblinToast_PoisoningInterrogation will trigger after one goblin approach you." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="235" />
			<attribute id="synopsis" type="LSString" value="One of the goblins stops the player and accusses them of poisoning their beer and thus killing some of the goblins." />
