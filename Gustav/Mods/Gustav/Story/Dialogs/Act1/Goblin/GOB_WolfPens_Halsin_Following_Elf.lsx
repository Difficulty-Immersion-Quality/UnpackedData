	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Steps to reproduce:&#xD;&#xA;1. Start the game.&#xD;&#xA;2. loadlevel WLD_Main_A&#xD;&#xA;3. goto 402.894; 32.458; -27&#xD;&#xA;4. Use illithid dialog choice to free Halsin.&#xD;&#xA;5. Side with him and kill the surrounding goblins (killcombat)&#xD;&#xA;6. Talk with Halsin and convince him to join you by accepting his quest.&#xD;&#xA;7. Participate in fight and wait until Halsin takes enough damage to be reverted into his human form.&#xD;&#xA;7. Talk with Halsin." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1166" />
			<attribute id="synopsis" type="LSString" value="Halsin, arch-druid of the Emerald Grove, is  following the player inside the Goblin Camp in his elf form, trying to find and kill the goblin leadership. The player can tell him to hold his position." />
