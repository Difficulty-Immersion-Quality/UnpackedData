	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- loadlevel WLD_Main_A&#xD;&#xA;- goto -307; 589&#xD;&#xA;- Skip through HAG_HagLair_EntranceDouble and Skip through HagLair_TalkingDoor if they play&#xD;&#xA;- Recruit origin(s) you want to test&#xD;&#xA;- Pick up a Whispering Mask and put it on&#xD;&#xA;- HAG_HagLair_PutOnMask will play. You'll then enter combat with your party members and this dialogue will play shortly after." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="111" />
			<attribute id="synopsis" type="LSString" value="Hag mode. Player has failed a wisdom save while wearing the mask and the hag has taken over their mind. Cruel and triumphant. The other origin characters realise what has happened." />
