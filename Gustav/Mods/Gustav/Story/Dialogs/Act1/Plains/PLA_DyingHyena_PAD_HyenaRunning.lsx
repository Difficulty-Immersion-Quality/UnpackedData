	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="* Start a combat with hyenas at 26; 30; 527&#xD;&#xA;* One healthy hyena will bark and will try to run away during its turn.&#xD;&#xA;* One of the players will trigger the PAD" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="When the party starts the combat with dying hyenas, one of them - healthy hyena - will run away to call the gnolls nearby. This PAD is to ensure the player will understand what hyena is up to." />
