											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="Pulls eyeball from socket, waves hand around it and then jams it back into the players head &lt;AaronH&gt;, CDavis: [Hag] Raises her arm, finger straightens to a point as if a blade. Drives her finger/nail into the [Players] eye and after a beat yanks it back out. The players eye is on the nail, and then she either - kisses it gently or wave her hand over it (whatever is easier), then jams it back into the [Players] empty socket." />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
											<attribute id="val" type="LSString" value="Default" />
										</node>
