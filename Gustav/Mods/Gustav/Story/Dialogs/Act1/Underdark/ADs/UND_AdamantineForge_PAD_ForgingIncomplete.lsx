		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Go to adamantine forge&#xD;&#xA;create UNI_LOOT_AdamantineForge_ScimitarMold&#xD;&#xA;create UNI_PUZ_MithralOre&#xD;&#xA;fill mold chamber and forge&#xD;&#xA;click lever to trigger hammer strike&#xD;&#xA;click on the chamber or forge" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="Adamantine forge: players have inserted mould into the mould chamber, mithral into the forge, clicked the lever to trigger the hammer and the platform went down. Now they click again on the forge/chamber expecting to get the result. However, they still need to add the lava. This PAD is a hint to the fact that something is still missing (or, after crafting once, that lava needs to be added)." />
			<children>
