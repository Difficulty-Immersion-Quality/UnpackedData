	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Click on&#xD;&#xA;Stained Cask - S_UND_ElevatorGnome_BeerBarrel 3c1836b4-2bae-4f2d-9903-4b609639cf57 - (-615; 0; 391)&#xD;&#xA;and combine it with any poison&#xD;&#xA;then go up and talk to Stickpit. Wait for him to go to the Stained Cask and use it. Then he'll go back and give the poisoned booze to the two duergar. They will drink it and die.&#xD;&#xA;Stickpit will say this AD" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="A deep gnome watches his two slavers die after drinking poisoned beer (although, he didn't know that the beer was poisoned when he brought it to them)." />
