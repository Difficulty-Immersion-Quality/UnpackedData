	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="To trigger Greeting nodes -&#xD;&#xA;1. loadlevel WLD_Main_A&#xD;&#xA;2. goto -607.02, 0.54, 410.79&#xD;&#xA;3. Talk with Brathwen.&#xD;&#xA;&#xD;&#xA;To trigger Greeting (has met)&#xD;&#xA;1. loadlevel WLD_Main_A&#xD;&#xA;2. goto -607.02, 0.54, 410.79&#xD;&#xA;3. Finish the first dialogue about the corpses and loot&#xD;&#xA;4. Talk to Brathwen again.&#xD;&#xA;&#xD;&#xA;To trigger Greeting (DEEPGNOME has met)&#xD;&#xA;1. loadlevel WLD_Main_A&#xD;&#xA;2. Put the mouse pointer over your character and use the recon command: &quot;addTag DEEPGNOME:2bbc3217-3d8c-46e6-b599-a0f1c9063f9a &quot;&#xD;&#xA;3. goto -607.02, 0.54, 410.79&#xD;&#xA;4. Finish the first dialogue about the corpses and loot&#xD;&#xA;5. Talk to Brathwen again.&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="25" />
			<attribute id="synopsis" type="LSString" value="Short dialogues when i'm done doing the main 'looting' scene with this character." />
