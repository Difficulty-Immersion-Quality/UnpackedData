	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Repro steps:&#xD;&#xA;1. Start the game.&#xD;&#xA;2. loadlevel WLD_Main_A&#xD;&#xA;3. goto -634, 15, 310&#xD;&#xA;4. Ctrl+Shift+K the Cave-In (Nere will speak to you automatically)&#xD;&#xA;5. Select dialogue options &quot;Stop! No more...&quot;, &quot;I act on...&quot;, &quot;You wouldn't dare...&quot;, then &quot;You so much...&quot;&#xD;&#xA;6. killcombat&#xD;&#xA;7. Speak with Beldron" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="20" />
			<attribute id="synopsis" type="LSString" value="Dialog for gnome foreman on the other side of the ebon lake after they were saved by player. Mentions the other gnomes being kept at moonrise towers." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
