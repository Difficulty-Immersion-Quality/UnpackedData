			<attribute id="nextNodeId" type="uint32" value="64" />
			<attribute id="synopsis" type="LSString" value="Player clicks on the scrying eye patrolling in Grymdark. Passing an Insight check lets you look back into the presence watching you (one of the scryers at Moonrise Towers). This dialogue uses the same template as the dialogue with the scrying eye in the goblin camp." />
