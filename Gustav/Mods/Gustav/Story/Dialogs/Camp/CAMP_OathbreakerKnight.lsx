	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. Start the game as a paladin.&#xD;&#xA;2. Become an oathbreaker (oe MakeOathbreaker with the paladin selected).&#xD;&#xA;3. End the day." />
			<attribute id="autoFidelity" type="LSString" value="Gold" />
			<attribute id="bronzeNodesCount" type="int32" value="88" />
			<attribute id="currentFidelity" type="LSString" value="Gold" />
