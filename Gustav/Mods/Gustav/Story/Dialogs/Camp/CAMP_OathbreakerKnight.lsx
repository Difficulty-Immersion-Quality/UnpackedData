			<attribute id="nextNodeId" type="uint32" value="711" />
			<attribute id="overrideFidelity" type="LSString" value="None" />
			<attribute id="synopsis" type="LSString" value="When a paladin becomes an oathbreaker the Oathbreaker knight will appear to be their guide. He will stay at the camp as a camp follower.&#xD;&#xA;If a non-oathbreaker paladin speaks to the Oathbreaker, they begin a short interactive dialogue. The Oathbreaker is mildly impressed that they are still dedicated to their cause, but warns that the course ahead will test their commitment." />
