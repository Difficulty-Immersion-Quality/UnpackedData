	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Repro steps:&#xD;&#xA;1. Start the game&#xD;&#xA;2. loadlevel WLD_Main_A&#xD;&#xA;3. add Astarion to your party&#xD;&#xA;4. oe qnight NIGHT_AstarionHungerC_Bite_fe3fd3a0-70d1-4bc4-8a7f-4614f89ac23d&#xD;&#xA;5. go to camp and take a long rest" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="805" />
			<attribute id="synopsis" type="LSString" value="You wake up and find Astarion hunching over you, fangs bared. You fight him off. Caught off guard, he's alarmed and worried that you're going to kill him. He tries to be charming, explaining that he's too weak without blood. If you push back against his excuses he gets frustrated - he tries to bargain with you. If you agree to let him bite you, he's thrilled. He feels in control again. After drinking, he feels invigorated and cocky." />
