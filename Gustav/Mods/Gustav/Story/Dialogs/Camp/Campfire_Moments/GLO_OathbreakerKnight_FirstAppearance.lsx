	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Playing as a paladin break your oath and start a long rest.&#xD;&#xA;Fastest way would be:&#xD;&#xA;1. Start as a paladin.&#xD;&#xA;2. recon infiniteAp&#xD;&#xA;3. spawnCharacter Drow_Male_Civilian_Lolth_05447998-ac54-4394-8d56-39739d7ed948&#xD;&#xA;4. Go into FTB, kill the civilian.&#xD;&#xA;or&#xD;&#xA;1. Start with a paladin.&#xD;&#xA;2. oe MakeOathbreaker" />
