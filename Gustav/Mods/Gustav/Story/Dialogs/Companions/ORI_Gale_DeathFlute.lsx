			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="301" />
			<attribute id="synopsis" type="LSString" value="In this dialog the player can make a magma mephit appear that when answered correctly will breathe fire on a letter, turning it into a powerful magical scroll. The language the mephit speaks is called Ignan and can be spoken as the words appear – simply think away the many apostrophes. In the actor context are the approximations of what the mephit is saying so that the tone can be matched to the content." />
