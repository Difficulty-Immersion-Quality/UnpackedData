	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="423" />
			<attribute id="synopsis" type="LSString" value="Shadowheart reacts to taking offerings made at a shrine to Selûne, the rival of her goddess Shar. If Shadowheart is the avatar, she has a moment of introspection where she considers if she should take the items of not. If Shadowheart is a companion, she encourages the player to not take the items. The player can try talk her around, and may discover she is a Shar worshipper if they don't already know. The outcome of this dialogue potentially strengthens or damages Shadowheart's opinion of the player." />
