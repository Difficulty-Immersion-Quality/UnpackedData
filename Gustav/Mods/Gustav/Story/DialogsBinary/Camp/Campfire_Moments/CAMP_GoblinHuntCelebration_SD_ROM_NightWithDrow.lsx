											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="--fade in--&#xD;&#xA;Minthara holds the player's head close with her right, releasing their grip to move south--the player respondes to the sensation.&#xD;&#xA;The player player dances their finger playfully across Minthara's ear for a moment.&#xD;&#xA;Minthara turns, kissing it before guiding her head down the player's stomach.&#xD;&#xA;The player's hand moves from the ear gently follow Minthara's head down.&#xD;&#xA;--fade out--" />
										</node>
									</children>
								</node>
							</children>
