game.states.WYR_RefugeeCamp_Refugee_15 = State { function ()
    description = [[ A behaviour for a refugee whos friend is wounded. ]]

    modules = { "shared.dialog" }

    local tieflingsAreNotPresentFlag = Flag("WYR_RefugeeCamp_State_NoTieflingsCamp_6947d1af-e1a1-47bf-833e-10dca6311be7")

    nodes.AtCamp = Proxy {
        game.states.WYR_LoopingAnimAtTrigger,
        params = {
            pauseBeforeFirstPlay = 4.0,
            animEnd = [[CUST_FryingRat_01_End_700461f9-3b56-459d-b559-5add56c98358]],
            animLoops = {
                [[CUST_FryingRat_01_Loop_027bf518-3a11-4145-8e5c-c067ba4e7a3d]],
            },
            trigger = [[S_WYR_RefugeeCamp_Refugee_15_CampPos_a2579c52-e9cc-4792-8f51-18d36a21f620]],
            animStart = [[CUST_FryingRat_01_Start_1de0cfce-a416-486e-8ac0-390b87a70d48]],
        },
        Valid = function()
            return not GetFlag(tieflingsAreNotPresentFlag)
        end
    }

    nodes.AtBackupPos = Proxy {
        game.states.WYR_LoopingAnimAtTrigger,
        params = {
            pauseBeforeFirstPlay = 4.0,
            animEnd = [[CUST_FryingRat_01_End_700461f9-3b56-459d-b559-5add56c98358]],
            animLoops = {
                [[CUST_FryingRat_01_Loop_027bf518-3a11-4145-8e5c-c067ba4e7a3d]],
            },
            trigger = [[S_WYR_RefugeeCamp_Refugee_15_BackupPos_3001e9f1-4a48-4bde-99da-a8dc3ad7b2e0]],
            animStart = [[CUST_FryingRat_01_Start_1de0cfce-a416-486e-8ac0-390b87a70d48]],
        },
        Valid = function()
            return GetFlag(tieflingsAreNotPresentFlag)
        end
    }

    nodes.Fallback = Action {
        function()
            waitForCompletion()
        end
    }
end}