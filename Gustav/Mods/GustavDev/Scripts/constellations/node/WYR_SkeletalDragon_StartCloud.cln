game.states.WYR_SkeletalDragon_StartCloud =  State{
    function ()

        inputs.SurfacesOn = {help = "Start the surfaces"}
        inputs.SurfacesOff = {help = "End the surfaces"}


        socketEvents.SurfacesOn = function(e)

            local trigger1 = Entity("S_WYR_SkeletalDragon_StartLIghtningCloudTrigger1_d9ff2df8-95e0-4397-ae71-71d2add3ffa4")
            local trigger2 = Entity("S_WYR_SkeletalDragon_StartLIghtningCloudTrigger2_f17cb8f6-f359-46ba-997e-177e60f57619")
            local trigger3 = Entity("S_WYR_SkeletalDragon_StartLIghtningCloudTrigger3_a20cd37f-4055-4923-b2d8-1a900e6e95de")
            local dragon = Entity("S_WYR_SkeletalDragon_67770922-5e0a-40c5-b3f0-67e8eb50493a")
            
            CreateSurfaceAt(trigger1, SurfaceType.WATER_CLOUD_ELECTRIFIED, trigger1, -1.0, true, dragon, 30, 0.2)
            CreateSurfaceAt(trigger2, SurfaceType.WATER_CLOUD_ELECTRIFIED, trigger2, -1.0, true, dragon, 30, 0.2)
            CreateSurfaceAt(trigger3, SurfaceType.WATER_CLOUD_ELECTRIFIED, trigger3, -1.0, true, dragon, 30, 0.2)      

        end

        socketEvents.SurfacesOff = function(e)

            local trigger1 = Entity("S_WYR_SkeletalDragon_StartLIghtningCloudTrigger1_d9ff2df8-95e0-4397-ae71-71d2add3ffa4")
            local trigger2 = Entity("S_WYR_SkeletalDragon_StartLIghtningCloudTrigger2_f17cb8f6-f359-46ba-997e-177e60f57619")
            local trigger3 = Entity("S_WYR_SkeletalDragon_StartLIghtningCloudTrigger3_a20cd37f-4055-4923-b2d8-1a900e6e95de")
            
            RemoveSurfaceOfTypeAt(SurfaceType.WATER_CLOUD_ELECTRIFIED, trigger1, 30)
            RemoveSurfaceOfTypeAt(SurfaceType.WATER_CLOUD_ELECTRIFIED, trigger2, 30)
            RemoveSurfaceOfTypeAt(SurfaceType.WATER_CLOUD_ELECTRIFIED, trigger3, 30)

        end


    end
}
