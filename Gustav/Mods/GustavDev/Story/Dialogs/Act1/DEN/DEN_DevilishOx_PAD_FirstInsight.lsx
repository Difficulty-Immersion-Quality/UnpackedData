	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Walk to the tiefling cave, past Rolan and to the right. There will be two ox and Toron standing closeby. When close enough, a passive insight check will trigger." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="8" />
			<attribute id="synopsis" type="LSString" value="The player walks past and, if they notice (pass an insight check), responds to the ox looking at them strangely." />
