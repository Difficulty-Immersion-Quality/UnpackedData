	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Triggers if an avatar dies in the Astral Prison. They are resurrected shortly after and this Daisy AD plays." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="Daisy tells the avatar that they can't die here and she can take care of them. It should explain that it is because we're in the Astral Plane that Daisy can revive us like that." />
			<children>
				<node id="defaultAttitudes" />
				<node id="defaultEmotions" />
				<node id="isImportantForStagings" />
				<node id="isPeanuts" />
				<node id="speakerSlotDescription" />
