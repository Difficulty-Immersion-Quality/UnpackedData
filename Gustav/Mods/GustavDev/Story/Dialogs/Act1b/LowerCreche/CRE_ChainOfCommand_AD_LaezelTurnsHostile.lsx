	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CRE_Main_A&#xD;&#xA;Make sure you have Laezel with you.&#xD;&#xA;Go to 1392; -2; -780 and enter the captain's office and get through the dialog&#xD;&#xA;go to 1357; -7; -689&#xD;&#xA;enter the security office&#xD;&#xA;talk to the inquisitor, and show him the artifact&#xD;&#xA;talk to Vlaakith and tell her you won't do it&#xD;&#xA;Laezel should have left the party and is waiting for you to enter the Astral Prism&#xD;&#xA;Leave the security office - Lae'zel will go hostile, and trigger this AD.&#xD;&#xA;&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Lae'zel says this AD as she attacks the player for the following actions:&#xD;&#xA;- You walk out of the Creche Security office after Vlaakith orders you to enter the Astral Prism&#xD;&#xA;- You attack the Inquisitor" />
