	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Use Debug Book to travel to Act 1b -&gt; Creche - Main Creche floor&#xD;&#xA;Get through the dialog with the guards at the checkpoint (you'll likely need to use killcombat in recon)&#xD;&#xA;Once through the doors go left (west), then right (north), and enter the Hatchery Chamber through the door at the end of the corridor.&#xD;&#xA;Speak to the guard to the right (north) as you enter the room - he's standing at the edge of the pool beside a pillar." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="183" />
			<attribute id="synopsis" type="LSString" value="A male gith guard, watching over the hatchery where gith eggs are hatched. He's a caustic personality, ready to kill anyone who touches the lone egg in the hatchery. " />
