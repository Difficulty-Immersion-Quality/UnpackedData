	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="When the player first steps into the hatchery, which is filed with gith pheromone fumes.&#xD;&#xA;Use Debug Book to travel to Act 1b -&gt; Creche - Main Creche floor&#xD;&#xA;Get through the dialog with the guards at the checkpoint (you'll likely need to use killcombat in recon)&#xD;&#xA;Once through the doors go left (west), then right (north), and enter the Hatchery Chamber through the door at the end of the corridor." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="73" />
			<attribute id="synopsis" type="LSString" value="The player is affected by the strange fumes in the hatchery surrounding the egg (actually gith pheromones). To non-gith, they stink and weaken you slightly (gain status to make you more vulnerable to physical damage). To gith characters, they're actually quite pleasant and make you feel tougher (status gives you resistence to physical damage boost)." />
			<children>
				<node id="defaultAttitudes" />
				<node id="defaultEmotions" />
