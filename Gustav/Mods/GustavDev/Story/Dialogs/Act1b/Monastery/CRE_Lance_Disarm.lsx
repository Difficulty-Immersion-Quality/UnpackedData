									<children>
										<node id="data">
											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="[ChrisD] Player inserts the crest inside the pedestal to disarm the trap. Player slowly takes the mace with ease and examines it a bit." />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
