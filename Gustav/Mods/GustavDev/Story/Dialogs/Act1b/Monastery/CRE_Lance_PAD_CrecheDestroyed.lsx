			<attribute id="nextNodeId" type="uint32" value="7" />
			<attribute id="synopsis" type="LSString" value="Group Discussion converted to Voicebark&#xD;&#xA;This is played after the player escapes the destruction of the Gith Creche.&#xD;&#xA;This intentionally excludes Laezel, who has an origin moment if she is present instead." />
