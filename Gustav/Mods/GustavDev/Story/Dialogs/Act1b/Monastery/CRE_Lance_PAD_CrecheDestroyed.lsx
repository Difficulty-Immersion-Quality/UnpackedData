	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CRE_Main_A&#xD;&#xA;open recon&#xD;&#xA;use &quot;oe cre_testlance&quot;&#xD;&#xA;take the blood of lathander&#xD;&#xA;teleport party to -12; 18; -13&#xD;&#xA;exit turn based mode and wait for the destruction cinematic to play&#xD;&#xA;the voicebark will play after it ends" />
