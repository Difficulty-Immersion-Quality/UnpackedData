	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CRE_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MonkAmulet_Get&quot; and equip the amulet.&#xD;&#xA;- Approach the Blood of Lathander in the Creche: S_CRE_MonkAmulet_BloodOfLathanderBanter_4e40660b-9ea9-4716-9379-a521f333a920&#xD;&#xA;&quot;goto 1077 3 -782&quot;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="4" />
			<attribute id="synopsis" type="LSString" value="The spirit inside the Sentient Amulet, once a monk of Lathander, sees the true Blood of Lathander displayed before us. This was a holy relic for which many devout followers made their pilgrimage to the monastery that eventually became the Gith Creche." />
