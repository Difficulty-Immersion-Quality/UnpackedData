	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CRE_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MonkAmulet_Get&quot; and equip the amulet.&#xD;&#xA;- Approach the statue of Lathander in the Creche: S_CRE_MonkAmulet_StatueBanter_f83fe070-3bae-4996-a349-7e14f0a0573a&#xD;&#xA;&quot;goto 75 9 62&quot;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="4" />
			<attribute id="synopsis" type="LSString" value="The spirit inside the Sentient Amulet, once a monk of Lathander, sees a statue of Lathander in the interior courtyard of the Gith Creche, once a Lathander monastery. Pilgrims of old used to visit the statue to see a holy relic - the Blood of Lathander - though unbeknownst to them, it was a fake prop. The Mad Monk reminisces about his own pilgrimage." />
