	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Tun on Roll Amazing,&#xD;&#xA;- On CRE_Main_A go to 74; 24; 81 and pick the lock on the hidden door (S_CRE_WeaponsPuzzle_HiddenDoor)&#xD;&#xA;- Read the note in the bag, and close it. The translated string ID of the note is: CRE_WeaponsPuzzle_HastyNote" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="The character comments on a note left by the last dawnmaster next to the hidden key in the weapons puzzle. The note cryptically refers to the Blood of Lathander, and catches the Player character's attention." />
			<children>
				<node id="defaultAttitudes" />
