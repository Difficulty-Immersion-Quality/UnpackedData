	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1) Go to 1353; 2; -773 and watch the dialog between the Captain and Templar. &#xD;&#xA;2) Then set roll amazing, sneak behind the Captain and steal the item in her inventory (stub name |Gith Shard|). &#xD;&#xA;3) Talk to the captain, and convince her to let you in to the templar (roll amazing will help)&#xD;&#xA;She will walk to the door control and say the line, then turn hostile." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="The captain tries to let the player in through the barrier in her office, but the player has already pickpocketed the key off her. She immediately suspects the outsiders, and turns hostile on them." />
