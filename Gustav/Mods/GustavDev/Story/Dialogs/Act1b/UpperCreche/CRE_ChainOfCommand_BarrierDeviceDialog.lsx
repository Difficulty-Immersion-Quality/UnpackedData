	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1) Go to 1353; 2; -773 and watch the dialog between the Captain and Templar. &#xD;&#xA;2) Then set roll amazing, sneak behind the Captain and steal the item in her inventory (stub name |Gith Shard|). &#xD;&#xA;3) Use the door device and insert the Shard. The dialog will start." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="In gameplay the player has inserted the key (stub name |Gith Shard|) into the barrier control device in the captain's office. The device turns on, and connects the palyer to the Inquisitor, who speaks through the device (voice only). If the Captain is still alive, she tries to interrupt, but the Inquisitor allows the players in." />
