	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CRE_Main_A&#xD;&#xA;go to 1330; -2; -794&#xD;&#xA;go into stealth, and make sure no one notices as you interact with the portrait on the wall&#xD;&#xA;choose to vandalise it&#xD;&#xA;after the dialog has ended the gith boy will react with this world behaviour&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="3" />
			<attribute id="synopsis" type="LSString" value="The GIth boy is cleaning the Vandalised / Vandalised_Failed portrait, trying to wipe it off desperatedly. The animation loops endlessly." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
