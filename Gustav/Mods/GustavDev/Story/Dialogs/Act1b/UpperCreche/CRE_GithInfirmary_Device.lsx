	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="start game with new character, add companions using oe debugbook&#xD;&#xA;loadlevel CRE_Main_A&#xD;&#xA;teleport S_CRE_Doctor&#xD;&#xA;as a companion, speak w doctor&#xD;&#xA;say your friend needs a tadpole removed&#xD;&#xA;switch to plyr and speak with doctor&#xD;&#xA;accept help and interact with zaith'isk" />
			<attribute id="autoFidelity" type="LSString" value="Silver" />
			<attribute id="bronzeNodesCount" type="int32" value="90" />
			<attribute id="currentFidelity" type="LSString" value="Silver" />
