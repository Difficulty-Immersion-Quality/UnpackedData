			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2296" />
			<attribute id="overrideFidelity" type="LSString" value="None" />
			<attribute id="synopsis" type="LSString" value="The player attempts to remove their tadpole with the device, not realising that it will kill them as it does so. The player has opportunity to save themselves from the machine. If they fail or refuse those opportunities, Daisy will intervene. Variations based on whether the doctor and Lae'zel are present or not." />
