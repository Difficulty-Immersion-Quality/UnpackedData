			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="An Ardent shows up after the infirmary ambush and sends the player to talk to the captain. This is to communicate to the player that they may continue exploring the Creche." />
