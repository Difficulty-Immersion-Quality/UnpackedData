		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up cre_main_A&#xD;&#xA;go to 1285; -2; -801&#xD;&#xA;talk to the doctor asking to use the zaithisk&#xD;&#xA;break the zaithisk by completing the dialog&#xD;&#xA;go out of the room and fight the ambushing gith&#xD;&#xA;the ardent will show up to say this line." />
