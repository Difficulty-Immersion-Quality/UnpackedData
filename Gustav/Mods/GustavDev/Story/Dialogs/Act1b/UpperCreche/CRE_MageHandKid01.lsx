			<attribute id="HowToTrigger" type="LSString" value="Speak to MageHandKid01 after you've made them stop shoving the chest. " />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="32" />
			<attribute id="synopsis" type="LSString" value="One of the gith kids can't wait for the player to open the chest (knowing that a gremishka will pop out.) &#xD;&#xA;&#xD;&#xA;Before opening chest - gleeful anticipation. After opening chest - laughing in the player's face. If chest stolen - sulky." />
