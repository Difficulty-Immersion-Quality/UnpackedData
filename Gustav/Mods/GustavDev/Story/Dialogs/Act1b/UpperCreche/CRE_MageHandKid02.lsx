		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Speak to MageHandKid02 after you've made them stop shoving the chest.&#xD;&#xA;loadlevel CRE_Main_A&#xD;&#xA;teleport MageHandKid02&#xD;&#xA;speak with + intimidate to stop&#xD;&#xA;speak with again&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="24" />
			<attribute id="synopsis" type="LSString" value="One of the gith kids can't wait for the player to open the chest (knowing that a gremishka will pop out.) &#xD;&#xA;&#xD;&#xA;Before opening chest - gleeful anticipation. After opening chest - laughing in the player's face. " />
