	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Get spotted by the hidden checkpoint guards.  Input &quot;oe cre_voss_friendly&quot; and &quot;oe cre_voss_hostile&quot; as debug commands respectively to test the different Voss permutations (&quot;oe cre_voss_skipped&quot; clears both tags). " />
