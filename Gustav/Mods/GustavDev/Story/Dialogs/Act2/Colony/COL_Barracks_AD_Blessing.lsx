	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Barracks with &quot;goto 728 16 14&quot;&#xD;&#xA;- Approach the Mistress of Souls from a distance - she will start blessing the Skull Lashers. Do not come too close or interfere." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="13" />
			<attribute id="synopsis" type="LSString" value="Krustine, Mistress of Souls, is blessing three Skull Lashers in the Colony Barracks. This AD can be interrupted." />
