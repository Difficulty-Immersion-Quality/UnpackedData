	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Barracks using the debugbook&#xD;&#xA;- Approach Krustine and the Skull Lashers - don't get too close or interrupt the blessing, but let it complete.&#xD;&#xA;- You can also interrupt the blessing and take your way out of it.&#xD;&#xA;- After this, they will move on into their behaviours - Krustine will send the Skull Lashers on their way with this AD" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Krustine, Mistress of Souls in the Colony Barracks, sends the Skull Lashers on their way to prepare for the march on Baldur's Gate. Played only once." />
