	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Barracks using the debugbook&#xD;&#xA;- Engage Krustine and her Skull Lashers in combat&#xD;&#xA;- Hairy Henry, the bugbear, will say this AD when he gets the chance. Each Myrkulite here will get the chance to say their own AD in each combat round (after everyone has had a turn). They will only be able to play this AD once." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Hairy Henry, one of three Skull Lashers in the Colony Barracks, combat AD. Played only once." />
