	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Barracks using the debugbook&#xD;&#xA;- Approach Krustine and her Skull Lashers and wait until the blessing ceremony is over (or trespass and tell her you're a True Soul).&#xD;&#xA;- Hairy Henry will say this AD while he is praying at a shrine to Myrkul in his room in the Barracks. It will be repeated every time he gets to the shrine." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="Hairy Henry, a male bugbear, one of three Skull Lashers in the Colony Barracks, repeated behaviour AD for when he is praying to Myrkul. He is preparing for war in the Absolute's army." />
