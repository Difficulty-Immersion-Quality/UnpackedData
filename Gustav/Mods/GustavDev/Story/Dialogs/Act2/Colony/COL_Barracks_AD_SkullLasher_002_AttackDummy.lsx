	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Barracks using the debugbook&#xD;&#xA;- Approach Krustine and her Skull Lashers and wait until the blessing ceremony is over (or trespass and tell her you're a True Soul).&#xD;&#xA;- Ironfinger will say this AD while she is attacking a training dummy in her room in the Barracks. It will be repeated every time she gets to the dummy." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="Ironfinger, a female halfling, one of three Skull Lashers in the Colony Barracks, repeated behaviour AD for when she is attacking an attack dummy. She is preparing for war in the Absolute's army." />
