	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Barracks with &quot;goto 728 16 14&quot;&#xD;&#xA;- Let the Mistress of Souls finish blessing the Skull Lashers. Do not come too close or interfere.&#xD;&#xA;- Talk to Hairy Henry after Krustine's blessing AD has finished.&#xD;&#xA;- If you attacked Ketheric on the Moonrise rooftop before coming to Colony, the Myrkulites will be hostile to you on sight." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="Default dialogue with Hairy Henry, one of the Skull Lashers in the Colony Barracks. Overseen by Krustine, Mistress of Souls. Shouldn't have too much to say. A male bugbear. (Myrkulite)" />
			<children>
