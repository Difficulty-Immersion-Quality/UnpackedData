	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MemLib_AllJars&quot; to get all the brain jars and teleport to the Brain Reading Device.&#xD;&#xA;- In front of you will be a severed head and a receptacle to its left. Insert the appropriate brain jar into the receptacle by interacting with it - the jar is called &quot;Butchered Mind&quot;.&#xD;&#xA;- After inserting the jar, it will appear on top of the receptacle and you can talk to the severed head for the dialogue to start." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="42" />
			<attribute id="synopsis" type="LSString" value="One of the memories available in the Colony &quot;Brain Reader&quot; depicts how a colony uses the flesh of its victims to expand, like a living thing." />
