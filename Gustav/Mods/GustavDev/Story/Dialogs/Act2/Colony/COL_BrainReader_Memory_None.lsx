	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MemLib_AllJars&quot; to get all the brain jars and teleport to the Brain Reading Device.&#xD;&#xA;- In front of you will be a severed head. Talk to it without inserting a brain jar into the receptacle next to it, and it will give this dialogue." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="10" />
			<attribute id="synopsis" type="LSString" value="The default dialog that plays when interacting with the brain reading device/severed head in the lower Colony. Interacting with the severed head will yield no information, as it only serves to narrate memories from brain jars inserted into the device." />
