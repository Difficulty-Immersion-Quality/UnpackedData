	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MemLib_AllJars&quot; to get all the brain jars and teleport to the Brain Reading Device.&#xD;&#xA;- In front of you will be a severed head and a receptacle to its left. Insert the appropriate brain jar into the receptacle by interacting with it - the jar is called &quot;Slave Mind&quot;.&#xD;&#xA;- After inserting the jar, it will appear on top of the receptacle and you can talk to the severed head for the dialogue to start.&#xD;&#xA;- This jar is one of the two jars that can be found in the tutorial level (Nautiloid)." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="16" />
			<attribute id="synopsis" type="LSString" value="One of the memories available in the Colony &quot;Brain Reader&quot; depicts a kidnapped thrall who knows MF's are in their head.  This is one of the brain jars that can be found in the tutorial area of the game." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
					</children>
				</node>
				<node id="defaultEmotions">
