	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Go to the lower floor of the Colony, to the Cleansing Room chute. Press the button on the console to drop the body out of the chute (happens only once). This corpse appearing requires no flags at the moment, but will require some in the future. Give yourself a Speak With Dead spell through ReCon and cast it onto the corpse." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="33" />
