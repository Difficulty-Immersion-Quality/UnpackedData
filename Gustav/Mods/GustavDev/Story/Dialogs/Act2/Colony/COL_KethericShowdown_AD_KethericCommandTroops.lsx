	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="This AD plays during the Ketheric Showdown in the lower Colony, when Ketheric uses his &quot;Command Troops&quot; ability to make his minions focus their efforts on attacking a specific target. This will only happen during the first phase, in Ketheric's human form.&#xD;&#xA;&#xD;&#xA;- Load SCL_Main_A&#xD;&#xA;- Using ReCon command &quot;oe KethericShowdown_Start&quot;  to teleport yourself there.&#xD;&#xA;- Go through the dialog, approach Ketheric, go through that dialog too. Combat will start.&#xD;&#xA;- It is advisable to enter godmode with ReCon command &quot;god&quot;. - Wait in combat for Ketheric to use this ability." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="13" />
			<attribute id="synopsis" type="LSString" value="This AD plays during the Ketheric Showdown in the lower Colony, when Ketheric uses his &quot;Command Troops&quot; ability to make his minions focus their efforts on attacking a specific target. This will only happen during the first phase, in Ketheric's human form." />
