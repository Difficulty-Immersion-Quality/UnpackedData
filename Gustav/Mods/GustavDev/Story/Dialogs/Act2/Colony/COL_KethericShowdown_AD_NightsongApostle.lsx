	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="This AD plays during the Ketheric Showdown in the lower Colony. It will play on Nightsong.&#xD;&#xA;&#xD;&#xA;- Load SCL_Main_A&#xD;&#xA;- Using ReCon command &quot;oe KethericShowdown_Start&quot;  to teleport yourself there.&#xD;&#xA;- Use &quot;oe KethericShowdown_Transform&quot;. This will initiate stage 2 and transform Ketheric into the Apostle of Myrkul.&#xD;&#xA;- Once Nightsong gets her first turn in combat (and she is available to speak), this AD will play on her." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="11" />
			<attribute id="synopsis" type="LSString" value="This AD plays during the Ketheric Showdown in the lower Colony, after Ketheric has transformed into his Apostle form/reached his second stage, Nightsong will react to this upon her first combat turn after this." />
