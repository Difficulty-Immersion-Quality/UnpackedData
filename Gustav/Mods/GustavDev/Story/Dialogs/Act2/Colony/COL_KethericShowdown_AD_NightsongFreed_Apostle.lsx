	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Go to lower Colony in SCL_Main_A, to the Ketheric Showdown boss chamber (&quot;oe KethericShowdown_Start&quot;). This dialog will trigger if Nightsong is freed after the Ketheric combat has already started, after his first phase." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="9" />
			<attribute id="synopsis" type="LSString" value="Ketheric comments on Nightsong being freed from her soul cage in the Colony, after the combat has already started, in his Apostle form. This means Ketheric will have been convinced to relent, and has been transformed into his Apostle form before Nightsong is freed from her soul cage." />
