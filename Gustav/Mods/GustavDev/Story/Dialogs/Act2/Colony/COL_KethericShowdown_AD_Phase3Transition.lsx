	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="This AD plays during the Ketheric Showdown in the lower Colony. It will play on Ketheric during the third phase of the fight, upon his first combat turn in the third phase.&#xD;&#xA;&#xD;&#xA;- Load SCL_Main_A&#xD;&#xA;- Using ReCon command &quot;oe KethericShowdown_Start&quot;  to teleport yourself there.&#xD;&#xA;- Skip to phase 2 of the combat by using command &quot;oe KethericShowdown_Transform&quot;, spam through the dialog.&#xD;&#xA;- Initiate phase 3 using &quot;oe KethericShowdown_Phase3&quot;.&#xD;&#xA;- This AD will play on Ketheric when his turn starts." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="This AD plays during the Ketheric Showdown in the lower Colony, when the third phase of the fight starts, this will play only once on Ketheric when his turn starts. Ketheric, in his Apostle of Myrkul form, calls upon the Necromites to sacrifice themselves to heal him." />
