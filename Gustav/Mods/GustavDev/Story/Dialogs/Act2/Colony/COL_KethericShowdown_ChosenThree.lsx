	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="loadlevel SCL_Main_A ; goto 833 -47 -25&#xD;&#xA;The Chosen Three cinematic will play upon entering the large trigger here (S_COL_KethericShowdown_ChosenThree_Box_1581a588-b69f-41c9-a591-5959751f3cdf). Entering this trigger also initializes the boss chamber and the NPCs inside correctly." />
			<attribute id="autoFidelity" type="LSString" value="Gold" />
			<attribute id="bronzeNodesCount" type="int32" value="47" />
			<attribute id="currentFidelity" type="LSString" value="Gold" />
			<attribute id="customNodesCount" type="int32" value="24" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="857" />
			<attribute id="overrideFidelity" type="LSString" value="None" />
			<attribute id="synopsis" type="LSString" value="Upon entering the Ketheric boss chamber on the lower floor of the Colony, the party will see a cinematic of the Chosen Three gearing up to continue on to the next stage of their master plan. Ketheric, Orin and Gortash will be discussing the next steps and the tension caused by the player's actions. Ketheric tadpoles Duke Ravengard and we lay eyes upon the Elder Brain in the flesh. Orin and Gortash depart with the Duke and the Elder Brain in a nearby Nautiloid to march onto Baldur's Gate. We see the Nautiloid appear above Moonrise Towers and cue the armies of the Absolute to start marching. Ketheric stays behind to deal with some local issues." />
			<attribute id="targetFidelity" type="LSString" value="None" />
