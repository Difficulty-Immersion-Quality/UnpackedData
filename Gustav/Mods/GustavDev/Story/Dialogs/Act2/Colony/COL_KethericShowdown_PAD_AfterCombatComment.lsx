	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use &quot;oe KethericShowdown_Defeat&quot;&#xD;&#xA;- Go through the interactive dialogue. A PAD should play afterwards." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="30" />
			<attribute id="synopsis" type="LSString" value="A PAD commenting on defeating Ketheric in his Apostle form at the end of the mind flayer Colony. After this the player will say that they need to go discuss the next course of action with their allies (alluding to Intermezzo in Moonrise Tower).&#xD;&#xA;At this point the players should take Ketheric's Netherstone (but we can't ensure that a player hasn't already looted said netherstone off his corpse by the time that end node is played).&#xD;&#xA;If there are two players available, they will banter together, otherwise a solo PAD will play." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="Neutral" />
