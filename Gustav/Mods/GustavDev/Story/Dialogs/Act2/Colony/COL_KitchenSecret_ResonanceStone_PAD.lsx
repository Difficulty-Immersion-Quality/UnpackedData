	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="This dialog is triggered once per user and nearby players upon gaining or losing the Eldritch Pleasure buff (determined by a flag) as bestowed by the aura of the Resonance Stone in the secret sideroom of the kitchen/dissection room on the lower floor of the Colony. The Resonance Stone can be picked up and may give the Eldritch Pleasure buff to those nearby the player carrying the stone. The removal dialog will only trigger upon losing the buff while inside a trigger near the Colony kitchen." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="10" />
			<attribute id="synopsis" type="LSString" value="The players react to gaining or losing the &quot;Eldritch Pleasure&quot; status effect from the Resonance Stone in the secret sideroom of the Colony kitchen/dissection room. This status is applied or removed upon gaining the &quot;Eldritch Pleasure&quot; buff bestowed by the aura effect of the Resonance Stone, and will only play once per user and nearby player. The removal dialog will only trigger upon losing the buff while inside a trigger near the Colony kitchen, as to avoid it playing unexpectedly during later parts of the game." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
