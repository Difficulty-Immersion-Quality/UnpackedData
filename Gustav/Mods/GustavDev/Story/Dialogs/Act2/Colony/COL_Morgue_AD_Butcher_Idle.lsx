	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use command &quot;oe COL_Butcher&quot; or go to the Colony Morgue with the debugbook&#xD;&#xA;- Observe Chop, the Colony butcher, repeating this sequential AD every now and then" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="13" />
			<attribute id="synopsis" type="LSString" value="Sequential, repeated AD for Chop, the Colony butcher. He will say a line every few seconds while in his idle behaviour. Chop is generally enjoying his job, but something deep beneath his enthralled exterior realizes the horror of his reality. Some of these lines could be considered a little bit song-like - Chop would be humming to himself while working." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
