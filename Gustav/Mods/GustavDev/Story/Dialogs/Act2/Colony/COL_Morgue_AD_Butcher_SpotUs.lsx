	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe morgue_us&quot; and &quot;oe COL_Butcher&quot;, in either order&#xD;&#xA;- Walk close to Us' cage door&#xD;&#xA;- Use command &quot;select S_COL_Morgue_Cage_Us&quot; and &quot;unlock&quot; - Us should start following you&#xD;&#xA;- Use command &quot;select player&quot; and &quot;statusapply GREATER_INVISIBILITY 10&quot;&#xD;&#xA;- Walk towards the corpse chute to make Us follow you and get spotted outside of its cage, without the player or anyone else in the party being visible&#xD;&#xA;- Chop will turn hostile on Us and say this AD" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="This AD plays when Chop spots Us the intellect devourer outside of his cage, without seeing a player nearby to arrest." />
