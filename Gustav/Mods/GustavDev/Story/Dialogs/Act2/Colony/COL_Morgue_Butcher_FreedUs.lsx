	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- &quot;goto 676 21 -74&quot; or &quot;oe COL_Butcher&quot; to get to the Colony Morgue&#xD;&#xA;- Use &quot;oe morgue_us&quot; to get Us into the cage here.&#xD;&#xA;- Free Us from the cage, and get spotted by Chop.&#xD;&#xA;- You can unlock/use/cast Knock on the cage door or somehow teleport Us outside of the cage." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="87" />
			<attribute id="synopsis" type="LSString" value="Crime reaction for Chop, the Colony Butcher, after we either free Us from its cage, mess with the cage or kill Us." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
						<node id="data">
