	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- &quot;goto 676 21 -74&quot; or &quot;oe COL_Butcher&quot; to get to the Colony Morgue&#xD;&#xA;- Use &quot;oe morgue_us&quot; to get Us into the cage here.&#xD;&#xA;- Talk to Us." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="29" />
			<attribute id="synopsis" type="LSString" value="Default dialogue with Us while they are in the Colony. Us is either locked in a cage in the Morgue, trying to sneak away from the Butcher, or thanking you for saving them, after which they will disappear." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
