	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe Necromancer_Audience&quot;&#xD;&#xA;- Wait for the Necromancer's turn in combat, he will send a zombie to light a candle.&#xD;&#xA;- When that zombie starts running to the candle, kill it with Ctrl+Shift+K.&#xD;&#xA;- On the Necromancer's next turn, he will send another zombie and play this AD." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="The necromancer is sending a zombie to light the candles that start an arcane ritual which drains the player's hitpoints and ultimately turns them into a zombie, after the player has extinguished them." />
			<children>
