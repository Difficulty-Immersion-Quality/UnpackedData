	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe Necromancer_Audience&quot;&#xD;&#xA;- Stay inside the cages.&#xD;&#xA;- Wait for the Necromancer's turn in combat, he will send a zombie to light the candles.&#xD;&#xA;- Wait for the Necromancer's next turn - he will start resurrecting the nearby NPCs and turn them into zombies. " />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="13" />
			<attribute id="synopsis" type="LSString" value="Balthazar casts a resurrection spell on a zombie while in combat after the Audience Route in the Colony.&#xD;&#xA;&#xD;&#xA;For help with Latin, contact either Tom Ryckeboer or Ilya Voulis." />
