	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Tadpoling Centre (ReCon command &quot;oe tc_teleport&quot;)&#xD;&#xA;- Interact with the mind flayer device that controls the pod.&#xD;&#xA;- Select the &quot;Release&quot; option.&#xD;&#xA;- killcombat&#xD;&#xA;- The Flaming Fist Manip will make this comment after some time during her idle behaviour." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="41" />
			<attribute id="synopsis" type="LSString" value="Behaviour AD from the Flaming Fist Manip after she is released from her pod in the mind flayer Colony's Tadpoling Centre. After the mind flayers are defeated, she will eventually make this comment about her surroundings." />
