			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Tadpoling Centre (ReCon command &quot;oe tc_teleport&quot;)&#xD;&#xA;- Interact with S_COL_TadpolingCentre_MemoryImprint_010_6f296af9-d391-414b-b62b-bb4bd961b91d" />
