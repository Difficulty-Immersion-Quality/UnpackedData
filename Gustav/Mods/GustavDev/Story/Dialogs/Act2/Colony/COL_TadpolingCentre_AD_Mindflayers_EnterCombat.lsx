	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use the debugbook's &quot;go to region&quot; options to go to the Colony Tadpoling Centre (act 2)&#xD;&#xA;- Use either ReCon command &quot;tc_releasepods&quot;, the debugbook quest flags and options, or just use the mind flayer device that controls the pods.&#xD;&#xA;- Mind flayers will all do this AD together in the first mind flayer combat turn." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="The mind flayers in the pods in the Tadpoling Centre are released and enter combat with the players. They will say this AD simultaneously on the first mind flayer combat turn, only once." />
