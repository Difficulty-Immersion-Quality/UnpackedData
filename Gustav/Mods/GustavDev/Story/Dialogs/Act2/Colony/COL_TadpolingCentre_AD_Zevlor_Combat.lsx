	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Go to the Colony Tadpoling Centre (ReCon command &quot;oe tc_teleport&quot;)&#xD;&#xA;- Interact with the mind flayer device that controls the pods, and choose to release the occupants of the pods.&#xD;&#xA;- Zevlor will play this AD on his first combat turn in the resulting combat." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Zevlor is freed from his imprisonment in one the pods in the Colony Tadpoling Centre. This AD is played on his first combat turn with the mind flayers that were also released from the pods." />
