	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use Recon command &quot;oe tc_teleport&quot;&#xD;&#xA;- Zevlor, if present (did not die before this point), will do repeated ADs while in the pod near 694; 18; 13" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="33" />
			<attribute id="synopsis" type="LSString" value="Repeated ADs from Zevlor, while he is (alive) inside one of the Colony's Tadpoling Centre pods. He is a bit dazed, mumbling about the events that lead up to his capture, mixed with traumatic memories of Elturel, Avernus, and his exile from his paladin order." />
			<children>
				<node id="defaultAttitudes">
					<children>
