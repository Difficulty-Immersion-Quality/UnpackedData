	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- &quot;goto 678 18 41&quot;&#xD;&#xA;- Interact with S_COL_TadpolingCentre_DarkUrgePod_1c7028d3-bb96-4bc5-8fb6-8b6e1d6a5e27&#xD;&#xA;- This interaction will be disabled if you enter the Colony without the Dark Urge in party/camp (meaning the DU would not exist in this playthrough). This only happens if you enter the Colony through gameplay or the debugbook. It will get re-enabled if you recruit the Dark Urge via debug." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="64" />
			<attribute id="synopsis" type="LSString" value="A player character interacts with a pod in the Tadpoling Centre that once belonged to the Dark Urge character. Other player characters may also investigate the pod, and imply something about who the pod belonged to if they succeed a skill check." />
