	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Recruit Wyll through the debugbook&#xD;&#xA;- Use the debugbook to go to region -&gt; COL -&gt; Tadpoling Centre&#xD;&#xA;- Walk towards the back of the Tadpoling Centre, near Mizora's pod&#xD;&#xA;- This PAD will play upon entering S_COL_Mizora_PodApproach_Box_ab898639-200e-4cf5-a693-dcb27d3a4fcc" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="11" />
			<attribute id="synopsis" type="LSString" value="Players comment when approaching Mizora's pod in the back of the Tadpoling Centre, provided she is there." />
