			<attribute id="HowToTrigger" type="LSString" value="Go to S_COL_Vault_PuzzleButton3_0f07d5be-159d-48f4-94c4-4c9ee0234423&#xD;&#xA;Click on the button.&#xD;&#xA;Start solving the puzzle.&#xD;&#xA;Solve for at least one of the nodes.&#xD;&#xA;Continue clicking nodes." />
