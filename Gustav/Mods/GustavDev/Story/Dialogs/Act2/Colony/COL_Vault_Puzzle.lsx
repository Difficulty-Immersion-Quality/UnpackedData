	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load GustavDev/SCL_Main_A&#xD;&#xA;- Teleport near S_COL_Vault_PuzzleButton3_0f07d5be-159d-48f4-94c4-4c9ee0234423&#xD;&#xA;- Press the button." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="152" />
			<attribute id="synopsis" type="LSString" value="This dialog plays when interacting with the button at the Colony Vault. It is an interaction with the mind within the illithid machine. Only companions with a tadpole may interact with the machine, or they will be denied access.&#xD;&#xA;&#xD;&#xA;Interacting with the mind allows the player to start solving the puzzle, reset the puzzle or talk to it after the puzzle is solved. When it is solved, the mind considers you its master, and you can ask it to do things like open or close the vaults (which contain rewards), show you a map of the Colony or &quot;shatter&quot; the mind to its original state." />
			<children>
				<node id="defaultAttitudes">
					<children>
