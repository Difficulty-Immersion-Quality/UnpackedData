	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. run oe SCE_SetupGnomes_SetFlags&#xD;&#xA;2. Run&#xD;&#xA;oe SCE_SetupGnomes_AllGnomes&#xD;&#xA;-or-&#xD;&#xA;oe SCE_SetupGnomes_NoBarcus&#xD;&#xA;-or-&#xD;&#xA;oe SCE_SetupGnomes_DeadN&#xD;&#xA;-or-&#xD;&#xA;oe SCE_SetupGnomes_DeadWulbren&#xD;&#xA;3. Run oe SCE_SetupDebrief&#xD;&#xA;4. Go to Act 2 Coordinates X:-166 Y:-170 (Moonrise Bazaar)&#xD;&#xA;5. Engage one of the gnomes in dialogue" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="24" />
			<attribute id="synopsis" type="LSString" value="Eagerly awaiting the next steps from their leader Wulbren. Ready to do whatever he directs. If Wulbren's dead they'll be noticably more downbeat." />
