	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use &quot;oe SCE_SetupDebrief&quot; or use the debugbook to go to act 2 region &quot;Epilogue&quot;.&#xD;&#xA;- Enter the trigger S_SCE_PartyVB_CurseStateComment_Trigger_fa7ca051-347b-4719-91ba-c60330e355f5 on the way to the road to Baldur's Gate near the army campsite." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="18" />
			<attribute id="synopsis" type="LSString" value="After the act 2 epilogue, the party comments on the state of the Shadow Curse before leaving for Baldur's Gate." />
			<children>
				<node id="defaultAttitudes" />
				<node id="defaultEmotions" />
				<node id="isImportantForStagings" />
