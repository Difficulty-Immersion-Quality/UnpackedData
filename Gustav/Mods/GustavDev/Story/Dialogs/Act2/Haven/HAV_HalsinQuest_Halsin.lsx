	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Speak to Halsin in HAV_CursedFist, but do not revive Art the Cursed Fist. Then speak to Halsin again." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="60" />
			<attribute id="synopsis" type="LSString" value="A fallback scene where Halsin has visited Art, the cursed flaming fist in the Last Light Inn, but the player has not yet fulfilled the requirements for the story to progress (waking Art by retrieving his guitar). Halsin needs to speak to Art, and supposes that there must be a way to stir him." />
			<children>
				<node id="defaultAttitudes">
