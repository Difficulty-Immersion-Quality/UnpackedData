	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. Go to debug book&#xD;&#xA;2. Set quest flags and optiond -&gt; act 2 -&gt; GLO - Lifting the Curse -&gt; Quest States -&gt; Halsin at camp with spirit&#xD;&#xA;3. Go to camp&#xD;&#xA;4. Talk to Thaniel" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="41" />
			<attribute id="synopsis" type="LSString" value="The player tries to interact with Thaniel, the spirit of the land, after Halsin rescues him from the Shadowfell. Thaniel is unconscious/unresponsive however.&#xD;&#xA;Later - Thaniel is recovering and able to talk. A somewhat otherworldly, wise far beyond his years 'child'. He instructs you on what comes next/offers his thanks once you have succeeded." />
			<children>
