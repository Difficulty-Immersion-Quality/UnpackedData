	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. DebugBook &gt; Goto Region: Act 2 &gt; ShadowCurseLands &gt; Mountain Pass Entry. &#xD;&#xA;&#xD;&#xA;2. Goto 57.566; 42.958; 134.421&#xD;&#xA;3. Agree to help fight the shadow creatures&#xD;&#xA;4. reCon killCombat&#xD;&#xA;5. Agree to follow them to Haven&#xD;&#xA;6. At CheckPoint Cinematic, press choice 1 all the way.&#xD;&#xA;7. Follow Lassandra all the way to a small makeshift altar&#xD;&#xA;8. Talk to her to trigger dialogue&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="186" />
			<attribute id="synopsis" type="LSString" value="Dialogue in Haven for one of the harper scouts you helped in SCL (SCL_HarperScouts_ShadowCreatures). She is mourning Yonas' death and gives some information about the shadow curse." />
