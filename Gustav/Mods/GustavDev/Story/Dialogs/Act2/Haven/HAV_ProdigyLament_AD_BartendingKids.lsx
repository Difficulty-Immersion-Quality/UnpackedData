			<attribute id="nextNodeId" type="uint32" value="75" />
			<attribute id="synopsis" type="LSString" value="Two kids are playing bartender in the bar of an abandoned inn. They're having fun initially, but after an attack on the town they start to get worried and are more downbeat." />
