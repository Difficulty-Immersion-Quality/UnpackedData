	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="-Use Debug Book to teleport to Act 2 -&gt; Haven -&gt; Outside checkpoint.&#xD;&#xA;- Go through checkpoint dialogue and enter Haven.&#xD;&#xA;- Walk to dock underneath the inn.&#xD;&#xA;- Use oe command oe prisonersreturn to spawn Harper and prisoners.&#xD;&#xA;- Click through dialog and observe ADs" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="17" />
			<attribute id="synopsis" type="LSString" value="ADs before and after the Harper at the docks inspects the gnomes/tieflings rescued from Moonrise jail. He's affable, but a little wary." />
