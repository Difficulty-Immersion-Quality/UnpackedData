	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="-Use Debug Book to teleport to Act 2 -&gt; Haven -&gt; Outside checkpoint.&#xD;&#xA;- Go through checkpoint dialogue and enter Haven.&#xD;&#xA;- Walk to dock underneath the inn.&#xD;&#xA;- Use oe command oe prisonersreturn to spawn Harper and prisoners&#xD;&#xA;- Go through the arrival dialog. When the dialog ends and the Harper starts to inspect the prisoners, speak to him." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="12" />
			<attribute id="synopsis" type="LSString" value="The Harper Inspecter is either looking over a batch of prisoners who've just arrived in Moonrise or has just finished inspecting them and is walking away when the player intercepts him. A gruff and suspicious guard." />
			<children>
