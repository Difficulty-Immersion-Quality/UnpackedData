	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Enter Haven (Last Light). Use debug book command &quot;Set quest flags&quot; -&gt; Act2 -&gt; Haven -&gt; Siege -&gt; Start Siege right away&#xD;&#xA;OR&#xD;&#xA;Enter Haven, go to Isobel room, kill Isobel (can kill marcus too).&#xD;&#xA;Fight through the Siege" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="SCL Haven: Isobel is kidnapped/killed and shadows engulf the inn, combat starts against the shadows. At some point a huge tentacle emerges from the fountain in the middle of the yard, destroying the fountain. Player character has a PAD comment on the event." />
			<children>
