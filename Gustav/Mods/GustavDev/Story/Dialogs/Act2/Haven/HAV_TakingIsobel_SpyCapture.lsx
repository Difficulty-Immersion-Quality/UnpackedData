											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="Marcus lands on the balcony, where Isobel had previously been performing her ritual. He lands kneeling, then rises to his full height, striding through the balcony door to take the same position as when he's already in the room." />
