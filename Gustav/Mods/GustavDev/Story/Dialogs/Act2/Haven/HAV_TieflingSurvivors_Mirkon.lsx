	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="61" />
			<attribute id="synopsis" type="LSString" value="Mirkon is the boy who survived the Harpies trying to lull him into the water in the grove. He is a timid boy who does his best to be brave, and dreams of being an adventurer one day. This is his dialogue in Haven, which covers the main states of the kidnapping, losing Isobel, reporting that his fellow tieflings died, when the player returns them and so on." />
			<children>
				<node id="defaultAttitudes">
