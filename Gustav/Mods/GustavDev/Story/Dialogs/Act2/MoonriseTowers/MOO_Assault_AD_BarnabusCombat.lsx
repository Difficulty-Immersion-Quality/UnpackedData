	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="For the Freed version, go through the kitchen fight sequence (left room on the main floor of the tower) and succeed the active rolls after he kill his master. Then start the assault and enter combat in the bazaar (Moonrise entrance)" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="A combat AD that plays on Barnabus' turn during the Moonrise Assault. If the player freed them, they are allied with them and will call back to that. Otherwise, he will do a generic combat AD." />
