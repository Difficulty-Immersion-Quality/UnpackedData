		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="load SCL_Main_A&#xD;&#xA;oe mooassault_alive 1&#xD;&#xA;Walk just far enough through the main door of the tower to cause the harpers/flaming fist to move into the tower&#xD;&#xA;Wait for Z'rell to trigger her ADs" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="20" />
			<attribute id="synopsis" type="LSString" value="The Harpers and/or Flaming Fist have moved into the main entrance of Moonrise, but have not started battle yet. She yells to them, taunting them and waiting for them to initiate the combat (by the player).&#xD;&#xA;&#xD;&#xA;Will only play if either Jaheira or Florrick are there, otherwise this AD will not trigger" />
