	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="loadlevel SCL_Main_A&#xD;&#xA;oe debugbook &gt; Go to region &gt; Act 2 &gt; HAV &gt; Isobels room&#xD;&#xA;Speak with isobel and accept protection spell.&#xD;&#xA;Another dialogue will follow. Protect Isobel.&#xD;&#xA;killcombat&#xD;&#xA;teleport S_MOO_KethericHound&#xD;&#xA;Follow through with dialogue and accept to deal with the goblins.&#xD;&#xA;crimes -disable&#xD;&#xA;teleport S_MOO_KethericHound&#xD;&#xA;interact with Hound, let her sniff you&#xD;&#xA;oe mooassault_alive&#xD;&#xA;this will trigger moonrise assault event&#xD;&#xA;teleport S_MOO_KethericHound" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="6" />
			<attribute id="synopsis" type="LSString" value="If Ketherics Hound smelled Isobel's blessing on the player, she will move into Isobels room and not participate in the combat ongoing throughout the tower, as she is lost in vague feelings and hazy memories of a life past." />
			<children>
				<node id="defaultAttitudes">
