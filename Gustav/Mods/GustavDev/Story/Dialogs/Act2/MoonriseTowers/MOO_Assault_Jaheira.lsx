	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Free Nightsong (oe mooassault_alive 1)&#xD;&#xA;Walk accross the bridge and talk to Jaheira" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="603" />
			<attribute id="synopsis" type="LSString" value="Jaheira lead the harpers to Moonrise after Nightsong was freed. As the player arrives to Moonrise, she greets them and can follow the player for the assault, If she doesn't follow, she will still join combat and move into the tower, in which the player has another oppertunity to have her follow them to fight Ketheric. Once Ketheric flees she will move up to the roof to offer recruitment." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
