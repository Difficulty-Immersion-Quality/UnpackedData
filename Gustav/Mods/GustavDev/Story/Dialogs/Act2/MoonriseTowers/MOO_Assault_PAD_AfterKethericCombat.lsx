	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use the debugbook -&gt; MOO quest flags and options -&gt; either start the Assault on Moonrise/Audience with the Absolute and attack Ketheric on the rooftop of Moonrise Tower&#xD;&#xA;- Get Ketheric to leave to the Colony (killcombat or Ctrl+Shift+K Ketheric, keep attacking Ketheric if he's still invulnerable)&#xD;&#xA;- After the combat is over, a player will say this PAD after a few seconds, while still on the rooftop and not blocked from talking" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="12" />
			<attribute id="synopsis" type="LSString" value="After attacking Ketheric on the Moonrise Rooftop, a tentacle tears through one of the towers and provides a hole that leads down into the mind flayer Colony. The party must follow Ketheric down there to continue the main quest, and this PAD should hint at that." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="Neutral" />
