	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Speak to the Bugbear on the bottom floor of MOO. " />
			<attribute id="autoFidelity" type="LSString" value="Copper" />
			<attribute id="currentFidelity" type="LSString" value="Copper" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="268" />
			<attribute id="overrideFidelity" type="LSString" value="None" />
			<attribute id="synopsis" type="LSString" value="A merchant selling in the bazaar on the ground floor of Moonrise Tower. He is a passionate bugbear who believes only the strongest should enjoy the Absolute's spoils. Players can earn his respect for a discount." />
			<attribute id="targetFidelity" type="LSString" value="None" />
			<children>
				<node id="defaultAttitudes">
					<children>
