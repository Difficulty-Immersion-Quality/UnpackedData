		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Talk to the Infernal Merchant at Moonrise (Araj Oblodra)&#xD;&#xA;Inquire her special offer and provide the blood&#xD;&#xA;Use the potion received&#xD;&#xA;Trigger a long rest" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="The player has given blood to the Infernal Vendor to make a unique potion. Once this potion is used, the player who gave the blood will feel sick after long rest (applying a debuff).&#xD;&#xA;The potion's effect depends on the player, but the debuff is universal." />
