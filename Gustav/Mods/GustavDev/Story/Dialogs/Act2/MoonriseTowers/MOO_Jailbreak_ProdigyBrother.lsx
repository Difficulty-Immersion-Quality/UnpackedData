			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="86" />
			<attribute id="synopsis" type="LSString" value="Cal is the brother of Lia and Rolan. He was ambushed along with the other tieflings and taken to Moonrise. His brother Rolan is at Last light inn. He is afraid but trying to be strong for the other tieflings, and is determined to save his sister. " />
