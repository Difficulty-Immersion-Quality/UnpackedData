	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Go to Ketheric's room&#xD;&#xA;Attack, roll a succesful perception check, or attack the loose floor board&#xD;&#xA;Open the container and read the letter (will trigger once the book UI closes)&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="The player found and read the letter written by Melodia, wife of Ketheric (string name: MOO_KethericsChambers_NoteFromWife). It is found in Ketherics room under a loose floor board. Reading this letter opens the option to have Ketheric stand down during the colony fight (he still dies). &#xD;&#xA;The VB helps support the notion that this letter is significant." />
