	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe Oubliette_Enter&quot;&#xD;&#xA;- Walk towards the window with the tentacle, towards the Colony. A player should say this comment." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Party reacts to seeing the Colony through the blood aquarium window that separates the Oubliette from the Colony Morgue. The intention here is to strongly imply that we cannot get into the Colony from the Oubliette." />
