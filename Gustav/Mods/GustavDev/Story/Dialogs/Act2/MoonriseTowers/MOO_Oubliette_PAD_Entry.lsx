	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="This dialog can be triggered either through jumping into either the main pit by the Moonrise prison, by jumping into the hole in one of the prison cells, or by climbing down the cliffside that players would usually use to escape the Oubliette in the other direction. If they come down through the cliffside, they need to enter the bloodbath section of the Oubliette for this dialog to trigger.&#xD;&#xA;&#xD;&#xA;Debug command &quot;oe Oubliette_Enter&quot; for the first time, then &quot;oe Oubliette_Entrance&quot; and &quot;oe Oubliette_Enter&quot; for the second time." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="A PAD reacting to arriving in the bloodbath section of the Oubliette. This will also trigger a second time if the player leaves the Oubliette area and re-enters the bloodbath section." />
			<children>
