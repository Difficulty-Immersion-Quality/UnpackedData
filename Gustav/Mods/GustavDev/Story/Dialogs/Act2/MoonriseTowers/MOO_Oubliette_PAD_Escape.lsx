	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="In order for this dialog to trigger, the player character must first enter the bloodbath section of the Oubliette (everything below the cave overhang) and then return up to the prison by entering S_MOO_Oubliette_Escape_Box. A quick way to trigger this dialog is by using the debug commands &quot;oe Oubliette_Enter&quot; and &quot;oe Oubliette_Entrance_Escape&quot; in order." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="A PAD of the players reacting to escaping the Oubliette after having been in the bloodbath section, where they literally waded through blood and human remains. The players climb up the cliff face and arrive in the cavern adjacent to the prison." />
			<children>
