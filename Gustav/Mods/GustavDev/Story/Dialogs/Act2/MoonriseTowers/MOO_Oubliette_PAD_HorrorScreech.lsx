	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load SCL_Main_A, run debug command &quot;oe Oubliette_Enter&quot; and walk towards the upper area of the Oubliette (trigger at 687.933; -33.278; -53.106). This will play once per user and nearby players.&#xD;&#xA;To set the &quot;seen hook horrors&quot; flag, select the desired character with Ctrl+Shift+LeftClick and run ReCon command &quot;SetCharacterOsirisFlag UND_HookHorrors_Knows_SeenHookHorrors&quot;, then use the commands above. To reset the Oubliette dialogs, use &quot;oe Oubliette_Reset&quot;." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="7" />
			<attribute id="synopsis" type="LSString" value="A PAD reacting to an audible screech from a hook horror in the Oubliette. The screech plays and the player character reacts to hearing it. If they have encountered Hook Horrors before in the Underdark, they will react differently." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
