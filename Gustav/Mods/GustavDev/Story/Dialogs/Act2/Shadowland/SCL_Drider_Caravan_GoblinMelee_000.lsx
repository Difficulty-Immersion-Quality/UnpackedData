	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Do NOT get the mission to go to Moonrise from Minthara. &#xD;&#xA;- Enter SCL via the mountain pass and proceed to the goblin camp below. &#xD;&#xA;- Gain access to the camp by talking to the checkpoint goblin. &#xD;&#xA;- Speak to the other goblin at the camp that has dialogue. " />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1093" />
			<attribute id="synopsis" type="LSString" value="If the player has been allowed entry to the camp, they can talk to this goblin to learn that they are waiting for a harp from Minthara with which to summon a guide that will protect them from the shadow curse on the path to Moonrise and if they haven't got it, they need to get it from Minthara. If the player has killed Minthara and hasn't already told the checkpoint goblin, they can mention it here." />
			<children>
