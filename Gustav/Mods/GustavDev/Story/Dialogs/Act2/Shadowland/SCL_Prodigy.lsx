	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. Load SCL_Main_A.&#xD;&#xA;2. Open the debug book and set up the tiefling path.&#xD;&#xA;3. Speak with Rolan at -77; 27; 147&#xD;&#xA;4. goto 10; 29; 99 and wait for Rolan to leave Haven.&#xD;&#xA;5. goto -77; 12; -117, killcombat and speak with him." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="50" />
			<attribute id="synopsis" type="LSString" value="Players find Rolan in SCL being attacked by the shadows after deciding to go by himself to save his siblings. After the dialog he will return to Haven" />
