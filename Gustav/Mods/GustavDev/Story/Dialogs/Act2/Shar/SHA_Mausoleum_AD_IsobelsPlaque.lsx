	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Interact with the plaque on Isobel's tomb in the mausoleum." />
			<attribute id="autoFidelity" type="LSString" value="Brass" />
			<attribute id="bronzeNodesCount" type="int32" value="1" />
			<attribute id="currentFidelity" type="LSString" value="Brass" />
			<attribute id="customNodesCount" type="int32" value="2" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="48" />
			<attribute id="overrideFidelity" type="LSString" value="None" />
			<attribute id="synopsis" type="LSString" value="Narrator/player to reading the plaque on Isobel's tomb . If they already know Isobel is Ketheric's daughter, the narrator reaction is different. The Elvish translates to 'Light slays darkness'.&#xD;&#xA;&#xD;&#xA;Note: the unusual structure of this is because the Origin PAD template is a greeting node and can't be connected to normally." />
