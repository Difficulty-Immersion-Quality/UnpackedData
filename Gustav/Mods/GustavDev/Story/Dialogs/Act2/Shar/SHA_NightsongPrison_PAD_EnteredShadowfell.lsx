	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Should play ~ 3 seconds after the end of the cinematic after entering Nightsongs Prison.&#xD;&#xA;&#xD;&#xA;‘loadlevel SCL_Main_A’ and ‘goto -440.61, -6.42, -1420.77’&#xA;&#xA;Cinematic will play, choose ‘Lead on, then.’ After the cinematic, wait for the PAD to play." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="PAD that plays after the end the cinematic upon entering the shadowfell in Nightsong's prison. Calls out to the player that they can jump down to the platforms below safely." />
