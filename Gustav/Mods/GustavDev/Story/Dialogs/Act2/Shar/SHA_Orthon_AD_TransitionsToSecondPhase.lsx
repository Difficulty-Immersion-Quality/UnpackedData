	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Engage in combat with the Orthon. Survive X number of rounds/kill X number of merregons/lower the Orthon's HP by X" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="9" />
			<attribute id="synopsis" type="LSString" value="During combat, the orthon escalates to phase two (intensifying his attacks and changing up his tactics). This is prompted by:&#xD;&#xA;- killing a certain number of minions&#xD;&#xA;- lowering his HP a certain amount&#xD;&#xA;- surviving for a certain number of combat rounds" />
			<children>
