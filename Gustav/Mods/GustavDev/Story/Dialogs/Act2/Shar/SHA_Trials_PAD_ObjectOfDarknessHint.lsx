			<attribute id="HowToTrigger" type="LSString" value="Enter the trial area after having read/not read the clue book in the library" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="8" />
			<attribute id="synopsis" type="LSString" value="The player speaks up on entering one of the trial areas in the temple of Shar. If they had previously read a book in the library area, they'll have an idea of what they need to do (navigate the maze and get through the locked door on the far side without being detected/setting off a trap). Otherwise they'll be none the wiser." />
