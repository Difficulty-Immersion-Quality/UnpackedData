	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Open ReCon and use &quot;statusapply INVISIBILITY&quot;, and also &quot;god&quot; to protect you from the shadowcurse.&#xD;&#xA;Go to -111; 24; -29 in SCL_Main_A which teleports Korrilla to-108; 24; -19.  Approach Korrilla and initiate dialog. If you are not invisible, she should teleport away if she sees you approach." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="This is a fallback one-liner. In case the Player manages to approach her an initiate dialog in TWN, Korrilla gives a cryptic one-liner to the player. No Hasmet node is needed, as she teleports away right after.&#xD;&#xA;She would be struggling with the shadow curse as she says this line." />
