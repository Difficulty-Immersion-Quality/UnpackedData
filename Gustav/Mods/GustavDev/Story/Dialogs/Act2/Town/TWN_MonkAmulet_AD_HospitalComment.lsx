	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/SCL_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MonkAmulet_Get&quot; and equip the amulet.&#xD;&#xA;- Go to the TWN hospital at S_TWN_MonkAmulet_HospitalBanter_Trigger_1d2c7a81-a1c3-47f8-b4ff-266ebfb3a70a&#xD;&#xA;- Resolve the Surgeon situation or kill the surgeon and his nurses" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="3" />
			<attribute id="synopsis" type="LSString" value="The spirit of the amulet comments on the shadow-cursed town's hospital, and the Sharran hospital stuff that aren't shy of torture and mutilation." />
