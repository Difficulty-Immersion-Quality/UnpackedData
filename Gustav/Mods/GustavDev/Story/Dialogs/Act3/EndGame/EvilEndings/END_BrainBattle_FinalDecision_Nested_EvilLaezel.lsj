                        "constructor" : {"type" : "FixedString", "value" : "TagAnswer"},
                        "editorData" : [
                           {
                              "data" : [
                                 {
                                    "key" : {"type" : "FixedString", "value" : "AnimationTags"},
                                    "val" : {"type" : "LSString", "value" : "[DAN] Nautiloids power up and move in the sky. Lae'zel motions with her right hand for the Dragon to descend above her. She looks to her left and glares at Mindlflayers stood off to the side. She then walks fowards towards the landed dragon. She approaches the Dragon's right side cheek and runs her hand lovlingly across it, the Dragon rears its head up and she crosses to the other side."}
                                 },
                                 {
                                    "key" : {"type" : "FixedString", "value" : "Attitude"},
                                    "val" : {"type" : "LSString", "value" : "Default"}
                                 },
                                 {
                                    "key" : {"type" : "FixedString", "value" : "CinematicNodeContext"},
                                    "val" : {"type" : "LSString", "value" : "The nautilods begin to power up, turning their noses outwards. With a gesture, Lae'zel summons a red dragon and mounts it, soaring upwards to join the fleet."}
                                 },
