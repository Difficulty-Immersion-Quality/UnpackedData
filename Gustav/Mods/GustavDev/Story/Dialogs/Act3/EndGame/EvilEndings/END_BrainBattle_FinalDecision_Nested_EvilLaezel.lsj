                                    "key" : {"type" : "FixedString", "value" : "AnimationTags"},
                                    "val" : {"type" : "LSString", "value" : "[DAN] Lae'zel turns her back on the crowd in front of her by turning to her left, and gazes upwards at the Nautloids hanging in the sky above her"}
