									<children>
										<node id="data">
											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="[DAN] Nautiloids power up and move in the sky. Lae'zel motions with her right hand for the Dragon to descend above her. She looks to her left and glares at Mindlflayers stood off to the side. She then walks fowards towards the landed dragon. She approaches the Dragon's right side cheek and runs her hand lovlingly across it, the Dragon rears its head up and she crosses to the other side." />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
											<attribute id="val" type="LSString" value="Default" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="The nautilods begin to power up, turning their noses outwards. With a gesture, Lae'zel summons a red dragon and mounts it, soaring upwards to join the fleet." />
										</node>
