                        "Tags" : [ {} ],
                        "UUID" : {"type" : "FixedString", "value" : "224cb091-04dd-3783-10b4-097be7f17811"},
                        "checkflags" : [ {} ],
                        "children" : [
                           {
                              "child" : [
