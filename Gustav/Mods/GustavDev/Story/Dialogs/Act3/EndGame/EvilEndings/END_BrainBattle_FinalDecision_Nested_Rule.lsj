                                    "val" : {"type" : "LSString", "value" : "Default"}
                                 },
                                 {
                                    "key" : {"type" : "FixedString", "value" : "CinematicNodeContext"},
                                    "val" : {"type" : "LSString", "value" : "Wider, and we see it's market day in Baldur's Gate. It's idlyllic, with bright sunshine, happy people wandering stalls, birdsong, bunting and more. A child runs by, carrying a ball."}
