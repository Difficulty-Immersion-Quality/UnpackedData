	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="They are 2 ways to trigger this dAD.&#xD;&#xA;1) Attack Orin before she spots you.&#xD;&#xA;2) Click the Dialog Attack button while in dialog with her.&#xD;&#xA;&#xD;&#xA;Different nodes is for when the players have a DU present during the initialition of this combat, or if the DU is somehow out of the temple." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="20" />
			<attribute id="synopsis" type="LSString" value="Normally, Orin will try to spot for players so she can start a dialog with them.At the end of the dialog with her, she normally turns into the Slayer in cinematic then combat ensues. ('Normally', because there is an edgecase in DU path that Orin can't turn into a Slayer if the DU already has the slayer form).&#xD;&#xA;&#xD;&#xA;But players can immediately attack Orin before her dialog and therefore miss the whole turn into slayer transformation.&#xD;&#xA;&#xD;&#xA;This AD is for 2 circumstances :-&#xD;&#xA;1) Players attack Orin before she spots them, therefore never entering dialog with her and therefore combat must begin immediately. Combat begins, she needs to wait for her turn to play this AD, at the end of which she will then turn into the slayer in gameplay.&#xD;&#xA;2) In dialog with her, players click the Attack button, and therefore ending the dialogue abruptly and starts the combat - which is then similar to scenario 1." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
					</children>
				</node>
				<node id="defaultEmotions">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
					</children>
				</node>
				<node id="isImportantForStagings">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="True" />
						</node>
						<node id="data">
							<attribute id="key" type="FixedString" value="1" />
							<attribute id="val" type="LSString" value="True" />
						</node>
					</children>
				</node>
				<node id="isPeanuts">
