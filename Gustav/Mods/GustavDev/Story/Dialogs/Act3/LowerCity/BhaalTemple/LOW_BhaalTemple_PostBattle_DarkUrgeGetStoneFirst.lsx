	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1) Start new game with Dark Urge&#xD;&#xA;2) Go to Act 3 -&gt; Bhaal Temple&#xD;&#xA;3) Talk to door or oe BTForceOpenDoor&#xD;&#xA;4) Defeat Orin&#xD;&#xA;5) Go through all the post battle dialogs.&#xD;&#xA;6) Depending on choice, will automatically get the netherstone or have to loot Orin's body for the Netherstone Dagger to get the Netherstone.&#xD;&#xA;7) If her stone is the first one before Gortash, dialog will trigger." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="179" />
			<attribute id="synopsis" type="LSString" value="Triggers when the Orin's stone is &#xD;&#xA;- picked up by the DarkUrge&#xD;&#xA;- is first stone to be picked up (as opposed to Gortash's stone picked up first)." />
