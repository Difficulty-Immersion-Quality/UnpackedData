			<attribute id="nextNodeId" type="uint32" value="10" />
			<attribute id="synopsis" type="LSString" value="Two nobles in Jannath Estate argue and finally come to blows. This oneliner is for if AngryNoble_002 is the survivor or if both nobles were calmed down. This noble was the one who purchased the fake painting." />
