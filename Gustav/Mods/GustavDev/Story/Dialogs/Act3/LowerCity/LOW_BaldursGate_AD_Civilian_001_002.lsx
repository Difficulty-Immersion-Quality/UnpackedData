			<attribute id="HowToTrigger" type="LSString" value="Being near S_LOW_BaldursGate_Civilian_001_01bf1f19-906d-49f6-92ae-2140132e4bde and &#xD;&#xA;S_LOW_BaldursGate_Civilian_002_65c3898f-aaf0-4690-8f3d-4f67ca38d8b1 and wait." />
