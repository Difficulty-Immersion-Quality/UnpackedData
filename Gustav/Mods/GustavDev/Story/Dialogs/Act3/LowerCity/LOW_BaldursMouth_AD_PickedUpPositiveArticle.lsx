	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Pick up one of the positive articles in the Baldurs Mouth Gazette Building. In baskets in CTY_Main_A at coords: (41, 37, -56) (44, 37, -44) (56, 37, -46) " />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="34" />
			<attribute id="synopsis" type="LSString" value="One line narrator PADs to call attention to a positive article being picked up in the Baldurs Mouth Gazette situation." />
			<children>
				<node id="defaultAttitudes">
					<children>
