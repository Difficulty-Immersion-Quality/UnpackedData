	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Debugbook option &quot;Act3 → LOW - Auntie Ethel's Revenge → Hag defeated&#xD;&#xA;- Attack the hag at -114; 26; -93&#xD;&#xA;- THe PAD will play after the combat is resolved" />
