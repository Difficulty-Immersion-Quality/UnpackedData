			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="One-liner with masked Quenora while she is under hag mind-control.&#xD;&#xA;&#xD;&#xA;Quenora can only be talked to by a player char if it wears a hag mask, otherwise Quenora attacks on sight." />
