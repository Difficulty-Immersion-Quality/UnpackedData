	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. Don't kill the hag beforehand!&#xD;&#xA;2. Use Scroll of Burning Pearls on the Circle of Pearls, it will start burning&#xD;&#xA;3. When the Circle of Pearls is burning, you need to throw Marrow of Mercy in it. At least one party member needs to be nearby the hag at the moment to witness the dialogue" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="12" />
			<attribute id="synopsis" type="LSString" value="If Marrow of Mercy is thrown in the burning Circle of Pearls while Vanra is still alive inside the hag, the hag will vomit her out in this dialogue" />
