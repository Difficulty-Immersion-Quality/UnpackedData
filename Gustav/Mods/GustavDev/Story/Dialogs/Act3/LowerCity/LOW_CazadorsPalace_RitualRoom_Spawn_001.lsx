	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Origin Debug Book (Ctrl+Shift+7 )&#xD;&#xA;Astarion - Act 3 Lower City - Black Mass Ritual - Telepor to the Ritual Chamber&#xD;&#xA;Make sure you don't have Astarion or leave him here.&#xD;&#xA;Move forward.&#xD;&#xA;A dialog with Cazador will start.&#xD;&#xA;Click on &quot;Attack Button&quot; or choose to attack him in the dialog.&#xD;&#xA;Defeat all the enemies.&#xD;&#xA;Cazador will fly to his sarcophagus.&#xD;&#xA;Click on the sarcophagus.&#xD;&#xA;Choose &quot;Kill Cazadoz&quot;&#xD;&#xA;Choose &quot;Break the staff and leave the prisoners in their cells&quot;&#xD;&#xA;Click on the spawn." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="51" />
			<attribute id="synopsis" type="LSString" value="Dialog with a spawn after Cazador is defeated, but spawn is not killed / left yet." />
