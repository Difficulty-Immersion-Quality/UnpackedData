	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Talk to the civilian4 in the group of wizards and stragglers around the fountain nearby the Sorcerous Sundries." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="10" />
			<attribute id="synopsis" type="LSString" value="One-liner for Ma Festina, Civilian4 from the Eastway's Wizards Vignette.&#xD;&#xA;" />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
