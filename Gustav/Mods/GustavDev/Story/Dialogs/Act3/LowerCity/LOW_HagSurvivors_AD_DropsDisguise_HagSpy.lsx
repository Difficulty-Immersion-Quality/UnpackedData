			<attribute id="nextNodeId" type="uint32" value="25" />
			<attribute id="synopsis" type="LSString" value="AD that hag spy (Jatlo) does when it drops disguise. Should speak in redcap voice.&#xD;&#xA;&#xD;&#xA;Other hag survivors available to participate in AD are shocked." />
