			<attribute id="nextNodeId" type="uint32" value="68" />
			<attribute id="synopsis" type="LSString" value="Dialogue between the players and Cora Highberry in the Serial Killer situation. Appears when Roger is dead (before or after Dolor appears). There are the first victims. A flag mark the dialogue happens before Dolor appears and other flag if Dolor is killed." />
