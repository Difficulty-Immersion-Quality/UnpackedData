	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Dig up the body in the graveyard at (TBD)&#xD;&#xA;- This is a quick moment just to draw attention to it. Doesn't need to be anything super involved." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="27" />
			<attribute id="synopsis" type="LSString" value="The player has dug up a body that looks particularly messy/bloody/scarred. For anyone else, this is just a simple &quot;Ew&quot; moment to question why you're going digging.  But for the Dark urge, they remember and are happy with it, which prompts a PAD that follows this up." />
