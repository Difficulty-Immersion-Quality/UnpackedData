		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Use ReCon command &quot;oe MonkAmulet_Get&quot; and equip the amulet.&#xD;&#xA;- Approach the underground entrance to the Sharran Grotto where Viconia can be found:&#xD;&#xA;S_LOW_MonkAmulet_SharranGrottoBanter_c00ca9c7-f1f4-4134-86b2-ebddcd3b6ae5" />
