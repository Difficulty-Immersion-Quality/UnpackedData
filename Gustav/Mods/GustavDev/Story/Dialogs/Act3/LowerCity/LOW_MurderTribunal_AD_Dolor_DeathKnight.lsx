	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Use &quot;oe MT_Start&quot;, enter the tombstone shop and go down into the Murder Tribunal&#xD;&#xA;- Use &quot;oe MT_Dolor 1&quot; to get Dolor to appear at the Death Knight guarding the courtroom.&#xD;&#xA;- Walk up near them without getting spotted, and this AD will play." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="If the party has killed two of the murder targets themselves, Dolor will come to the Murder Tribunal instead of his usual questline. When we approach, we can overhear Dolor and the Death Knight discussing that there is another aspirant seeking the Murder Tribunal." />
