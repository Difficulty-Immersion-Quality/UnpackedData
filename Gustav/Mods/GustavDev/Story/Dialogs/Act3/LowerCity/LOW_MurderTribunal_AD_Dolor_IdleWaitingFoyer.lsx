	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Use &quot;oe MT_Start&quot;, enter the tombstone shop and go down into the Murder Tribunal&#xD;&#xA;- Use &quot;oe MT_Dolor_NDK&quot; to get Dolor to appear near the courtroom door and have the Death Knight be dead.&#xD;&#xA;- These ADs will be repeated during his idle behaviours." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="14" />
			<attribute id="synopsis" type="LSString" value="Dolor waits at the door to the Murder Tribunal's courtroom - the Death Knight dead or absent, waiting on his rumoured rival to become an Unholy Assassin to appear." />
