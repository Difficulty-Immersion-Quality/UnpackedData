	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Use &quot;oe MT_Start&quot;, enter the tombstone shop and go down into the Murder Tribunal&#xD;&#xA;- Ctrl+Shift+K the Death Knight guarding the door&#xD;&#xA;- Use &quot;oe MT_Dolor 1&quot; to get Dolor to appear at the door.&#xD;&#xA;- This AD will play once when you enter combat with him." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="If we killed two targets from the murder target list, Dolor will make his way to the Murder Tribunal. If the Death Knight guarding the door is unavailable at this point, Dolor will instantly turn on us when he sees us." />
