	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Go to the Murder Tribunal: &quot;oe MT_Court&quot;&#xD;&#xA;- This AD will play during combat with Sarevok when he casts Target_LOW_DeathbringerAssault_Sarevok. He will need to perform a few main hand attacks before he can use this spell." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="13" />
			<attribute id="synopsis" type="LSString" value="Combat AD for Sarevok at the Murder Tribunal. Sarevok is presiding over the Murder Tribunal to judge Bhaalists who aspire to become Unholy Assassins. This is for when he uses Target_LOW_DeathbringerAssault_Sarevok" />
