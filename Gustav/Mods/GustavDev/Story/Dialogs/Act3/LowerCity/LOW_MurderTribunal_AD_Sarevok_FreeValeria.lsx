	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Use &quot;oe MT_Baptism&quot;, then use &quot;oe MT_Court&quot; to teleport to the courtroom.&#xD;&#xA;- Walk to your right into the abattoir, where Valeria is chained by a blood pool.&#xD;&#xA;- Unlock the chain or just try to use it. If Sarevok can see this, he will say this AD as combat starts." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Sarevok has a crime reaction to a party member trying to free Valeria from her chains at the Murder Tribunal/Blood Baptism." />
