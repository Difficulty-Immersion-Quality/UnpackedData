	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Go to the Murder Tribunal: &quot;oe MT_Court&quot;&#xD;&#xA;- This AD will play when Sarevok dies: S_LOW_MurderTribunal_Sarevok_ae9f784a-ea64-4297-95a7-8377e85231b6" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="9" />
			<attribute id="synopsis" type="LSString" value="Death AD for Sarevok at the Murder Tribunal. Sarevok is presiding over the Murder Tribunal to judge Bhaalists who aspire to become Unholy Assassins. He will react differently, depending on how far the player has advanced in to the Murder Tribunal." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
