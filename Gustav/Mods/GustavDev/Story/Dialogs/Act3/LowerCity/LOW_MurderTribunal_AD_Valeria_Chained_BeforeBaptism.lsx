	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- &quot;goto -1260 -1 466&quot; or go to S_LOW_MurderTribunal_Baptism_Valeria_Point_2ddc0200-9b06-436f-8d7c-b8f11498811c&#xD;&#xA;- Valeria will start the AD when she spots you, and it will be repeated every few seconds. It will stop if the Blood Baptism gets started." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="17" />
			<attribute id="synopsis" type="LSString" value="We enter the Abattoir, where Valeria is chained up, before starting the Blood Baptism. When she spots us, she will call for help." />
