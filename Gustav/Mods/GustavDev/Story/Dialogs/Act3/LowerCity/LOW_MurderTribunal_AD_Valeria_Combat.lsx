	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Use &quot;oe MT_Baptism&quot;, then use &quot;oe MT_Court&quot; to teleport to the courtroom.&#xD;&#xA;- Walk to your right into the abattoir, where Valeria is chained by a blood pool.&#xD;&#xA;- Unlock the chain with Knock, debug selecting and unlocking through ReCon or plain old lockpicking.&#xD;&#xA;- You and Valeria will enter combat against the Murder Tribunal. On Valeria's first combat turn, she will say this AD. You can always resurrect her if she winds up dead before her first turn." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="Valeria enters combat at the Murder Tribunal. She will say this AD on her first combat turn." />
