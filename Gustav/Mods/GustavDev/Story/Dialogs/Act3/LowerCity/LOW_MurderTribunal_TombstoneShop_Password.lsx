	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Go to the Tombstone shop door (goto 68 41 21) (near S_LOW_MurderTribunal_TombstoneShop_Door_ef23ee25-c62e-4fab-badd-4f98e364ebd5)&#xD;&#xA;- Use &quot;oe MT_Start&quot; to go to the door OR&#xD;&#xA;use &quot;oe MT_GetDolorItems&quot;, read Orin's note and learn the Word of Passage that will open the door.&#xD;&#xA;- Interact with the door while it is still locked." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="57" />
			<attribute id="synopsis" type="LSString" value="The secret entrance to the Murder Tribunal, the door of a decrepit tombstone shop, will open when the Word of Passage is spoken: Quietus (Latin for silence). The door will then unlock itself." />
