			<attribute id="nextNodeId" type="uint32" value="32" />
			<attribute id="synopsis" type="LSString" value="One shot voicebark in the Lower City. One origin character remarks something while passing through an area, then three other origins may respond to that remark. The respondents are prioritized from top to bottom. If none of the respondents are available, this won't play." />
