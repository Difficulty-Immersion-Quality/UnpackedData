		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/CTY_Main_A&#xD;&#xA;- Go to S_LOW_OneShotVB_Minsc_OnlyWhenCooked_Trigger_325f99d9-e33b-4e2c-b00f-94866d698504 near the Sahuagin attack beach/Lower City entrance waypoint, with the initiator + one the respondents in your party" />
