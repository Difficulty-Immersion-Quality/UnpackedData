	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Interact with the Wine Cart from dolor. The carts are outside the crime scenes before he kills everybody.&#xD;&#xA;&#xD;&#xA;Coordinates (example, every wine cart will react like this: larian://bookmark?mod=GustavDev&amp;level=BGO_Main_A&amp;camPos=-1729.846802;40.721867;637.162964&amp;camTarget=-1726.875488;39.579491;638.617798&#xD;&#xA;&#xD;&#xA;Relevant commands in this page: https://larianstudios.atlassian.net/wiki/spaces/GUS/pages/2624159852/Lower+City+Debug+Commands&#xD;&#xA;" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="2" />
			<attribute id="synopsis" type="LSString" value="PAD when the player interact with Dolor's wine cart in the serial killer situation. If the player knows about the poison, they will smell it." />
