	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Talk to one of the animated armors other than Klank in Sorcerous Sundries. CTY_Main_A  -17; 26; -88" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="4" />
			<attribute id="synopsis" type="LSString" value="One liner for the animated armors that are inside Sorcerous Sundries (other than Klank). It should also take into account that this dialog can fire while the animated armor is unconcious due to having cast Dispel Magic." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
						</node>
