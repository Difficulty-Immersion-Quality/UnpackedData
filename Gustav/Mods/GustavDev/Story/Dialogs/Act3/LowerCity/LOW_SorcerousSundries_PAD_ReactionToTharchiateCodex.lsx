	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="In CTY_Main_A, call oe LOW_SorcerousSundries_GetTomes&#xD;&#xA;Read Tharchiate Codex" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="6" />
			<attribute id="synopsis" type="LSString" value="PAD for when reading the Tharchiate Codex, a necromantic book that applies a curse which reduces CON stats (which can be removed to get a positive boost)  but also will allow players to read the last page of Necromancy of Thay. &#xD;&#xA;&#xD;&#xA;If players have managed to read " />
