		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="When asking Rolan in dialog to take the player's to Lorroakan and him going to the location where he casts a portal.&#xD;&#xA;Location: BGO_Main_A: 222; 16; 324" />
