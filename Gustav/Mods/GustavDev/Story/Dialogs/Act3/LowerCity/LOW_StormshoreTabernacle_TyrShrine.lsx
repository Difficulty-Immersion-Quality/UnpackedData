			<attribute id="HowToTrigger" type="LSString" value="Interact with the Tyr Shrine in CTY_Main_A 117; 44; -27" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="135" />
			<attribute id="synopsis" type="LSString" value="Dialog when interactin with the shrine dedicated to Tyrin Stormshore Tabernacle. All players will be able to read some lore about the god. Additionally, if the player is a cleric of Tyr they'll be able to give offerings and pray/communicate with the god to get a blessing." />
