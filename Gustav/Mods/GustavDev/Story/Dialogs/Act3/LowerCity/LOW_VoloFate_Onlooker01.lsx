			<attribute id="HowToTrigger" type="LSString" value="Approach the place of the situation at -229; 4; -160 in lower city, in the docks, near the steelwatch foundry.&#xD;&#xA;One player character should start the execution scene, another player character can talk to other NPCs." />
			<attribute id="needLayout" type="bool" value="False" />
