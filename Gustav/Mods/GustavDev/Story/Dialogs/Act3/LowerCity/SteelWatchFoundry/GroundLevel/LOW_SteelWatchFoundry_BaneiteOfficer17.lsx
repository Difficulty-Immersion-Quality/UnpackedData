	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CTY_Main_A&#xD;&#xA;Open Recon, and turn on Roll Amazing&#xD;&#xA;teleport to -269; 6; -149, and a dialog will auto-start&#xD;&#xA;Chose the deception option in the dialog&#xD;&#xA;After succeeding, the dialog should soon end&#xD;&#xA;walk up to and click on S_LOW_BaneiteOfficer17_f6614259-eec4-4c38-b87b-cf5c806be6fd" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="6" />
			<attribute id="synopsis" type="LSString" value="One-liner dialog with Baneite Officer 17, available if the player resolves the dead mans switch threat dialog without combat." />
