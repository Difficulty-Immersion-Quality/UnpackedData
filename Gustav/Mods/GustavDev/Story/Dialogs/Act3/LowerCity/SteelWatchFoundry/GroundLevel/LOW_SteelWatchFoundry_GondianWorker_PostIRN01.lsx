		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CTY_Main_A&#xD;&#xA;Go to -267; 6; -148&#xD;&#xA;pick a fight with the people in the room and kill everyone&#xD;&#xA;open debugbook and set all prisoners to saved&#xD;&#xA;Watch the confrontation dialog&#xD;&#xA;killcombat in the fight that starts&#xD;&#xA;click on GondianWorker_PostIRN01" />
