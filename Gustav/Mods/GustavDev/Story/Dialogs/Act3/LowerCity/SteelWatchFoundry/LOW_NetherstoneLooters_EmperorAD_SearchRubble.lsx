	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load CTY_Main_A&#xD;&#xA;Go to steel watch foundry&#xD;&#xA;Get at least one stone through the debug book (Emperor Prelude)&#xD;&#xA;Drop at least one inside the steel watch foundry building&#xD;&#xA;SetGlobalOsirisFlag IRN_IronThrone_State_Destroyed" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="A player left a Netherstone on the ground inside the Steel Watch Foundry before they blew it up.The Emperor is not very impressed and directs them towards the rubble to try finding them. They'll encounter a small group of Kobolds digging through the rubble who will be holding them. On entering combat, they'll run away." />
