		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load CTY_Main_A&#xD;&#xA;Go to steel watch foundry&#xD;&#xA;Get at least one stone through the debug book (Emperor Prelude)&#xD;&#xA;Drop at least one inside the steel watch foundry building&#xD;&#xA;SetGlobalOsirisFlag IRN_IronThrone_State_Destroyed&#xD;&#xA;Walk to the Looters (should see Netherstone icons on map)&#xD;&#xA;Kill them&#xD;&#xA;Loot the stones" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="A player left a Netherstone on the ground inside the Steel Watch Foundry before they blew it up.The player spots the looters who have the Netherstones and must chase after them. Once they get the stones back, the Emperor expresses relief and a bit of frustration." />
