		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CTY_Main_A&#xD;&#xA;use the debugbook to set up that the gondians are saved, and to teleport to the control centre of the foundry &#xD;&#xA;use &quot;oe LOW_GiveBomb&quot;&#xD;&#xA;go to the boss room on the floor and kill the bosses&#xD;&#xA;go to the switchboard and use the bomb in the dialog to blow up the foundry&#xD;&#xA;go through the outcome dialog, and side with the gondians&#xD;&#xA;once the dust settles, talk to Toobin" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="28" />
			<attribute id="synopsis" type="LSString" value="Toobin thanks the player for his help. If the the player has earned gondian support, Toobin also swears to back them up in the END fight." />
