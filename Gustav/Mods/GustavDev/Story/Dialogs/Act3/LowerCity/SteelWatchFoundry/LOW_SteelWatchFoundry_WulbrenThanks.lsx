	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load up CTY_Main_A&#xD;&#xA;Go to -1935; -7; 206&#xD;&#xA;Use Debug Book to get runepowder bomb&#xD;&#xA;(Set quest flags and options &gt; Act 3 Low &gt; 10. Steel Watch Foundry &gt; 5. Get Runepowder Bomb&#xD;&#xA;Click Neural Switchboard &gt; 3. Carefully place the Rune Bomb Powder) &#xD;&#xA;wait for the explosion cinematic to finish&#xD;&#xA;observe the cutscene.&#xD;&#xA;Choose to side with Wulbren against the Gondians, and kill them.&#xD;&#xA;Click on Wulbren to trigger this dialog" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="13" />
			<attribute id="synopsis" type="LSString" value="Followup dialog with Wulbren after siding with him in the Foundry Outcome. He promises the player to back them up in the END fight." />
			<children>
				<node id="defaultAttitudes">
					<children>
