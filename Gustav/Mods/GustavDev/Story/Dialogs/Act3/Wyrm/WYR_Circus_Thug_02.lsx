	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Debug book, act 3, wyrm's crossing, circus of the last days. One of the thugs standing near the animal cages by dribbles' stage." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="3" />
			<attribute id="synopsis" type="LSString" value="Dialog with the thug - Dribbles-doppelganger associate. Stands near the animal cages. Probably just a one-liner." />
			<children>
