	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Load up GustavDev/BGO_Main_A&#xD;&#xA;- Either go to Carmen's Cosmetics shop, encounter Naaber and push him into the river, or use &quot;oe Naaber_Chasm&quot;. The shop is near S_WYR_FigaroSister_DEBUG_Point_5d7b1276-f516-49f2-b3ea-3564b25cd35c&#xD;&#xA;- Find Naaber at S_WYR_FigaroSister_Naaber_Riverside_Point_e8cf2752-8e2e-4318-a3cf-cf985d7b43cd and get spotted by him." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="We re-encounter Naaber on the Chiontar riverside after we &quot;accidentally&quot; pushed him off the Wyrm's Crossing bridge into the river." />
