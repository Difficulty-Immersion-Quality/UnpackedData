	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Load BGO_Main_A. Debug book &quot;Quest Flags and Options&quot; -&gt; Act3 -&gt; Ironhand Gnomes -&gt; Setup all gnomes -&gt; 1. Set up Oppress Scene.&#xD;&#xA;Debug Book -&gt; Go To Region -&gt; Act3 -&gt; WYR -&gt; Ironhand gnomes hideout.&#xD;&#xA;Find Nickels and talk to him. If a crime dialog is started, mention Barcus or Wulbren or &quot;I'm here to trade&quot; option." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="39" />
			<attribute id="synopsis" type="LSString" value="Ironhand gnome Nickels hiding in a smithy cellar (came from Act2)" />
