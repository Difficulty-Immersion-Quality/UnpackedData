			<attribute id="nextNodeId" type="uint32" value="24" />
			<attribute id="synopsis" type="LSString" value="Gnome S_WYR_Ironhand_Artificer_002 stands near cave entrance into Ironhand basement lab. It greets player with a dialog. If player follows gnomes after checkpoint, they're included in the dialog." />
