			<attribute id="nextNodeId" type="uint32" value="5" />
			<attribute id="synopsis" type="LSString" value="A family of refugees plead for the Open Hand Temple to open its doors for them again. They rely on the charity of the church to survive and mourn the death of the Head Priest too. This is the tiefling mother's one-liner. " />
