			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="35" />
			<attribute id="synopsis" type="LSString" value="Players enter a cave where there can see a pitch battle between Farlin and Caïros forces are about to be underway.&#xD;&#xA;&#xD;&#xA;When the players approach closer, players will overhear |Attackers|(Farlins forces from The Guild) and Smugglers (Cairo's forces from Stone Man) taunting each other." />
