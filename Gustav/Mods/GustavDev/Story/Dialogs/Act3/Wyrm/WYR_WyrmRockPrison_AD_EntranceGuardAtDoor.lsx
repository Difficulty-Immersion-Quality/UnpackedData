	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="goto 51; 12; -746&#xD;&#xA;click on the sleeping guard to start a dialog&#xD;&#xA;Intimidate her to let you in&#xD;&#xA;wait for her to approach the door and play the AD&#xD;&#xA;&#xD;&#xA;if you want to see the confused node: unlock the door before talking to the guard." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="11" />
			<attribute id="synopsis" type="LSString" value="You convinced the entrance guard in Wyrm Rock Prison to open the entrance door for you. This is the AD she says after she approached the door to unlock it.&#xD;&#xA;1. If the door is destroyed she is VERY confused, and comments on how it got destroyed during her shift.&#xD;&#xA;2. If the door is locked she unlocks it and welcomes you in&#xD;&#xA;3. If the door is unlocked she is confused by that." />
