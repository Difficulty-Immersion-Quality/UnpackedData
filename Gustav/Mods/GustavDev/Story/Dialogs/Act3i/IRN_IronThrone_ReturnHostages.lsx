	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Talk to S_IRN_EscapingHostage_614ceeec-24a5-4491-98b3-a83ab235f158 after successfully escaping the IronThrone.&#xD;&#xA;&#xD;&#xA;If he died, talk to any other surviving hostage." />
			<attribute id="autoFidelity" type="LSString" value="Copper" />
			<attribute id="currentFidelity" type="LSString" value="Copper" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="133" />
			<attribute id="overrideFidelity" type="LSString" value="None" />
			<attribute id="synopsis" type="LSString" value="The hostage thanks the player for saving him and/or the other hostages. He will also beg the player to save their families working in the Steelwatch Foundry, giving them the quest if they don't already have it. If the majority of Iron Throne hostages AND the majority of Steelwatch Foundry hostages are saved, they will aid the player by making Steel Watchers on their side for the final battle. Otherwise they won't.&#xD;&#xA;&#xD;&#xA;Some variation based on whether the player has already been to the Steelwatch foundry and knows about the Iron Throne hostages, promised to help free the Iron Throne hostages, or doesn't know anything about them.&#xD;&#xA;&#xD;&#xA;If enough Iron Throne hostages survived, they should hint the player that they might reward them if they save their families. If not enough Iron Throne hostages survived, they should make it clear that the player will not receive any signifacant reward, other than narrative and thanks.&#xD;&#xA;&#xD;&#xA;If EscapedHostage has died, the dialog will trigger by talking to any one of the other surviving Gondians, but a Narrator will talk instead of all of them, as otherwise the permutations are too many. This will be an edge case, as EscapedHostage is very very likely to survive.&#xD;&#xA;" />
			<attribute id="targetFidelity" type="LSString" value="None" />
