	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="If the main spokesperson is dead after leaving the Iron Throne, but at least one other hostage survived, players can speak to them instead. Can be triggered by clicking on 9 different potential hostages.&#xD;&#xA;&#xD;&#xA;To trigger, play through the IronThrone by using the DebugBook -&gt; Set Quest Flags and Options -&gt; LOW -&gt; Iron Throne -&gt; StartGameplay. Then follow through the situation and save whichever number of hostages you need.&#xD;&#xA;&#xD;&#xA;ToDo: Add easier debug ways to trigger this dialog." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="28" />
			<attribute id="synopsis" type="LSString" value="Brief narrator nodes concluding the hostage rescue situation. Should be treated as an edge case. Can be triggered by clicking on 9 different potential hostages and they can be both male and female." />
			<children>
