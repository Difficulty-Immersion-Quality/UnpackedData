	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Speak to Santoria - S_GLO_IronThrone_Group4_Prisoner1 a1831c84-e443-4ba9-95b2-49758d576bf5 - (-9; 37; 19)  in the Dock warehouse after saving them.&#xD;&#xA;&#xD;&#xA;Quick setup:&#xD;&#xA;- Load CTY_Main_A&#xD;&#xA;- Use Debug Book (Ctrl + Shift + 9)&#xD;&#xA;- Set Quest Flags and Options -&gt; Act3 (LOW) -&gt; Iron Throne -&gt; Change State -&gt; Back At Docks -&gt; MajoritySaved&#xD;&#xA;- Then talk to the NPC" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="3" />
			<attribute id="synopsis" type="LSString" value="One of the hostages thanks you for saving them from the Iron Throne. One-liner dialog." />
