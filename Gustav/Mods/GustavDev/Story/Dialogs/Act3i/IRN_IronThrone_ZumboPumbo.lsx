	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Speak to Zumbo Pumbo - S_GLO_IronThrone_Group1_Prisoner1_18991627-0e38-44d0-a8ac-31e1105d5392 in the Dock warehouse after saving them.&#xD;&#xA;&#xD;&#xA;Quick setup:&#xD;&#xA;- Load CTY_Main_A&#xD;&#xA;- Use Debug Book (Ctrl + Shift + 9)&#xD;&#xA;- Set Quest Flags and Options -&gt; Act3 (LOW) -&gt; Iron Throne -&gt; Change State -&gt; Back At Docks -&gt; MajoritySaved&#xD;&#xA;- Then talk to Zumbo Pumbo" />
			<attribute id="needLayout" type="bool" value="False" />
