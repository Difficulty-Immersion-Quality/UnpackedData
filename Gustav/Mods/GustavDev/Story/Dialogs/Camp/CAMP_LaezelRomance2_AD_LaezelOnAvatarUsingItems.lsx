	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Plays the first time the player uses an item in the duel against Laezel." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="Laezel remarks that using items is cheating in a duel like this. But she brushes it off in the end. We don't have reactivity in the romance scene to cover for the player cheating, so this should be very light and playful rather than blaming.&#xD;&#xA;&#xD;&#xA;Added because Laezel will be blocked from using items during the fight as we don't want her to deplete the player's resources." />
