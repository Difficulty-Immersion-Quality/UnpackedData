											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="[LILI] Daisy lift up one hand to stop incoming object and another to push player back to waking world. Player floats up and flys backward" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
											<attribute id="val" type="LSString" value="Default" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="Daisy gestures, floating the player off the ground, then astral pushes them back to the waking world!&#xD;&#xA;&#xD;&#xA;|Daisy puts their hand over our heads again. While they speak, the dream world fades away. The player wakes in camp, dazed. The night sky is peaceful - no battle to be seen. |" />
										</node>
