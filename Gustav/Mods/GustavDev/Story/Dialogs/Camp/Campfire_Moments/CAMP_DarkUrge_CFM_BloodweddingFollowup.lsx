			<attribute id="nextNodeId" type="uint32" value="610" />
			<attribute id="synopsis" type="LSString" value="Jaheira and Minsc confront the Dark Urge about their recent revelation they are a Bhaalspawn. Depending on how much the player has given into Bhaal, they are either more sympathetic, or almost hostile. But either way, they are supportive and want to use their knowledge of fighting alongside Bhaalspawn in the past to convince you that you can do good" />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
