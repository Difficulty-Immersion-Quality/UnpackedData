			<attribute id="nextNodeId" type="uint32" value="272" />
			<attribute id="synopsis" type="LSString" value="Voss arrives at camp and attempts to sway Laezel to his side after the events of the Creche. The Avatar can push Laezel to either agree or stay true to herself, potentially putting her on her Orpheus path." />
