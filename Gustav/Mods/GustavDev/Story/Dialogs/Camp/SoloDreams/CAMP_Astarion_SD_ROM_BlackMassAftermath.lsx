											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="[AL] Custom animation for AST finishing his carving and sitting down. This will be the _IN of his sitting state., , [AMN][GUS-254172] Astarion sits back on his heels. He stows away the dagger (right hand) then both hands rest loosely onto his lap. He remains in silent contemplation., (Note:Astarion is still kneeling down), , Player stands back and watches. They understand this is a solemn moment (Use stand construction anim)" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
											<attribute id="val" type="LSString" value="Default" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="Astarion sits back, looking at his gravestone, saying nothing. He's in a moment of deep reflection. (Note:Astarion is still kneeling down)" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="CinematicObjects" />
											<attribute id="val" type="LSString" value="[AMN][GUS-254172] Old gravestone prop with Astarion's name. No longer covered in ivy" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="CustomCineArtKeysPresent" />
