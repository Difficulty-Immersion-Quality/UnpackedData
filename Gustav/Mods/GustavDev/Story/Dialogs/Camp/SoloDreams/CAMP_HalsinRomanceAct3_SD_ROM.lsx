								<node id="editorData">
									<children>
										<node id="data">
											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="[ADAM] Halsin and player kiss against the tree trunk" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
											<attribute id="val" type="LSString" value="Default" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="[SCENE] Halsin seizes the player and presses them up against the trunk of a tree. He kisses them once again, then sinks to his knees, out of frame. The player gasps and keeps his head down with one hand. Offscreen, Halsin utters a muffled, animalistic growl. Halsin rises to his feet." />
