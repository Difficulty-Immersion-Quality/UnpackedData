		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Recruit Companion Astarion.&#xD;&#xA;Speak to companion Astarion." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="778" />
			<attribute id="synopsis" type="LSString" value="Astarion's default dialog - the dialog you'll get if you speak to him while you're just wandering around in the world. This will cover many different topics, filling out his background and expanding on plot points as they happen in the game. Be aware that at the start of the game, players will not be aware that Astarion is a vampire. These nodes have been marked in the context field." />
			<children>
				<node id="defaultAttitudes" />
				<node id="defaultEmotions" />
				<node id="isImportantForStagings" />
