		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Use companion debug to recruit Karlach + click on her" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="1042" />
			<attribute id="synopsis" type="LSString" value="Karlach's inparty dialogue when she's in your party and you click on her&#xD;&#xA;Order of nodes:&#xD;&#xA;1. Generic Blockers (Jaheira/Other avatar/Mindflayer)&#xD;&#xA;2. IPRDs (will override anything under it)&#xD;&#xA;3. Astarion's bite&#xD;&#xA;4. InRegion/specific situations branches&#xD;&#xA;5. Romance branches.&#xD;&#xA;6. Default greeting node." />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="10" />
							<attribute id="val" type="LSString" value="Neutral" />
