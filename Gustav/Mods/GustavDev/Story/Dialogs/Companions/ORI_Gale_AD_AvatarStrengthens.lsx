	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="With Gale, use the debug spell to mimic consuming a magic item while in combat." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="39" />
			<attribute id="synopsis" type="LSString" value="Gale Avatar has consumed a magic item and the bomb abates.&#xD;&#xA;&#xD;&#xA;This is a fallback AD." />
			<children>
				<node id="defaultAttitudes">
