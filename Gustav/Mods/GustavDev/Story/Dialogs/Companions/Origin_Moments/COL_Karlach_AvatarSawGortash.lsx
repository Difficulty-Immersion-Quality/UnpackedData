			<attribute id="HowToTrigger" type="LSString" value="Play as avatar Karlach and defeat Ketheric." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="33" />
			<attribute id="synopsis" type="LSString" value="Karlach has a self-dialogue after defeating Ketheric in the Colony. This is also her first chance to reflect on seeing Gortash - she was NOT expecting to see him here. Because the moment right before this is very high-intensity, I wanted this Karlach moment to start low-intensity and ramp up from there." />
