	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. Recruit Karlach as companion.&#xD;&#xA;2. Speak with any steel watcher by clicking on it as Karlach with no one around.&#xD;&#xA;OR&#xD;&#xA;1. Recruit Karlach as avatar.&#xD;&#xA;2. Speak with any steel watcher by clicking on it with her." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="336" />
			<attribute id="synopsis" type="LSString" value="Karlach encounters a steel watcher and it thinks she is one of them because of her infernal engine." />
