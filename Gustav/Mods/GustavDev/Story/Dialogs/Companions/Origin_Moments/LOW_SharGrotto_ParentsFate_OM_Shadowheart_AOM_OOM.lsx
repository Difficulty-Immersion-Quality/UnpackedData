									<children>
										<node id="data">
											<attribute id="key" type="FixedString" value="AnimationTags" />
											<attribute id="val" type="LSString" value="Shadowheart doubles over in pain as her incurable wound flares intensely. Her parents also writhe in agony. Finally it abates and Shadowheart stands" />
										</node>
										<node id="data">
											<attribute id="key" type="FixedString" value="Attitude" />
