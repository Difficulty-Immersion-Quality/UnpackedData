		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="1. Spare Nightsong on Avatar Shadowheart&#xD;&#xA;2. Leave the Shadowfell&#xD;&#xA;3. Be pulled in the dialog" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="10" />
			<attribute id="synopsis" type="LSString" value="Angered by Shadowheart not killing Nightsong, Shar pulls Shadowheart aside in the Shadowfell. Tormenting her through her incurable wound till her hair turns white before ejecting her." />
