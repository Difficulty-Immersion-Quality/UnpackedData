	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Ctrl+Shift+7 (Origin Debug Book)&#xD;&#xA;For AOM&#xD;&#xA;Astarion - Recruit - As Avatar&#xD;&#xA;Astarion - Origin Moments - Gur Camp&#xD;&#xA;Approach the Gur Camp as Astarion Avatar.&#xD;&#xA;For OOM&#xD;&#xA;Astarion - Recruit - As Companion&#xD;&#xA;Astarion - Origin Moments - Gur Camp&#xD;&#xA;Approach the Gur Camp as Astarion Companion without other characters in party." />
