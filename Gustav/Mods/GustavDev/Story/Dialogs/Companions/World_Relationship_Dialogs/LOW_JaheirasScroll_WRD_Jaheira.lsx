	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="- Go to Jaheira's Basement with Jaheira&#xD;&#xA;- Straight ahead on the barrel, there's a semi-hidden scroll beneath a book and surrounded by rare alchemy items. Pick it up (Or read it) and Jaheira will talk to you about it&#xD;&#xA;&#xD;&#xA;Bookmark: larian://bookmark?name=CTY_JaheiraBasement&amp;mod=GustavDev&amp;level=CTY_Main_A&amp;camPos=-1537.007690;17.081484;1028.876221&amp;camTarget=-1537.406860;16.317995;1028.368530" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="38" />
			<attribute id="synopsis" type="LSString" value="Player has found Jaheira's scroll (marked 'Last Resort') in the basement of her house.&#xD;&#xA;&#xD;&#xA;Mainly this is here to open up the fact that Jaheira has something deeper you need to talk about and give you the follow up in her default dialogue" />
