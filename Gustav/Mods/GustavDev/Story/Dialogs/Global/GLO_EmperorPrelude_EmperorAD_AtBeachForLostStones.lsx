	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Go to Iron Throne&#xD;&#xA;Debug add the stones (example, oe glo_emperorprelude_gortash)&#xD;&#xA;Drop one or more stones&#xD;&#xA;Leave Iron Throne&#xD;&#xA;goto 35 7 -142&#xD;&#xA;Go to the beach" />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="9" />
			<attribute id="synopsis" type="LSString" value="The player has arrived to the beach where the Sahuagin Attack Booster takes place in lower city after losing a stone in Iron Throne. Depending what state the attack is in (hasn't started yet, already happened and merchant alive or dead), then the stones can be found on either the leading Sahuagin, the merchant which the player needs to buy back, or in a dead fish that swallowed them. " />
