			<attribute id="nextNodeId" type="uint32" value="1" />
			<attribute id="synopsis" type="LSString" value="AD oneliner for when after players have antagonized Us in the nautiloid and fled, &#xD;&#xA;&#xD;&#xA;He will appear in the mindflayer room with the other intellect devourer. When seeing players again, he will say this AD while entering combat." />
