									<attribute id="val" type="LSString" value="0" />
								</node>
								<node id="flagParameterMappings" />
								<node id="speakerLinking" />
								<node id="speakerlist" />
							</children>
						</node>
					</children>
				</node>
			</children>
		</node>
	</region>
</save>