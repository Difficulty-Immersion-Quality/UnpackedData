											<attribute id="key" type="FixedString" value="CinematicNodeContext" />
											<attribute id="val" type="LSString" value="The player looks up as the static gyro rings above their head shudder into life, slowly rotating independently.&#xD;&#xA;&#xD;&#xA;Pillars rise from the darkness. As each pillar locks into place, one of the four gyro rings locks with its crystal pointing toward the pillar followed by the pillar crystal illuminating.&#xD;&#xA;&#xD;&#xA;A glow forms in the middle of the gyro as a portal opens in the doorway, a beam of light then shooting out of the gyro’s glow straight through the portal." />
										</node>
									</children>
								</node>
							</children>
