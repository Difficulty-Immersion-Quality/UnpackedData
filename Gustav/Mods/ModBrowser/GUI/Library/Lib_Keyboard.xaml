<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:ls="clr-namespace:ls;assembly=Code"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    mc:Ignorable="d">

    <!-- Adding in the header tab templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Core;component/Library/NavButtons_k.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Storyboard x:Key="ShowSidePanel" FillBehavior="Stop">
        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="ModInfoSidePanel" Duration="0:0:0.5" To="0,0,-350,0">
            <ThicknessAnimation.EasingFunction>
                <SineEase EasingMode="EaseInOut"/>
            </ThicknessAnimation.EasingFunction>
        </ThicknessAnimation>
    </Storyboard>

    <Storyboard x:Key="HideSidePanel" FillBehavior="Stop">
        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="ModInfoSidePanel" Duration="0:0:0.5" To="0,0,-1410,0">
            <ThicknessAnimation.EasingFunction>
                <SineEase EasingMode="EaseInOut"/>
            </ThicknessAnimation.EasingFunction>
        </ThicknessAnimation>
    </Storyboard>

    <DataTemplate x:Key="NavigationButtonTemplate" DataType="ls:LSButton">
        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="27"/>
                <ColumnDefinition Width="58"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="19"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="92"/>
            </Grid.RowDefinitions>
            <Image x:Name="iconEnabled" Grid.Column="1" Source="{StaticResource navigationIconDefault}" Stretch="Uniform"/>
            <Image x:Name="iconDisabled" Grid.Column="1" Source="{StaticResource navigationIconDefault}" Stretch="Uniform" Visibility="Collapsed"/>
            <TextBlock x:Name="label" Grid.Column="2" Text="{Binding .,Converter={StaticResource TranslatedStringConverter}}" MaxWidth="280" FontSize="{StaticResource SmallFontSize}" FontWeight="Bold"
                       Foreground="{StaticResource LS_accent75TxtColor}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" noesis:Text.StrokeThickness="4" noesis:Text.Stroke="{StaticResource LS_tint00}"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Path=IsEnabled, RelativeSource={RelativeSource Mode=Self}}" Value="False">
                <Setter Property="Foreground" Value="{StaticResource LS_extraspecialTxtColor}" TargetName="label"/>
                <Setter Property="Visibility" Value="Collapsed" TargetName="iconEnabled"/>
                <Setter Property="Visibility" Value="Visible" TargetName="iconDisabled"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ls:LSButton}}}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource LS_accent100TxtColor}" TargetName="label"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType={x:Type ls:LSButton}}}" Value="OpenModBrowserHome">
                <Setter Property="Source" Value="{StaticResource homeIconEnabled}" TargetName="iconEnabled"/>
                <Setter Property="Source" Value="{StaticResource homeIconDisabled}" TargetName="iconDisabled"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType={x:Type ls:LSButton}}}" Value="OpenModBrowserDownload">
                <Setter Property="Source" Value="{StaticResource browseIconEnabled}" TargetName="iconEnabled"/>
                <Setter Property="Source" Value="{StaticResource browseIconDisabled}" TargetName="iconDisabled"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType={x:Type ls:LSButton}}}" Value="OpenModBrowserInstalled">
                <Setter Property="Source" Value="{StaticResource installedIconEnabled}" TargetName="iconEnabled"/>
                <Setter Property="Source" Value="{StaticResource installedIconDisabled}" TargetName="iconDisabled"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <ControlTemplate x:Key="BrowserTopButtons">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Rectangle Height="164" Width="Auto" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Top" Fill="Black" />

            <Image Grid.Column="0" Source="{StaticResource NavButtonsBgSide}" HorizontalAlignment="Right" VerticalAlignment="Top" Height="162" Stretch="None"/>

            <Grid Grid.Column="2" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Grid.ColumnSpan="4" Source="{StaticResource NavButtonsBgSideRight}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="162" Stretch="None" />

                <Control Grid.Column="0" x:Name="ModMemoryWidget" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0, 0, 20, 0">
                    <Control.Template>
                        <ControlTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" x:Name="ModMemoryWidgetTitle" Text="{Binding Source='hb12566a0g9c86g497fgb496gded088e143b0', Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent100TxtColor}" FontSize="{StaticResource ScaledSmallishFontSize}" HorizontalAlignment="Right" TextWrapping="Wrap"/>
                                <StackPanel Grid.Row="1" x:Name="ModMemoryWidgetContentComplete" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Image x:Name="ModMemoryWidgetImageComplete" Source="{StaticResource detailsFileSize}" Stretch="None"/>
                                    <TextBlock x:Name="MemoryTextComplete" FontWeight="DemiBold">
                                    <Run x:Name="CurrentMemoryComplete" Text="{Binding Data.UsedModDiskSpace, Converter={StaticResource FileSizeConverter}}"/>
                                    <Run Text="{Binding Source='hd64bfe4cgadadg4468g8b0ag70330ffc717c', Converter={StaticResource TranslatedStringConverter}}"/>
                                    <Run Text="{Binding Data.TotalModDiskSpace, Converter={StaticResource FileSizeConverter}}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Row="1" x:Name="ModMemoryWidgetContentSimple" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                                    <Image Source="{StaticResource detailsFileSize}" Stretch="None"/>
                                    <TextBlock x:Name="MemoryTextSimple" FontWeight="DemiBold">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                                <Binding Source="h9fed80b2g8f32g401dg8e1eg40bfbb55593e"/>
                                                <Binding Path="Data.UsedModDiskSpace" Converter="{StaticResource FileSizeConverter}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <!-- Some platforms can't get TotalModDiskSpace. Hide ModMemoryWidgetContentComplete and show ModMemoryWidgetContentSimple instead. -->
                                <DataTrigger Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="False">
                                    <Setter TargetName="ModMemoryWidgetContentComplete" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ModMemoryWidgetContentSimple" Property="Visibility" Value="Visible"/>
                                </DataTrigger>

                                <!-- Show image and text as red if not enough space -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="True"/>
                                        <Condition Binding="{Binding ActiveTabID}" Value="Browse"/>
                                        <Condition Binding="{Binding InDetailsView}" Value="True"/>
                                        <Condition Binding="{Binding SelectedMod.InstallState}" Value="Uninstalled"/>
                                        <Condition Value="False">
                                            <Condition.Binding>
                                                <MultiBinding Converter="{StaticResource LessThanOrEqualMultiConverter}">
                                                    <Binding Path="PotentialUsedModDiskSpace"/>
                                                    <Binding Path="Data.TotalModDiskSpace"/>
                                                </MultiBinding>
                                            </Condition.Binding>
                                        </Condition>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="ModMemoryWidgetImageComplete" Property="Source" Value="{StaticResource detailsFileSizeRed}"/>
                                    <Setter TargetName="MemoryTextComplete" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="True"/>
                                        <Condition Binding="{Binding ActiveTabID}" Value="Browse"/>
                                        <Condition Binding="{Binding InDetailsView}" Value="True"/>
                                        <Condition Binding="{Binding SelectedMod.VersionState}" Value="Older"/>
                                        <Condition Value="False">
                                            <Condition.Binding>
                                                <MultiBinding Converter="{StaticResource LessThanOrEqualMultiConverter}">
                                                    <Binding Path="PotentialUsedModDiskSpace"/>
                                                    <Binding Path="Data.TotalModDiskSpace"/>
                                                </MultiBinding>
                                            </Condition.Binding>
                                        </Condition>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="ModMemoryWidgetImageComplete" Property="Source" Value="{StaticResource detailsFileSizeRed}"/>
                                    <Setter TargetName="MemoryTextComplete" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="True"/>
                                        <Condition Binding="{Binding ActiveTabID}" Value="Installed"/>
                                        <Condition Binding="{Binding SelectedMod.VersionState}" Value="Older"/>
                                        <Condition Value="False">
                                            <Condition.Binding>
                                                <MultiBinding Converter="{StaticResource LessThanOrEqualMultiConverter}">
                                                    <Binding Path="PotentialUsedModDiskSpace"/>
                                                    <Binding Path="Data.TotalModDiskSpace"/>
                                                </MultiBinding>
                                            </Condition.Binding>
                                        </Condition>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="ModMemoryWidgetImageComplete" Property="Source" Value="{StaticResource detailsFileSizeRed}"/>
                                    <Setter TargetName="MemoryTextComplete" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                                </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Control.Template>
                </Control>

                <ls:LSButton x:Name="accountButton" Grid.Column="1" VerticalAlignment="Center" Command="{Binding CustomEvent}" CommandParameter="OpenAccountManagement">
                    <ls:LSButton.Template>
                        <ControlTemplate TargetType="ls:LSButton">
                            <StackPanel Orientation="Vertical" Background="Transparent">
                                <TextBlock x:Name="accountStateLabel" ls:TextBlockFormatter.SourceText="{Binding Source=hb9ff318ag5054g4b96gb5cfg1f05349b6174, Converter={StaticResource TranslatedStringConverter}}"
                                           Foreground="{StaticResource LS_baseTxtColor}" FontSize="{StaticResource ScaledSmallishFontSize}" TextWrapping="Wrap" TextAlignment="Right" Margin="0,0,12,-4"/>
                                <TextBlock x:Name="accountName" Text="{Binding Data.LarianNetUserName}" Foreground="{StaticResource LS_extraspecialTxtColor}" HorizontalAlignment="Right" Margin="0,0,12,0" TextAlignment="Right"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="Offline">
                                    <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText"
                                            Value="{Binding Source=h9f4ad432g31dfg43e5gad49gffbf79873345, Converter={StaticResource TranslatedStringConverter}}"/>
                                    <Setter TargetName="accountName" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="OnlineNoAccountConnected">
                                    <Setter TargetName="accountName" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="LarianConnected">
                                    <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source=h27e58bb5g18d9g4044ga4f4ga166113693ab, Converter={StaticResource TranslatedStringConverter}}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="ModioConnected">
                                    <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source=hfa041695g2655g4540g91aege61c49fd327b, Converter={StaticResource TranslatedStringConverter}}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ls:LSButton.Template>
                </ls:LSButton>
                <ls:LSButton x:Name="avatarButton" Grid.Column="2" Margin="5,0,0,0" Command="{Binding CustomEvent}" CommandParameter="OpenAccountManagement">
                    <ls:LSButton.Template>
                        <ControlTemplate TargetType="ls:LSButton">
                            <Grid Background="Transparent">
                                <Image x:Name="avatarFrame" Source="{StaticResource accountFrameDefault}" Stretch="None"/>
                                <Rectangle x:Name="avatarIcon" Width="{StaticResource avatarIconSize}" Height="{StaticResource avatarIconSize}" Fill="{Binding CurrentPlayer.CommunityIcon}"/>
                                <Image x:Name="defaultIcon" Width="{StaticResource avatarIconSize}" Height="{StaticResource avatarIconSize}" Stretch="Fill" Source="{StaticResource accountUnknownPortrait}" Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="avatarFrame" Property="Source" Value="{StaticResource accountFrameHighlight}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="Offline">
                                    <Setter TargetName="avatarIcon" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="defaultIcon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="OnlineNoAccountConnected">
                                    <Setter TargetName="avatarIcon" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="defaultIcon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ls:LSButton.Template>
                </ls:LSButton>
                <ls:LSButton x:Name="closeButtonTop" Grid.Column="3" VerticalAlignment="Top" Margin="{StaticResource SmallCloseButtonDefaultMargin}" Style="{StaticResource SmallCloseButton}"
                         SoundID="UI_HUD_Options_Close" Command="{Binding CustomEvent}" CommandParameter="CloseWidget" BoundEvent="UICancel">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseEnter">
                            <b:InvokeCommandAction Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="UI_Shared_Hover"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </ls:LSButton>
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-68,0,0" >
                <ls:LSButton x:Name="browseButton" Content="{Binding Source='h355d15dag71c4g4c86g941bg0cc9388a89d2', Converter={StaticResource TranslatedStringConverter}}" Command="{Binding CustomEvent}" CommandParameter="OpenModBrowserDownload" Template="{StaticResource NavButtonTemplate}" Style="{StaticResource ShortNavButtonStyle}"/>

                <ls:LSButton x:Name="installedButton" Content="{Binding Source='h22d04d59g92cdg4f7ag8185g50d6e34d2e3a', Converter={StaticResource TranslatedStringConverter}}" Command="{Binding CustomEvent}" CommandParameter="OpenModBrowserInstalled" Template="{StaticResource NavButtonTemplate}" Style="{StaticResource ShortNavButtonStyle}"/>
            </StackPanel>

            <StackPanel x:Name="zoomOutPanel" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,600,25" Visibility="Collapsed">
                <TextBlock x:Name="zoomOutHint" Text="{Binding Source=hce6efd68gaa45g4da2gaf87g58a6d03bb3f7, Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center"
                               Foreground="{StaticResource LS_extraspecialTxtColor}" FontSize="{StaticResource ScaledLargeFontSize}"/>
                <ls:LSButton x:Name="zoomOutButton" Margin="10,0,0,0" Style="{StaticResource CloseButton}"
                             SoundID="UI_HUD_Options_Close" Command="{Binding ToggleScreenshotZoomCommand}" BoundEvent="UICancel">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="MouseEnter">
                            <b:InvokeCommandAction Command="{Binding DataContext.PlaySoundEvent, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="UI_Shared_Hover"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </ls:LSButton>
            </StackPanel>
        </Grid>

        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding ActiveTabID}" Value="Browse">
                <Setter TargetName="browseButton" Property="Style" Value="{StaticResource ShortSelectedNavButtonStyle}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ActiveTabID}" Value="Installed">
                <Setter TargetName="installedButton" Property="Style" Value="{StaticResource ShortSelectedNavButtonStyle}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding InScreenshotZoom}" Value="True">
                <Setter TargetName="closeButtonTop" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="accountButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="avatarButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ModMemoryWidget" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="zoomOutPanel" Property="Visibility" Value="Visible"/>
                <Setter TargetName="installedButton" Property="IsEnabled" Value="False"/>
                <Setter TargetName="browseButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="Offline">
                <Setter TargetName="accountButton" Property="CommandParameter" Value="OpenSignUp"/>
                <Setter TargetName="avatarButton" Property="CommandParameter" Value="OpenSignUp"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="OnlineNoAccountConnected">
                <Setter TargetName="accountButton" Property="CommandParameter" Value="OpenSignUp"/>
                <Setter TargetName="avatarButton" Property="CommandParameter" Value="OpenSignUp"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="WarningLabelTemplateWide" TargetType="Control">
        <StackPanel Orientation="Horizontal" Margin="-16,0,0,0">
            <Rectangle Fill="{TemplateBinding Background}" VerticalAlignment="Top" MinHeight="{StaticResource MinimumWarningIconSize}" MinWidth="{StaticResource MinimumWarningIconSize}"/>
            <TextBlock VerticalAlignment="Top" ls:TextBlockFormatter.SourceText="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}" MaxWidth="1900" Foreground="{TemplateBinding Foreground}" Style="{StaticResource TooltipStringBodyStyle}" Margin="4,2,0,0"/>
        </StackPanel>
    </ControlTemplate>

    <DataTemplate x:Key="ModPreviewTemplate" DataType="{x:Type ls:VMModPreview}">
        <Grid x:Name="modPreviewRoot" HorizontalAlignment="Stretch" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- Mod Image -->
            <Rectangle x:Name="modScreenshot" Grid.Column="0" Fill="{Binding MainScreenshot.Screenshot}" Margin="9,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Width="242">
                <Rectangle.Height>
                    <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                        <Binding Path="ActualWidth" ElementName="modScreenshot"/>
                        <Binding Path="Fill.ImageSource.Width" ElementName="modScreenshot"/>
                        <Binding Path="Fill.ImageSource.Height" ElementName="modScreenshot"/>
                    </MultiBinding>
                </Rectangle.Height>
            </Rectangle>

            <Grid Margin="20,0,20,0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <!-- Mod Title -->
                <TextBlock x:Name="modTitle" Grid.Row="0" HorizontalAlignment="Left" Width="Auto" FontSize="{StaticResource ScaledLargeFontSize}" Foreground="{StaticResource LS_modsTextColor}" Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <!-- Mod Main Tag -->
                <TextBlock x:Name="modMainTag" Grid.Row="1" FontSize="{StaticResource ScaledLargeFontSize}" Foreground="{StaticResource LS_modsTextColor}" Text="{Binding Tags[0].Name}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Visibility="{Binding Text, RelativeSource={RelativeSource Self}, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter='EmptyString'}"/>
            </Grid>
        </Grid>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                <Setter TargetName="modTitle" Property="Foreground" Value="{StaticResource LS_tint100}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding MainScreenshot.HasScreenshotTexture}" Value="False">
                <Setter TargetName="modScreenshot" Property="Fill" Value="{StaticResource ugcDisabledMaskSmall}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DataContext.Data.IsUGCDisabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True">
                <Setter TargetName="modScreenshot" Property="Fill" Value="{StaticResource ugcDisabledMaskSmall}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <ControlTemplate x:Key="ModBrowserBackgroundTemplate">
        <Grid x:Name="HudRoot" Background="{StaticResource LS_PanelBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Image x:Name="MenuBackground" Grid.Row="0" Grid.RowSpan="2" Source="{StaticResource OptionsBackground}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="UniformToFill"/>

            <Rectangle Grid.Row="1" Height="1280" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Fill="{StaticResource BottomToTopDarkGradientBrush}" />

            <Control Grid.Row="0" Template="{StaticResource BrowserTopButtons}" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>

            <ContentPresenter Grid.Row="1" x:Name="HudRootPresenter" Margin="0,-10,0,0"/>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="SubscribeButtonTemplate">
        <ls:LSButton x:Name="subscribeButton" Style="{StaticResource BigBrownButtonStyle}" Content="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282', Converter={StaticResource TranslatedStringConverter}}"
                     Command="{Binding DataContext.SubscribeModCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}"/>
    </ControlTemplate>

    <ControlTemplate x:Key="SubscribeButtonTemplateBrowse">
        <ls:LSButton x:Name="subscribeButton" Style="{StaticResource SmallBrownButtonStyle}" Content="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282', Converter={StaticResource TranslatedStringConverter}}"
                     Command="{Binding DataContext.SubscribeModCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}" Width="460"/>
    </ControlTemplate>

    <ControlTemplate x:Key="AlreadySubscribedButtonTemplate">
        <TextBlock Text="{Binding Source='hf3bbce24gd050g434bg9600g167a0c64da09', Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_modsContentSubscribedColor}" TextAlignment="Center" Margin="0,0,0,6" />
    </ControlTemplate>

    <ControlTemplate x:Key="DownloadButtonTemplate">
        <ls:LSButton x:Name="downloadButton" Style="{StaticResource BigBrownButtonStyle}" Content="{Binding Source='h0c9f422cga55cg4d2agb342ga095b82caa58', Converter={StaticResource TranslatedStringConverter}}"
                 Command="{Binding DataContext.DownloadModCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}" />
    </ControlTemplate>

    <ControlTemplate x:Key="DownloadButtonTemplateBrowse">
        <ls:LSButton x:Name="downloadButton" Style="{StaticResource SmallBrownButtonStyle}" Content="{Binding Source='h0c9f422cga55cg4d2agb342ga095b82caa58', Converter={StaticResource TranslatedStringConverter}}"
                 Command="{Binding DataContext.DownloadModCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}" Width="460"/>
    </ControlTemplate>

    <ControlTemplate x:Key="UpdateButtonTemplate">
        <ls:LSButton x:Name="updateButton" Style="{StaticResource BigBrownButtonStyle}" Content="{Binding Source='h99003f95g016bg4254g9fe4g6a731fc37383', Converter={StaticResource TranslatedStringConverter}}"
                 Command="{Binding DataContext.UpdateModVersionCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}" />
    </ControlTemplate>

    <ControlTemplate x:Key="DowndateButtonTemplate">
        <ls:LSButton x:Name="downdateButton" Style="{StaticResource BigBrownButtonStyle}" Content="{Binding Source='h36dc087egdc23g4b24gb7e7gf098613f1651', Converter={StaticResource TranslatedStringConverter}}"
                 Command="{Binding DataContext.UpdateModVersionCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}" />
    </ControlTemplate>

    <ControlTemplate x:Key="AlreadyDownloadedButtonTemplate">
        <TextBlock x:Name="alreadydownloadedButton" Text="{Binding Source='hef4ffa0ag1cabg4591g9d22gb787a3ba177f', Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_modsContentSubscribedColor}" TextAlignment="Center" Margin="0,0,0,6" />
    </ControlTemplate>

    <ControlTemplate x:Key="DownloadingBarTemplate">
        <Border x:Name="downloadBorder" BorderThickness="2" BorderBrush="{StaticResource LS_modsDownloadBarBorderColor}" Width="360" VerticalAlignment="Center" ClipToBounds="True" Background="{StaticResource LS_modsDownloadBarBgColor}" Effect="{StaticResource ShadowEffectSmall}">
            <Rectangle x:Name="runningBar" Fill="{StaticResource LS_modsDownloadBarColor}" Width="200" Height="8"/>
        </Border>
        <ControlTemplate.Triggers>
            <EventTrigger RoutedEvent="Loaded" SourceName="runningBar">
                <BeginStoryboard x:Name="IndefiniteLoading">
                    <Storyboard>
                        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="runningBar" Duration="0:0:1" From="0,0,200,0" To="0,0,-200,0" AutoReverse="True" RepeatBehavior="Forever">
                            <ThicknessAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </ThicknessAnimation.EasingFunction>
                        </ThicknessAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Unloaded" SourceName="runningBar">
                <StopStoryboard BeginStoryboardName="IndefiniteLoading"/>
            </EventTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--The following Enable templates should be merged and a LSToggleButton used in its stead-->
    <ControlTemplate x:Key="ModEnableButtonTemplate">
        <ls:LSButton x:Name="modEnableCheckBox" Command="{Binding DataContext.ToggleModEnabledStateCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                     CommandParameter="{Binding .}">
            <ls:LSButton.Template>
                <ControlTemplate TargetType="ls:LSButton">
                    <Grid x:Name="toggleRoot" Background="Transparent">
                        <Image x:Name="bgImg" VerticalAlignment="Center" Source="{StaticResource enableCheckBoxDefault}" Stretch="None"/>
