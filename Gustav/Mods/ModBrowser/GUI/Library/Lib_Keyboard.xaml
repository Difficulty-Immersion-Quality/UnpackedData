    <Style x:Key="SingleModStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ls:LSButton Command="{Binding DataContext.ToggleDetailsCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding .}" Width="512" Height="516">
                        <ls:LSButton.Content>
                            <Border x:Name="rootBorder" BorderThickness="2" BorderBrush="{StaticResource LS_modsSurroundColor}" CornerRadius="24,24,24,24" Width="496" Height="496">
                                <Grid>
                                    <StackPanel x:Name="modPreviewPanel" Orientation="Vertical">
                                        <!-- Mod Image-->
                                        <Rectangle x:Name="Screenshot" Fill="{Binding MainScreenshot.Screenshot}" Width="488" RadiusX="20" RadiusY="20" Effect="{StaticResource ShadowEffectSmall}" Margin="2,2">
                                            <Rectangle.Height>
                                                <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                                                    <Binding Path="ActualWidth" ElementName="Screenshot"/>
                                                    <Binding Path="Fill.ImageSource.Width" ElementName="Screenshot"/>
                                                    <Binding Path="Fill.ImageSource.Height" ElementName="Screenshot"/>
                                                </MultiBinding>
                                            </Rectangle.Height>
                                        </Rectangle>

                                        <!-- Mod Title-->
                                        <TextBlock x:Name="modTitle" FontSize="{StaticResource ScaledSmallFontSize}" Foreground="{StaticResource LS_modsTextColor}" Text="{Binding Name}" Margin="18,14,20,6" TextTrimming="CharacterEllipsis" Width="470"/>

                                        <!-- Mod Details -->
                                        <StackPanel Orientation="Horizontal" Margin="18,0" >

                                            <!-- Mod Downloads -->
                                            <Path x:Name="downloadIcon" Data="{StaticResource ico_downloads}" Fill="{StaticResource LS_accent25TxtColor}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                            <TextBlock x:Name="downloadValue" Text="{Binding TotalDownloads, Converter={StaticResource AbbreviateNumberConverter}}" Style="{StaticResource modsStatsStyle}" Margin="0,10,20,10"/>

                                            <!-- Mod Size -->
                                            <Path x:Name="sizeIcon" Data="{StaticResource ico_fileSize}" Fill="{StaticResource LS_accent25TxtColor}" Margin="0,0,12,4" VerticalAlignment="Center" />
                                            <TextBlock x:Name="sizeValue" Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" Style="{StaticResource modsStatsStyle}" Margin="0,10,20,10"/>

                                            <!-- Mod Likes -->
                                            <Path x:Name="likeIcon" Data="{StaticResource ico_likes}" Fill="{StaticResource LS_accent25TxtColor}" Margin="0,0,4,6" VerticalAlignment="Center" />
                                            <TextBlock x:Name="likeValue" Text="{Binding PositiveRating, Converter={StaticResource AbbreviateNumberConverter}}" Style="{StaticResource modsStatsStyle}" Margin="5,10"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Rectangle x:Name="MouseOver" Fill="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <!-- Mod Subscribe -->
                                    <Control x:Name="modStateControl" Template="{StaticResource DownloadButtonTemplateBrowse}" Margin="20,0,20,12" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Border>
                        </ls:LSButton.Content>
                    </ls:LSButton>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" SourceName="MouseOver" Value="True">
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{StaticResource LS_modsSurroundColorSelected}"/>
                            <Setter TargetName="rootBorder" Property="Background" Value="{StaticResource LS_modsBackgroundColor}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" SourceName="modStateControl" Value="True">
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{StaticResource LS_modsSurroundColorSelected}"/>
                            <Setter TargetName="rootBorder" Property="Background" Value="{StaticResource LS_modsBackgroundColor}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding InstallState}" Value="Downloading">
                            <Setter TargetName="modStateControl" Property="Template" Value="{StaticResource DownloadingBarTemplate}"/>
                            <Setter TargetName="modStateControl" Property="Margin" Value="0,20,0,40"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                            <Setter TargetName="modStateControl" Property="Template" Value="{StaticResource AlreadyDownloadedButtonTemplate}"/>
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{StaticResource LS_modsSurroundSubscribedColor}" />
                            <Setter TargetName="rootBorder" Property="Background" Value="{StaticResource LS_modsBackgroundSubscribedColor}" />
                            <Setter TargetName="likeValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="sizeValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="downloadValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="likeIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="sizeIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="downloadIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding InstallState}" Value="Uninstalled"/>
                                <Condition Binding="{Binding DataContext.Data.ModAccountState, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="ModioConnected"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="modStateControl" Property="Template" Value="{StaticResource SubscribeButtonTemplateBrowse}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding InstallState}" Value="Subscribed"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="modStateControl" Property="Template" Value="{StaticResource AlreadySubscribedButtonTemplate}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsInstalled}" Value="True"/>
                                <Condition Binding="{Binding ElementName=MouseOver, Path=IsMouseOver}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{StaticResource LS_modsContentSubscribedColor}"/>
                            <Setter TargetName="rootBorder" Property="Background" Value="{StaticResource LS_modsBackgroundSubscribedColorSelected}" />
                            <Setter TargetName="MouseOver" Property="Panel.ZIndex" Value="100"/>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

