    <ControlTemplate x:Key="SideSearchPanelTreeViewItemTemplate" TargetType="TreeViewItem">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="Root" Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Left" Margin="0,32,0,10">
                <ls:LSToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=TreeViewItem}}" SoundID="UI_Shared_Select" VerticalAlignment="Center" MinWidth="700" MinHeight="40">
                    <ls:LSToggleButton.Template>
                        <ControlTemplate TargetType="ls:LSToggleButton">
                            <Border Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                                <Path x:Name="Arrow" Data="M 7 0 L 21 14 L 7 28 Z" Fill="{StaticResource LS_accent75TxtColor}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="30,0,0,0"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource LS_accent100TxtColor}"></Setter>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Arrow" Property="Data" Value="M 0 0 L 14 14 L 28 0 Z"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ls:LSToggleButton.Template>
                </ls:LSToggleButton>

                <!-- Header will be over the expander button so on clicking on it, we will be reaching the button as well -->
                <ContentPresenter x:Name="PART_Header" ContentSource="Header" VerticalAlignment="Center" Margin="-620,0,0,0" IsHitTestVisible="False"/>
            </StackPanel>

            <ItemsPresenter x:Name="TreeItemsHost" Grid.Row="1" Margin="0"/>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="IsExpanded" Value="False">
                <Setter TargetName="TreeItemsHost" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="ls:AttachedProperties.InheritedTag" Value="FirstFilter">
                <Setter TargetName="Root" Property="Margin" Value="0,0,0,10"/>
            </Trigger>
            <Trigger Property="HasItems" Value="False">
                <!-- If there's no expander to show, hide it and restore header values to the default ones -->
                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="Root" Property="Margin" Value="0,0,0,0"/>
                <Setter TargetName="PART_Header" Property="Margin" Value="0"/>
                <Setter TargetName="PART_Header" Property="IsHitTestVisible" Value="True"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="FilterTextStyle" TargetType="TextBlock">
