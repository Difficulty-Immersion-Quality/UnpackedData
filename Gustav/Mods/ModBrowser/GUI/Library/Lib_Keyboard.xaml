    <Style x:Key="FilterToggleButtonStyle" TargetType="ls:LSToggleButton" BasedOn="{StaticResource {x:Type ls:LSToggleButton}}">
        <Style.Resources>
            <ImageSource x:Key="BgNormal">pack://application:,,,/ModBrowser;component/Assets/filters_pane_li_01.png</ImageSource>
            <ImageSource x:Key="BgHighlight">pack://application:,,,/ModBrowser;component/Assets/filters_pane_li_02.png</ImageSource>

            <ImageSource x:Key="TickBoxBgNormal">pack://application:,,,/Core;component/Assets/Options/checkBox_d.png</ImageSource>
            <ImageSource x:Key="TickBoxBgHighlight">pack://application:,,,/Core;component/Assets/Options/checkBox_h.png</ImageSource>
            <ImageSource x:Key="TickBoxBgPressed">pack://application:,,,/Core;component/Assets/Options/checkBox_p.png</ImageSource>
            <ImageSource x:Key="TickBoxBgDisabled">pack://application:,,,/Core;component/Assets/Options/checkBox_disabled.png</ImageSource>
            <ImageSource x:Key="TickBoxIconNormal">pack://application:,,,/Core;component/Assets/Options/ico_check_d.png</ImageSource>
            <ImageSource x:Key="TickBoxIconHighlight">pack://application:,,,/Core;component/Assets/Options/ico_check_h.png</ImageSource>
        </Style.Resources>
        <Setter Property="Foreground" Value="{StaticResource LS_tint100}"/>
        <Setter Property="Margin" Value="0,-5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image x:Name="bg" Grid.Column="0" Grid.ColumnSpan="2" Stretch="Fill" Source="{StaticResource BgNormal}" IsHitTestVisible="False"/>

                        <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="60,5,10,5" IsHitTestVisible="False">
                            <Image x:Name="img" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" Source="{StaticResource TickBoxBgNormal}"/>
                            <Image x:Name="check" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" Source="{StaticResource TickBoxIconHighlight}" Visibility="Hidden"/>
                        </Grid>

                        <TextBlock x:Name="Content" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Text="{TemplateBinding Content}" TextWrapping="Wrap" Style="{StaticResource FilterTextStyle}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Content" Property="Foreground" Value="{StaticResource LS_specialTxtColor}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="img" Property="Source" Value="{StaticResource TickBoxBgDisabled}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Source" Value="{StaticResource BgHighlight}"/>
                            <Setter TargetName="img" Property="Source" Value="{StaticResource TickBoxBgHighlight}"/>
                            <Setter TargetName="check" Property="Source" Value="{StaticResource TickBoxIconHighlight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed"  Value="True">
                            <Setter TargetName="img" Property="Source" Value="{StaticResource TickBoxBgPressed}"/>
                            <Setter TargetName="check" Property="Source" Value="{StaticResource TickBoxIconHighlight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Enabled}" Value="False">
                <Setter Property="Opacity" Value="{StaticResource DisabledOpacity}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="SearchActionButtonTemplate" TargetType="{x:Type Button}">
        <ls:LSNineSliceImage x:Name="bg" ImageSource="{StaticResource ModBrowserClearButton_d}" Slices="54,30,34,30" Padding="8,0,20,0" Height="64">
            <StackPanel Orientation="Horizontal">
