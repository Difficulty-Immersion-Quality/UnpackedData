                            </ls:LSButton.Resources>
                        </ls:LSButton>

                        <Control x:Name="unsubscribedDownloadingControl" Grid.Row="0" Margin="0,60,0,0" Template="{StaticResource DownloadingBarTemplate}" Visibility="Collapsed"
                     HorizontalAlignment="Center" VerticalAlignment="Top"/>

                        <ls:LSButton x:Name="enableModButton" Grid.Row="0" Margin="0,40,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"
                         CommandParameter="{Binding SelectedMod}" Template="{StaticResource DisableModButtonTemplate}" Command="{Binding ToggleModEnabledStateCommand}" Visibility="Collapsed"/>

                        <Control x:Name="modUpdateControl" Grid.Row="0" Margin="0,100,0,0" HorizontalAlignment="Center" VerticalAlignment="Top" Template="{StaticResource UpdateModButtonTemplate}" Visibility="Collapsed" Height="100"/>

                        <StackPanel x:Name="statsPanel" HorizontalAlignment="Center" Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Top" Margin="0,20,0,0">
                            <Image Stretch="None" Source="{StaticResource detailsDownloads}"/>
                            <TextBlock Text="{Binding SelectedMod.TotalDownloads, Converter={StaticResource AbbreviateNumberConverter}}" Margin="20,0,0,0"/>
                            <Image Stretch="None" Source="{StaticResource detailsFileSize}" Margin="60,0,0,0"/>
                            <TextBlock Text="{Binding SelectedMod.FileSize, Converter={StaticResource FileSizeConverter}}" Margin="20,0,0,0"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Grid.Row="2" VerticalAlignment="Top">
                            <ls:LSButton x:Name="endorseButton" Content="{Binding SelectedMod.PositiveRating, Converter={StaticResource AbbreviateNumberConverter}}"
                                         ContentTemplate="{StaticResource VoteButtonTemplate}"
                         VerticalAlignment="Top" Command="{Binding EndorseModCommand}" CommandParameter="{Binding SelectedMod}"  Visibility="Collapsed">
                                <ls:LSButton.Resources>
                                    <ImageBrush x:Key="IconNormal" ImageSource="{StaticResource detailsLike}"/>
                                    <ImageBrush x:Key="IconHighlight" ImageSource="{StaticResource detailsLike}"/>
                                    <ImageBrush x:Key="IconDisabled" ImageSource="{StaticResource detailsLike}"/>
                                    <ImageBrush x:Key="IconUpvoted" ImageSource="{StaticResource detailsLikeUpvoted}"/>
                                    <System:Double x:Key="IconWidth">48</System:Double>
                                    <System:Double x:Key="IconHeight">48</System:Double>
                                </ls:LSButton.Resources>
                            </ls:LSButton>
                            <ls:LSButton x:Name="reportButton" Content="{Binding Source='h3eb3aeabg68fcg418cga213ge00d639e4507', Converter={StaticResource TranslatedStringConverter}}"
                         ContentTemplate="{StaticResource ReportButtonTemplate}" Command="{Binding ReportModCommand}" VerticalAlignment="Top">
                                <ls:LSButton.Resources>
                                    <ImageBrush x:Key="IconNormal" ImageSource="{StaticResource reportIcon}"/>
                                    <ImageBrush x:Key="IconHighlight" ImageSource="{StaticResource reportIcon}"/>
                                    <ImageBrush x:Key="IconDisabled" ImageSource="{StaticResource reportIcon}"/>
                                    <System:Double x:Key="IconWidth">48</System:Double>
                                    <System:Double x:Key="IconHeight">48</System:Double>
                                </ls:LSButton.Resources>
                            </ls:LSButton>
                        </StackPanel>

                        <StackPanel x:Name="explicitContentPanel" Grid.Row="3" VerticalAlignment="Top" Margin="0,24,0,0" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding SelectedMod.IsMatureContent, Converter={StaticResource BoolToVisibleConverter}}">
                            <Image Source="{StaticResource IconWarningSoft}" Stretch="None" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Source=h044356fcgc4a6g44bfgaa75gc26eb46ae649, Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_warning50TxtColor}" Margin="6,3,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel x:Name="externalDependenciesContentPanel" Grid.Row="4" VerticalAlignment="Top" Margin="0,24,0,0" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding SelectedMod.IsExternalDependency, Converter={StaticResource BoolToVisibleConverter}}">
                            <Image Source="{StaticResource IconWarningSoft}" Stretch="None" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Source=h1b37a6fcg1771g407fg9187gb0ac1a152876, Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_warning50TxtColor}" Margin="6,3,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Image x:Name="dependenciesDivider" Grid.Row="5" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                               Source="{StaticResource detailsDivider}" Stretch="None" Margin="0,60,0,0"/>

                        <StackPanel Orientation="Vertical" Grid.Row="6"  Margin="0,10">
                            <ls:LSButton x:Name="detailUninstallButton" Visibility="Hidden" Style="{StaticResource SmallBrownButtonStyle}"
                                         Content="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5', Converter={StaticResource TranslatedStringConverter}}"
                                         Command="{Binding DataContext.UninstallModCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                         CommandParameter="{Binding SelectedMod}" Width="460"/>

                            <TextBlock x:Name="dependenciesTitle" Margin="60,25,0,0"
                                       Visibility="{Binding SelectedMod.Dependencies.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                       FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_accent100TxtColor}" >
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                        <Binding Source="h42f01947gd74eg48e6ga156gc5cb9ad93dfe"/>
                                        <Binding  Path="SelectedMod.Dependencies.Count"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <ScrollViewer x:Name="modDependencies" Grid.Row="7" HorizontalContentAlignment="Left" Template="{StaticResource ScrollViewerTemplate}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent" Margin="-10,0,0,0" VerticalAlignment="Stretch">
                            <ScrollViewer.Resources>
                                <Style x:Key="ScrollBarStyle" TargetType="ScrollBar" BasedOn="{StaticResource DecorativeGoldScrollBar}"/>
                                <GridLength x:Key="Top">50</GridLength>
                                <GridLength x:Key="Bottom">50</GridLength>
                            </ScrollViewer.Resources>

                            <ItemsControl ItemsSource="{Binding SelectedMod.Dependencies}" Visibility="{Binding SelectedMod.Dependencies.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="60,10,0,0" Orientation="Horizontal">
                                            <Image x:Name="dependencyState" Source="{x:Null}" Stretch="None"/>
                                            <Rectangle x:Name="dependencyScreenshot" Fill="{Binding MainScreenshot.Screenshot}" Margin="9,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Width="180">
                                                <Rectangle.Height>
                                                    <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                                                        <Binding Path="ActualWidth" ElementName="dependencyScreenshot"/>
                                                        <Binding Path="Fill.ImageSource.Width" ElementName="dependencyScreenshot"/>
                                                        <Binding Path="Fill.ImageSource.Height" ElementName="dependencyScreenshot"/>
                                                    </MultiBinding>
                                                </Rectangle.Height>
                                            </Rectangle>
                                            <TextBlock Text="{Binding Name}" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource LS_accent100TxtColor}" FontSize="{StaticResource ScaledIntermediateFontSize}" TextWrapping="Wrap" Width="800"/>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding EnabledCurrent}" Value="True">
                                                <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource enabledIcon}"/>
                                                <Setter TargetName="dependencyState" Property="Margin" Value="15,0,0,0"/>
                                                <Setter TargetName="dependencyScreenshot" Property="Margin" Value="15,0,0,0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding VersionState}" Value="Older">
                                                <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource updateIcon}"/>
                                                <Setter TargetName="dependencyState" Property="Margin" Value="15,0,0,0"/>
                                                <Setter TargetName="dependencyScreenshot" Property="Margin" Value="14,0,0,0"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsInstalled}" Value="True"/>
                                                    <Condition Binding="{Binding EnabledCurrent}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource IconWarningSoft}"/>
                                                <Setter TargetName="dependencyState" Property="Margin" Value="15,0,0,0"/>
                                                <Setter TargetName="dependencyScreenshot" Property="Margin" Value="22,0,0,0"/>
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
            <Grid x:Name="zoomedScreenshotRoot" Visibility="{Binding InScreenshotZoom, Converter={StaticResource BoolToVisibleConverter}}">
                <ls:LSNineSliceImage x:Name="zoomedScreenshotBackgroundFade"  ImageSource="{StaticResource backgroundFade}" Slices="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Border BorderThickness="10" BorderBrush="{StaticResource LS_extraspecialTxtColor}">
                        <Rectangle x:Name="zoomedImageMod" Width="2800" Fill="{Binding ElementName=imageMod, Path=Fill}">
                            <Rectangle.Height>
                                <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                                    <Binding Path="ActualWidth" ElementName="zoomedImageMod"/>
                                    <Binding Path="Fill.ImageSource.Width" ElementName="imageMod"/>
                                    <Binding Path="Fill.ImageSource.Height" ElementName="imageMod"/>
                                </MultiBinding>
                            </Rectangle.Height>
                        </Rectangle>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,50,0,0" HorizontalAlignment="Center" Visibility="{Binding SelectedMod.Screenshots.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <ls:LSButton x:Name="buttonPrevScreenshot" Template="{StaticResource ArrowButtonTemplate}" VerticalAlignment="Center"/>

                        <TextBlock x:Name="screenshotNumber" HorizontalAlignment="Center" FontSize="{StaticResource ScaledLargeFontSize}" Foreground="{StaticResource LS_extraspecialTxtColor}"
                                   Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}/{1}">
                                    <Binding Path="SelectedIndex" ElementName="extraImages" Converter="{StaticResource AddConverter}" ConverterParameter="1"/>
                                    <Binding Path="SelectedMod.Screenshots.Count"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <ls:LSButton x:Name="buttonNextScreenshot" Template="{StaticResource ArrowButtonTemplate}" RenderTransformOrigin="0.5,0.5" VerticalAlignment="Center" Margin="10,0,0,0">
                            <ls:LSButton.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </ls:LSButton.RenderTransform>
                        </ls:LSButton>
                        <b:Interaction.Triggers>
                            <b:EventTrigger SourceName="buttonPrevScreenshot" EventName="Click">
                                <ls:SelectNextListBoxItem Reversed="True" TargetObject="{Binding ElementName=extraImages}" ForceSelect="True" ForceMode="Cycle"/>
                            </b:EventTrigger>
                            <b:EventTrigger SourceName="buttonNextScreenshot" EventName="Click">
                                <ls:SelectNextListBoxItem TargetObject="{Binding ElementName=extraImages}" ForceSelect="True" ForceMode="Cycle"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding SelectedMod.Screenshots.Count}" Value="0">
                <Setter TargetName="extraImages" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ElementName=extraImages, Path=Visibility}" Value="Visible">
                <Setter TargetName="imageMod" Property="Fill" Value="{Binding ElementName=extraImages, Path=SelectedItem.Screenshot}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.MainScreenshot.HasScreenshotTexture}" Value="False">
                <Setter TargetName="imageSpinner" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.LastUpdatedDate}" Value="">
                <Setter TargetName="lastUpdatedValue" Property="Text" Value="{Binding Source=hcdb2c178g917cg4f01ga281g64ce59d0ad6b, Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.OriginalUploadDate}" Value="">
                <Setter TargetName="orgiginalUploadValue" Property="Text" Value="{Binding Source=hcdb2c178g917cg4f01ga281g64ce59d0ad6b, Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.EnabledCurrent}" Value="False">
                <Setter TargetName="enableModButton" Property="Template" Value="{StaticResource EnableModButtonTemplate}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.InstallState}" Value="Uninstalled"/>
                    <Condition Binding="{Binding SelectedMod.IsAvailable}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="subscribeButton" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.InstallState}" Value="Uninstalled"/>
                    <Condition Binding="{Binding Data.ModAccountState}" Value="ModioConnected"/>
                    <Condition Binding="{Binding ActiveTabID}" Value="Browse"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="subscribeButton" Property="Command" Value="{Binding SubscribeModCommand}"/>
                <Setter TargetName="subscribeButton" Property="Content" Value="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282', Converter={StaticResource TranslatedStringConverter}}"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.InstallState}" Value="Downloading"/>
                    <Condition Binding="{Binding SelectedMod.VersionState}" Value="Match"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="unsubscribedDownloadingControl" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.InstallState}" Value="Uninstalled"/>
                    <Condition Binding="{Binding ActiveTabID}" Value="Browse"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="subscribeButton" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.InstallState}" Value="Downloaded">
                <Setter TargetName="enableModButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="detailUninstallButton" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.InstallState}" Value="Subscribed">
                <Setter TargetName="enableModButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="detailUninstallButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="detailUninstallButton" Property="Content" Value="{Binding Source='h75fcf9abgbe78g4aa3g835bgc8f319c8942c', Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.VersionState}" Value="Older">
                <Setter TargetName="modUpdateControl" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.InstallState}" Value="Downloading">
                <Setter TargetName="modUpdateControl" Property="Template" Value="{StaticResource DownloadingBarTemplate}"/>
                <Setter TargetName="modUpdateControl" Property="Margin" Value="0,140,0,0"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="ModioConnected">
                <Setter TargetName="endorseButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="reportButton" Property="Grid.Column" Value="5"/>
                <Setter TargetName="reportButton" Property="Grid.ColumnSpan" Value="1"/>
                <Setter TargetName="reportButton" Property="HorizontalAlignment" Value="Left"/>
                <Setter TargetName="reportButton" Property="Margin" Value="0,0,0,0"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding InScreenshotZoom}" Value="True">
                <Setter TargetName="modDependencies" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="dependenciesTitle" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="dependenciesDivider" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="explicitContentPanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="externalDependenciesContentPanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="reportButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="endorseButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="statsPanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modUpdateControl" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="enableModButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="detailUninstallButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="unsubscribedDownloadingControl" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="subscribeButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="controlsBgImage" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modDescription" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="lastUpdatedHint" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="lastUpdatedValue" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="orgiginalUploadHint" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="orgiginalUploadValue" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="VersionHint" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="VersionValue" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modTags" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="authorPanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="titlePanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="headerBg" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="imageMod" Property="Margin" Value="0,-2200,0,0"/>
                <Setter TargetName="extraImages" Property="Margin" Value="0,-2500,0,0"/>
                <Setter TargetName="imageSpinner" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.IsUGCDisabled}" Value="True">
                <Setter TargetName="imageMod" Property="Fill" Value="{StaticResource ugcDisabledMaskBig}"/>
                <Setter TargetName="modUpdateControl" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="dependenciesTitle" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modDependencies" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="enableModButton" Property="IsEnabled" Value="False"/>
                <Setter TargetName="detailUninstallButton" Property="IsEnabled" Value="False"/>
                <Setter TargetName="imageSpinner" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="WaitingSpinnerTemplate">
        <StackPanel x:Name="spinnerRoot" VerticalAlignment="Top" HorizontalAlignment="Stretch">
            <TextBlock x:Name="waitLabel" Text="{Binding Source='h18414d2cg5e53g41dag8f35g774de89faaf8', Converter={StaticResource TranslatedStringConverter}}"/>
            <Control VerticalAlignment="Top" HorizontalAlignment="Center" Template="{StaticResource BusyElement}"/>
        </StackPanel>
    </ControlTemplate>
</ResourceDictionary>