<ls:UIWidget x:Name="AccountManagement_c"
             ls:UIWidget.ContextName="AccountManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance {x:Type ls:DCAccountManagement}, IsDesignTimeCreatable=True}"
             d:DesignHeight="2160" d:DesignWidth="3840"
             FocusDown="UIDown" FocusLeft="UILeft" FocusRight="UIRight" FocusUp="UIUp" ls:MoveFocus.FocusMovementMode="Closest" CanCacheFocusSurroundingElements="False">
    <ls:UIWidget.Template>
        <ControlTemplate TargetType="{x:Type ls:UIWidget}">
            <ControlTemplate.Resources>
                <ResourceDictionary>
                    <BitmapImage x:Key="PanelBackground" UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_menuPanelBG.png"/>

                    <Style x:Key="TitleText" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="{StaticResource ScaledBigFontSize}"/>
                        <Setter Property="Foreground" Value="{StaticResource LS_tint100}"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="10,60"/>
                    </Style>
                </ResourceDictionary>
            </ControlTemplate.Resources>

            <AdornerDecorator>
                <Grid x:Name="root" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource LS_PanelBackgroundLight}">
                    <ls:LSNineSliceImage ImageSource="{StaticResource accountManagementBg_c}" Width="1900" Height="1700" Slices="32"
                                     VerticalAlignment="Center" HorizontalAlignment="Center" Padding="28"/>

                    <StackPanel x:Name="screenContainer" VerticalAlignment="Top" HorizontalAlignment="Center" Width="1500" Margin="0,250,0,0">
                        <TextBlock x:Name="Title" Style="{StaticResource TitleText}"
                               Text="{Binding Source='ha2a8ea04gbc62g4b2cgb6c1g95bacabac37b', Converter={StaticResource TranslatedStringConverter}}"/>
                        <ls:LSNineSliceImage Style="{StaticResource DecorativePanelDividerNineSlice}" Width="1500" Height="96" HorizontalAlignment="Center" Margin="0,20,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="120,0,0,0">
                            <Grid x:Name="avatarGrid">
                                <Image x:Name="avatarFrame" Source="{StaticResource accountFrameDefault}" Width="160" Stretch="Uniform"/>
                                <Rectangle x:Name="avatarIcon" Width="110" Height="110" Fill="{Binding CurrentPlayer.CommunityIcon}"/>
                            </Grid>
                            <StackPanel Orientation="Vertical" Margin="20,5,0,0">
                                <TextBlock x:Name="userName" Foreground="{StaticResource LS_extraspecialTxtColor}"
                                       FontSize="{StaticResource ScaledBigFontSize}" TextTrimming="CharacterEllipsis" TextAlignment="Left"
                                       Text="{Binding Data.LarianNetUserName}" Width="900"/>
                                <TextBlock x:Name="accountStateLabel" Foreground="{StaticResource LS_accent100TxtColor}" FontSize="{StaticResource ScaledSmallFontSize}"
                                       ls:TextBlockFormatter.SourceText="{Binding Source=hcb6ce7afgf462g4603gb826g999d7238fd92, Converter={StaticResource TranslatedStringConverter}}"/>
                            </StackPanel>
                            <TextBlock x:Name="platformLabel" Margin="0,20,0,0" Text="{Binding Source=hf070f270g965fg493dgbfd3g84a74b0d7530,Converter={StaticResource TranslatedStringConverter}}"
                                       Foreground="{StaticResource LS_disabledPadTxtColor}"/>
                        </StackPanel>

                        <ls:LSNineSliceImage Style="{StaticResource DecorativePanelDividerNineSlice}" Width="1500" Height="96" HorizontalAlignment="Center" RenderTransformOrigin="0.5, 0.5" Margin="0,20,0,0">
                            <ls:LSNineSliceImage.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </ls:LSNineSliceImage.RenderTransform>
                        </ls:LSNineSliceImage>

                        <TextBlock x:Name="platformName" Text="{Binding Data.CommunityPlatform, Converter={StaticResource EnumTranslatedStringConverter}, ConverterParameter='hdb7e2a56g86d2g46c0g923cg11da095663d8'}" Visibility="Hidden" FontSize="{StaticResource ScaledTinyFontSize}"/>

                        <ls:LSButton x:Name="larianAccountButton" Style="{StaticResource FocusableButtonStyle}"
                                 Command="{Binding OpenURLInBrowserCommand}" CommandParameter="LarianAccount"
                                 Content="{Binding Source='h43faec29ged56g4f6bgaaedgc0b7b74ad4c8',Converter={StaticResource TranslatedStringConverter}}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="Loaded">
                                    <ls:SetMoveFocusAction TargetName="AccountManagement_c"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSButton>

                        <ls:LSButton x:Name="showFriendListButton" Style="{StaticResource FocusableButtonStyle}"
                                     Command="{Binding CustomEvent}" CommandParameter="OpenFriendsList">
                            <ls:LSButton.ContentTemplate>
                                <DataTemplate DataType="ls:VMInputEvent">
                                    <TextBlock x:Name="Content" IsEnabled="{TemplateBinding IsEnabled}" VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" Foreground="{TemplateBinding TextElement.Foreground}">
                                        <TextBlock.Tag>
                                            <MultiBinding Converter="{StaticResource AddMultipleConverter}">
                                                <Binding Path="DataContext.Data.CrossplayFriendRequests.Count" ElementName="AccountManagement_c"/>
                                                <Binding Path="DataContext.Data.CrossplayInvites.Count" ElementName="AccountManagement_c"/>
                                            </MultiBinding>
                                        </TextBlock.Tag>
                                        <Run Text="{Binding Source='hf510f042g617cg4571g8e7ag7f9e2b8dad94', Converter={StaticResource TranslatedStringConverter}}"/>
                                        <Run x:Name="RequestsCount" Text="{Binding Tag, ElementName=Content, StringFormat='{}({0})'}"/>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Tag, ElementName=Content}" Value="0">
                                            <Setter TargetName="RequestsCount" Property="Text" Value=""/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ls:LSButton.ContentTemplate>
                        </ls:LSButton>

                        <ls:LSButton x:Name="modioButton" Style="{StaticResource FocusableButtonStyle}"
                                     Command="{Binding CustomEvent}" CommandParameter="OpenModioSignIn"
                                     Content="{Binding Source='h49bcf50dg2cc0g4595ga3bbg635ba6932484',Converter={StaticResource TranslatedStringConverter}}"/>

                        <ls:LSButton x:Name="communityPlatformButton" Style="{StaticResource FocusableButtonStyle}"
                                 Command="{Binding OpenCommunityPlatformAccount}">
                            <ls:LSButton.Content>
                                <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}" ConverterParameter="h3bd3d2f4g1b73g474dgba18g0dac7c3b1c38">
                                    <Binding ElementName="platformName" Path="Text"/>
                                </MultiBinding>
                            </ls:LSButton.Content>
                        </ls:LSButton>
                        <ls:LSButton x:Name="disconnectButton" Style="{StaticResource FocusableButtonStyle}"
                                 Command="{Binding DisconnectAccount}"
                                 Content="{Binding Source='h89e53b75g16b6g4872gba2fg809c2ab840e6',Converter={StaticResource TranslatedStringConverter}}"/>
                    </StackPanel>

                    <ls:LSNineSliceImage VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Height="200" Slices="16,0" ImageSource="{StaticResource PanelBackground}"/>

                    <Grid x:Name="bottomArea" VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <ls:LSButton x:Name="selectButton" ContentTemplate="{StaticResource ControllerButtonHint}" Margin="{StaticResource ButtonHint.Margin}"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                     Tag="{Binding Source='hd0c08193ga7f2g4a7eg8225g63748c7b3096',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIAccept"
                                     Command="{Binding Path=FocusedElement.Command ,ElementName=AccountManagement_c}"
                                     CommandParameter="{Binding Path=FocusedElement.CommandParameter ,ElementName=AccountManagement_c}"/>

                            <ls:LSButton x:Name="backButton" ContentTemplate="{StaticResource ControllerButtonHint}" Margin="20,0,0,56"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                                     Tag="{Binding Source='h77fec760g866dg4e47g8e81g467c9c05e447',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UICancel"
                                     Command="{Binding CustomEvent}" CommandParameter="CloseWidget" SoundID="UI_Shared_Cancel"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </AdornerDecorator>
            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding Data.ModAccountState}" Value="ModioConnected">
                    <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source=hfa041695g2655g4540g91aege61c49fd327b, Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="modioButton" Property="Content" Value="{Binding Source=h213e8193gbd1cg446dgbac2g17924cccaf35, Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="modioButton" Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                    <Setter TargetName="modioButton" Property="CommandParameter" Value="ModioAccount"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Data.CommunityPlatform}" Value="Invalid">
                    <Setter TargetName="communityPlatformButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Data.CommunityPlatform}" Value="Galaxy">
                    <Setter TargetName="communityPlatformButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="MoveFocusUp">
            <ls:LSPlaySound Sound="UI_Shared_Hover" />
        </b:EventTrigger>

        <b:EventTrigger EventName="MoveFocusDown">
            <ls:LSPlaySound Sound="UI_Shared_Hover" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
</ls:UIWidget>
