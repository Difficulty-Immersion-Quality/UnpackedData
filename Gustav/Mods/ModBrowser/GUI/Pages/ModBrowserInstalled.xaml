<ls:UIWidget x:Name="ModBrowserInstalled"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             ls:UIWidget.ContextName="ModBrowserInstalled"
             Template="{StaticResource ModBrowserBackgroundTemplate}"
             d:DataContext="{d:DesignInstance Type=ls:DCModBrowser, IsDesignTimeCreatable=True}"
             d:DesignWidth="3840" d:DesignHeight="2160">
    <ls:UIWidget.ContentTemplate>
        <DataTemplate>
            <Grid HorizontalAlignment="Stretch">

                <Grid x:Name="InstalledGrid" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                    <b:Interaction.Behaviors>
                        <ls:CollectionSortBehavior x:Name="ModSorted" ItemsSource="{Binding Data.AvailableMods}" Comparer="{Binding SortModsComparer}"/>
                    </b:Interaction.Behaviors>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1604"/>
                        <ColumnDefinition Width="1124"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="146"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0, 10" >
                        <TextBlock x:Name="modsDisabledLabel"
                                   Text="{Binding Source='hbf3eac1fgc6b9g43bag915agf2418316d234', Converter={StaticResource TranslatedStringConverter}}"
                                   HorizontalAlignment="Center"
                                   FontSize="{StaticResource ScaledTitleFontSize}" Foreground="{StaticResource LS_extraspecialTxtColor}" FontWeight="DemiBold"
                                   Visibility="{Binding Data.IsUGCDisabled, Converter={StaticResource BoolToVisibleConverter}}"/>

                        <TextBlock x:Name="modsDisabledDesc"
                                   Text="{Binding Source='hcbb5efb0gb487g4fd9g86c1g8c1bcdf173ef', Converter={StaticResource TranslatedStringConverter}}"
                                   HorizontalAlignment="Center"
                                   FontSize="{StaticResource ScaledLargeFontSize}" Foreground="{StaticResource LS_baseTxtColor}" FontWeight="DemiBold"
                                   Visibility="{Binding Data.IsUGCDisabled, Converter={StaticResource BoolToVisibleConverter}}"/>
                    </StackPanel>

                    <Rectangle Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Fill="{StaticResource CenteredGradientLightShadingBrush}" />

                    <TextBlock x:Name="AvailableModsLabel" Grid.Row="1" Grid.Column="0" Margin="12,64,0,0"  Text="{Binding Source='h26846b3cgd238g4eb4g913ag60e5dce34ddc', Converter={StaticResource TranslatedStringConverter}}"
                           FontSize="{StaticResource ScaledBigFontSize}" Foreground="{StaticResource LS_extraspecialTxtColor}" FontWeight="DemiBold"/>


                    <ListBox x:Name="ModList" Grid.Row="2" Grid.Column="0" ItemsSource="{Binding ElementName=ModSorted, Path=SortedItems}" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.VirtualizationMode="Recycling" VerticalAlignment="Stretch"  HorizontalAlignment="Left" AlternationCount="{Binding ElementName=ModSorted, Path=SortedItemsCount}" SelectedIndex="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Margin" Value="0,0,44,16"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Grid Width="1526" VerticalAlignment="Stretch">
                                                <Border x:Name="rootBorder" BorderThickness="4" Width="1526" Height="152" HorizontalAlignment="Left" VerticalAlignment="Top" BorderBrush="{StaticResource LS_tint100}" Opacity="0" />
                                                <!-- Background-->
                                                <Rectangle x:Name="modListBG" Fill="{StaticResource modListBGDefault}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="1526" Height="152"/>

                                                <!-- Mod image and text/tag -->
                                                <ContentPresenter x:Name="modPreviewPanel" ContentTemplate="{StaticResource ModPreviewTemplate}" Content="{Binding .}"/>

                                                <!-- Mod Details -->
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,56,0" HorizontalAlignment="Right">
                                                    <Image x:Name="modUpdate" Source="{StaticResource updateIcon}" Stretch="None" Margin="0,-6,0,0" Visibility="Hidden"/>
                                                    <Image x:Name="modWarning" Source="{StaticResource IconWarningSoft}" Stretch="None" Margin="0,0,20,3" Visibility="Collapsed"/>

                                                    <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Converter={StaticResource AddConverter}, ConverterParameter=1}"
                                                               FontSize="{StaticResource ScaledLargeFontSize}"/>

                                                    <Control x:Name="modEnableToggle" Template="{StaticResource ModEnableButtonTemplate}" Margin="48,-7,0,0"
                                                             IsEnabled="{Binding Data.IsUGCDisabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource InvertBoolConverter}}"/>

                                                </StackPanel>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="rootBorder" Property="Opacity" Value="0.5"/>
                                                    <Setter TargetName="modListBG" Property="Fill" Value="{StaticResource modListBGHighlight}"/>
                                                </Trigger>
												<DataTrigger Binding="{Binding IsOutdated}" Value="True">
                                                    <Setter TargetName="modUpdate" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            	<DataTrigger Binding="{Binding IsOfficial}" Value="False">
                                                	<Setter TargetName="modWarning" Property="Visibility" Value="Visible"/>
                                            	</DataTrigger>
                                                <DataTrigger Binding="{Binding DataContext.Data.IsUGCDisabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True">
                                                    <Setter TargetName="modUpdate" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.Template>
                            <ControlTemplate>
                                <ScrollViewer x:Name="ModScrollViewer" HorizontalContentAlignment="Center" Template="{StaticResource NoForcedStyleScrollViewerTemplate}" Background="Transparent" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style x:Key="ScrollBarStyle" TargetType="ScrollBar" BasedOn="{StaticResource DecorativeGoldScrollBar}"/>
                                        <GridLength x:Key="Top">50</GridLength>
                                        <GridLength x:Key="Bottom">50</GridLength>
                                    </ScrollViewer.Resources>
                                    <ItemsPresenter HorizontalAlignment="Center"/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ListBox.Template>
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="Loaded">
                                <b:InvokeCommandAction Command="{Binding UpdateSelectedModDetails}" CommandParameter="{Binding ElementName=ModList, Path=SelectedItem}"/>
                            </b:EventTrigger>
                            <b:EventTrigger EventName="SelectionChanged">
                                <b:InvokeCommandAction Command="{Binding UpdateSelectedModDetails}" CommandParameter="{Binding ElementName=ModList, Path=SelectedItem}"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListBox>

                    <Grid x:Name="ModInfoSidePanel" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Margin="0,-100,0,0" VerticalAlignment="Stretch" Visibility="{Binding ElementName=ModList, Path=SelectedItem, Converter={StaticResource NullToCollapsedConverter}}">
                        <ls:LSNineSliceImage Margin="0,10,0,80" ImageSource="{StaticResource sidePanelBackground}" Slices="100,520,100,40" Padding="0,0,0,0" Width="1124" HorizontalAlignment="Center" VerticalAlignment="Stretch" />
                        <Control x:Name="SingleModInfoControl" Template="{StaticResource SidePanelModTemplate}" Margin="75,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                    </Grid>
                </Grid>

                <Control x:Name="ModDetailsControl" VerticalAlignment="Top" Template="{StaticResource ModDetailsTemplate}" Visibility="Collapsed"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding InDetailsView}" Value="True">
                    <Setter TargetName="ModDetailsControl" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="InstalledGrid" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </ls:UIWidget.ContentTemplate>
</ls:UIWidget>