<ls:UIWidget x:Name="ModBrowserSplashScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             ls:UIWidget.ContextName="ModBrowserHome"
             d:DataContext="{d:DesignInstance {x:Type ls:Widget}, IsDesignTimeCreatable=True}"
             d:DesignWidth="3840" d:DesignHeight="2160">
    <ls:UIWidget.Template>
        <ControlTemplate>
            <ControlTemplate.Resources>
                <Style TargetType="ls:LSHyperlink">
                    <Setter Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                    <Style.Triggers>
                        <Trigger Property="TagInfo" Value="ModdingToS">
                            <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                            <Setter Property="CommandParameter" Value="ModdingToS"/>
                        </Trigger>
                        <Trigger Property="TagInfo" Value="ModdingPrivacy">
                            <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                            <Setter Property="CommandParameter" Value="ModdingPrivacy"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource LS_tint100}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ControlTemplate.Resources>

            <Grid>
                <Image Source="{StaticResource backgroundFade}" Stretch="Fill"/>
                <ls:LSNineSliceImage Style="{StaticResource splashScreenBackground}" Width="1332" Height="1544" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <DockPanel>

                        <!-- buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,22" DockPanel.Dock="Bottom">

                            <ls:LSButton x:Name="CloseButton" Style="{StaticResource BrownButtonStyle}" 
                                         Content="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7', Converter={StaticResource TranslatedStringConverter}}" 
                                         Command="{Binding CustomEvent}" CommandParameter="CloseAll"/>

                            <ls:LSButton x:Name="AcceptButton" Style="{StaticResource BlueButtonStyle}" 
                                         Content="{Binding Source='hd3a02890gb44dg416fgb68dg9d2d899352cb', Converter={StaticResource TranslatedStringConverter}}"  
                                         Command="{Binding LarianModPolicyAcceptCommand}" 
                                         Margin="-10,0" IsEnabled="False">
                                <b:Interaction.Triggers>
                                    <b:EventTrigger EventName="Click">
                                        <b:InvokeCommandAction Command="{Binding CustomEvent}" CommandParameter="CloseWidget"/>
                                    </b:EventTrigger>
                                </b:Interaction.Triggers>
                            </ls:LSButton>
                        </StackPanel>

                        <!-- title -->
                        <TextBlock x:Name="Title" DockPanel.Dock="Top"
                                   Margin="0,80,0,0"
                                   Text="{Binding Source='h97115d38gfe9eg4f00g9b6bg00c48573c276',Converter={StaticResource TranslatedStringConverter}}"
                                   Foreground="{StaticResource LS_tint100}"
                                   FontSize="{StaticResource MassiveFontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <DockPanel x:Name="Body" Margin="200, 0, 200, 0" LastChildFill="False">

                            <TextBlock x:Name="Description" DockPanel.Dock="Top"
                                       Margin="0,70,0,20"
                                       Foreground="{StaticResource LS_accent75TxtColor}"
                                       FontSize="{StaticResource DefaultFontSize}"
                                       ls:TextBlockFormatter.SourceText="{Binding Source='he2141921g1131g442bgb305g1930322fa4d2',Converter={StaticResource TranslatedStringConverter}}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Left"/>

                            <Grid Margin="0,30,0,0" DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ls:LSCheckBox x:Name="LarianModPrivacyCheckbox" Grid.Column="0" VerticalAlignment="Top" Style="{StaticResource SimpleTickBoxStyle}" IsChecked="False"/>
                                <TextBlock x:Name="LarianPrivacyText" Grid.Column="1" VerticalAlignment="Center" ls:TextBlockFormatter.SourceText="{Binding Source='h2bf32ae0gc711g47ebgb7bcg36c8a0bde957',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,10" DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ls:LSCheckBox x:Name="LarianModTermsCheckbox" Grid.Column="0" VerticalAlignment="Top" Style="{StaticResource SimpleTickBoxStyle}" IsChecked="False"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" ls:TextBlockFormatter.SourceText="{Binding Source='hfaf055d3g0e1fg4562g80a6ge1139acd698b',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap" />
                            </Grid>

                        </DockPanel>

                    </DockPanel>
                </ls:LSNineSliceImage>
            </Grid>

            <ControlTemplate.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsChecked, ElementName=LarianModPrivacyCheckbox}" Value="True"/>
                        <Condition Binding="{Binding IsChecked, ElementName=LarianModTermsCheckbox}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="AcceptButton" Property="IsEnabled" Value="True"/>
                </MultiDataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>