					<attribute id="BodyPartForMocap" type="int32" value="1" />
					<attribute id="OverrideDefaultFoleySettings" type="bool" value="False" />
					<attribute id="PlayCount" type="int32" value="-1" />
					<attribute id="LoopDelay" type="float" value="0" />
					<children>
						<node id="FoleySettings">
							<attribute id="ShouldPlay" type="bool" value="True" />
							<attribute id="CameraCullingEnabled" type="bool" value="True" />
							<attribute id="WindowSize" type="uint32" value="2" />
							<attribute id="SpikeWindowSize" type="uint32" value="2" />
							<attribute id="MinVelocityThreshold" type="float" value="0.2" />
							<attribute id="MaxVelocityThreshold" type="float" value="8" />
							<attribute id="VelocitySpikeThreshold" type="float" value="3.25" />
							<attribute id="VelocityResumeSpikeDetectionThreshold" type="float" value="3.25" />
							<attribute id="MinRotationThreshold" type="float" value="0.2" />
							<attribute id="MaxRotationThreshold" type="float" value="10" />
							<attribute id="RotationSpikeThreshold" type="float" value="2.25" />
							<attribute id="RotationResumeSpikeDetectionThreshold" type="float" value="2.25" />
							<attribute id="ArmorType" type="uint8" value="13" />
						</node>
						<node id="QuestionHoldAutomation">
							<attribute id="IsEnabled" type="bool" value="True" />
							<attribute id="CycleSpeed" type="float" value="5" />
							<attribute id="CycleSpeedDeviation" type="float" value="1" />
							<attribute id="StartOffset" type="float" value="0" />
							<attribute id="StartOffsetDeviation" type="float" value="0" />
						</node>
					</children>
				</node>
				<node id="AdditionalLocations" />
			</children>
		</node>
	</region>
	<region id="EnterSoundEvents">
