<ls:UIWidget x:Name="SignUp"
             ls:UIWidget.ContextName="SignUp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance {x:Type ls:DCSignUp}, IsDesignTimeCreatable=True}"
             d:DesignHeight="2160" d:DesignWidth="3840">
	<ls:UIWidget.Template>
		<ControlTemplate TargetType="{x:Type ls:UIWidget}">
			<ControlTemplate.Resources>
				<ResourceDictionary>
                    <Style TargetType="ls:LSHyperlink">
                        <Setter Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                        <Style.Triggers>
                            <Trigger Property="TagInfo" Value="ToS">
                                <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                                <Setter Property="CommandParameter" Value="ToS"/>
                            </Trigger>
                            <Trigger Property="TagInfo" Value="Privacy">
                                <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                                <Setter Property="CommandParameter" Value="Privacy"/>
                            </Trigger>
                            <Trigger Property="TagInfo" Value="LarianAccount">
                                <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                                <Setter Property="CommandParameter" Value="LarianAccount"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource LS_tint100}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Thickness x:Key="IndentMargin">10,0,0,0</Thickness>
                    
                    <BitmapImage x:Key="SMSBell" UriSource="pack://application:,,,/Core;component/Assets/SignUp/ico_SMSbell.png"/>

                    <BitmapImage x:Key="SignUpBg" UriSource="pack://application:,,,/Core;component/Assets/Shared/mods_introPane_panelBG.png"/>

                    <ControlTemplate x:Key="SignUpMinimalButtonTemplate" TargetType="Button">
                        <Grid>
                            <Rectangle RadiusX="5" RadiusY="5" x:Name="ButtonBg" Stroke="DimGray" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <LinearGradientBrush.GradientStops>
                                            <GradientStop Offset="0" Color="Transparent"/>
                                            <GradientStop Offset="1" Color="#7F666666"/>
                                        </LinearGradientBrush.GradientStops>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBg" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>

                    <Style x:Key="SignUpTickBoxStyle" TargetType="CheckBox">
                        <Setter Property="Template" >
                            <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                    <Grid Background="Transparent">
                                        <Image x:Name="img" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" Source="{TemplateBinding ls:ButtonHelper.ImageSource}" IsHitTestVisible="False"/>
                                        <Image x:Name="check" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" Source="{TemplateBinding ls:ButtonHelper.SecondaryImageSource}" Visibility="Hidden" IsHitTestVisible="False"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Options/checkBox_d.png" />
                        <Setter Property="ls:ButtonHelper.SecondaryImageSource" Value="pack://application:,,,/Core;component/Assets/Options/ico_check_d.png" />
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Options/checkBox_disabled.png"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Options/checkBox_h.png"/>
                                <Setter Property="ls:ButtonHelper.SecondaryImageSource" Value="pack://application:,,,/Core;component/Assets/Options/ico_check_h.png"/>
                            </Trigger>
                            <Trigger Property="IsPressed"  Value="True">
                                <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Options/checkBox_p.png"/>
                                <Setter Property="ls:ButtonHelper.SecondaryImageSource" Value="pack://application:,,,/Core;component/Assets/Options/ico_check_h.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
						<Setter Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
						<Setter Property="TextWrapping" Value="Wrap"/>
						<Setter Property="Height" Value="120"/>
						<Setter Property="TextAlignment" Value="Center"/>
						<Style.Triggers>
							<DataTrigger Binding="{Binding LastError}" Value="EmailFormat">
								<Setter Property="Text" Value="{Binding Source='h430734afgc5ecg4567g9a89g0e83b864ec71', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="EmailExists">
								<Setter Property="Text" Value="{Binding Source='h8507397fg761ag4bb3g87eag0aca0e4647cd', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="PasswordFormat">
								<Setter Property="Text" Value="{Binding Source='hec58a7b2gde8bg48e8gbdb5g60f89ecd1a17', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="Login">
								<Setter Property="Text" Value="{Binding Source='h9f6a521fg8870g4005g8710gef05efed2f37', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="UsernameFormat">
								<Setter Property="Text" Value="{Binding Source='hc030ac78g94cag4c3cgb82egfeb45b5a1304', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="UsernameExists">
								<Setter Property="Text" Value="{Binding Source='h33cf87ecg3494g4420gbfb0g76461b2c48ed', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="ConfirmPassword">
								<Setter Property="Text" Value="{Binding Source='h59fcc107g7667g4a70gb7dcg8359ef26b9f6', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="CheckTerms">
								<Setter Property="Text" Value="{Binding Source='h847a3182g6cffg463bga590gb1b57c33a54c', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="MFA">
                                <Setter Property="Text" Value="{Binding Source='h9f6a521fg8870g4005g8710gef05efed2f37', Converter={StaticResource TranslatedStringConverter}}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="ForgotMessage">
                                <Setter Property="Text" Value="{Binding Source='h52ea6fa7g90d8g47c4g9957g07fda25f6fa1', Converter={StaticResource TranslatedStringConverter}}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="Unknown">
								<Setter Property="Text" Value="{Binding Source='h44ab220dgc343g43degb13aga1f4c9780318', Converter={StaticResource TranslatedStringConverter}}"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
						
					<ControlTemplate x:Key="SpinnerTemplate">
                        <StackPanel x:Name="SpinnerRoot" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="PleaseWait"
                                       Text="{Binding Source='h18414d2cg5e53g41dag8f35g774de89faaf8', Converter={StaticResource TranslatedStringConverter}}"/>
                            <Control VerticalAlignment="Top" HorizontalAlignment="Center" Template="{StaticResource BusyElement}"/>
                        </StackPanel>
                    </ControlTemplate>

                    <ControlTemplate x:Key="EllipseContentRadioButton" TargetType="RadioButton">
                        <Grid>
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Width="40" Height="40" Grid.Column="0" VerticalAlignment="Top" Margin="-48,8,8,8">
                                    <Ellipse x:Name="CircleBg" Width="40" Height="40" Fill="Transparent" Stroke="{StaticResource LS_accent00TxtColor}" StrokeThickness="4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Ellipse x:Name="CheckCircle" Width="18" Height="18" Grid.Column="0" Fill="White" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                            <Rectangle x:Name="HighlightVisual" Stroke="White" Visibility="Collapsed">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <LinearGradientBrush.GradientStops>
                                            <GradientStop Offset="0" Color="Transparent"/>
                                            <GradientStop Offset="1" Color="#7FFFFFFF"/>
                                        </LinearGradientBrush.GradientStops>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckCircle" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CircleBg" Property="Stroke" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HighlightVisual" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>

                    <ControlTemplate x:Key="SignUpTextTemplate" TargetType="Control">
                        <ls:LSNineSliceImage x:Name="Bg" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="92"
                         ImageSource="{TemplateBinding ls:ButtonHelper.ImageSource}" Slices="16" IsTabStop="False">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" IsEnabled="False" Margin="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Padding="{TemplateBinding Padding}" Foreground="{TemplateBinding Foreground}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </ls:LSNineSliceImage>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ls:MoveFocus.IsFocused" Value="True">
                                <Setter TargetName="PART_ContentHost" Property="IsEnabled" Value="True"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>

                    <Style x:Key="SignUpTextStyle" TargetType="Control">
                        <Setter Property="Template" Value="{StaticResource SignUpTextTemplate}" />
                        <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Shared/inp_signin_01_d.png" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Shared/inp_signin_01_h.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="SignUpTextErrorStyle" TargetType="Control">
                        <Setter Property="Template" Value="{StaticResource SignUpTextTemplate}" />
                        <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Shared/inp_signin_03_d.png" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="ls:ButtonHelper.ImageSource" Value="pack://application:,,,/Core;component/Assets/Shared/inp_signin_03_h.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <ControlTemplate x:Key="EmailTemplate">
                        <StackPanel x:Name="EmailRoot" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="Email" Margin="{StaticResource IndentMargin}"
                                       Text="{Binding Source='h94e957aega94cg4ed8g9138gfe77980182af', Converter={StaticResource TranslatedStringConverter}}"/>
                            <ls:LSTextBox x:Name="EmailEdit" Mask="Email" Text="{Binding Email, Mode=TwoWay}" Style="{StaticResource SignUpTextStyle}" OpenVirtualKeyboardOnFocus="False" CaretBrush="{StaticResource LS_accent100TxtColor}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding LastError}" Value="EmailFormat">
                                <Setter TargetName="EmailEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="EmailExists">
                                <Setter TargetName="EmailEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>

                    <ControlTemplate x:Key="PasswordTemplate">
                        <StackPanel x:Name="PasswordRoot" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="Password" Margin="{StaticResource IndentMargin}"
                                       Text="{Binding Source='hef04d4c2g1862g4ebfg9aabg7dc764288126', Converter={StaticResource TranslatedStringConverter}}"/>
                            <ls:LSPasswordBox x:Name="PasswordEdit" Text="{Binding Password, Mode=TwoWay}" Style="{StaticResource SignUpTextStyle}" OpenVirtualKeyboardOnFocus="False" CaretBrush="{StaticResource LS_accent100TxtColor}">
                                <ls:LSPasswordBox.ToolTip>
                                    <ls:LSTooltip x:Name="PasswordEditToolTip" CanBePinned="False" Placement="Right" VerticalOffset="-10" HorizontalOffset="100" PlayerId="{Binding Path=DataContext.CurrentPlayer.PlayerId, ElementName=SignUp}">
                                        <TextBlock x:Name="PasswordEditToolTipContent" TextAlignment="Left" MaxWidth="800" TextWrapping="Wrap"
													   Text="{Binding Source='hec58a7b2gde8bg48e8gbdb5g60f89ecd1a17', Converter={StaticResource TranslatedStringConverter}}"/>
                                    </ls:LSTooltip>
                                </ls:LSPasswordBox.ToolTip>
                            </ls:LSPasswordBox>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding LastError}" Value="PasswordFormat">
                                <Setter TargetName="PasswordEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="Login">
                                <Setter TargetName="PasswordEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
					
					<ControlTemplate x:Key="LarianAccountTemplate">
                        <Grid x:Name="ScreenContainer" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" VerticalAlignment="Top" Height="60" Margin="0,50" TextAlignment="Center" Text="{Binding Source='h2d0dcfb7g5a4bg4c0fg9a2fgefa48557c453', Converter={StaticResource TranslatedStringConverter}}"/>
                            <StackPanel VerticalAlignment="Top" Margin="50,160,50,0">
                                <TextBlock x:Name="Subtitle" HorizontalAlignment="Center" TextAlignment="Left" Margin="100,0" Foreground="{StaticResource LS_accent75TxtColor}"
										   Text="{Binding Source='h3c895f7fg70c9g4584g8a02g83c63a313cb7', Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap"/>

                                <ls:LSRadioButton x:Name="CreateAccountBtn" Template="{StaticResource EllipseContentRadioButton}" Padding="100,30" IsChecked="True">
									<StackPanel>
                                        <TextBlock x:Name="CreateAccountTitle" Text="{Binding Source='h81fa45a1gcee1g482dgb2bcge83b4bd783f7',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent100TxtColor}"/>
                                        <TextBlock x:Name="CreateAccountDescription" Text="{Binding Source='h1ccde1a9g8d34g439fgb40cg02035d666330',Converter={StaticResource TranslatedStringConverter}}"/>
                                    </StackPanel>
								</ls:LSRadioButton>
                                <ls:LSRadioButton x:Name="LoginBtn" Template="{StaticResource EllipseContentRadioButton}" Padding="100,30">
									<StackPanel>
                                        <TextBlock x:Name="LoginTitle" Text="{Binding Source='h224af12cg943dg40ebg9298g0166926b2f82',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent100TxtColor}"/>
                                        <TextBlock x:Name="LoginDescription" Text="{Binding Source='hc3a72c4dgf4e4g40ebg8f9cga0b0c1aa7aff',Converter={StaticResource TranslatedStringConverter}}"/>	
									</StackPanel>
								</ls:LSRadioButton>
                            </StackPanel>
							<TextBlock x:Name="Disclaimer" 
									   TextAlignment="Center"
									   TextWrapping="Wrap"
									   Margin="30,0,30,100"
									   ls:TextBlockFormatter.SourceText="{Binding Source='hb8303bf9g0397g45f1g8bceg5c4236867c8b',Converter={StaticResource TranslatedStringConverter}}"	
                                       VerticalAlignment="Bottom" />
                            <StackPanel x:Name="FlowButtons" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-12">
                                <ls:LSButton x:Name="BackBtn" Command="{Binding CancelBack}" Content="{Binding Source='h01d5c470g61bfg498cgb17eg7be425444fa5',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BrownButtonStyle}" />
                                <ls:LSButton x:Name="NextBtn" Content="{Binding Source='hd0c08193ga7f2g4a7eg8225g63748c7b3096',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BlueButtonStyle}" IsEnabled="False"/>
							</StackPanel>
						</Grid>
						<ControlTemplate.Triggers>
                            <Trigger SourceName="CreateAccountBtn" Property="IsMouseOver" Value="True">
                                <Setter TargetName="CreateAccountTitle" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                                <Setter TargetName="CreateAccountDescription" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                            </Trigger>
                            <Trigger SourceName="CreateAccountBtn" Property="IsChecked" Value="True">
								<Setter TargetName="NextBtn" Property="Command" Value="{Binding GoToCreateAccount}"/>
                                <Setter TargetName="NextBtn" Property="IsEnabled" Value="True"/>
                            </Trigger>
                            <Trigger SourceName="LoginBtn" Property="IsMouseOver" Value="True">
                                <Setter TargetName="LoginTitle" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                                <Setter TargetName="LoginDescription" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                            </Trigger>
                            <Trigger SourceName="LoginBtn" Property="IsChecked" Value="True">
								<Setter TargetName="NextBtn" Property="Command" Value="{Binding GoToLogin}"/>
								<Setter TargetName="NextBtn" Property="IsEnabled" Value="True"/>
							</Trigger>
                            <DataTrigger Binding="{Binding ShowFirstTimeSetup}" Value="True">
                                <Setter TargetName="BackBtn" Property="Command" Value="{Binding CustomEvent}"/>
                                <Setter TargetName="BackBtn" Property="CommandParameter" Value="OpenSensitiveSettings"/>
                                <Setter TargetName="BackBtn" Property="Content" Value="{Binding Source='h566118f2g4237g40e5gbd6agfa6a91271470',Converter={StaticResource TranslatedStringConverter}}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
					</ControlTemplate>

					<ControlTemplate x:Key="CreateAccountTemplate">
						<Grid x:Name="ScreenContainer">
                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Top" Height="60" Margin="0,50" Text="{Binding Source='hf88d69ccg846fg41a5g9413gcf6cb09d609b', Converter={StaticResource TranslatedStringConverter}}"/>
                            <StackPanel Margin="160,160,160,0" VerticalAlignment="Top" KeyboardNavigation.TabNavigation="Cycle">
                                <TextBlock x:Name="Username" Margin="{StaticResource IndentMargin}"
										   Text="{Binding Source='hfac7c8f2g905dg470eg9810g70b9a710b585', Converter={StaticResource TranslatedStringConverter}}"/>
                                <ls:LSTextBox x:Name="UsernameEdit" Text="{Binding UserName, Mode=TwoWay}" ProfanityFilter="True" OpenVirtualKeyboardOnFocus="False" Style="{StaticResource SignUpTextStyle}" CaretBrush="{StaticResource LS_accent100TxtColor}">
									 <ls:LSTextBox.ToolTip>
										<ls:LSTooltip x:Name="UsernameEditToolTip" CanBePinned="False" Placement="Right" VerticalOffset="-10" HorizontalOffset="100" PlayerId="{Binding Path=DataContext.CurrentPlayer.PlayerId, ElementName=SignUp}">
											<TextBlock x:Name="UsernameEditToolTipContent" TextAlignment="Left" MaxWidth="800" TextWrapping="Wrap"
													   Text="{Binding Source='hc030ac78g94cag4c3cgb82egfeb45b5a1304', Converter={StaticResource TranslatedStringConverter}}"/>
										</ls:LSTooltip>
									</ls:LSTextBox.ToolTip>
								</ls:LSTextBox>
								<Control x:Name="Email" VerticalAlignment="Top" HorizontalAlignment="Stretch" Template="{StaticResource EmailTemplate}" IsTabStop="False"/>
                                <Control x:Name="Password" VerticalAlignment="Top" HorizontalAlignment="Stretch" Template="{StaticResource PasswordTemplate}" IsTabStop="False"/>
                                <TextBlock x:Name="ConfirmPassword" Margin="{StaticResource IndentMargin}"
										   Text="{Binding Source='hb27434b8gcc29g44b6gbf23g945880c4f859', Converter={StaticResource TranslatedStringConverter}}"/>
                                <ls:LSPasswordBox x:Name="ConfirmPasswordEdit" Style="{StaticResource SignUpTextStyle}"
													  Text="{Binding ConfirmPassword, Mode=TwoWay}" OpenVirtualKeyboardOnFocus="False" CaretBrush="{StaticResource LS_accent100TxtColor}"/>
                                <Grid Margin="0,30,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ls:LSCheckBox x:Name="TermsCheck" Grid.Column="0" VerticalAlignment="Top" Style="{StaticResource SignUpTickBoxStyle}"
											       IsChecked="{Binding CheckTerms}" Command="{Binding CleanLastError}" IsTabStop="False"/>
                                    <TextBlock x:Name="TermsText" Grid.Column="1" VerticalAlignment="Center" ls:TextBlockFormatter.SourceText="{Binding Source='h433ee9f9g56fcg4107g8612gf3711bcad6cb',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap"/>
                                </Grid>
                                <Grid Margin="0,30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ls:LSCheckBox x:Name="SubscribeCheck" Grid.Column="0" VerticalAlignment="Top" Style="{StaticResource SignUpTickBoxStyle}"
											       IsChecked="{Binding Subscribe}" Command="{Binding CleanLastError}" IsTabStop="False"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Source='hcb35a7e4g4ebbg4245gb800g8cddab337d22',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap" />
                                </Grid>
                                <TextBlock x:Name="RequiredField" HorizontalAlignment="Left" Margin="0,10"
								   Text="{Binding Source='h7000d355g30c0g425aga3a5gf0b07b6c7d83', Converter={StaticResource TranslatedStringConverter}}" />
                                <TextBlock x:Name="ErrorText" Style="{StaticResource ErrorTextStyle}" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                            </StackPanel>
                            <Control x:Name="Spinner" VerticalAlignment="Bottom" Margin="0,0,0,90" HorizontalAlignment="Center" Template="{StaticResource SpinnerTemplate}" Visibility="Collapsed"/>
                            
                            <StackPanel x:Name="FlowButtons" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-12">
                                <ls:LSButton x:Name="BackBtn" Command="{Binding CancelBack}" Content="{Binding Source='h01d5c470g61bfg498cgb17eg7be425444fa5',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BrownButtonStyle}"/>
                                <ls:LSButton x:Name="CreateAccountBtn" Command="{Binding CreateAccount}" Content="{Binding Source='h7b591ae5g10b0g47deg991bgf3bca82abe96',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BlueButtonStyle}" />
							</StackPanel>
						</Grid>
						<ControlTemplate.Triggers>
							<DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                <Setter TargetName="Spinner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CreateAccountBtn" Property="IsEnabled" Value="False"/>
                            </DataTrigger>
							<DataTrigger Binding="{Binding LastError}" Value="ConfirmPassword">
                                <Setter TargetName="ConfirmPasswordEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
							</DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="UsernameFormat">
                                <Setter TargetName="UsernameEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="UsernameExists">
                                <Setter TargetName="UsernameEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="CheckTerms">
                                <Setter TargetName="TermsText" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="Unknown">
                                <Setter TargetName="UsernameEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
					</ControlTemplate>

                    <ControlTemplate x:Key="LoginTemplate">
						<Grid x:Name="ScreenContainer">
                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Top" Height="60" Margin="0,50" Text="{Binding Source='hb015b40eg3748g4fd3gbc77g92967ec3582e', Converter={StaticResource TranslatedStringConverter}}"/>
                            <StackPanel Margin="160,160,160,0" VerticalAlignment="Top">
                                <Grid KeyboardNavigation.TabNavigation="Cycle">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Control x:Name="Email" Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Stretch" Template="{StaticResource EmailTemplate}" IsTabStop="False"/>
                                    <Control x:Name="Password" Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Stretch" Template="{StaticResource PasswordTemplate}" IsTabStop="False"/>
                                </Grid>
                                <ls:LSButton x:Name="ForgotPwdBtn" HorizontalAlignment="Center" Style="{StaticResource BigBrownButtonStyle}" Command="{Binding ForgotPassword}" Content="{Binding Source='h238dc92egc516g4566gb9e9gb8731223fa04',Converter={StaticResource TranslatedStringConverter}}" Margin="0,30" IsTabStop="False"/>
                                <TextBlock x:Name="ForgotPasswordMessage" VerticalAlignment="Top" TextWrapping="Wrap" Margin="0,10" HorizontalAlignment="Center" Visibility="Collapsed" Text="{Binding Source='hf62d6904g1afeg4a02g9c5ag20abe4745e56', Converter={StaticResource TranslatedStringConverter}}"/>
                                <TextBlock x:Name="ErrorText" Style="{StaticResource ErrorTextStyle}" HorizontalAlignment="Center" Margin="0,10"/>
                            </StackPanel>
                            <Control x:Name="Spinner" VerticalAlignment="Bottom" Margin="0,0,0,90" HorizontalAlignment="Center" Template="{StaticResource SpinnerTemplate}" Visibility="Collapsed"/>
                            <StackPanel x:Name="FlowButtons" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-12">
                                <ls:LSButton x:Name="BackBtn" Command="{Binding CancelBack}" Content="{Binding Source='h01d5c470g61bfg498cgb17eg7be425444fa5',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BrownButtonStyle}"/>
                                <ls:LSButton x:Name="LoginBtn" Command="{Binding Login}" Content="{Binding Source='h224af12cg943dg40ebg9298g0166926b2f82',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BlueButtonStyle}"/>
							</StackPanel>
						</Grid>
						<ControlTemplate.Triggers>
							<DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                <Setter TargetName="Spinner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="LoginBtn" Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ShowForgottenPasswordMessage}" Value="True">
                                <Setter TargetName="ForgotPasswordMessage" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ForgotPwdBtn" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
					</ControlTemplate>

                    <ControlTemplate x:Key="TwoFactorTemplate">
						<Grid x:Name="ScreenContainer" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Top" Height="60" Margin="0,50" Text="{Binding Source='ha51a57beg4923g4fabga23eg3126d472efd6', Converter={StaticResource TranslatedStringConverter}}"/>
                            <StackPanel Margin="160,180,160,0" VerticalAlignment="Top">
								<DockPanel HorizontalAlignment="Center" Margin="0, 30">
									<Image x:Name="Bell" Source="{StaticResource SMSBell}" Stretch="None" HorizontalAlignment="Left" Margin="10" DockPanel.Dock="Left"/>
									<TextBlock x:Name="SMS" Margin="0,10" TextWrapping="Wrap" DockPanel.Dock="Right"
											   Text="{Binding Source='h0f722781g29dcg47cfgbaafg33c0698e131e', Converter={StaticResource TranslatedStringConverter}}"/>
								</DockPanel>
								<TextBlock x:Name="CodeHeader"
										   Text="{Binding Source='hc560d851g8d31g4b79ga5cdge370b1d9c88d', Converter={StaticResource TranslatedStringConverter}}"/>
                                <ls:LSTextBox x:Name="CodeEdit" Style="{StaticResource SignUpTextStyle}"
											  Text="{Binding SMSCode, Mode=TwoWay}" OpenVirtualKeyboardOnFocus="False"/>   
								<TextBlock x:Name="RequiredField" HorizontalAlignment="Left"
								   Text="{Binding Source='h7000d355g30c0g425aga3a5gf0b07b6c7d83', Converter={StaticResource TranslatedStringConverter}}" />
                                <TextBlock x:Name="ErrorText" Style="{StaticResource ErrorTextStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Control x:Name="Spinner"  VerticalAlignment="Bottom" Margin="0,0,0,90" HorizontalAlignment="Center" Template="{StaticResource SpinnerTemplate}" Visibility="Collapsed"/>

                            <StackPanel x:Name="FlowButtons" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-12">
                                <ls:LSButton x:Name="BackBtn" Command="{Binding CancelBack}" Content="{Binding Source='h01d5c470g61bfg498cgb17eg7be425444fa5',Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource BrownButtonStyle}"/>
                                <ls:LSButton x:Name="ContinueBtn" Style="{StaticResource BlueButtonStyle}"
											Command="{Binding TwoFactorContinue}"
											Content="{Binding Source='h45db0d8cg465fg4c1dg8c21gc894286fa41e',Converter={StaticResource TranslatedStringConverter}}"/>
                            </StackPanel>
                        </Grid>
						<ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding LastError}" Value="MFA">
                                <Setter TargetName="CodeEdit" Property="Style" Value="{StaticResource SignUpTextErrorStyle}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                <Setter TargetName="Spinner" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>

                    <ControlTemplate x:Key="LoginSuccessfulTemplate">
						<Grid x:Name="ScreenContainer" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Top" Height="60" Margin="0,50" Text="{Binding Source='hb015b40eg3748g4fd3gbc77g92967ec3582e', Converter={StaticResource TranslatedStringConverter}}"/>
                            <StackPanel Margin="160,180,160,0">
                                <TextBlock x:Name="LoggedInMessage" Foreground="{StaticResource LS_accent75TxtColor}" TextWrapping="Wrap" HorizontalAlignment="Left" TextAlignment="Left" VerticalAlignment="Top" Height="60" Text="{Binding Source='h9c7cc4c7g8dc9g4915g857cg05e21e576880', Converter={StaticResource TranslatedStringConverter}}"/>
                                <TextBlock x:Name="Username"  VerticalAlignment="Top" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_specialTxtColor}"
                                           HorizontalAlignment="Center" Text="{Binding UserName}"/>
                            </StackPanel>
                            <ls:LSButton x:Name="ContinueBtn"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Bottom"
                                         Margin="0,0,0,-12"
                                         Style="{StaticResource BlueButtonStyle}"
                                         Command="{Binding CustomEvent}"
                                         CommandParameter="CloseWidget"
                                         Content="{Binding Source='h45db0d8cg465fg4c1dg8c21gc894286fa41e',Converter={StaticResource TranslatedStringConverter}}"/>
						</Grid>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CurrentPlayer.UIData.PreviousState}" Value="ModBrowserDownload"/>
                                    <Condition Binding="{Binding Data.ModAccountState}" Value="LarianConnected"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ContinueBtn" Property="CommandParameter" Value="OpenModioSignIn"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding CurrentPlayer.UIData.PreviousState}" Value="ModBrowserInstalled"/>
                                    <Condition Binding="{Binding Data.ModAccountState}" Value="LarianConnected"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ContinueBtn" Property="CommandParameter" Value="OpenModioSignIn"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
					</ControlTemplate>

                    <ControlTemplate x:Key="AccountCreatedTemplate">
                        <Grid x:Name="ScreenContainer" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="Title" Foreground="{StaticResource LS_tint100}" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Top" Height="60" Margin="0,50" Text="{Binding Source='h0dc8f947gd342g4444g976bgb0804026c147', Converter={StaticResource TranslatedStringConverter}}"/>
                            <TextBlock x:Name="Description" Margin="160,180,160,0" VerticalAlignment="Top" TextWrapping="Wrap"
                                       ls:TextBlockFormatter.SourceText="{Binding Source='h536f1843g57e0g4368g8699gbcb87e8b6e07',Converter={StaticResource TranslatedStringConverter}}"/>
                            <ls:LSButton x:Name="CloseBtn"
                                         HorizontalAlignment="Center" 
										 VerticalAlignment="Bottom" 
										 Margin="0,0,0,-12"
										 Style="{StaticResource BlueButtonStyle}"
                                         Command="{Binding Login}"
                                         Content="{Binding Source='h45db0d8cg465fg4c1dg8c21gc894286fa41e',Converter={StaticResource TranslatedStringConverter}}"/>
                        </Grid>
                    </ControlTemplate>
				</ResourceDictionary>
			</ControlTemplate.Resources>
            <Grid Background="{StaticResource LS_PanelBackgroundLight}">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="{Binding ActualWidth, ElementName=TabBg}" Height="{Binding ActualHeight, ElementName=TabBg}">
                    <Image x:Name="TabBg" Source="{StaticResource SignUpBg}" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None"/>
                    <Control x:Name="CurrentTab" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="78"/>
                </Grid>

                <Grid x:Name="NoInternet" IsHitTestVisible="True" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Visibility="Collapsed">
                    <Grid.Background>
                        <SolidColorBrush Color="Black" Opacity="0.80"/>
                    </Grid.Background>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="Title" FontSize="{StaticResource ScaledTitleFontSize}" Foreground="{StaticResource LS_tint100}" Margin="100,200,100,200" HorizontalAlignment="Center"
                   Text="{Binding Source='h4c6a6f55gbb78g4a76g928cg77e6d9944abb', Converter={StaticResource TranslatedStringConverter}}"/>
                        <ls:LSButton x:Name="TryAgainBtn" HorizontalAlignment="Center" Template="{StaticResource SignUpMinimalButtonTemplate}"
									 Command="{Binding InternetConnectionTryAgain}" Margin="0,40" MinWidth="300" Padding="30,20"
									 Content="{Binding Source='h0ab67992g5f7cg4402gbd1dg07ea74fa5309',Converter={StaticResource TranslatedStringConverter}}"/>
                        <ls:LSButton x:Name="BackBtn" HorizontalAlignment="Center" Template="{StaticResource SignUpMinimalButtonTemplate}"
									 Command="{Binding CancelBack}" Margin="0,40" MinWidth="300" Padding="30,20"
									 Content="{Binding Source='h9d3b37a6gf7e3g40a8g87d3g21b1d1732512',Converter={StaticResource TranslatedStringConverter}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
			<ControlTemplate.Triggers>
				<DataTrigger Binding="{Binding CurrentScreen}" Value="LarianAccount">
                    <Setter TargetName="CurrentTab" Property="Template" Value="{StaticResource LarianAccountTemplate}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding CurrentScreen}" Value="CreateAccount">
                    <Setter TargetName="CurrentTab" Property="Template" Value="{StaticResource CreateAccountTemplate}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding CurrentScreen}" Value="Login">
                    <Setter TargetName="CurrentTab" Property="Template" Value="{StaticResource LoginTemplate}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding CurrentScreen}" Value="TwoFactor">
                    <Setter TargetName="CurrentTab" Property="Template" Value="{StaticResource TwoFactorTemplate}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding CurrentScreen}" Value="LoginSuccessful">
                    <Setter TargetName="CurrentTab" Property="Template" Value="{StaticResource LoginSuccessfulTemplate}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding CurrentScreen}" Value="AccountCreated">
                    <Setter TargetName="CurrentTab" Property="Template" Value="{StaticResource AccountCreatedTemplate}"/>
				</DataTrigger>
                <DataTrigger Binding="{Binding InternetConnection}" Value="False">
                    <Setter TargetName="NoInternet" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="CurrentTab" Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
		</ControlTemplate>
	</ls:UIWidget.Template>
</ls:UIWidget>
