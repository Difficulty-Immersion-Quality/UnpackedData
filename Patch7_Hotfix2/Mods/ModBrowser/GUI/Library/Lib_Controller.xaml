<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:ls="clr-namespace:ls;assembly=Code"
                    xmlns:System="clr-namespace:System;assembly=mscorlib"
                    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
                    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    mc:Ignorable="d">
    <Storyboard x:Key="ShowSidePanel" FillBehavior="Stop">
        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="ModInfoSidePanel" Duration="0:0:0.5" To="0,0,-400,0">
            <ThicknessAnimation.EasingFunction>
                <SineEase EasingMode="EaseInOut"/>
            </ThicknessAnimation.EasingFunction>
        </ThicknessAnimation>
    </Storyboard>

    <Storyboard x:Key="HideSidePanel" FillBehavior="Stop">
        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="ModInfoSidePanel" Duration="0:0:0.5" To="0,0,-1410,0">
            <ThicknessAnimation.EasingFunction>
                <SineEase EasingMode="EaseInOut"/>
            </ThicknessAnimation.EasingFunction>
        </ThicknessAnimation>
    </Storyboard>

    <ControlTemplate x:Key="DownloadingBar" TargetType="Control">
        <StackPanel x:Name="downloadingBorder" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="-20,0,0,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right" Text="{Binding Source='hdab4d70ege6aeg4b26gac04g9f607899eca8',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_modsDownloadBarColor}" Style="{StaticResource TooltipStringBodyStyle}" Margin="0,4,0,6"/>
                <Border BorderThickness="2" BorderBrush="{StaticResource LS_modsDownloadBarBorderColor}" Width="412" ClipToBounds="True"
                                    Background="{StaticResource LS_modsDownloadBarBgColor}" Effect="{StaticResource ShadowEffectSmall}" Height="12" HorizontalAlignment="Center">
                    <Rectangle x:Name="runningBar" Fill="{StaticResource LS_modsDownloadBarColor}" Width="200" Height="8"/>
                </Border>
            </StackPanel>
            <Image Source="{StaticResource updateIcon_c}" Stretch="None" VerticalAlignment="Center" />
        </StackPanel>
        <ControlTemplate.Triggers>
            <EventTrigger RoutedEvent="Loaded" SourceName="runningBar">
                <BeginStoryboard x:Name="IndefiniteLoading">
                    <Storyboard>
                        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="runningBar" Duration="0:0:1" From="0,0,200,0" To="0,0,-200,0" AutoReverse="True" RepeatBehavior="Forever">
                            <ThicknessAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </ThicknessAnimation.EasingFunction>
                        </ThicknessAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Unloaded" SourceName="runningBar">
                <StopStoryboard BeginStoryboardName="IndefiniteLoading"/>
            </EventTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="BrowserTopButtons_c">
        <Grid VerticalAlignment="Top" HorizontalAlignment="Stretch" Focusable="False" Height="164">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Control x:Name="HeaderBackground" Grid.Column="0" Grid.ColumnSpan="3"  Template="{StaticResource TopCarouselBackground}"/>

            <TextBlock x:Name="SelectedModName" Grid.Column="1" Text="{Binding SelectedMod.Name}" Visibility="Collapsed" Foreground="{StaticResource LS_extraspecialTxtColor}" FontSize="{StaticResource ScaledLargeFontSize}" FontWeight="DemiBold"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <ListBox x:Name="HeaderCarouselList" Grid.Column="1"
                     VerticalAlignment="Center"
                     ItemContainerStyle="{StaticResource CarouselItemContainerStyle}"
                     Margin="40,0">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <ItemsPresenter x:Name="dots" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <ContentControl x:Name="base" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,59,0,0">
                                <Grid>
                                    <ls:LSButton x:Name="leftBtn" BoundEvent="UITabPrev" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" HorizontalAlignment="Left" Margin="0,-46,0,0"
                                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UITabPrev'}"/>
                                    <Border Width="{Binding ElementName=dots, Path=ActualWidth, Converter={StaticResource AddConverter}, ConverterParameter=260}" Margin="60,0,60,0"/>
                                    <ls:LSButton x:Name="rightBtn" BoundEvent="UITabNext" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" HorizontalAlignment="Right" Margin="0,-46,0,0"
                                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UITabNext'}"/>
                                </Grid>
                            </ContentControl>
                            <b:Interaction.Triggers>
                                <b:EventTrigger SourceName="leftBtn" EventName="Click">
                                    <ls:SelectNextListBoxItem Reversed="True" TargetObject="{Binding RelativeSource={RelativeSource TemplatedParent}}" ForceSelect="True" ForceMode="Cycle"/>
                                </b:EventTrigger>
                                <b:EventTrigger SourceName="rightBtn" EventName="Click">
                                    <ls:SelectNextListBoxItem TargetObject="{Binding RelativeSource={RelativeSource TemplatedParent}}" ForceSelect="True" ForceMode="Cycle"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding ItemsSource.Count, RelativeSource={RelativeSource Self}}" Value="1">
                                <Setter TargetName="leftBtn" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="rightBtn" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding CustomEvent}"
                                               CommandParameter="{Binding ElementName=HeaderCarouselList, Path=SelectedItem.Tag}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <ListBoxItem Content="{Binding Source='h355d15dag71c4g4c86g941bg0cc9388a89d2'}" Tag="OpenModBrowserDownload"/>
                <ListBoxItem Content="{Binding Source='h22d04d59g92cdg4f7ag8185g50d6e34d2e3a'}" Tag="OpenModBrowserInstalled"/>
            </ListBox>

            <Control x:Name="ModMemoryWidget" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,-190">
                <Control.Template>
                    <ControlTemplate>
                        <StackPanel Orientation="Horizontal" >

                            <TextBlock x:Name="ModMemoryWidgetTitle" Text="{Binding Source='hb12566a0g9c86g497fgb496gded088e143b0', Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent25TxtColor}" FontSize="{StaticResource ScaledSmallishFontSize}" HorizontalAlignment="Right" noesis:Text.Stroke="{StaticResource LS_PanelBackdrop}" noesis:Text.StrokeThickness="8" TextAlignment="Right" Margin="0,0,4,0"/>
                            <StackPanel x:Name="ModMemoryWidgetContentComplete" Orientation="Horizontal" HorizontalAlignment="Right">

                                <Image x:Name="ModMemoryWidgetImageComplete" Source="{StaticResource detailsFileSize}" Stretch="None" Margin="0,3,0,0"/>
                                <TextBlock x:Name="MemoryTextComplete" Foreground="{StaticResource LS_accent25TxtColor}" FontWeight="DemiBold" FontSize="{StaticResource ScaledSmallishFontSize}" noesis:Text.Stroke="{StaticResource LS_PanelBackdrop}" noesis:Text.StrokeThickness="8" Margin="4, 0, 0, 0">
                                    <Run x:Name="CurrentMemoryComplete" Text="{Binding Data.UsedModDiskSpace, Converter={StaticResource FileSizeConverter}}"/>
                                    <Run Text="{Binding Source='hd64bfe4cgadadg4468g8b0ag70330ffc717c', Converter={StaticResource TranslatedStringConverter}}"/>
                                    <Run Text="{Binding Data.TotalModDiskSpace, Converter={StaticResource FileSizeConverter}}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel x:Name="ModMemoryWidgetContentSimple" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                                <Image Source="{StaticResource detailsFileSize}" Stretch="None" Margin="0,3,0,0"/>
                                <TextBlock x:Name="MemoryTextSimple" Foreground="{StaticResource LS_accent25TxtColor}" FontWeight="DemiBold" FontSize="{StaticResource ScaledSmallishFontSize}" Margin="4, 0, 0, 0">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                            <Binding Source="h9fed80b2g8f32g401dg8e1eg40bfbb55593e"/>
                                            <Binding Path="Data.UsedModDiskSpace" Converter="{StaticResource FileSizeConverter}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <!-- Some platforms can't get TotalModDiskSpace. Hide it. -->
                            <DataTrigger Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="False">
                                <Setter TargetName="ModMemoryWidgetContentComplete" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ModMemoryWidgetContentSimple" Property="Visibility" Value="Visible"/>
                            </DataTrigger>

                            <!-- Show image and text as red if not enough space -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="True"/>
                                    <Condition Binding="{Binding ActiveTabID}" Value="Browse"/>
                                    <Condition Binding="{Binding InDetailsView}" Value="True"/>
                                    <Condition Binding="{Binding SelectedMod.ModState}" Value="Unsubscribed"/>
                                    <Condition Value="False">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource LessThanOrEqualMultiConverter}">
                                                <Binding Path="PotentialUsedModDiskSpace"/>
                                                <Binding Path="Data.TotalModDiskSpace"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ModMemoryWidgetImageComplete" Property="Source" Value="{StaticResource detailsFileSizeRed}"/>
                                <Setter TargetName="MemoryTextComplete" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="True"/>
                                    <Condition Binding="{Binding ActiveTabID}" Value="Browse"/>
                                    <Condition Binding="{Binding InDetailsView}" Value="True"/>
                                    <Condition Binding="{Binding SelectedMod.IsOutdated}" Value="True"/>
                                    <Condition Value="False">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource LessThanOrEqualMultiConverter}">
                                                <Binding Path="PotentialUsedModDiskSpace"/>
                                                <Binding Path="Data.TotalModDiskSpace"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ModMemoryWidgetImageComplete" Property="Source" Value="{StaticResource detailsFileSizeRed}"/>
                                <Setter TargetName="MemoryTextComplete" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Data.IsTotalModDiskSpaceValid}" Value="True"/>
                                    <Condition Binding="{Binding ActiveTabID}" Value="Installed"/>
                                    <Condition Binding="{Binding SelectedMod.IsOutdated}" Value="True"/>
                                    <Condition Value="False">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource LessThanOrEqualMultiConverter}">
                                                <Binding Path="PotentialUsedModDiskSpace"/>
                                                <Binding Path="Data.TotalModDiskSpace"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ModMemoryWidgetImageComplete" Property="Source" Value="{StaticResource detailsFileSizeRed}"/>
                                <Setter TargetName="MemoryTextComplete" Property="Foreground" Value="{StaticResource LS_alertTxtColor}"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Control.Template>
            </Control>

            <Grid x:Name="accountPanel" Grid.Column="2" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="accountStateLabel" ls:TextBlockFormatter.SourceText="{Binding Source=hb9ff318ag5054g4b96gb5cfg1f05349b6174, Converter={StaticResource TranslatedStringConverter}}"
                               Foreground="{StaticResource LS_baseTxtColor}" Width="500" TextWrapping="NoWrap"  TextTrimming="CharacterEllipsis" TextAlignment="Right" FontSize="{StaticResource ScaledSmallFontSize}" Margin="0,0,12,-8"/>
                    <TextBlock Grid.Row="1" x:Name="accountName" Text="{Binding CurrentPlayer.Name}" Foreground="{StaticResource LS_extraspecialTxtColor}" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                </Grid>

                <Grid x:Name="avatarGrid" Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center">
                    <Image x:Name="avatarFrame" Source="{StaticResource accountFrameDefault}" Stretch="None"/>
                    <Rectangle x:Name="avatarIcon" Width="{StaticResource avatarIconSize}" Height="{StaticResource avatarIconSize}" Fill="{Binding CurrentPlayer.CommunityIcon}"/>
                    <Image x:Name="defaultIcon" Width="{StaticResource avatarIconSize}" Height="{StaticResource avatarIconSize}" Stretch="Fill" Source="{StaticResource accountUnknownPortrait}" Visibility="Collapsed"/>
                </Grid>

                <ls:LSButton x:Name="accountButton" Grid.Column="2" BoundEvent="ToggleInGameMenu" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" VerticalAlignment="Center"
                             Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='ToggleInGameMenu'}"
                             Command="{Binding CustomEvent}" CommandParameter="OpenAccountManagement"/>
            </Grid>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding ActiveTabID}" Value="Browse">
                <Setter TargetName="HeaderCarouselList" Property="SelectedIndex" Value="0"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding ActiveTabID}" Value="Installed">
                <Setter TargetName="HeaderCarouselList" Property="SelectedIndex" Value="1"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding InDetailsView}" Value="True">
                <Setter TargetName="SelectedModName" Property="Visibility" Value="Visible"/>
                <Setter TargetName="HeaderCarouselList" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding InScreenshotZoom}" Value="True">
                <Setter TargetName="HeaderBackground" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="accountPanel" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="Offline">
                <Setter TargetName="avatarIcon" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="defaultIcon" Property="Visibility" Value="Visible"/>
                <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText"
                        Value="{Binding Source=h9f4ad432g31dfg43e5gad49gffbf79873345, Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="accountName" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="accountStateLabel" Property="Margin" Value="0,0,12,0" />
                <Setter TargetName="accountButton" Property="CommandParameter" Value="OpenSignUp"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="OnlineNoAccountConnected">
                <Setter TargetName="avatarIcon" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="defaultIcon" Property="Visibility" Value="Visible"/>
                <Setter TargetName="accountName" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="accountStateLabel" Property="Margin" Value="0,0,12,0" />
                <Setter TargetName="accountButton" Property="CommandParameter" Value="OpenSignUp"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="LarianConnected">
                <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source=h27e58bb5g18d9g4044ga4f4ga166113693ab, Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="ModioConnected">
                <Setter TargetName="accountStateLabel" Property="ls:TextBlockFormatter.SourceText" Value="{Binding Source=hfa041695g2655g4540g91aege61c49fd327b, Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="WarningLabelTemplateWide" TargetType="Control">
        <StackPanel Orientation="Horizontal" Margin="-16,0,0,0">
            <Rectangle Fill="{TemplateBinding Background}" VerticalAlignment="Top" MinHeight="{StaticResource MinimumWarningIconSize}" MinWidth="{StaticResource MinimumWarningIconSize}"/>
            <TextBlock VerticalAlignment="Top" ls:TextBlockFormatter.SourceText="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}" MaxWidth="2200" Foreground="{TemplateBinding Foreground}" Style="{StaticResource TooltipStringBodyStyle}" Margin="6,0,0,0"/>
        </StackPanel>
    </ControlTemplate>

    <DataTemplate x:Key="ModPreviewTemplate" DataType="{x:Type ls:VMModPreview}">
        <Grid x:Name="modPreviewRoot" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- Mod Image -->
            <Rectangle x:Name="modScreenshot" Grid.Column="0" HorizontalAlignment="Left" Fill="{Binding MainScreenshot.Screenshot}" Width="242"  Margin="14,0,0,0" VerticalAlignment="Center" Effect="{StaticResource ShadowEffectSmall}">
                <Rectangle.Height>
                    <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                        <Binding Path="ActualWidth" ElementName="modScreenshot"/>
                        <Binding Path="Fill.ImageSource.Width" ElementName="modScreenshot"/>
                        <Binding Path="Fill.ImageSource.Height" ElementName="modScreenshot"/>
                    </MultiBinding>
                </Rectangle.Height>
            </Rectangle>

            <Grid Margin="36,0,20,0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <!-- Mod Title -->
                <TextBlock x:Name="modTitle" Grid.Row="0" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_accent75TxtColor}" Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left" Width="Auto"/>
                <!-- Mod Main Tag -->
                <TextBlock x:Name="modMainTag" Grid.Row="1" FontSize="{StaticResource ScaledIntermediateFontSize}" Foreground="{StaticResource LS_modsTextColor}" HorizontalAlignment="Left" Text="{Binding Tags[0].Name}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Visibility="{Binding Text, RelativeSource={RelativeSource Self}, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter='EmptyString'}" Width="740"/>
            </Grid>
        </Grid>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Disabled">
                <Setter TargetName="modTitle" Property="Foreground" Value="{StaticResource LS_accent25TxtColor}"/>
                <Setter TargetName="modScreenshot" Property="Opacity" Value="0.6"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Focused">
                <Setter TargetName="modTitle" Property="Foreground" Value="{StaticResource LS_selectedTextPad}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding MainScreenshot.HasScreenshotTexture}" Value="False">
                <Setter TargetName="modScreenshot" Property="Fill" Value="{StaticResource ugcDisabledMaskSmall_c}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DataContext.Data.IsUGCDisabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True">
                <Setter TargetName="modScreenshot" Property="Fill" Value="{StaticResource ugcDisabledMaskSmall_c}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <ControlTemplate x:Key="ModBrowserBackgroundTemplate_c">
        <Grid x:Name="HudRoot" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource LS_PanelBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="252"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image x:Name="MenuBackground" Grid.Row="0" Grid.RowSpan="2" Source="{StaticResource OptionsBackground}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="UniformToFill" ls:MoveFocus.Focusable="False"/>
            <Rectangle Grid.Row="1" Height="1280" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Fill="{StaticResource BottomToTopDarkGradientBrush}" Opacity="0.6" />
            <Control Grid.Row="0" Template="{StaticResource BrowserTopButtons_c}" HorizontalAlignment="Stretch" VerticalAlignment="Top" ls:MoveFocus.Focusable="False"/>
            <ContentPresenter x:Name="HudRootPresenter" VerticalAlignment="Stretch" Grid.Row="1"/>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="InstalledBottomButtons">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,56">
            <ls:LSButton x:Name="toggleButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                         Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                         Margin="20,0,0,0" BoundEvent="UIAccept"
                         Command="{Binding ToggleModEnabledStateCommand}" CommandParameter="{Binding SelectedMod}"
                         Tag="{Binding Source='h73880dc7ga260g4f04gab87ga0afe4b0794e',Converter={StaticResource TranslatedStringConverter}}"/>
            <ls:LSButton x:Name="unsubscribeButton" ContentTemplate="{StaticResource ControllerButtonHint}" Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}" Margin="20,0,0,0" BoundEvent="UIAccept" Command="{Binding UninstallModCommand}" CommandParameter="{Binding SelectedMod}" Tag="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}" Visibility="Collapsed">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="LSButtonPressed">
                        <ls:SetMoveFocusAction TargetName="ModBrowserInstalled_c" DeferFocusAction="True"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ls:LSButton>
            <ls:LSButton x:Name="detailsButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                         Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIDelete'}"
                         Tag="{Binding Source='h6dd87748g1061g4e27gade4g9d6709511bfd',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="UIDelete"
                         Command="{Binding ToggleDetailsCommand}" IsEnabled="{Binding Data.IsUGCDisabled, Converter={StaticResource InvertBoolConverter}}"
                         CommandParameter="{Binding SelectedMod}"/>

            <ls:LSButton ContentTemplate="{StaticResource ControllerButtonHint}" HorizontalAlignment="Right" Margin="0,0,150,0"
                         Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                         BoundEvent="UICancel"
                         Tag="{Binding Source='h6fefa28bg2149g4cacga071gd95b236b2d0b',Converter={StaticResource TranslatedStringConverter}}"
                         Command="{Binding CustomEvent}"
                         SoundID="UI_Shared_Cancel"
                         CommandParameter="CloseWidget"/>
        </StackPanel>
        <ControlTemplate.Triggers>
            <!-- Rearrange Mods-->
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="editPriority">
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="updateCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h592534fcg597cg43d0gb491g9e25a011f31f',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding UpdateModCommand}"/>
                <Setter TargetName="toggleButton" Property="CommandParameter" Value="{Binding SelectedMod}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="downloadingInProgress">
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="reportCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='hd0c08193ga7f2g4a7eg8225g63748c7b3096',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding ReportModCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.IsOfficial}" Value="False">
                <Setter TargetName="detailsButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="enableCommand"/>
                    <Condition Binding="{Binding SelectedMod.IsEnabled}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h5af0e4c5g6634g4ccbg886dg0c5dbd83b026',Converter={StaticResource TranslatedStringConverter}}"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="enableCommand"/>
                    <Condition Binding="{Binding SelectedMod.IsEnabled}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h5fa6eb5cg13a3g4278g8db7g815e96b0125b',Converter={StaticResource TranslatedStringConverter}}"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="unsubscribeCommand"/>
                    <Condition Binding="{Binding SelectedMod.ModState}" Value="Unsubscribed"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="unsubscribeButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="unsubscribeButton" Property="Tag" Value="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="unsubscribeButton" Property="Command" Value="{Binding UninstallModCommand}"/>
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="unsubscribeCommand"/>
                    <Condition Binding="{Binding SelectedMod.ModState}" Value="Installed"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="unsubscribeButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="unsubscribeButton" Property="Tag" Value="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="unsubscribeButton" Property="Command" Value="{Binding UninstallModCommand}"/>
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="unsubscribeCommand"/>
                    <Condition Binding="{Binding SelectedMod.ModState}" Value="Subscribed"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="unsubscribeButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="unsubscribeButton" Property="Tag" Value="{Binding Source='h75fcf9abgbe78g4aa3g835bgc8f319c8942c',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="unsubscribeButton" Property="Command" Value="{Binding UnsubscribeModCommand}"/>
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding Data.IsUGCDisabled}" Value="True">
                <Setter TargetName="toggleButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="unsubscribeCommand"/>
                    <Condition Binding="{Binding Data.IsUGCDisabled}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="IsEnabled" Value="True"/>
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="reportCommand"/>
                    <Condition Binding="{Binding Data.IsUGCDisabled}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="IsEnabled" Value="True"/>
            </MultiDataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Mod Browse Element-->
    <Style x:Key="SingleModStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="Margin" Value="24,20,24,20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentControl x:Name="ContentHolder" Style="{StaticResource FocusableContentControlNoBG}" >
                        <Grid x:Name="rootPanel" Background="{StaticResource LS_PadSelectablePanelBg}" VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Mod Image-->
                            <Rectangle x:Name="modScreenshot" Width="Auto" Grid.Row="0" Grid.ColumnSpan="2" Margin="10,10" Fill="{Binding MainScreenshot.Screenshot}" Effect="{StaticResource ShadowEffectSmall}">
                                <Rectangle.Height>
                                    <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                                        <Binding Path="ActualWidth" ElementName="modScreenshot"/>
                                        <Binding Path="Fill.ImageSource.Width" ElementName="modScreenshot"/>
                                        <Binding Path="Fill.ImageSource.Height" ElementName="modScreenshot"/>
                                    </MultiBinding>
                                </Rectangle.Height>
                            </Rectangle>

                            <!--Subscribed to Mod Label -->
                            <Grid x:Name="subscribedIcon" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10" Width="130" Height="130" Visibility="Collapsed">
                                <Image Source="{StaticResource bg_subscribed}" Height="130" Width="130"/>
                                <Image Source="{StaticResource enabledIcon_c}" Margin="60,0,0,60"/>
                            </Grid>

                            <!-- Mod Title-->
                            <TextBlock x:Name="modTitle" Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Name}" Margin="32,0" TextTrimming="CharacterEllipsis" Width="576" Foreground="{StaticResource LS_modsTextColor}"/>

                            <!-- Mod Details -->
                            <StackPanel x:Name="statPanel" Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="2" Grid.ColumnSpan="2" Margin="32,-8,32,0">

                                <!-- Mod Downloads -->
                                <Path x:Name="downloadIcon" Data="{StaticResource ico_downloads}" Fill="{StaticResource LS_accent25TxtColor}" VerticalAlignment="Center" Margin="0,0,10,2" Stretch="Fill" Height="36" />
                                <TextBlock x:Name="downloadValue" Text="{Binding TotalDownloads, Converter={StaticResource AbbreviateNumberConverter}}" Style="{StaticResource modsStatsStyle_c}" Margin="0,10,32,10"/>

                                <!-- Mod Size -->
                                <Path x:Name="sizeIcon" Data="{StaticResource ico_fileSize}" Fill="{StaticResource LS_accent25TxtColor}" Margin="0,0,12,2" VerticalAlignment="Center" Stretch="Fill" Height="36" />
                                <TextBlock x:Name="sizeValue" Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" Style="{StaticResource modsStatsStyle_c}" Margin="0,10,32,10"/>

                                <!-- Mod Likes -->
                                <Path x:Name="likeIcon" Data="{StaticResource ico_likes}" Fill="{StaticResource LS_accent25TxtColor}" Margin="0,0,8,4" VerticalAlignment="Center" Stretch="Fill" Height="36" />
                                <TextBlock x:Name="likeValue" Text="{Binding PositiveRating}" Style="{StaticResource modsStatsStyle_c}" Margin="5,10"/>
                            </StackPanel>

                            <!-- Download Bar -->
                            <Border x:Name="downloadingBorder" Visibility="Collapsed" Grid.Row="2" Grid.ColumnSpan="2" BorderThickness="2" BorderBrush="{StaticResource LS_modsDownloadBarBorderColor}" Width="562" VerticalAlignment="Center" ClipToBounds="True" Background="{StaticResource LS_modsDownloadBarBgColor}" Effect="{StaticResource ShadowEffectSmall}" Margin="0,18">
                                <Rectangle x:Name="runningBar" Fill="{StaticResource LS_modsDownloadBarColor}" Width="200" Height="8"/>
                            </Border>
                        </Grid>
                    </ContentControl>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded" SourceName="runningBar">
                            <BeginStoryboard x:Name="IndefiniteLoading">
                                <Storyboard>
                                    <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="runningBar" Duration="0:0:1" From="0,0,200,0" To="0,0,-200,0" AutoReverse="True" RepeatBehavior="Forever">
                                        <ThicknessAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Unloaded" SourceName="runningBar">
                            <StopStoryboard BeginStoryboardName="IndefiniteLoading"/>
                        </EventTrigger>
                        <DataTrigger Binding="{Binding ModState}" Value="Subscribed">
                            <Setter TargetName="rootPanel" Property="Background" Value="{StaticResource LS_modsBackgroundSubscribedColor}" />
                            <Setter TargetName="likeValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="sizeValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="downloadValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="likeIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="sizeIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="downloadIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="subscribedIcon" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ModState}" Value="Installed">
                            <Setter TargetName="rootPanel" Property="Background" Value="{StaticResource LS_modsBackgroundSubscribedColor}" />
                            <Setter TargetName="likeValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="sizeValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="downloadValue" Property="Foreground" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="likeIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="sizeIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="downloadIcon" Property="Fill" Value="{StaticResource LS_modsContentSubscribedColor}" />
                            <Setter TargetName="subscribedIcon" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ModState}" Value="Downloading">
                            <Setter TargetName="downloadingBorder" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="rootPanel" Property="Background" Value="{StaticResource ItemRarityColour.UncommonStroke}"/>
                            <Setter TargetName="statPanel" Property="Visibility" Value="Hidden"/>
                        </DataTrigger>

                        <Trigger SourceName="ContentHolder" Property="ls:MoveFocus.IsFocused" Value="True">
                            <Setter TargetName="modTitle" Property="Foreground" Value="{StaticResource LS_selectedTextPad}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SidePanelModTemplate">
        <AdornerDecorator>
            <Grid Height="1750">
                <Grid.RowDefinitions>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="658"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding SelectedMod.Name}" Grid.Row="0" Height="90" TextTrimming="CharacterEllipsis" Width="1168" HorizontalAlignment="Center" TextAlignment="Center"/>
                <Rectangle x:Name="modScreenshot" Grid.Row="1" Width="1168" Fill="{Binding SelectedMod.MainScreenshot.Screenshot}">
                    <Rectangle.Height>
                        <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                            <Binding Path="ActualWidth" ElementName="modScreenshot"/>
                            <Binding Path="Fill.ImageSource.Width" ElementName="modScreenshot"/>
                            <Binding Path="Fill.ImageSource.Height" ElementName="modScreenshot"/>
                        </MultiBinding>
                    </Rectangle.Height>
                </Rectangle>

                <Control x:Name="imageSpinner" Template="{StaticResource BusyElement}" VerticalAlignment="Center" Grid.Row="1" HorizontalAlignment="Center" Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" Grid.Row="2">
                    <!-- Mod Update Button -->
                    <ContentControl x:Name="updateGrid" Style="{StaticResource FocusableContentControlStyleBold}" Margin="0,30,0,0" ls:MoveFocus.FocusMovementMode="MainAxisTunnel"  HorizontalAlignment="Left" Tag="updateCommand" Visibility="Collapsed" ls:MoveFocus.FocusForcedNextLeftElement="{Binding Tag, ElementName=root}">
                        <Grid Width="626" Height="156" Background="{StaticResource modUpdateBGDefault}">
                            <StackPanel x:Name="downloadingContent" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="{StaticResource updateIcon_c}" Stretch="None" VerticalAlignment="Center" />
                                <TextBlock x:Name="updateLabel" FontSize="{StaticResource ScaledDefaultFontSize}" Text="{Binding Source='h99003f95g016bg4254g9fe4g6a731fc37383',Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" FontWeight="DemiBold" Foreground="{StaticResource LS_partyTxtColor}" />
                            </StackPanel>
                            <!-- Progress Bar -->
                            <StackPanel x:Name="downloadingBorder" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="-20,0,0,0" Visibility="Collapsed">
                                <Image Source="{StaticResource updateIcon_c}" Stretch="None" VerticalAlignment="Center" />
                                <Border BorderThickness="2" BorderBrush="{StaticResource LS_modsDownloadBarBorderColor}" Width="412" ClipToBounds="True"
                                    Background="{StaticResource LS_modsDownloadBarBgColor}" Effect="{StaticResource ShadowEffectSmall}" Height="12" HorizontalAlignment="Center">
                                    <Rectangle x:Name="runningBar" Fill="{StaticResource LS_modsDownloadBarColor}" Width="200" Height="8"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ContentControl>

                    <!-- Mod Enabled Button -->
                    <ContentControl x:Name="modEnableButton" Style="{StaticResource FocusableContentControlStyleBold}" Margin="0,30,0,0" HorizontalAlignment="Left" Tag="enableCommand" ls:MoveFocus.FocusMovementMode="MainAxisTunnel" ls:MoveFocus.FocusForcedNextLeftElement="{Binding Tag, ElementName=root}">
                        <Border x:Name="modEnableBorder" Width="1284" Height="156">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image x:Name="enabledIcon" Source="{StaticResource disabledIcon_c}" Stretch="None" VerticalAlignment="Center" />
                                <TextBlock x:Name="enabledLabel" FontSize="{StaticResource ScaledDefaultFontSize}" Text="{Binding Source='h5af0e4c5g6634g4ccbg886dg0c5dbd83b026',Converter={StaticResource TranslatedStringConverter}}"
                                           VerticalAlignment="Center" FontWeight="DemiBold" Foreground="{StaticResource LS_baseTxtColor}" />
                            </StackPanel>
                        </Border>
                    </ContentControl>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="3">
                    <!-- Mod Subscribe Button -->
                    <ContentControl x:Name="modUnsubscribeButton" Style="{StaticResource FocusableContentControlStyleBold}" Margin="0,10,0,0" ls:MoveFocus.FocusMovementMode="MainAxisTunnel" HorizontalAlignment="Left" Tag="unsubscribeCommand" ls:MoveFocus.FocusForcedNextLeftElement="{Binding Tag, ElementName=root}">
                        <Border Width="626" Height="156">
                            <TextBlock x:Name="modUnsubscribeLabel" FontSize="{StaticResource ScaledDefaultFontSize}" Text="{Binding Source='h75fcf9abgbe78g4aa3g835bgc8f319c8942c',Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" FontWeight="DemiBold" HorizontalAlignment="Center" Foreground="{StaticResource LS_baseTxtColor}" />
                        </Border>
                    </ContentControl>

                    <!-- Mod Report Button -->
                    <ContentControl x:Name="modReportButton" Style="{StaticResource FocusableContentControlStyleBold}" Margin="30,10,0,0" ls:MoveFocus.FocusMovementMode="MainAxisTunnel" HorizontalAlignment="Left" Tag="reportCommand">
                        <Border Width="626" Height="156">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path x:Name="reportIcon" Data="{StaticResource ico_report}" Fill="{StaticResource LS_accent25TxtColor}" Margin="0,0,8,4" VerticalAlignment="Center" Stretch="Fill" Height="42" />

                                <TextBlock x:Name="reportLabel" FontSize="{StaticResource ScaledDefaultFontSize}" Text="{Binding Source='h3eb3aeabg68fcg418cga213ge00d639e4507',Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" FontWeight="DemiBold" HorizontalAlignment="Center" Foreground="{StaticResource LS_baseTxtColor}" />
                            </StackPanel>
                        </Border>
                    </ContentControl>
                </StackPanel>

                <!-- Warnings -->
                <StackPanel x:Name="deprecatedWarning" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed" Grid.Row="4">
                    <Image Source="{StaticResource IconWarningSoft}" Stretch="None"/>
                    <TextBlock Margin="5,0,0,0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                                <Binding Source="h7173cd4dg1cc0g41f2g8f89g5ecc6d1c049c"/>
                                <Binding Source="hb464e905g27afg4274g8b67g39e1b330862a" Converter="{StaticResource TranslatedStringConverter}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel x:Name="unofficialWarning" Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed">
                    <Image Source="{StaticResource IconWarningSoft}" Stretch="None"/>
                    <TextBlock Text="{Binding Source='h4fa235dbg6a63g40ebg8d27gfcbb88a1037d', Converter={StaticResource TranslatedStringConverter}}" Margin="5,0,0,0" />
                </StackPanel>

                <!-- Mod Dependiencies -->
                <TextBlock x:Name="dependenciesTitle" Grid.Row="6" Margin="0,10,0,0" Foreground="{StaticResource LS_baseTxtColor}"
                           FontSize="{StaticResource ScaledMediumFontSize}" Visibility="Collapsed">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ParameterizedTranslatedStringConverter}">
                            <Binding Source="h42f01947gd74eg48e6ga156gc5cb9ad93dfe"/>
                            <Binding  Path="SelectedMod.Dependencies.Count"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <ls:LSScrollViewer Grid.Row="7" HorizontalContentAlignment="Left" Template="{StaticResource ScrollViewerTemplate}" VerticalScrollBarVisibility="Auto" ls:ScrollViewerHelper.VerticalScrollOffsetMargin="164" HorizontalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <ItemsControl x:Name="modDependencies" ItemsSource="{Binding SelectedMod.Dependencies}" Margin="0,10,0,0" >
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl x:Name="contentHolder" Style="{StaticResource FocusableContentControlStyleBold}" ls:MoveFocus.FocusMovementMode="MainAxisTunnel" HorizontalAlignment="Stretch" Tag="noEdit" BorderThickness="2" Margin="0,0,0,12">
                                        <StackPanel Margin="10,10,0,10" Orientation="Horizontal">
                                            <Rectangle x:Name="modDependencyScreenshot" Fill="{Binding MainScreenshot.Screenshot}" Width="242" VerticalAlignment="Center"  HorizontalAlignment="Left">
                                                <Rectangle.Height>
                                                    <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                                                        <Binding Path="ActualWidth" ElementName="modDependencyScreenshot"/>
                                                        <Binding Path="Fill.ImageSource.Width" ElementName="modDependencyScreenshot"/>
                                                        <Binding Path="Fill.ImageSource.Height" ElementName="modDependencyScreenshot"/>
                                                    </MultiBinding>
                                                </Rectangle.Height>
                                            </Rectangle>
                                            <TextBlock Text="{Binding Name}" Padding="12,5,10,5" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ls:LSScrollViewer>
            </Grid>
        </AdornerDecorator>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding SelectedMod.MainScreenshot.HasScreenshotTexture}" Value="False">
                <Setter TargetName="imageSpinner" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=(ls:MoveFocus.IsFocused), ElementName=modUnsubscribeButton}" Value="True">
                <Setter TargetName="modUnsubscribeLabel" Property="Foreground" Value="{StaticResource LS_selectedTextPad}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=(ls:MoveFocus.IsFocused), ElementName=modReportButton}" Value="True">
                <Setter TargetName="reportLabel" Property="Foreground" Value="{StaticResource LS_selectedTextPad}"/>
                <Setter TargetName="reportIcon" Property="Fill" Value="{StaticResource LS_selectedTextPad}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=(ls:MoveFocus.IsFocused), ElementName=modEnableButton}" Value="True">
                <Setter TargetName="enabledLabel" Property="Foreground" Value="{StaticResource LS_selectedTextPad}"/>
            </DataTrigger>
            <EventTrigger RoutedEvent="Loaded" SourceName="runningBar">
                <BeginStoryboard x:Name="IndefiniteLoading">
                    <Storyboard>
                        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="runningBar" Duration="0:0:1" From="0,0,200,0" To="0,0,-200,0" AutoReverse="True" RepeatBehavior="Forever">
                            <ThicknessAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </ThicknessAnimation.EasingFunction>
                        </ThicknessAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Unloaded" SourceName="runningBar">
                <StopStoryboard BeginStoryboardName="IndefiniteLoading"/>
            </EventTrigger>
            <DataTrigger Binding="{Binding SelectedMod.ModState}" Value="Unsubscribed">
                <Setter TargetName="modUnsubscribeLabel" Property="Text" Value="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.ModState}" Value="Installed">
                <Setter TargetName="modUnsubscribeLabel" Property="Text" Value="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.IsOutdated}" Value="True" />
                    <Condition Binding="{Binding Data.IsUGCDisabled}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="updateGrid" Property="Visibility" Value="Visible"/>
                <Setter TargetName="modEnableBorder" Property="Width" Value="626"/>
                <Setter TargetName="modEnableButton" Property="Width" Value="626"/>
                <Setter TargetName="modEnableButton" Property="Margin" Value="30,30,0,0"/>
                <Setter TargetName="modEnableButton" Property="ls:MoveFocus.FocusForcedNextLeftElement" Value="{Binding ElementName=updateGrid}"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.ModState}" Value="Downloading">
                <Setter TargetName="downloadingBorder" Property="Visibility" Value="Visible"/>
                <Setter TargetName="downloadingContent" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.IsEnabled}" Value="True">
                <Setter TargetName="enabledIcon" Property="Source" Value="{StaticResource enabledIcon_c}"/>
                <Setter TargetName="enabledLabel" Property="Foreground" Value="{StaticResource LS_bonusTxtColor}"/>
                <Setter TargetName="enabledLabel" Property="Text" Value="{Binding Source='h054025c0gd806g418agb58dg6b325823b7cd',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.Dependencies.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                <Setter TargetName="dependenciesTitle" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.IsOfficial}" Value="False">
                <Setter TargetName="unofficialWarning" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=Tag, ElementName=ModList}" Value="EditModeOn">
                <Setter TargetName="updateGrid" Property="ls:MoveFocus.Focusable" Value="False"/>
                <Setter TargetName="modEnableButton" Property="ls:MoveFocus.Focusable" Value="False"/>
                <Setter TargetName="modReportButton" Property="ls:MoveFocus.Focusable" Value="False"/>
                <Setter TargetName="modUnsubscribeButton" Property="ls:MoveFocus.Focusable" Value="False"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.IsUGCDisabled}" Value="True">
                <Setter TargetName="enabledLabel" Property="Text" Value="{Binding Source='he79bc68eg0d72g4553g836cg0784a84470a0',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="modScreenshot" Property="Fill" Value="{StaticResource ugcDisabledMaskBig_c}"/>
                <Setter TargetName="updateGrid" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="dependenciesTitle" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modDependencies" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="PageSelectionTemplate">
        <ControlTemplate.Resources>
            <System:Int32 x:Key="firstPageValue">1</System:Int32>

            <ControlTemplate x:Key="PageTemplate" TargetType="ListBoxItem">
                <Border x:Name="bg" MinWidth="80" Margin="4,0" Height="80" BorderThickness="4" Background="{StaticResource LS_pageBackground}" BorderBrush="{StaticResource LS_modsSurroundFadedColor}">
                    <TextBlock x:Name="pageNumber" Text="{Binding PageNumber}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource ScaledDefaultFontSize}" FontWeight="DemiBold" Foreground="{StaticResource LS_accent25TxtColor}"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource LS_accent75TxtColor}"/>
                        <Setter TargetName="pageNumber" Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                        <Setter Property="IsEnabled" Value="False"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
            <ControlTemplate x:Key="DotsTemplate" TargetType="ListBoxItem">
                <TextBlock Text="{Binding Source='hbf484ef4g6e44g4aa7gb5dbgd8439bbd1d79',Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" IsEnabled="False" Margin="0,10,0,0" TextAlignment="Center" Width="75"/>
            </ControlTemplate>
        </ControlTemplate.Resources>
        <StackPanel x:Name="PageControlsRoot" Orientation="Horizontal" Visibility="Collapsed">
            <ls:LSButton x:Name="leftBtn" BoundEvent="JumpToFromTab" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" HorizontalAlignment="Left" Margin="0,0,0,0"
                         Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='JumpToFromTab'}" IsEnabled="False"
                         Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding CurrentPage.PageNumber, Converter={StaticResource AddConverter}, ConverterParameter=-1}"/>
            <ListBox ItemsSource="{Binding Pages}" HorizontalAlignment="Center" SelectedItem="{Binding CurrentPage}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template" Value="{StaticResource PageTemplate}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PageNumber}" Value="-1">
                                <Setter Property="Template" Value="{StaticResource DotsTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
            <ls:LSButton x:Name="rightBtn" BoundEvent="ToggleSummaryFocus" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" HorizontalAlignment="Right" Margin="0,0,45,0"
                          Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='ToggleSummaryFocus'}"
                          Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" CommandParameter="{Binding CurrentPage.PageNumber, Converter={StaticResource AddConverter}, ConverterParameter=1}"/>
        </StackPanel>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding PageCount, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True">
                <Setter TargetName="PageControlsRoot" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding CurrentPage.PageNumber, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True">
                <Setter TargetName="leftBtn" Property="IsEnabled" Value="True"/>
            </DataTrigger>
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EqualConverter}">
                        <Binding Path="PageCount"/>
                        <Binding Path="CurrentPage.PageNumber"/>
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter TargetName="rightBtn" Property="IsEnabled" Value="False"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DataContext.Data.IsUGCDisabled, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="True">
                <Setter TargetName="PageControlsRoot" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ModVerificationWindowTemplate">
        <Grid x:Name="ModVerificationWarningGrid" Visibility="{Binding ShowModValidationWindow, Converter={StaticResource BoolToVisibleConverter}, FallbackValue=Collapsed}" HorizontalAlignment="Center" VerticalAlignment="Stretch">

            <Image Source="{StaticResource backgroundFade}" Stretch="Fill"/>
            <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Fill="{StaticResource CenteredGradientShadingBrushBrown}" />

            <Grid VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,10">
                    <TextBlock x:Name="Title" Text="{Binding Source='haeca4890g1d5cg412bg8fa7g797fbe79a1be',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_tint100}" FontSize="{StaticResource TitleFontSize}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SubTitle" Text="{Binding Source='hcf72c0c0gcaa6g451cg9134g800b6d4dc958',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledMediumFontSize}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Control x:Name="ModIssuesWarning"  Margin="0,15,0,5" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Template="{StaticResource WarningLabelTemplateWide}" Background="{StaticResource IconBrushWarningSoft}"
                             Foreground="{StaticResource LS_warning50TxtColor}"
                             Tag="{Binding Source='h65e1dd33gc84ag4537ga0e5g30e69522f504',Converter={StaticResource TranslatedStringConverter}}"
                             Visibility="{Binding ModMismatchFixed, Converter={StaticResource BoolToHiddenConverter}, FallbackValue=Hidden}"/>
                </StackPanel>

                <ls:LSNineSliceImage Grid.Row="1" Style="{StaticResource SpecialPopupBg}" Width="2576" HorizontalAlignment="Stretch" VerticalAlignment="Top">

                    <Grid Height="1600" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <!-- Additional rows are for when we add additional title or warning as per design-->
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="ModList" Grid.Row="1" Width="2346" ItemsSource="{Binding InvalidMods}" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.VirtualizationMode="Recycling" SelectionMode ="Single" SelectedIndex="0" Margin="50,0" AlternationCount="{Binding InvalidMods.Count}" HorizontalAlignment="Center">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.Resources>
                                <DataTemplate DataType="{x:Type ls:VMEnumData}">
                                    <TextBlock x:Name="ListHeader" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledIntermediateFontSize}" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ReflectionString}" Value="ExtraMods">
                                            <Setter TargetName="ListHeader" Property="Text" Value="{Binding Source=h3217caa2gf989g4afbg95efge22457720760, Converter={StaticResource TranslatedStringConverter}}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ReflectionString}" Value="ModIssues">
                                            <Setter TargetName="ListHeader" Property="Text" Value="{Binding Source=h18454734g079ag4604g9e57ga534da9157d2, Converter={StaticResource TranslatedStringConverter}}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ReflectionString}" Value="NonCuratedMods">
                                            <Setter TargetName="ListHeader" Property="Text" Value="{Binding Source=h50c23a57ge83dg4f30gae8bg3fd53e67c3e7, Converter={StaticResource TranslatedStringConverter}}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>

                                <DataTemplate DataType="{x:Type ls:VMModPreview}">
                                    <Grid Width="2286" Height="164" Margin="0,0,0,4">
                                        <ContentControl x:Name="contentHolder" Style="{StaticResource FocusableContentControlStyleBold}" ls:MoveFocus.FocusMovementModeUp="MainAxisTunnel"  HorizontalAlignment="Stretch" Tag="noEdit" BorderThickness="2">

                                            <b:Interaction.Triggers>
                                                <b:DataTrigger Binding="{Binding Path=(ls:MoveFocus.IsFocused), ElementName=contentHolder}" Value="True">
                                                    <b:ChangePropertyAction TargetName="root" PropertyName="Tag" Value="{Binding Path=FocusedElement, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                                                </b:DataTrigger>
                                            </b:Interaction.Triggers>

                                            <Grid Width="2286" Height="164" HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Mod image and text/tag -->
                                                <ContentPresenter x:Name="modPreview" Grid.Column="0" ContentTemplate="{StaticResource ModPreviewTemplate}" Content="{Binding .}" Tag=""/>
                                                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,0,40,0" HorizontalAlignment="Right"  VerticalAlignment="Center">
                                                    <Control x:Name="UnofficialModWarning" Template="{StaticResource WarningLabelTemplate}" Visibility="Collapsed" Background="{StaticResource IconBrushWarningSoft}" Foreground="{StaticResource LS_warning50TxtColor}" Tag="{Binding Source='h9f0fa61dge6afg4e04g8e26g60c7efddbbd2',Converter={StaticResource TranslatedStringConverter}}" />
                                                    <Control x:Name="MustBeEnabledWarning" Template="{StaticResource WarningLabelTemplate}" Background="{StaticResource IconBrushWarningSoft}" Foreground="{StaticResource LS_warning50TxtColor}" Tag="{Binding Source='h93bd5308gb122g4ae5g80fega01d1ebc0bd7',Converter={StaticResource TranslatedStringConverter}}" Visibility="Collapsed"/>
                                                    <TextBlock x:Name="OptionalLabel" Text="{Binding Source='h61447832g1d4fg419agbf5cg51b1761a9ba0',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent75TxtColor}" FontSize="{StaticResource ScaledMediumFontSize}" Margin="0,0,5,0" Visibility="Collapsed"/>
                                                    <StackPanel x:Name="SubscribeLabel" Orientation="Horizontal" Margin="-16,0,0,0" Visibility="Collapsed">
                                                        <TextBlock VerticalAlignment="Top" Text="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_accent100TxtColor}" Style="{StaticResource TooltipStringBodyStyle}" Margin="0,4,0,0"/>
                                                        <Image VerticalAlignment="Center" Source="{StaticResource detailsSubscribe}" Stretch="None" />
                                                    </StackPanel>

                                                    <!-- Progress Bar -->
                                                    <Control x:Name="downloadingProgressBar" Template="{StaticResource DownloadingBar}" Visibility="Collapsed"/>

                                                    <ls:LSCheckBox x:Name="modEnableCheckBox" IsChecked="{Binding IsEnabled, Mode=OneWay}" Margin="24,-7,0,0" Visibility="Hidden">
                                                        <CheckBox.Template>
                                                            <ControlTemplate TargetType="CheckBox">
                                                                <Image x:Name="iconEnabled" VerticalAlignment="Center" Source="{StaticResource disabledIcon_c}" Stretch="None" />
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="iconEnabled" Property="Source" Value="{StaticResource enabledIcon_c}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </CheckBox.Template>
                                                    </ls:LSCheckBox>

                                                    <Control x:Name="LoadingModSpinner" Template="{StaticResource BusyElement}"/>
                                                </StackPanel>
                                            </Grid>
                                        </ContentControl>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ModRequired}" Value="Disabled" />
                                                <Condition Binding="{Binding IsEnabled}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="MustBeEnabledWarning" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="MustBeEnabledWarning" Property="Tag" Value="{Binding Source='h5fa6eb5cg13a3g4278g8db7g815e96b0125b',Converter={StaticResource TranslatedStringConverter}}"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ModRequired}" Value="Enabled" />
                                                <Condition Binding="{Binding IsEnabled}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="MustBeEnabledWarning" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="MustBeEnabledWarning" Property="Tag" Value="{Binding Source='h93bd5308gb122g4ae5g80fega01d1ebc0bd7',Converter={StaticResource TranslatedStringConverter}}"/>
                                        </MultiDataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsCurated}" Value="False" />
                                                <Condition Binding="{Binding IsEnabled}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="MustBeEnabledWarning" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="MustBeEnabledWarning" Property="Tag" Value="{Binding Source='h40b5f8a7gc661g4963gbef2gfaba181af605',Converter={StaticResource TranslatedStringConverter}}"/>
                                        </MultiDataTrigger>

                                        <DataTrigger Value="False">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource ListContainsItemConverter}">
                                                    <Binding Path="DataContext.ModInfoRequests" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                                                    <Binding Path="PublishHandle"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter TargetName="LoadingModSpinner" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ModState}" Value="Unsubscribed"/>
                                                <Condition Value="False">
                                                    <Condition.Binding>
                                                        <MultiBinding Converter="{StaticResource ListContainsItemConverter}">
                                                            <Binding Path="DataContext.ModInfoRequests" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                                                            <Binding Path="PublishHandle"/>
                                                        </MultiBinding>
                                                    </Condition.Binding>
                                                </Condition>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="SubscribeLabel" Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>

                                        <DataTrigger Binding="{Binding ModState}" Value="Downloading">
                                            <Setter TargetName="downloadingProgressBar" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ModState}" Value="Subscribed"/>
                                                <Condition Value="False">
                                                    <Condition.Binding>
                                                        <MultiBinding Converter="{StaticResource ListContainsItemConverter}">
                                                            <Binding Path="DataContext.ModInfoRequests" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                                                            <Binding Path="PublishHandle"/>
                                                        </MultiBinding>
                                                    </Condition.Binding>
                                                </Condition>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="modEnableCheckBox" Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ModState}" Value="Installed"/>
                                                <Condition Value="False">
                                                    <Condition.Binding>
                                                        <MultiBinding Converter="{StaticResource ListContainsItemConverter}">
                                                            <Binding Path="DataContext.ModInfoRequests" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                                                            <Binding Path="PublishHandle"/>
                                                        </MultiBinding>
                                                    </Condition.Binding>
                                                </Condition>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="modEnableCheckBox" Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsOfficial}" Value="False" />
                                                <Condition Binding="{Binding ModState}" Value="Unsubscribed" />
                                                <Condition Value="False">
                                                    <Condition.Binding>
                                                        <MultiBinding Converter="{StaticResource ListContainsItemConverter}">
                                                            <Binding Path="DataContext.ModInfoRequests" RelativeSource="{RelativeSource AncestorType={x:Type ls:UIWidget}}"/>
                                                            <Binding Path="PublishHandle"/>
                                                        </MultiBinding>
                                                    </Condition.Binding>
                                                </Condition>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="UnofficialModWarning" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="SubscribeLabel" Property="Visibility" Value="Collapsed"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}, Path=ContextName}" Value="LoadSaveGames" />
                                                <Condition Binding="{Binding IsOverdated}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="OptionalLabel" Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                            <Setter TargetName="modPreview" Property="Tag" Value="Disabled"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.Resources>
                            <ListBox.Template>
                                <ControlTemplate>
                                    <ls:LSScrollViewer x:Name="ScrollViewer" HorizontalContentAlignment="Center" Template="{StaticResource ScrollViewerTemplate}" VerticalScrollBarVisibility="Auto" ls:ScrollViewerHelper.VerticalScrollOffsetMargin="164" HorizontalScrollBarVisibility="Hidden">
                                        <ItemsPresenter HorizontalAlignment="Center" />
                                    </ls:LSScrollViewer>
                                </ControlTemplate>
                            </ListBox.Template>
                            <b:Interaction.Triggers>
                                <b:PropertyChangedTrigger Binding="{Binding FocusedElement, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}">
                                    <b:Interaction.Behaviors>
                                        <b:ConditionBehavior>
                                            <b:ConditionalExpression>
                                                <b:ComparisonCondition LeftOperand="{Binding Path=FocusedElement.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}, Converter={StaticResource TypeConverter}}" Operator="Equal" RightOperand="ls.VMModPreview"/>
                                            </b:ConditionalExpression>
                                        </b:ConditionBehavior>
                                    </b:Interaction.Behaviors>
                                    <b:ChangePropertyAction PropertyName="SelectedItem" Value="{Binding FocusedElement.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                                </b:PropertyChangedTrigger>
                            </b:Interaction.Triggers>
                        </ListBox>

                        <Control x:Name="ModListPermissionsSpinner" Grid.Row="1" Template="{StaticResource BusyElement}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed"/>

                        <Control x:Name="UGCDisabled" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Template="{StaticResource WarningLabelTemplateWide}" Background="{StaticResource IconBrushWarningSoft}"
                                 Foreground="{StaticResource LS_warning50TxtColor}"
                                 Tag="{Binding Source='hc8b6cc7dgda8bg49fcg84f9gcbea92d18277',Converter={StaticResource TranslatedStringConverter}}"
                                 Visibility="{Binding Data.IsUGCDisabled, Converter={StaticResource BoolToVisibleConverter}}"/>
                    </Grid>
                </ls:LSNineSliceImage>
            </Grid>

            <StackPanel Style="{StaticResource ButtonHint.Container.Center}">
                <ls:LSButton x:Name="ActionButton" 
                                     Tag="{Binding Source='h5fa6eb5cg13a3g4278g8db7g815e96b0125b',Converter={StaticResource TranslatedStringConverter}}"
                                     Content = "{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                     ContentTemplate="{StaticResource ControllerButtonHint}"
                                     BoundEvent="UIAccept"
                                     Command="{Binding ToggleModEnabledStateCommand}"
                                     CommandParameter="{Binding ElementName=ModList, Path=SelectedItem}"/>
                <ls:LSButton x:Name="StartGameButton"
                                     Tag="{Binding Source='hff3fbf0fgf6c5g427fga4dfgbb238c01cb4c', Converter={StaticResource TranslatedStringConverter}}"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIMessageBoxY'}"
                                     ContentTemplate="{StaticResource ControllerButtonHint}"
                                     BoundEvent="UIMessageBoxY"/>
                <ls:LSButton x:Name="CancelButton"
                                     Tag="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7', Converter={StaticResource TranslatedStringConverter}}"
                                     Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                                     ContentTemplate="{StaticResource ControllerButtonHint}"
                                     BoundEvent="UICancel"/>
            </StackPanel>

            <b:Interaction.Triggers>
                <b:PropertyChangedTrigger Binding="{Binding Path=Visibility, ElementName=ModVerificationWarningGrid}">
                    <b:Interaction.Behaviors>
                        <b:ConditionBehavior>
                            <b:ConditionalExpression>
                                <b:ComparisonCondition LeftOperand="{Binding Path=Visibility, ElementName=ModVerificationWarningGrid}" Operator="Equal" RightOperand="Visible"/>
                            </b:ConditionalExpression>
                        </b:ConditionBehavior>
                    </b:Interaction.Behaviors>
                    <ls:SetMoveFocusAction TargetName="ModList" DeferFocusAction="True"/>
                </b:PropertyChangedTrigger>
            </b:Interaction.Triggers>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding Path=SelectedItem.IsEnabled, ElementName=ModList}" Value="False">
                <Setter TargetName="ActionButton" Property="Tag" Value="{Binding Source='h5af0e4c5g6634g4ccbg886dg0c5dbd83b026',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <!-- show subscribe button for official unsubscribed mods -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=SelectedItem.ModState, ElementName=ModList}" Value="Unsubscribed"/>
                    <Condition Binding="{Binding Path=SelectedItem.IsOfficial, ElementName=ModList}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ActionButton" Property="Tag" Value="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="ActionButton" Property="Command" Value="{Binding DownloadModCommand}"/>
            </MultiDataTrigger>
            <!-- show Update button for official outdated mods -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=SelectedItem.IsOfficial, ElementName=ModList}" Value="True"/>
                    <Condition Binding="{Binding Path=SelectedItem.IsOutdated, ElementName=ModList}" Value="True" />
                    <Condition Binding="{Binding Path=SelectedItem.IsEnabled, ElementName=ModList}" Value="True" />
                    <Condition Binding="{Binding Path=SelectedItem.ModState, ElementName=ModList}" Value="Installed"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ActionButton" Property="Tag" Value="{Binding Source='h99003f95g016bg4254g9fe4g6a731fc37383',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="ActionButton" Property="Command" Value="{Binding UpdateModVersionCommand}"/>
            </MultiDataTrigger>
            <!-- show Downgrade button for official mods with newer versions -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=SelectedItem.IsOfficial, ElementName=ModList}" Value="True"/>
                    <Condition Binding="{Binding Path=SelectedItem.IsOverdated, ElementName=ModList}" Value="True" />
                    <Condition Binding="{Binding Path=SelectedItem.IsEnabled, ElementName=ModList}" Value="True" />
                    <Condition Binding="{Binding Path=SelectedItem.ModState, ElementName=ModList}" Value="Installed"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ActionButton" Property="Tag" Value="{Binding Source='h36dc087egdc23g4b24gb7e7gf098613f1651',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="ActionButton" Property="Command" Value="{Binding UpdateModVersionCommand}"/>
            </MultiDataTrigger>
            <!-- can't subscribe on unofficial mod -->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=SelectedItem.ModState, ElementName=ModList}" Value="Unsubscribed"/>
                    <Condition Binding="{Binding Path=SelectedItem.IsOfficial, ElementName=ModList}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ActionButton" Property="IsEnabled" Value="False"/>
            </MultiDataTrigger>
            <!-- mod downloading -->
            <DataTrigger Binding="{Binding Path=SelectedItem.ModState, ElementName=ModList}" Value="Downloading">
                <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ActionButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}, Path=ContextName}" Value="MainMenu">
                <Setter TargetName="StartGameButton" Property="Command" Value="{Binding ShowModValidationWarningCommand}"/>
                <Setter TargetName="CancelButton" Property="Command" Value="{Binding CloseModVerificationWindowCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}, Path=ContextName}" Value="LoadSaveGames">
                <Setter TargetName="StartGameButton" Property="Command" Value="{Binding SkipModValidationAndLoadGameCommand}"/>
                <Setter TargetName="CancelButton" Property="Command" Value="{Binding CloseSaveModVerificationWindowCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}, Path=ContextName}" Value="LobbyBrowser">
                <Setter TargetName="StartGameButton" Property="Command" Value="{Binding SkipModValidationAndJoinGameCommand}"/>
                <Setter TargetName="CancelButton" Property="Command" Value="{Binding CloseModVerificationWindowCommand}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding ModMismatchFixed}" Value="False"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}, Path=ContextName}" Value="LobbyBrowser" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="StartGameButton" Property="IsEnabled" Value="False" />
            </MultiDataTrigger>
            <!--Block loading save games on console whilst there are outstanding issues-->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsConsolePlatform}" Value="True"/>
                    <Condition Binding="{Binding ModMismatchFixed}" Value="False"/>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}, Path=ContextName}" Value="LoadSaveGames" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="StartGameButton" Property="IsEnabled" Value="False" />
            </MultiDataTrigger>

            <DataTrigger Binding="{Binding Data.IsUGCDisabled}" Value="True">
                <Setter TargetName="SubTitle" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ModIssuesWarning" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ModList" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="StartGameButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsWaitingOnPermissionsChanged}" Value="True">
                <Setter TargetName="ModList" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ModListPermissionsSpinner" Property="Visibility" Value="Visible"/>
                <Setter TargetName="StartGameButton" Property="IsEnabled" Value="False"/>
                <Setter TargetName="ActionButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsWaitingOnPermissionsRequest}" Value="True">
                <Setter TargetName="ModList" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="ModListPermissionsSpinner" Property="Visibility" Value="Visible"/>
                <Setter TargetName="StartGameButton" Property="IsEnabled" Value="False"/>
                <Setter TargetName="ActionButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SideSearchPanelTreeViewItemTemplate" TargetType="TreeViewItem">
        <StackPanel x:Name="Root" HorizontalAlignment="Left" Margin="0,-4,0,0">
            <ContentPresenter x:Name="PART_Header" ContentSource="Header" IsHitTestVisible="False"/>
            <ItemsPresenter x:Name="TreeItemsHost"/>
        </StackPanel>

        <ControlTemplate.Triggers>
            <Trigger Property="HasItems" Value="False">
                <Setter TargetName="Root" Property="Margin" Value="0"/>
                <Setter TargetName="PART_Header" Property="Margin" Value="0"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="FilterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource ScaledDefaultFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource LS_accent75TxtColor}"/>
    </Style>

    <Style x:Key="FilterTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource FilterTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource LS_accent25TxtColor}"/>
        <Setter Property="Margin" Value="80,12,0,6"/>
    </Style>

    <Style x:Key="FilterToggleButtonStyle" TargetType="ls:LSToggleButton" BasedOn="{StaticResource {x:Type ls:LSToggleButton}}">
        <Style.Resources>
            <ImageSource x:Key="BgNormal">pack://application:,,,/ModBrowser;component/Assets/filters_pane_li_01.png</ImageSource>
            <ImageSource x:Key="BgHighlight">pack://application:,,,/ModBrowser;component/Assets/filters_pane_li_02.png</ImageSource>

            <ImageSource x:Key="TickBoxBgNormal">pack://application:,,,/Core;component/Assets/Options/checkBox_d.png</ImageSource>
            <ImageSource x:Key="TickBoxBgHighlight">pack://application:,,,/Core;component/Assets/Options/checkBox_h.png</ImageSource>
            <ImageSource x:Key="TickBoxBgPressed">pack://application:,,,/Core;component/Assets/Options/checkBox_p.png</ImageSource>
