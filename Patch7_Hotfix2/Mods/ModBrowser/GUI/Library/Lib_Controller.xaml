                    <Grid x:Name="zoomedScreenshotGrid" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="120,-60,120,0">
                        <Rectangle x:Name="zoomedImageMod" Margin="0,-60,0,0" Width="Auto" MaxWidth="3000" Fill="{Binding ElementName=imageMod, Path=Fill}" Stroke="White" StrokeThickness="10">
                            <Rectangle.Height>
                                <MultiBinding Converter="{StaticResource KeepAspectRatioConverter}" ConverterParameter="FromWidth">
                                    <Binding Path="ActualWidth" ElementName="zoomedImageMod"/>
                                    <Binding Path="Fill.ImageSource.Width" ElementName="zoomedImageMod"/>
                                    <Binding Path="Fill.ImageSource.Height" ElementName="zoomedImageMod"/>
                                </MultiBinding>
                            </Rectangle.Height>
