                            <Setter TargetName="img" Property="Source" Value="{StaticResource TickBoxBgHighlight}"/>
                            <Setter TargetName="check" Property="Source" Value="{StaticResource TickBoxIconHighlight}"/>
                            <Setter TargetName="FocusedMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Content" Property="Foreground" Value="{StaticResource LS_tint100}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
