                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LSButtonPressed">
                                <ls:SelectNextListBoxItem TargetName="extraImages" Reversed="True" ForceSelect="True" ForceMode="Cycle"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>
                    <ls:LSButton x:Name="zoomNext" HorizontalAlignment="Right" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" VerticalAlignment="Center" BoundEvent="UITabNext"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UITabNext'}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LSButtonPressed">
                                <ls:SelectNextListBoxItem TargetName="extraImages" ForceSelect="True" ForceMode="Cycle"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ls:LSButton>
                </Grid>
                <Grid VerticalAlignment="Bottom" Margin="20,0,20,56" Width="2540">
                    <ls:LSButton x:Name="prevModButton" ContentTemplate="{StaticResource ControllerButtonHint}" HorizontalAlignment="Left"
                             Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='JumpToFromTab'}"
                             Tag="{Binding Source='hc0258f26g3fd8g4346gb87ega6970e58b852',Converter={StaticResource TranslatedStringConverter}}" BoundEvent="JumpToFromTab"
                             Command="{Binding PrevModDetailsCommand}" CommandParameter="{Binding SelectedMod}"/>

                    <ls:LSButton x:Name="nextModButton" ContentTemplate="{StaticResource ControllerButtonHint}" Grid.Row="7" Grid.Column="4" HorizontalAlignment="Right"
                             Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='ToggleSummaryFocus'}"
                             Tag="{Binding Source=hfce3e682g151ag47b8g83a2ge40e0ac6594a, Converter={StaticResource TranslatedStringConverter}}" BoundEvent="ToggleSummaryFocus"
                             Command="{Binding NextModDetailsCommand}" CommandParameter="{Binding SelectedMod}"/>

                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <ls:LSButton x:Name="toggleButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 BoundEvent="UIAccept" Tag="{Binding Source='h04f38549g65b8g4b72g834eg87ee8863fdc5',Converter={StaticResource TranslatedStringConverter}}"
                                 CommandParameter="{Binding SelectedMod}"/>
                        <ls:LSButton x:Name="zoomScreenshotButton" ContentTemplate="{StaticResource ControllerButtonHint}" BoundEvent="UICreate"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICreate'}"
                                 Tag="{Binding Source='hbd5a17f0g8dcbg42c7g9016ge849ae545969',Converter={StaticResource TranslatedStringConverter}}"
                                 Command="{Binding ToggleScreenshotZoomCommand}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="LSButtonPressed">
                                    <ls:SetMoveFocusAction TargetObject="{Binding Path=., RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ls:UIWidget}}}" Reset="True"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ls:LSButton>
                        <ls:LSButton Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIScroll'}"
                         ContentTemplate="{StaticResource ControllerButtonHint}"
                         Tag="{Binding Source='h29f2b927gf6feg48e8g8bc9gdc391427b51c', Converter={StaticResource TranslatedStringConverter}}"
                         VerticalAlignment="Center"
                         Visibility="{Binding ComputedVerticalScrollBarVisibility, ElementName=PreviewScroll}"/>
                        <ls:LSButton x:Name="closeButton" ContentTemplate="{StaticResource ControllerButtonHint}"
                             Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                             BoundEvent="UICancel" Tag="{Binding Source='h566c2213g6b06g4c09g912ege16b46f520ba',Converter={StaticResource TranslatedStringConverter}}"
                             Command="{Binding ToggleDetailsCommand}" SoundID="UI_Shared_Cancel"/>

                        <ls:LSButton x:Name="zoomOutButton" ContentTemplate="{StaticResource ControllerButtonHint}" HorizontalAlignment="Center"
                             Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}" Visibility="Collapsed"
                             BoundEvent="UICancel" Tag="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7',Converter={StaticResource TranslatedStringConverter}}" SoundID="UI_Shared_Cancel" Command="{Binding ToggleScreenshotZoomCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </AdornerDecorator>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding SelectedMod.IsUpvoted}" Value="True">
                <Setter TargetName="endorseIcon" Property="Source" Value="{StaticResource detailsLikeUpvoted}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.IsOutdated}" Value="True" />
                    <Condition Binding="{Binding Data.IsUGCDisabled}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="updateGrid" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.Screenshots.Count}" Value="0">
                <Setter TargetName="extraImages" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="prevScreenshotButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="nextScreenshotButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="zoomPrev" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="zoomNext" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="screenshotNumber" Property="Text" Value="1"/>
                <Setter TargetName="zoomOutButton" Property="Margin" Value="0,0,0,0"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding SelectedMod.Screenshots.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True"/>
                    <Condition Binding="{Binding ActiveTabID}" Value="Installed"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="zoomedImageMod" Property="Width" Value="2700"/>
                <Setter TargetName="zoomedScreenshotGrid" Property="Margin" Value="0,0,0,100"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding ElementName=extraImages, Path=Visibility}" Value="Visible">
                <Setter TargetName="imageMod" Property="Fill" Value="{Binding ElementName=extraImages, Path=SelectedItem.Screenshot}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.MainScreenshot.HasScreenshotTexture}" Value="False">
                <Setter TargetName="imageSpinner" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.IsEnabled}" Value="True">
                <Setter TargetName="enabledIcon" Property="Source" Value="{StaticResource enabledIcon_c}"/>
                <Setter TargetName="enabledLabel" Property="Foreground" Value="{StaticResource LS_bonusTxtColor}"/>
                <Setter TargetName="enabledLabel" Property="Text" Value="{Binding Source='h054025c0gd806g418agb58dg6b325823b7cd',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.ModState}" Value="Subscribed">
                <Setter TargetName="modSubscribeButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="unsubscribeButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="modEnableButton" Property="Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.ModState}" Value="Downloading">
                <Setter TargetName="updateGrid" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="downloadingBorder" Property="Visibility" Value="Visible"/>
                <Setter TargetName="subscribeButtonContent" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="toggleButton" Property="IsEnabled" Value="False"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.ModState}" Value="Installed">
                <Setter TargetName="modSubscribeButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modEnableButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="unsubscribeButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="unsubscribeButton" Property="Tag" Value="uninstallCommand"/>
                <Setter TargetName="unsubscribeLabel" Property="Text" Value="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.LastUpdatedDate}" Value="">
                <Setter TargetName="lastUpdatedValue" Property="Text" Value="{Binding Source=hcdb2c178g917cg4f01ga281g64ce59d0ad6b, Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SelectedMod.OriginalUploadDate}" Value="">
                <Setter TargetName="originalUploadValue" Property="Text" Value="{Binding Source=hcdb2c178g917cg4f01ga281g64ce59d0ad6b, Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="enableCommand"/>
                    <Condition Binding="{Binding SelectedMod.IsEnabled}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h5af0e4c5g6634g4ccbg886dg0c5dbd83b026',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding ToggleModEnabledStateCommand}"/>
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="enableCommand"/>
                    <Condition Binding="{Binding SelectedMod.IsEnabled}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h5fa6eb5cg13a3g4278g8db7g815e96b0125b',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding ToggleModEnabledStateCommand}"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="updateCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h592534fcg597cg43d0gb491g9e25a011f31f',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding UpdateModCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="uninstallCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h07287a93g6ca8g4d72g9554g452d6c2431f5',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding UninstallModCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="subscribeCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h0c9f422cga55cg4d2agb342ga095b82caa58',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding DownloadModCommand}"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="subscribeCommand"/>
                    <Condition Binding="{Binding Data.ModAccountState}" Value="ModioConnected"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding SubscribeModCommand}"/>
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="unsubscribeCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h75fcf9abgbe78g4aa3g835bgc8f319c8942c',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding UnsubscribeModCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="endorseCommand">
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding EndorseModCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="reportCommand">
                <Setter TargetName="toggleButton" Property="Tag" Value="{Binding Source='h3eb3aeabg68fcg418cga213ge00d639e4507',Converter={StaticResource TranslatedStringConverter}}"/>
                <Setter TargetName="toggleButton" Property="Command" Value="{Binding ReportModCommand}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Data.ModAccountState}" Value="ModioConnected">
                <Setter TargetName="endorseButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="subscribeLabel" Property="Text" Value="{Binding Source='h143b56a0g1c2eg4522g83abg5e2d25798282',Converter={StaticResource TranslatedStringConverter}}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding InScreenshotZoom}" Value="True">
                <Setter TargetName="imageMod" Property="Margin" Value="0,-1200,0,0"/>
                <Setter TargetName="extraImages" Property="Margin" Value="0,-1400,0,0"/>
                <Setter TargetName="prevScreenshotButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="nextScreenshotButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modDescription" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="lastUpdatedHint" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="lastUpdatedValue" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="originalUploadHint" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="originalUploadValue" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="controlsPanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="bottomDetailsDivider" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="extraDetailsPanel" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="prevModButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="nextModButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="toggleButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="zoomScreenshotButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="closeButton" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="zoomOutButton" Property="Visibility" Value="Visible"/>
                <Setter TargetName="imageSpinner" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="modsAdditionalContent" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="ExpanderGroup"/>
                    <Condition Binding="{Binding FocusedElement.(ls:AttachedProperties.InheritedTag), RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="tagsHeader"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="tagsToggleInput" Property="IsEnabled" Value="True"/>
                <Setter TargetName="toggleButton" Property="IsEnabled" Value="False"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding FocusedElement.Tag, RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="ExpanderGroup"/>
                    <Condition Binding="{Binding FocusedElement.(ls:AttachedProperties.InheritedTag), RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}" Value="dependenciesHeader"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="dependenciesToggleInput" Property="IsEnabled" Value="True"/>
                <Setter TargetName="toggleButton" Property="IsEnabled" Value="False"/>
            </MultiDataTrigger>
            <EventTrigger RoutedEvent="Loaded" SourceName="runningBar">
                <BeginStoryboard x:Name="IndefiniteLoading">
                    <Storyboard>
                        <ThicknessAnimation Storyboard.TargetProperty="Margin" Storyboard.TargetName="runningBar" Duration="0:0:1" From="0,0,200,0" To="0,0,-200,0" AutoReverse="True" RepeatBehavior="Forever">
                            <ThicknessAnimation.EasingFunction>
                                <SineEase EasingMode="EaseInOut"/>
                            </ThicknessAnimation.EasingFunction>
                        </ThicknessAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Unloaded" SourceName="runningBar">
                <StopStoryboard BeginStoryboardName="IndefiniteLoading"/>
            </EventTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="WaitingSpinnerTemplate">
        <StackPanel x:Name="spinnerRoot" VerticalAlignment="Top" HorizontalAlignment="Stretch">
            <TextBlock x:Name="waitLabel" Text="{Binding Source='h18414d2cg5e53g41dag8f35g774de89faaf8', Converter={StaticResource TranslatedStringConverter}}"/>
            <Control VerticalAlignment="Top" HorizontalAlignment="Center" Template="{StaticResource BusyElement}" Margin="0,-23,0,0"/>
        </StackPanel>
    </ControlTemplate>
</ResourceDictionary>