                    </Grid>
                    <ls:LSButton x:Name="zoomPrev" ContentTemplate="{StaticResource ControllerButtonHintImageOnly}" VerticalAlignment="Center" HorizontalAlignment="Left" BoundEvent="UITabPrev"
