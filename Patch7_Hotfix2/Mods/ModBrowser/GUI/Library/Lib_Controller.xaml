                                                        <Image x:Name="dependencyState" Source="{StaticResource disabledIcon_c}" Stretch="None" Margin="0,0,20,0"/>
                                                    </StackPanel>
                                                </ContentControl>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                        <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource enabledIcon_c}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsOutdated}" Value="True">
                                                        <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource updateIcon_c}"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ModState}" Value="Installed"/>
                                                            <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource IconWarningSoft}"/>
                                                        <Setter TargetName="dependencyState" Property="Margin" Value="7,0,27,0"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ModState}" Value="Subscribed"/>
                                                            <Condition Binding="{Binding IsEnabled}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="dependencyState" Property="Source" Value="{StaticResource IconWarningSoft}"/>
                                                        <Setter TargetName="dependencyState" Property="Margin" Value="7,0,27,0"/>
                                                    </MultiDataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>

                                <ls:LSInputBinding x:Name="dependenciesToggleInput" BoundEvent="UIAccept" Focusable="False" EatInput="True" IsEnabled="False" Height="0">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="LSInputBindingPressed">
                                            <b:ChangePropertyAction TargetName="dependenciesExpander" PropertyName="IsExpanded" Value="{Binding Path=IsExpanded, ElementName=dependenciesExpander, Converter={StaticResource InvertBoolConverter}}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </ls:LSInputBinding>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                <Grid x:Name="zoomedScreenshotRoot" HorizontalAlignment="Stretch"
