<ls:UIWidget x:Name="ModioSignIn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"             
             ContextName="ModioSignIn"
             d:DataContext="{d:DesignInstance {x:Type ls:DCModioSignIn}, IsDesignTimeCreatable=True}"
             d:DesignWidth="3840" d:DesignHeight="2160">

    <ls:UIWidget.Template>
        <ControlTemplate>
            <ControlTemplate.Resources>
                <Style TargetType="ls:LSHyperlink">
                    <Setter Property="Foreground" Value="{StaticResource LS_accent100TxtColor}"/>
                    <Style.Triggers>
                        <Trigger Property="TagInfo" Value="Privacy">
                            <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                            <Setter Property="CommandParameter" Value="Privacy"/>
                        </Trigger>
                        <Trigger Property="TagInfo" Value="ModioToS">
                            <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                            <Setter Property="CommandParameter" Value="ModioToS"/>
                        </Trigger>
                        <Trigger Property="TagInfo" Value="ModioPrivacy">
                            <Setter Property="Command" Value="{Binding OpenURLInBrowserCommand}"/>
                            <Setter Property="CommandParameter" Value="ModioPrivacy"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource LS_tint100}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <ControlTemplate x:Key="ModioSignInTemplate">
                    <DockPanel>

                        <TextBlock x:Name="FailedAuthenticationError" Width="1000" Height="200" DockPanel.Dock="Bottom" Margin="0,100,0,-300" Foreground="{StaticResource LS_alertTxtColor}" Text="{Binding Source='h5362fb3fg10a1g46a0gb3a0ga40a09944e83',Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Opacity="0"/>
                        
                        <!-- buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,22" DockPanel.Dock="Bottom">
                            <ls:LSButton x:Name="CloseButton" Style="{StaticResource BrownButtonStyle}" Content="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7', Converter={StaticResource TranslatedStringConverter}}" Command="{Binding CustomEvent}" CommandParameter="CloseWidget"/>
                            <ls:LSButton x:Name="SignInButton" Style="{StaticResource BlueButtonStyle}" Content="{Binding Source='h2a30d2efgf070g425bg9f3cgdf92a16e2bb3', Converter={StaticResource TranslatedStringConverter}}" IsEnabled="False" Command="{Binding SignInModio}" Margin="-10,0"/>
                        </StackPanel>
                        <TextBlock x:Name="bottomMessage" DockPanel.Dock="Bottom"
                             Margin="0,0,0,24"
                             FontSize="{StaticResource DefaultFontSize}"
                             Foreground="{StaticResource LS_baseTxtColor}"
                             ls:TextBlockFormatter.SourceText="{Binding Source='h6d24bbf7gb955g4c58g8ebeg206e953141c1',Converter={StaticResource TranslatedStringConverter}}"
                             TextWrapping="Wrap"
                             TextAlignment="Center"/>
                        <Control x:Name="waitingSpinner" DockPanel.Dock="Bottom" Margin="0,0,0,0" HorizontalAlignment="Center" Template="{StaticResource WaitingSpinnerTemplate}" Visibility="Collapsed"/>

                        <!-- title -->
                        <TextBlock x:Name="Title" DockPanel.Dock="Top"
                               Margin="0,80,0,0"
                               Text="{Binding Source='h2fa22eb7g9c8eg4ba4g9054g9b04840734e1',Converter={StaticResource TranslatedStringConverter}}"
                               Foreground="{StaticResource LS_tint100}"
                               FontSize="{StaticResource MassiveFontSize}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <DockPanel Margin="200, 0, 200, 0">

                            <TextBlock x:Name="Description" DockPanel.Dock="Top"
                               Margin="0,70,0,20"
                               Foreground="{StaticResource LS_accent75TxtColor}"
                               FontSize="{StaticResource DefaultFontSize}"
                               ls:TextBlockFormatter.SourceText="{Binding Source='hc0cef6ceg9ecbg4949g9ad7gf681804c8651',Converter={StaticResource TranslatedStringConverter}}"
                               TextWrapping="Wrap"
                               TextAlignment="Left"/>

                            <Image Source="{StaticResource splashScreenPanelDivider}" Stretch="None" DockPanel.Dock="Top" Margin="-80,0,-80,0"/>

                            <DockPanel HorizontalAlignment="Center" Margin="0,10,0,10" DockPanel.Dock="Top" >
                                <Image x:Name="modioIcon" Source="{StaticResource modioIcon}" Stretch="None" Margin="0,0,0,85" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="ModIoAccountMessage"
                                   Margin="20,0,0,0"
                                   Foreground="{StaticResource LS_accent75TxtColor}"
                                   FontSize="{StaticResource DefaultFontSize}"
                                   ls:TextBlockFormatter.SourceText="{Binding Source='h96d90910gc334g46bbg99f4gef8bbd1ee8d1',Converter={StaticResource TranslatedStringConverter}}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"
                                   />
                            </DockPanel>

                            <Image Source="{StaticResource splashScreenPanelDivider}" Stretch="None" RenderTransformOrigin="0.5, 0.5" DockPanel.Dock="Top" Margin="-80,0,-80,0">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="180"/>
                                </Image.RenderTransform>
                            </Image>

                            <Grid Margin="0,10" DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ls:LSCheckBox x:Name="ModioTermsCheckbox" Grid.Column="0" VerticalAlignment="Top" Style="{StaticResource SimpleTickBoxStyle}" IsChecked="{Binding ModioCheck}"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" ls:TextBlockFormatter.SourceText="{Binding Source='h87d7f4b6g17bfg446ag91cfg972e512da2a3',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap" />
                            </Grid>

                            <DockPanel Margin="0,55,0,0">
                                <Image x:Name="generalWarningIcon" Source="{StaticResource generalWarningIcon}" Stretch="None" Margin="0,0,0,300" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="CompatibilityWarning" DockPanel.Dock="Left"
                                   Margin="5,0,0,0"
                                   Foreground="{StaticResource LS_accent75TxtColor}"
                                   FontSize="{StaticResource DefaultFontSize}"
                                   FontStyle ="Italic"
                                   Text="{Binding Source='h11329411g4346g409aga3e0gb40e574de386',Converter={StaticResource TranslatedStringConverter}}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"/>
                            </DockPanel>

                        </DockPanel>
                    </DockPanel>
                    <ControlTemplate.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ModioCheck}" Value="True"/>
                                <Condition Binding="{Binding AuthenticationState}" Value="NotAuthenticated"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="SignInButton" Property="IsEnabled" Value="True"/>
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticationRequested">
                            <Setter TargetName="ModioTermsCheckbox" Property="IsEnabled" Value="False"/>
                            <Setter TargetName="bottomMessage" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="waitingSpinner" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticationFailed">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FailedAuthenticationError" Storyboard.TargetProperty="Opacity">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:5.7" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:6" Value="0"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <Setter TargetName="SignInButton" Property="IsEnabled" Value="True"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

                <ControlTemplate x:Key="ModioSignInSuccessful">
                    <Grid Margin="100,22">
                        <TextBlock x:Name="Title" VerticalAlignment="Top" HorizontalAlignment="Center"  Text="{Binding Source='h2fa22eb7g9c8eg4ba4g9054g9b04840734e1',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_tint100}" FontSize="{StaticResource MassiveFontSize}" Margin="0,80,0,0"/>
                        
                        <TextBlock x:Name="Description" VerticalAlignment="Top" Text="{Binding Source='h0ea4a6aag4866g4f57g912agdd2d1e8f912a',Converter={StaticResource TranslatedStringConverter}}" Margin="0,200,0,0" />

                        <ls:LSButton x:Name="CloseButton" VerticalAlignment="Bottom" Style="{StaticResource BrownButtonStyle}" Content="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7', Converter={StaticResource TranslatedStringConverter}}" Command="{Binding CustomEvent}" CommandParameter="CloseWidget"/>
                    </Grid>
                </ControlTemplate>
            </ControlTemplate.Resources>
            <Grid>
                <Image Source="{StaticResource backgroundFade}" Stretch="Fill"/>
                <ls:LSNineSliceImage Style="{StaticResource splashScreenBackground}" Width="1332" Height="1544" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Control x:Name="ModioSignInContent" Template="{StaticResource ModioSignInTemplate}"/>
                </ls:LSNineSliceImage>
            </Grid>
            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticatedSuccessfully">
                    <Setter TargetName="ModioSignInContent" Property="Template" Value="{StaticResource ModioSignInSuccessful}"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>