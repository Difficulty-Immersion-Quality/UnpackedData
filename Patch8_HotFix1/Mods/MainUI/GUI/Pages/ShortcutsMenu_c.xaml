<ls:UIWidget xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="shortcutsMenu"
             ls:UIWidget.ContextName="GameMenu"
             d:DesignWidth="3840" d:DesignHeight="2160" d:DataContext="{d:DesignInstance {x:Type ls:DCGameMenu}, IsDesignTimeCreatable=True}">

    <ls:UIWidget.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Core;component/Library/Radials_c.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Thickness x:Key="SlotPosition1">-172,-172,-172,-148</Thickness>
            <Thickness x:Key="SlotPosition2">-172,-172,-172,-126</Thickness>

            <ImageSource x:Key="Inspiration_dImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_inspirationShortCut_d.png</ImageSource>
            <ImageSource x:Key="breadCrumbFrame">pack://application:,,,/Core;component/Assets/PanelSelect_c/breadCrumb_frame.png</ImageSource>
            <ImageSource x:Key="breadCrumb">pack://application:,,,/Core;component/Assets/PanelSelect_c/breadCrumb.png</ImageSource>
            <ImageSource x:Key="highlightArrow">pack://application:,,,/Core;component/Assets/PanelSelect_c/ico_tutCrumb1.png</ImageSource>
            <ImageSource x:Key="highlightDot">pack://application:,,,/Core;component/Assets/PanelSelect_c/ico_tutCrumb2.png</ImageSource>
            <ImageSource x:Key="campSuppliesIcon">pack://application:,,,/Core;component/Assets/MakeCamp_c/c_ico_headerMakeCamp.png</ImageSource>

            <BitmapImage x:Key="ButtonMask" UriSource="pack://application:,,,/Core;component/Assets/Shared_c/highlightMask.png"/>

            <Storyboard x:Key="ScreenAppear" FillBehavior="Stop">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BackgroundCover" Storyboard.TargetProperty="Opacity">
                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.02" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuRadial" Storyboard.TargetProperty="Opacity">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.02" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                </DoubleAnimationUsingKeyFrames>

                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuRadial" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                    <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.9" />
                    <LinearDoubleKeyFrame KeyTime="0:0:0.02" Value="0.9" />
                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>

                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MenuRadial" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                    <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.9" />
                    <LinearDoubleKeyFrame KeyTime="0:0:0.02" Value="0.9" />
                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <ParallelTimeline x:Key="SelectorDotStoryboard">
                <DoubleAnimationUsingKeyFrames Duration="0:0:2.5" Storyboard.TargetName="Img2" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                    <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.5" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Duration="0:0:2.5" Storyboard.TargetName="EntryDotBig" Storyboard.TargetProperty="Opacity" RepeatBehavior="Forever">
                    <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.1" Value="1"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.5" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Duration="0:0:2.5" Storyboard.TargetName="EntryDotBig" Storyboard.TargetProperty="Width" RepeatBehavior="Forever">
                    <LinearDoubleKeyFrame KeyTime="0:0:2" Value="130"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.1" Value="130"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.5" Value="180"/>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Duration="0:0:2.5" Storyboard.TargetName="EntryDotSmall" Storyboard.TargetProperty="Width" RepeatBehavior="Forever">
                    <LinearDoubleKeyFrame KeyTime="0:0:2" Value="80"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.1" Value="130"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.3" Value="80"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:2.5" Value="80"/>
                </DoubleAnimationUsingKeyFrames>
            </ParallelTimeline>

            <Storyboard x:Key="ArrowHighlight" RepeatBehavior="Forever">
                <ThicknessAnimationUsingKeyFrames Storyboard.TargetName="ArrowImage" Storyboard.TargetProperty="Margin">
                    <LinearThicknessKeyFrame KeyTime="0" Value="0,0,0,0"/>
                    <LinearThicknessKeyFrame KeyTime="0:0:0.4" Value="0,50,0,0"/>
                    <LinearThicknessKeyFrame KeyTime="0:0:0.5" Value="0,0,0,0"/>
                </ThicknessAnimationUsingKeyFrames>

                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DotImage" Storyboard.TargetProperty="Width">
                    <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="96"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="120"/>
                    <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="96"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <ControlTemplate x:Key="RadialItemIconTemplate">
                <Grid>
                    <Image x:Name="BaseImg" VerticalAlignment="Center" HorizontalAlignment="Center" Source="{DynamicResource BaseImage}" Stretch="None"/>
                    <Image x:Name="Highlight2" VerticalAlignment="Center" HorizontalAlignment="Center" Source="{DynamicResource HLImage}" Stretch="None" Opacity="0"/>
                </Grid>
                <ControlTemplate.Triggers>

                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ls:LSRadialListItem}}}" Value="True"/>
                            <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType={x:Type ls:LSRadialListItem}}}" Value="True"/>
                        </MultiDataTrigger.Conditions>

                        <MultiDataTrigger.EnterActions>
                            <BeginStoryboard x:Name="FadeInSelectedAnim">
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="Highlight2">
                                        <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.02" Value="1"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </MultiDataTrigger.EnterActions>
                        <MultiDataTrigger.ExitActions>
                            <BeginStoryboard x:Name="FadeOutSelectedAnim">
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="Highlight2">
                                        <EasingDoubleKeyFrame KeyTime="0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </MultiDataTrigger.ExitActions>
                    </MultiDataTrigger>
                    <EventTrigger RoutedEvent="FrameworkElement.Unloaded">
                        <StopStoryboard BeginStoryboardName="FadeInSelectedAnim"/>
                        <StopStoryboard BeginStoryboardName="FadeOutSelectedAnim"/>
                    </EventTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </ResourceDictionary>
    </ls:UIWidget.Resources>
    <ls:UIWidget.Template>

        <ControlTemplate>
            <Grid x:Name="BackgroundCover" Background="{StaticResource LS_PanelBackground}">
                <!-- Extra Split Screen background -->
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <b:ChangePropertyAction TargetName="SplitScreenBg" PropertyName="Tag" Value="{Binding Data.IsCameraSplit}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <b:Interaction.Behaviors>
                    <ls:RuleSetModifierValueBehavior x:Name="IronManModifier" Modifiers="{Binding Data.CurrentRuleSetModifiers}" ModifierName="IRONMAN_MODE"/>
                </b:Interaction.Behaviors>

                <Grid x:Name="SplitScreenBg" Visibility="Collapsed" HorizontalAlignment="Stretch" Tag="" VerticalAlignment="Stretch">
                    <Grid.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="1" Color="#00000000"/>
                                <GradientStop Offset="0.5" Color="Black"/>
                                <GradientStop Offset="0" Color="Black"/>
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Grid.OpacityMask>

                    <Rectangle x:Name="SplitScreenBgGrad">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0f0b09" Offset="0"/>
                                <GradientStop Color="#000f0b09" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Border>
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0.5,0.5" RadiusX="1.5" RadiusY="0.9">
                                <GradientStop Color="#FF000000" Offset="0.9"/>
                                <GradientStop Color="#FF000000" Offset="0.9"/>
                                <GradientStop Color="#FF241712" Offset="0.7"/>
                                <GradientStop Color="#B3000000" Offset="0.55"/>
                                <GradientStop Color="#00000000" Offset="0.4"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border>
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0.5,0.5" RadiusX="1" RadiusY="1">
                                <GradientStop Color="#b5241712" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="0.4"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <Grid x:Name="RadialResizer" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" Width="1920">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <ls:Radial ls:ElementCacheHelper.GroupId="Shortcuts" x:Name="MenuRadial" Margin="0,0,0,120" PlayerId="{Binding CurrentPlayer.PlayerId}" RenderTransformOrigin="0.5,0.5" Padding="-222,-810,0,0">
                        <ls:Radial.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </TransformGroup>
                        </ls:Radial.RenderTransform>
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="LocalFocusChanged">
                                <ls:LSPlaySound Sound="UI_HUD_Controller_ShortcutsMenu_Hover" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                        <ls:LSRadialListItem x:Name="ShortCutCharacterSheet" Tag="CharacterSheet">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_characterSheet_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_characterSheet_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem x:Name="ShortCutSpellBook" Tag="SpellBook">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_spellBook_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_spellBook_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem Tag="TadPoles" IsEnabled="{Binding CurrentPlayer.PartyUnlockedTadpolePowers}">
                            <Grid Visibility="{Binding CurrentPlayer.PartyUnlockedTadpolePowers, Converter={StaticResource BoolToVisibleConverter}}">
                                <TextBlock x:Name="TadpoleCount" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="160,-60,-60,50" Text="{Binding CurrentPlayer.PartyTadpoleCount, StringFormat={}x{0}}"/>
                                <Control Template="{StaticResource RadialItemIconTemplate}" HorizontalAlignment="Center" VerticalAlignment="Center" >
                                    <Control.Resources>
                                        <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_illithidPowers_d.png</ImageSource >
                                        <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_illithidPowers_h.png</ImageSource>
                                    </Control.Resources>
                                </Control>
                            </Grid>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem Tag="Journal">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_journal_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_journal_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem Tag="CombatLog">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_inventory_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_inventory_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem x:Name="LongRestItem" Tag="LongRest">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_longRest_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_longRest_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem x:Name="CampItem" Tag="Camp" IsEnabled="False">
                            <Grid>
                                <Control x:Name="GoToCampControl" Template="{StaticResource RadialItemIconTemplate}">
                                    <Control.Resources>
                                        <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_goToCamp_d.png</ImageSource>
                                        <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_goToCamp_h.png</ImageSource>
                                    </Control.Resources>
                                </Control>
                                <Control x:Name="LeaveCampControl" Template="{StaticResource RadialItemIconTemplate}" Visibility="Collapsed">
                                    <Control.Resources>
                                        <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_leaveCamp_d.png</ImageSource>
                                        <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_leaveCamp_h.png</ImageSource>
                                    </Control.Resources>
                                </Control>
                            </Grid>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem x:Name="ShortRestItem" Tag="ShortRest" IsEnabled="{Binding CurrentPlayer.SelectedCharacter.Stats.ShortRestPointsResource.Value, Converter={StaticResource GreaterThanConverter}, ConverterParameter='0'}">
                            <ls:LSRadialListItem.Resources>
                                <ImageSource x:Key="SRAvailableImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_shortRest_available.png</ImageSource>
                            </ls:LSRadialListItem.Resources>
                            <Grid>
                                <Grid x:Name="DotsPanel" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Image x:Name="SR1" Source="{StaticResource SRAvailableImage}" Grid.Column="0" Width="48"/>
                                    <Image x:Name="SR2" Source="{StaticResource SRAvailableImage}" Grid.Column="1" Width="48"/>
                                </Grid>
                                <Control Template="{StaticResource RadialItemIconTemplate}">
                                    <Control.Resources>
                                        <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_shortRest_d.png</ImageSource>
                                        <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_shortRest_h.png</ImageSource>
                                    </Control.Resources>
                                </Control>
                            </Grid>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem x:Name="FTBItem" Tag="FTB" IsEnabled="{Binding CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.IsTBMCoolingDown, Converter={StaticResource InvertBoolConverter}}">
                            <Grid>
                                <Grid.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_ftb_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_ftb_h.png</ImageSource>
                                    <ImageSource x:Key="IconRTNoArrow">pack://application:,,,/Core;component/Assets/BottomBar/ico_RT_d_noArrow.png</ImageSource>
                                </Grid.Resources>

                                <Image x:Name="BaseImg" VerticalAlignment="Center" HorizontalAlignment="Center" Source="{StaticResource BaseImage}" Stretch="None"/>
                                <Grid x:Name="AnimChrono" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Hidden">
                                    <Image x:Name="icoAnim" Source="{StaticResource IconRTNoArrow}" Stretch="None" Margin="0,-4,0,0"/>
                                    <Path x:Name="Arrow" Stretch="None" Width="88" Height="88" StrokeThickness="0" Stroke="#88000000" Fill="White" RenderTransformOrigin="0.5,0.534">
                                        <Path.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform/>
                                                <RotateTransform Angle="{Binding CurrentPlayer.SelectedCharacter.PlayerCharacterProperties.TBMCooldownProgress, Converter={StaticResource MultiplierConverter}, ConverterParameter=360}"/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </Path.RenderTransform>
                                        <Path.Data>
                                            <Geometry>M40,51 V45 L68,23 L47,51 Z</Geometry>
                                        </Path.Data>
                                    </Path>
                                </Grid>
                                <Image x:Name="Highlight2" VerticalAlignment="Center" HorizontalAlignment="Center" Source="{StaticResource HLImage}" Stretch="None" Opacity="0"/>
                            </Grid>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem Tag="Map">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_map_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_map_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem x:Name="WaypointsItem" Tag="Waypoints" IsEnabled="False">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_quickTravel_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_quickTravel_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:LSRadialListItem Tag="Alchemy">
                            <Control Template="{StaticResource RadialItemIconTemplate}">
                                <Control.Resources>
                                    <ImageSource x:Key="BaseImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_alchemy_d.png</ImageSource>
                                    <ImageSource x:Key="HLImage">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_ico_alchemy_h.png</ImageSource>
                                </Control.Resources>
                            </Control>
                        </ls:LSRadialListItem>
                        <ls:Radial.ItemContainerStyle>
                            <Style TargetType="ls:LSRadialListItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ls:LSRadialListItem">
                                            <ControlTemplate.Resources>
                                                <ImageSource x:Key="RadialSlotBg">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_shortCutMenu_slotAlt_d.png</ImageSource>
                                                <ImageSource x:Key="RadialSlotActiveBg">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_shortCutMenu_slot_Active.png</ImageSource>
                                                <ImageSource x:Key="RadialSlotHighlightBg">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_shortCutMenu_slot_Red.png</ImageSource>
                                                <ImageSource x:Key="RadialSlotHighlight">pack://application:,,,/Core;component/Assets/PanelSelect_c/c_shortCutMenu_slot_h.png</ImageSource>
                                            </ControlTemplate.Resources>
                                            <Grid ls:LSRadialListItem.RotateType="Rotate" RenderTransformOrigin="0.5 1">

                                                <Grid x:Name="slotRoot" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,410">
                                                    <Image x:Name="SlotBg" Stretch="None" Source="{StaticResource RadialSlotBg}" RenderTransformOrigin="0.5 0.5" Opacity="1">
                                                        <Image.RenderTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </Image.RenderTransform>
                                                    </Image>

                                                    <Grid x:Name="HighlightFrame" RenderTransformOrigin="0.5 0.5" Margin="10,0" Visibility="Collapsed">
                                                        <Grid.RenderTransform>
                                                            <TransformGroup>
                                                                <RotateTransform Angle="-90"/>
                                                                <ScaleTransform ScaleX="0.96"/>
                                                                <ScaleTransform ScaleY="0.96"/>
                                                            </TransformGroup>
                                                        </Grid.RenderTransform>
                                                        <Image x:Name="Img1" Source="{StaticResource breadCrumbFrame}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="-20,-20,-20,-20">
                                                            <Image.OpacityMask>
                                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="1">
                                                                    <GradientStop Offset="0" Color="#ffffff"/>
                                                                    <GradientStop Offset="0.5" Color="#20ffffff"/>
                                                                    <GradientStop Offset="1" Color="#ffffff"/>
                                                                </LinearGradientBrush>
                                                            </Image.OpacityMask>
                                                        </Image>
                                                        <Image x:Name="Img2" Source="{StaticResource breadCrumbFrame}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="-20,-20,-20,-20"/>
                                                    </Grid>

                                                    <Image x:Name="Selected" Stretch="None" Margin="{StaticResource SlotPosition1}" Source="{StaticResource RadialSlotHighlight}" Opacity="0" RenderTransformOrigin="0.5 0.5">
                                                        <Image.RenderTransform>
                                                            <TransformGroup>
                                                                <RotateTransform Angle="-90"/>
                                                                <ScaleTransform ScaleX="1.04"/>
                                                                <ScaleTransform ScaleY="1.04"/>
                                                            </TransformGroup>
                                                        </Image.RenderTransform>
                                                    </Image>
                                                    <Image x:Name="Selected2" Stretch="None" Margin="{StaticResource SlotPosition1}" Source="{StaticResource RadialSlotHighlight}" Opacity="0" RenderTransformOrigin="0.5 0.5">
                                                        <Image.RenderTransform>
                                                            <TransformGroup>
                                                                <RotateTransform Angle="-90"/>
                                                                <ScaleTransform ScaleX="1.04"/>
                                                                <ScaleTransform ScaleY="1.04"/>
                                                            </TransformGroup>
                                                        </Image.RenderTransform>
                                                        <Image.Effect>
                                                            <DropShadowEffect BlurRadius="24" ShadowDepth="10" Opacity="1" Color="{StaticResource tint00}"/>
                                                        </Image.Effect>
                                                    </Image>

                                                    <Grid x:Name="NewEntryNotification" RenderTransformOrigin="0.5 0.5" Margin="0,0,0,-415" Visibility="Collapsed">
                                                        <Image x:Name="EntryDotSmall" Source="{StaticResource breadCrumb}" Width="80"/>
                                                        <Image x:Name="EntryDotBig" Source="{StaticResource breadCrumb}" Width="130" Opacity="0"/>
                                                        <Grid.Triggers>
                                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                <BeginStoryboard Name="HighlightDotSb">
                                                                    <BeginStoryboard.Storyboard>
                                                                        <Storyboard Children="{StaticResource SelectorDotStoryboard}"/>
                                                                    </BeginStoryboard.Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                            <EventTrigger RoutedEvent="FrameworkElement.Unloaded">
                                                                <StopStoryboard BeginStoryboardName="HighlightDotSb"/>
