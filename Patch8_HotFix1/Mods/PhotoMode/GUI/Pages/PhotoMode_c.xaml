                <DataTrigger Binding="{Binding SelectedItem.MirrorX, ElementName=CurrentStickersAvailable}" Value="True">
                    <Setter TargetName="MirrorXText" Property="Text" Value="{Binding Source='hdafef797ga739g44bfg9fd7gc77467430825', Converter={StaticResource TranslatedStringConverter}}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding SelectedItem.MirrorY, ElementName=CurrentStickersAvailable}" Value="True">
                    <Setter TargetName="MirrorYText" Property="Text" Value="{Binding Source='hdafef797ga739g44bfg9fd7gc77467430825', Converter={StaticResource TranslatedStringConverter}}"/>
                </DataTrigger>

                <Trigger SourceName="TogglePanelVisibilityButton" Property="IsChecked" Value="True">
                    <Setter TargetName="TogglePanelVisibilityButton" Property="Tag" Value="{Binding Source='hc66610c2gdd3dg492eg8ddfgeb81d9b09037', Converter={StaticResource TranslatedStringConverter}}"/>
                    <Setter TargetName="CameraControlPrompts" Property="Visibility" Value="Visible"/>
                </Trigger>

                <DataTrigger Binding="{Binding CurrentPlayer.IsHost}" Value="False">
                    <Setter TargetName="ClosePhotoModeButton" Property="Opacity" Value="{StaticResource DisabledOpacity}"/>
                </DataTrigger>

            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>