<ls:UIWidget x:Name="PhotoMode_c"
             ContextName="PhotoMode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance {x:Type ls:DCPhotoMode}, IsDesignTimeCreatable=True}"
			 FocusDown="UIDown" FocusLeft="UILeft" FocusRight="UIRight" FocusUp="UIUp"
             xmlns:ls="clr-namespace:ls;assembly=Code">
    <ls:UIWidget.Template>
        <ControlTemplate>
            <Grid x:Name="PhotoModeRoot">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <b:InvokeCommandAction Command="{Binding ToggleUICameraControl}" CommandParameter="{StaticResource FalseValue}"/>
                        <b:InvokeCommandAction Command="{Binding EnableTooltipOnUIElementCommand, ElementName=PhotoMode_c}"/>
                    </b:EventTrigger>
                    <b:DataTrigger Binding="{Binding PhotoStatus}" Value="Prepared">
                        <b:InvokeCommandAction Command="{Binding TakePhoto}"/>
                    </b:DataTrigger>
                    <b:EventTrigger EventName="GotKeyboardFocus">
                        <b:InvokeCommandAction Command="{Binding ShowTooltipOnUIElementCommand, ElementName=PhotoMode_c}" CommandParameter="{Binding Path=FocusedElement, ElementName=PhotoMode_c}"/>
                    </b:EventTrigger>
                    <b:DataTrigger Binding="{Binding HasInputEnabled, ElementName=PhotoMode_c}" Value="True">
                        <b:InvokeCommandAction Command="{Binding ShowTooltipOnUIElementCommand, ElementName=PhotoMode_c}" CommandParameter="{Binding FocusedElement, ElementName=PhotoMode_c}"/>
                    </b:DataTrigger>
                    <b:DataTrigger Binding="{Binding PhotoResult}" Value="Success">
                        <ls:LSPlaySound Sound="PhotoMode_UI_Shared_Photo" />
                    </b:DataTrigger>
                </b:Interaction.Triggers>

                <!-- BARS -->
                <Control x:Name="BarsControl" Template="{StaticResource DecorBarTemplate}"/>

                <!-- FRAMES -->
                <ls:LSNineSliceImage x:Name="PhotoModeFrame" IsHitTestVisible="False" Opacity="{Binding SelectedDecorFrameOpacity}" Style="{StaticResource PhotoModeFrameStyle}"/>

                <!-- STICKERS  -->
                <ItemsControl x:Name="CurrentStickersCollection" ItemsSource="{Binding CurrentStickers}" ItemTemplate="{StaticResource StickerTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Opacity" Value="{Binding Opacity}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>


                <Control x:Name="ReticleGrid" Template="{StaticResource ReticleGridTemplate}" Visibility="{Binding ReticleVisibility, Converter={StaticResource BoolToVisibleConverter}}"/>

                <Path x:Name="CompositionGrid" StrokeThickness="2" StrokeDashArray="2,16" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Fill" Visibility="{Binding GridVisibility, Converter={StaticResource BoolToVisibleConverter}}" Data="{StaticResource GridGeometry}">
                    <Path.Stroke>
                        <RadialGradientBrush>
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="White" Offset="0.9"/>
                            <GradientStop Color="#A0FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Path.Stroke>
                </Path>

                <ls:LSInputBinding x:Name="BlockInputWhileTakingPhoto" AnyClick="True" AnyKey="True" EatInput="True" IsEnabled="False"/>

                <Rectangle x:Name="PanelBG" Visibility="{Binding CurrentPlayer.UIData.UICameraControlToggle, Converter={StaticResource BoolToCollapsedConverter}}" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="{StaticResource ControllerPanelBGWidth}">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="{StaticResource transparentBGColor}"/>
                            <GradientStop Offset="0.3" Color="{StaticResource translucidBGColor}"/>
                            <GradientStop Offset="1" Color="{StaticResource opaqueBGColor}"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <TabControl x:Name="PhotoModePanel" Visibility="{Binding CurrentPlayer.UIData.UICameraControlToggle, Converter={StaticResource BoolToCollapsedConverter}}" Style="{StaticResource PhotoModeTabPanelController}" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="{StaticResource ControllerPanelWidth}" Margin="20,0,30,180">
                    <!--Camera Tab-->
                    <TabItem x:Name="CameraTab">
                        <TabItem.Header>
                            <ContentControl>
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <Image x:Name="HeaderImage" Source="{StaticResource CameraIconDefaultController}" Stretch="None"/>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Path=IsSelected,  RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                                                <Setter TargetName="HeaderImage" Property="Source" Value="{StaticResource CameraIconHighlightController}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </TabItem.Header>
                        <StackPanel>
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="Loaded">
                                    <ls:SetMoveFocusAction TargetName="PhotoMode_c"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                            <TextBlock Text="{Binding Source='ha0235395g1e92g4e47ga1d5g2c9c5cae0c48', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleLabelStyle}"/>
                            <!-- FOCUS CONTROL -->
                            <ContentControl x:Name="FocusedActorSelector" Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton BoundEvent="UILeft" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="Click">
                                                <ls:SelectNextListBoxItem Reversed="True" TargetName="FocusedCharactersListBox" ForceSelect="True"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton BoundEvent="UIRight" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="Click">
                                                <ls:SelectNextListBoxItem TargetName="FocusedCharactersListBox" ForceSelect="True"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </ls:LSRepeatButton>

                                    <TextBlock Text="{Binding Source='h42540f79gf986g4fb8g8316gb716a6917b23', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>
                                    <TextBlock Text="{Binding TrackedActor.Actor.Name}" Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" DockPanel.Dock="Bottom"/>

                                    <ListBox x:Name="FocusedCharactersListBox"
											 ItemsSource="{Binding ActorSettings, Mode=OneWay}"
											 SelectedItem="{Binding TrackedActor}"
											 HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="0,6,0,0"
											 ItemContainerStyle="{StaticResource ListBoxDashItemStyle}">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="SelectionChanged">
                                                <b:InvokeCommandAction Command="{Binding UpdateCameraTracking}"/>
                                                <ls:LSPlaySound Sound="UI_Controller_DefaultSlider_Step"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                </DockPanel>
                            </ContentControl>

                            <!-- TRACKING CONTROL -->
                            <ContentControl x:Name="TrackCharacterToggle" Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSToggleButton x:Name="TrackCharacterToggleLeft" IsChecked="{Binding TrackCharacter}" Command="{Binding UpdateCameraTracking}" BoundEvent="UILeft" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSToggleButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSToggleButton.RenderTransform>
                                    </ls:LSToggleButton>
                                    <ls:LSToggleButton x:Name="TrackCharacterToggleRight" IsChecked="{Binding TrackCharacter}" Command="{Binding UpdateCameraTracking}" BoundEvent="UIRight" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Style="{StaticResource TitleTextOptionStyle}" Text="{Binding Source='hf275610fgd057g4d11gb5a5gca667d698f7e', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>

                                    <TextBlock x:Name="TrackCharacterText" Text="{Binding Source='h1bfe4972g2615g4418g8ac3gdc35eddc8c15', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Bottom"/>

                                    <Control HorizontalAlignment="Center" Template="{StaticResource DashLineCheckbox}" DataContext="{Binding TrackCharacter}"/>
                                </DockPanel>
                            </ContentControl>

                            <!-- TILT CONTROL -->
                            <ContentControl Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='h7c2c1340g5a65g4bd6g9cf0gc5b7e682e1ce', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>
                                    <TextBlock Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                                        <Run>
                                            <Run.Text>
                                                <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                    <Binding Path="Value" ElementName="TiltSlider"/>
                                                    <Binding Source="57.35"/>
                                                </MultiBinding>
                                            </Run.Text>
                                        </Run>
                                        <Run Text="°"/>
                                    </TextBlock>


                                    <Slider x:Name="TiltSlider" Template="{StaticResource SliderTemplatePM}" Value="{Binding Tilt}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" SmallChange="0.0174" Minimum="-3.14" Maximum="3.14">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="ValueChanged">
                                                <b:InvokeCommandAction Command="{Binding UpdateCameraTilt}"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                            </ContentControl>

                            <!-- OFFSET X CONTROL -->
                            <ContentControl Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='hd18e09fdg471bg45c2g93cdg216c95a46b85', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>
                                    <TextBlock Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                                         <Run>
                                             <Run.Text>
    	                                        <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                    <Binding Path="Value" ElementName="OffsetXSlider"/>
                                                    <Binding Source="50"/>
                                                </MultiBinding>
                                             </Run.Text>
                                            </Run>
                                        <Run Text="%"/>
                                    </TextBlock>

                                    <Slider x:Name="OffsetXSlider" Template="{StaticResource SliderTemplatePM}" Value="{Binding CameraOffsetX}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" SmallChange="0.02" Minimum="-2" Maximum="2">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="ValueChanged">
                                                <b:InvokeCommandAction Command="{Binding UpdateCameraOffset}"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                            </ContentControl>

                            <!-- OFFSET Y CONTROL -->
                            <ContentControl Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='h825a040ag9824g4974g8ad3g94e89e7da7e8', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>
                                    <TextBlock Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                                         <Run>
                                             <Run.Text>
                                                <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                    <Binding Path="Value" ElementName="OffsetYSlider"/>
                                                    <Binding Source="50"/>
                                                </MultiBinding>
                                             </Run.Text>
                                            </Run>
                                        <Run Text="%"/>
                                    </TextBlock>

                                    <Slider x:Name="OffsetYSlider" Template="{StaticResource SliderTemplatePM}" Value="{Binding CameraOffsetY}" HorizontalAlignment="Center" VerticalAlignment="Center" SmallChange="0.02" Margin="10,0,0,0" Minimum="-2" Maximum="2">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="ValueChanged">
                                                <b:InvokeCommandAction Command="{Binding UpdateCameraOffset}"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                            </ContentControl>

                            <!-- OFFSET Z CONTROL -->
                            <ContentControl Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='h41b2ace0g354fg42c3g8c65g48cfe625d525', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>
                                    <TextBlock Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                                        <Run>
                                            <Run.Text>
                                                <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                    <Binding Path="Value" ElementName="OffsetZSlider"/>
                                                    <Binding Source="50"/>
                                                </MultiBinding>
                                            </Run.Text>
                                        </Run>
                                        <Run Text="%"/>
                                    </TextBlock>

                                    <Slider x:Name="OffsetZSlider" Template="{StaticResource SliderTemplatePM}" Value="{Binding CameraOffsetZ}" HorizontalAlignment="Center" VerticalAlignment="Center" SmallChange="0.02" Margin="10,0,0,0" Minimum="-2" Maximum="2">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="ValueChanged">
                                                <b:InvokeCommandAction Command="{Binding UpdateCameraOffset}"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                            </ContentControl>

                            <!-- RETICULE CONTROL -->
                            <ContentControl x:Name="ReticuleToggle" Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSToggleButton x:Name="ReticuleToggleLeft" IsChecked="{Binding ReticleVisibility}" BoundEvent="UILeft" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSToggleButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSToggleButton.RenderTransform>
                                    </ls:LSToggleButton>
                                    <ls:LSToggleButton x:Name="ReticuleToggleRight" IsChecked="{Binding ReticleVisibility}" BoundEvent="UIRight" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='hd125032eg9598g4766g900ag191ab0cfdab6', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>

                                    <TextBlock x:Name="ReticleVisibilityText" Text="{Binding Source='h1bfe4972g2615g4418g8ac3gdc35eddc8c15', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Bottom"/>

                                    <Control HorizontalAlignment="Center" Template="{StaticResource DashLineCheckbox}" DataContext="{Binding ReticleVisibility}"/>
                                </DockPanel>
                            </ContentControl>

                            <!-- GRID CONTROL -->
                            <ContentControl x:Name="CompositionGridToggle" Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSToggleButton x:Name="CompositionGridToggleLeft" IsChecked="{Binding GridVisibility}" BoundEvent="UILeft" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSToggleButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSToggleButton.RenderTransform>
                                    </ls:LSToggleButton>
                                    <ls:LSToggleButton x:Name="CompositionGridToggleRight" IsChecked="{Binding GridVisibility}" BoundEvent="UIRight" Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='ha4548c3eg1e2ag4bd4gbb39geb6d87b9bb4f', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>

                                    <TextBlock x:Name="GridVisibilityText" Text="{Binding Source='h1bfe4972g2615g4418g8ac3gdc35eddc8c15', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Bottom"/>

                                    <Control HorizontalAlignment="Center" Template="{StaticResource DashLineCheckbox}" DataContext="{Binding GridVisibility}"/>
                                </DockPanel>
                            </ContentControl>

                            <!-- RESTORE CAMERA BUTTON -->
                            <ContentControl x:Name="RestoreCameraButton" Style="{StaticResource FocusableContentControlStyle}" Margin="0,0,0,56" Content="{Binding }">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <ls:LSButton BoundEvent="UIAccept">
                                            <b:Interaction.Triggers>
                                                <b:EventTrigger EventName="Click">
                                                    <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="Tilt" Value="0"/>
                                                    <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="CameraOffsetX" Value="0"/>
                                                    <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="CameraOffsetY" Value="0"/>
                                                    <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="CameraOffsetZ" Value="0"/>
                                                    <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="TrackCharacter" Value="False"/>
                                                    <b:InvokeCommandAction Command="{Binding UpdateCameraTracking}"/>
                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Source='h25d571f7g0b5fg4c8agb2f9g6b3aab5225ce', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                                <Control x:Name="img" DataContext="{Binding DataContext.CurrentPlayer.UIData.InputEvents, ElementName=PhotoMode_c, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}" Template="{StaticResource ControllerButton.ImageSwitcher}" Width="{DynamicResource ScaledControllerHintSize}" Height="{DynamicResource ScaledControllerHintSize}" VerticalAlignment="Center" VerticalContentAlignment="Center" Opacity="0.05"/>
                                            </StackPanel>
                                        </ls:LSButton>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Path=(ls:MoveFocus.IsFocused), ElementName=RestoreCameraButton}" Value="True">
                                                <Setter TargetName="img" Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </StackPanel>
                    </TabItem>

                    <!--Lens Tab-->
                    <TabItem x:Name="LensTab">
                        <TabItem.Header>
                            <ContentControl>
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <Image x:Name="HeaderImage" Source="{StaticResource LensIconDefaultController}" Stretch="None"/>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Path=IsSelected,  RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                                                <Setter TargetName="HeaderImage" Property="Source" Value="{StaticResource LensIconHighlightController}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </TabItem.Header>
                        <StackPanel>
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="Loaded">
                                    <ls:SetMoveFocusAction TargetName="PhotoMode_c"/>
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                            <TextBlock Text="{Binding Source='hcd9a6f69g9cb1g4e9fg9c2ag409b9f60785f', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleLabelStyle}"/>

                            <!-- FIELD OF VIEW CONTROL -->
                            <ContentControl x:Name="FieldOfViewSlider" Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

                                    <TextBlock Text="{Binding Source='h840ea402gd31dg469dg98d4g29227e4faa24', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextOptionStyle}" VerticalAlignment="Top" HorizontalAlignment="Center" DockPanel.Dock="Top"/>
                                    <TextBlock Style="{StaticResource LabelTextOptionStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                                        <Run>
                                            <Run.Text>
                                                <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                    <Binding Path="Value" ElementName="FoVSlider"/>
                                                    <Binding Source="57.2958"/>
                                                </MultiBinding>
                                            </Run.Text>
                                        </Run>
                                        <Run Text="º"/>
                                    </TextBlock>
                                    <Slider x:Name="FoVSlider"  Template="{StaticResource SliderTemplatePM}" Value="{Binding FieldOfView}" SmallChange="{StaticResource DegreeInRadians}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0"  Minimum="0.1" Maximum="2">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="ValueChanged">
                                                <b:InvokeCommandAction Command="{Binding UpdateFoV}"/>
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                            </ContentControl>

                            <!-- EXPOSURE CONTROL -->
                            <ContentControl x:Name="ExposureSlider" Style="{StaticResource FocusableContentControlStyle}" Margin="{StaticResource PhotoListPadding}">
                                <DockPanel Height="180">
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Left" RenderTransformOrigin="0.5,0.5">
                                        <ls:LSRepeatButton.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </ls:LSRepeatButton.RenderTransform>
                                    </ls:LSRepeatButton>
                                    <ls:LSRepeatButton Style="{StaticResource IconCarouselButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" EatInput="False" DockPanel.Dock="Right"/>

