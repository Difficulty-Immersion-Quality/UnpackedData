<ls:UIWidget x:Name="ModioSignIn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             ContextName="ModioSignIn"
             d:DataContext="{d:DesignInstance {x:Type ls:DCModioSignIn}, IsDesignTimeCreatable=True}"
             d:DesignWidth="3840" d:DesignHeight="2160"
             FocusDown="UIDown" FocusLeft="UILeft" FocusRight="UIRight" FocusUp="UIUp" ls:MoveFocus.FocusMovementMode="Closest" CanCacheFocusSurroundingElements="False">

    <ls:UIWidget.Template>
        <ControlTemplate>
            <ControlTemplate.Resources>
                <System:Double x:Key="SplashContentWidth">1140</System:Double>
                <Style TargetType="TextBlock" BasedOn="{StaticResource BaseTextStyle}">
                    <Setter Property="FontSize" Value="{StaticResource ScaledDefaultFontSize}"/>
                    <Setter Property="Foreground" Value="{StaticResource LS_accent75TxtColor}" />
                </Style>

                <ControlTemplate x:Key="ModioSignInTemplate">
                    <DockPanel x:Name="rootPanel">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="Loaded">
                                <ls:SetMoveFocusAction TargetName="ModioSignIn" FocusElement="{Binding ElementName=ModioCheck}"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>

                        <!-- title -->
                        <TextBlock x:Name="Title" Text="{Binding Source='h2fa22eb7g9c8eg4ba4g9054g9b04840734e1',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_tint100}" FontSize="{StaticResource MassiveFontSize}" TextAlignment="Center" HorizontalAlignment="Center" DockPanel.Dock="Top"/>

                        <TextBlock x:Name="FailedAuthenticationError" Width="2000" Height="200" DockPanel.Dock="Bottom" Margin="0,50,0,-250" Foreground="{StaticResource LS_alertTxtColor}" Text="{Binding Source='h5362fb3fg10a1g46a0gb3a0ga40a09944e83',Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Opacity="0"/>

                        <DockPanel Margin="0,40,0,0">
                            <TextBlock x:Name="Description"  ls:TextBlockFormatter.SourceText="{Binding Source='hc0cef6ceg9ecbg4949g9ad7gf681804c8651',Converter={StaticResource TranslatedStringConverter}}" DockPanel.Dock="Top" Margin="240,0" TextWrapping="Wrap"/>

                            <ls:LSNineSliceImage Style="{StaticResource DecorativePanelDividerNineSlice}" Width="1600" Height="96" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0"/>

                            <DockPanel HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="240,0">
                                <Image DockPanel.Dock="Left" x:Name="modioIcon" Source="{StaticResource modioIcon}" VerticalAlignment="Top" Stretch="None" Margin="0,10,0,0"/>
                                <TextBlock x:Name="ModIoAccountMessage" Margin="20,0,0,0" ls:TextBlockFormatter.SourceText="{Binding Source='h96d90910gc334g46bbg99f4gef8bbd1ee8d1',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap"/>
                            </DockPanel>

                            <ls:LSNineSliceImage Style="{StaticResource DecorativePanelDividerNineSlice}" Width="1600" Height="96" HorizontalAlignment="Center" RenderTransformOrigin="0.5, 0.5" DockPanel.Dock="Top" Margin="0">
                                <ls:LSNineSliceImage.RenderTransform>
                                    <RotateTransform Angle="180"/>
                                </ls:LSNineSliceImage.RenderTransform>
                            </ls:LSNineSliceImage>

                            <DockPanel HorizontalAlignment="Center" Margin="0,20,0,20" DockPanel.Dock="Top">
                                <Image x:Name="generalWarningIcon" DockPanel.Dock="Left" Source="{StaticResource c_generalWarningIcon}" VerticalAlignment="Top" Stretch="None" Margin="0,3,2,0"/>
                                <TextBlock x:Name="CompatibilityWarning" DockPanel.Dock="Left" Margin="5,0,0,0" FontStyle ="Italic" Text="{Binding Source='h11329411g4346g409aga3e0gb40e574de386',Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap"/>
                            </DockPanel>

                            <Grid x:Name="LegalButtons" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="30,10" DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ls:LSButton x:Name="ModioPrivacyBtn"
                                             Grid.Column="0"
                                             Style="{StaticResource FocusableButtonStyle}"
                                             Margin="10"
                                             VerticalAlignment="Top"
                                             Command="{Binding OpenURLInBrowserCommand}"
                                             CommandParameter="ModioPrivacy"
                                             Content="{Binding Source='h37fe6089g9c14g46f8g8b9bg897e659e596d',Converter={StaticResource TranslatedStringConverter}}"/>
                                <ls:LSButton x:Name="ModioToSBtn"
                                             Grid.Column="1"
                                             Style="{StaticResource FocusableButtonStyle}"
                                             Margin="10"
                                             VerticalAlignment="Top"
                                             Command="{Binding OpenURLInBrowserCommand}"
                                             CommandParameter="ModioToS"
                                             Content="{Binding Source='h3ca07309gfeccg4089gbec6g28b5b1af0358',Converter={StaticResource TranslatedStringConverter}}"/>
                            </Grid>

                            <ls:LSCheckBox x:Name="ModioCheck" Style="{StaticResource DefaultSimpleCheckBoxStyle}" 
                                           Margin="40,12" DockPanel.Dock="Top" Height="140"
                                           IsChecked="{Binding ModioCheck}" 
                                           Command="{Binding ToggleModioCheck}" 
                                           Content="{Binding Source='h9b70f042g9450g46ffg9e48g2b81ce752690',Converter={StaticResource TranslatedStringConverter}}"/>
                            <Grid Height="192">
                                <Control x:Name="waitingSpinner" HorizontalAlignment="Center" VerticalAlignment="Center" Template="{StaticResource WaitingSpinnerTemplate}" Visibility="Collapsed"/>
                                
                                <ls:LSButton x:Name="SignInModioBtn" Style="{StaticResource FocusableButtonStyle}" 
                                             Width="1140" VerticalAlignment="Center"
                                             Command="{Binding SignInModio}" IsEnabled="False" Opacity="{StaticResource DisabledOpacity}"
                                             Content="{Binding Source='h3e1b8237g8c6bg476ag95a2g97e9187b9eab',Converter={StaticResource TranslatedStringConverter}}"/>
                            </Grid>
                        </DockPanel>
                    </DockPanel>
                    <ControlTemplate.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ModioCheck}" Value="True"/>
                                <Condition Binding="{Binding AuthenticationState}" Value="NotAuthenticated"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="SignInModioBtn" Property="IsEnabled" Value="True"/>
                            <Setter TargetName="SignInModioBtn" Property="Opacity" Value="1"/>
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticationRequested">
                            <Setter TargetName="ModioCheck" Property="IsEnabled" Value="False"/>
                            <Setter TargetName="SignInModioBtn" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="waitingSpinner" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="rootPanel" Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticatedSuccesfully">
                            <Setter TargetName="SignInModioBtn" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticationFailed">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FailedAuthenticationError" Storyboard.TargetProperty="Opacity">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:5.7" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:6" Value="0"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <Setter TargetName="SignInModioBtn" Property="IsEnabled" Value="True"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

                <ControlTemplate x:Key="ModioSignInSuccessful">
                    <Grid Margin="100,22">
                        <TextBlock x:Name="Title" VerticalAlignment="Top" HorizontalAlignment="Center"  Text="{Binding Source='h2fa22eb7g9c8eg4ba4g9054g9b04840734e1',Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource LS_tint100}" FontSize="{StaticResource MassiveFontSize}" Margin="0,0,0,0"/>

                        <TextBlock x:Name="Description" VerticalAlignment="Top" HorizontalAlignment="Center" Text="{Binding Source='h0ea4a6aag4866g4f57g912agdd2d1e8f912a',Converter={StaticResource TranslatedStringConverter}}" Margin="0,200,0,0" />
                    </Grid>
                </ControlTemplate>
            </ControlTemplate.Resources>
            <Grid Background="{StaticResource LS_PanelBackground}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                <ls:LSNineSliceImage Style="{StaticResource GenericControllerPanelBackground}" Margin="0,-150" Width="1920" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,340,0,320">
                    <Control x:Name="ModioSignInContent" Template="{StaticResource ModioSignInTemplate}"/>
                </ls:LSNineSliceImage>

                <!-- buttons -->
                <StackPanel Style="{StaticResource ButtonHint.Container.Center}" >
                    <ls:LSButton x:Name="AcceptButton"
                                Tag="{Binding Source='hd0c08193ga7f2g4a7eg8225g63748c7b3096', Converter={StaticResource TranslatedStringConverter}}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 ContentTemplate="{StaticResource ControllerButtonHint}"
                                 BoundEvent="UIAccept"
                                 Command="{Binding Path=FocusedElement.Command ,ElementName=ModioSignIn}"
                                 CommandParameter="{Binding Path=FocusedElement.CommandParameter ,ElementName=ModioSignIn}"/>
                    <ls:LSButton x:Name="CloseButton"
                                Tag="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7', Converter={StaticResource TranslatedStringConverter}}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UICancel'}"
                                 ContentTemplate="{StaticResource ControllerButtonHint}"
                                 BoundEvent="UICancel"
                                 Command="{Binding CustomEvent}"
                                 CommandParameter="CloseWidget"/>
                    <ls:LSButton x:Name="FinishButton"
                                 Tag="{Binding Source='hce6efd68gaa45g4da2gaf87g58a6d03bb3f7', Converter={StaticResource TranslatedStringConverter}}"
                                 Content="{Binding CurrentPlayer.UIData.InputEvents, Converter={StaticResource FindInputEventConverter}, ConverterParameter='UIAccept'}"
                                 ContentTemplate="{StaticResource ControllerButtonHint}"
                                 BoundEvent="UIAccept"
                                 Command="{Binding CustomEvent}"
                                 CommandParameter="CloseWidget"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </Grid>

            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticatedSuccessfully">
                    <Setter TargetName="AcceptButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CloseButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="FinishButton" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ModioSignInContent" Property="Template" Value="{StaticResource ModioSignInSuccessful}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding AuthenticationState}" Value="AuthenticationRequested">
                    <Setter TargetName="AcceptButton" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>
</ls:UIWidget>