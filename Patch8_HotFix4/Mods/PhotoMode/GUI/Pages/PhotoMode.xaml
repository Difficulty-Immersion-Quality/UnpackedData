<ls:UIWidget x:Name="PhotoMode"
             ContextName="PhotoMode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance {x:Type ls:DCPhotoMode}, IsDesignTimeCreatable=True}"
             xmlns:ls="clr-namespace:ls;assembly=Code">
    <ls:UIWidget.Template>
        <ControlTemplate>
            <ControlTemplate.Resources>
                <System:Double x:Key="RowMinHeight">88</System:Double >
                <GridLength x:Key="ColumnWidth">120</GridLength>
            </ControlTemplate.Resources>
            <Grid x:Name="PhotoModeRoot">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="Loaded">
                        <b:InvokeCommandAction Command="{Binding ToggleUICameraControl}" CommandParameter="{Binding PhotoPreviewOn, Converter={StaticResource InvertBoolConverter}}"/>
                    </b:EventTrigger>
                    <b:DataTrigger Binding="{Binding PhotoStatus}" Value="Prepared">
                        <b:InvokeCommandAction Command="{Binding TakePhoto}"/>
                    </b:DataTrigger>
                    <b:DataTrigger Binding="{Binding PhotoResult}" Value="Success">
                        <ls:LSPlaySound Sound="PhotoMode_UI_Shared_Photo" />
                    </b:DataTrigger>
                </b:Interaction.Triggers>

                <!-- BARS -->
                <Control x:Name="BarsControl" Template="{StaticResource DecorBarTemplate}"/>

                <!-- FRAMES -->
                <ls:LSNineSliceImage x:Name="PhotoModeFrame" IsHitTestVisible="False" Opacity="{Binding SelectedDecorFrameOpacity}" Visibility="{Binding SelectedDecorFrame.FrameImageName, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter='EmptyString'}" Style="{StaticResource PhotoModeFrameStyle}"/>

                <!-- STICKERS  -->
                <ItemsControl x:Name="CurrentStickersCollection" ItemsSource="{Binding CurrentStickers}" ItemTemplate="{StaticResource StickerTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Opacity" Value="{Binding Opacity}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ls:LSButton x:Name="CloseBtn" Margin="0,20,20,0" Style="{StaticResource CloseButton}" SoundID="UI_Shared_Cancel" HorizontalAlignment="Right" VerticalAlignment="Top"
                             Command="{Binding TogglePhotoModeCommand}" CommandParameter="{StaticResource FalseValue}"
                             IsEnabled="{Binding CurrentPlayer.IsHost}"
                             ToolTipService.ShowOnDisabled="True"
                             ToolTipService.Placement="Left"
                             ToolTipService.IsEnabled="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={StaticResource InvertBoolConverter}}">
                    <ls:LSButton.ToolTip>
                        <ls:LSTooltip>
                            <TextBlock Text="{Binding Source='hef0689f9gb8c4g4e22g8637g60eb6c6b3750', Converter={StaticResource TranslatedStringConverter}}" Foreground="{StaticResource TooltipColor.Primary}"/>
                        </ls:LSTooltip>
                    </ls:LSButton.ToolTip>
                </ls:LSButton>
                
                <Control x:Name="ReticleGrid" Template="{StaticResource ReticleGridTemplate}" Visibility="{Binding ReticleVisibility, Converter={StaticResource BoolToVisibleConverter}}"/>

                <Path x:Name="CompositionGrid" StrokeThickness="2" StrokeDashArray="2,16" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Fill" Visibility="{Binding GridVisibility, Converter={StaticResource BoolToVisibleConverter}}" Data="{StaticResource GridGeometry}">
                    <Path.Stroke>
                        <RadialGradientBrush>
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="White" Offset="0.9"/>
                            <GradientStop Color="#A0FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Path.Stroke>
                </Path>

                <ls:LSInputBinding x:Name="UITogglePhotoMode" BoundEvent="UITogglePhotoMode" Command="{Binding TogglePhotoModeCommand}" CommandParameter="{StaticResource FalseValue}" EatInput="True"/>

                <ls:LSToggleButton x:Name="TogglePhotoPreviewButton" BoundEvent="UITogglePhotoPreview" Margin="100,0,0,170" VerticalAlignment="Bottom" HorizontalAlignment="Left" EatInput="True" Content="{Binding CurrentPlayer.UIData.InputEvents, ConverterParameter=UITogglePhotoPreview, Converter={StaticResource FindInputEventConverter}}" Command="{Binding ToggleUICameraControl}" CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}, Converter={StaticResource InvertBoolConverter}}" IsChecked="{Binding PhotoPreviewOn}">
                    <ls:LSToggleButton.ContentTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Background="#AF000000" CornerRadius="5" BorderBrush="Black" >
                                    <Border.Effect>
                                        <BlurEffect Radius="40"/>
                                    </Border.Effect>
                                </Border>
                                <TextBlock Effect="{StaticResource ShadowEffect}" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0">
								<Run Text="["/>
								<Run
                      Text="{Binding Shortcut}" Foreground="{StaticResource TooltipColor.Secondary}"/>
								<Run
                    Text="] "/>
								<Run
					    Text="{Binding Caption}"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ls:LSToggleButton.ContentTemplate>
                </ls:LSToggleButton>

                <ls:LSButton x:Name="TakePhotoButton" BoundEvent="UIPhotoModeTakePicture" Margin="0,0,0,170" VerticalAlignment="Bottom" HorizontalAlignment="Center" Command="{Binding RequestPhoto}">
                    <ls:LSButton.Template>
                        <ControlTemplate>
                            <Grid>
                                <Border Background="#AF000000" CornerRadius="5" BorderBrush="Black" >
                                    <Border.Effect>
                                        <BlurEffect Radius="40"/>
                                    </Border.Effect>
                                </Border>
                                <DockPanel Margin="20,10">
                                    <ls:LSNineSliceImage DockPanel.Dock="Left" Style="{StaticResource ButtonPromptBG}" Padding="30,10">
                                        <TextBlock Text="{Binding Source='hac26f85dg8815g4309g8764g37182c71c9be', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource LabelTextStyle}" FontSize="{StaticResource ScaledTinyFontSize}"/>
                                    </ls:LSNineSliceImage>
                                    <TextBlock Text="{Binding Source='h079597acg5ff1g4e57g90efgc173ba703607', Converter={StaticResource TranslatedStringConverter}}" DockPanel.Dock="Left" Effect="{StaticResource ShadowEffect}" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center" Margin="5,0"/>
                                </DockPanel>
                            </Grid>
                        </ControlTemplate>
                    </ls:LSButton.Template>
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="Click">
                            <ls:LSPlaySound Sound="PhotoMode_Snap"/>
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </ls:LSButton>

                <Grid x:Name="SteamDeckInstructions"  HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="Collapsed" Margin="0,0,0,250" MaxWidth="1000">
                    <Border Background="#AF000000" CornerRadius="5" BorderBrush="Black">
                        <Border.Effect>
                            <BlurEffect Radius="40"/>
                        </Border.Effect>
                    </Border>
                    <TextBlock Text="{Binding Source=h236d5aa6gae2bg4789ga5ecgaddf29234999, Converter={StaticResource TranslatedStringConverter}}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"  Style="{StaticResource TitleTextStyle}" Effect="{StaticResource ShadowEffect}" Margin="40,0"/>
                </Grid>

                <ls:LSInputBinding x:Name="BlockInputWhileTakingPhoto" AnyClick="True" AnyKey="True" EatInput="True" IsEnabled="False"/>

                <Canvas x:Name="PhotoModePanelArea">

                    <TabControl x:Name="PhotoModePanel" Style="{StaticResource PhotoModeTabPanel}" Canvas.Top="100" Canvas.Right="100">

                        <!--===== CAMERA TAB =====-->
                        <TabItem x:Name="CameraTab">
                            <TabItem.Header>
                                <Image Source="{StaticResource CameraIconDefault}" Stretch="None"/>
                            </TabItem.Header>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <ls:LSButton x:Name="RestoreCameraButton" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource RestoreButtonStyle}" Visibility="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={StaticResource BoolToVisibleConverter}}" ToolTipService.Placement="Right" ToolTipService.VerticalOffset="-36" ToolTipService.HorizontalOffset="20">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Click">
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="Tilt" Value="0"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="CameraOffsetX" Value="0"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="CameraOffsetY" Value="0"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="CameraOffsetZ" Value="0"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="TrackCharacter" Value="False"/>
                                            <b:InvokeCommandAction Command="{Binding UpdateCameraTracking}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <ls:LSButton.ToolTip>
                                        <ls:LSTooltip Content="{Binding Source='h25d571f7g0b5fg4c8agb2f9g6b3aab5225ce',Converter={StaticResource TranslatedStringConverter}}"/>
                                    </ls:LSButton.ToolTip>
                                </ls:LSButton>
                                <TextBlock Grid.Row="0" Text="{Binding Source='h7d4cf1a3g7ea0g407ag984ag31d7803d1f97', Converter={StaticResource TranslatedStringConverter}}" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Top" HorizontalAlignment="Center"/>

                                <Grid Visibility="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={StaticResource BoolToVisibleConverter}}" Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="380"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="{StaticResource ColumnWidth}"/>
                                </Grid.ColumnDefinitions>
                                    
                                <!-- FOCUS CHARACTER -->
                                <TextBlock Text="{Binding Source='h42540f79gf986g4fb8g8316gb716a6917b23', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                <ls:LSComboBox x:Name="FocusedCharactersListBox"
                                               Grid.Row="0" Grid.Column="1"
                                               ItemsSource="{Binding ActorSettings, Mode=OneWay}"
                                               SelectedItem="{Binding TrackedActor}"
                                               Foreground="{StaticResource LS_specialTxtColor}" 
                                               Style="{StaticResource PhotoModeComboBoxStyle}"                                               
                                               Text="{Binding SelectedItem.Actor.Name, Mode=OneWay, RelativeSource={RelativeSource Mode=Self}}">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="SelectionChanged">
                                            <b:InvokeCommandAction Command="{Binding UpdateCameraTracking}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <ls:LSComboBox.ItemContainerStyle>
                                        <Style BasedOn="{StaticResource PhotoModeComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ActorSettingsNameTextBlockTemplate}"/>
                                        </Style>
                                    </ls:LSComboBox.ItemContainerStyle>
                                </ls:LSComboBox>
                                <!-- track character -->
                                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Margin="40,0,0,0">
                                    <Image Source="{StaticResource ChildIndicatorDecor}" VerticalAlignment="Center"/>
                                    <ls:LSCheckBox x:Name="TrackCharacterToggle" Style="{StaticResource PhotoModeTickBoxStyle}" IsChecked="{Binding TrackCharacter}" Command="{Binding UpdateCameraTracking}" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Source='hf5995e1egbf28g4ba0g9a72g503cd666c124', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="10,0"/>
                                    </ls:LSCheckBox>
                                </StackPanel>

                                <!-- CAMERA TILT -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Source='h7c2c1340g5a65g4bd6g9cf0gc5b7e682e1ce', Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                    <Slider x:Name="TiltSlider" Grid.Row="2" Grid.Column="1" Style="{StaticResource PhotoModeSliderCenterBarStyle}" Value="{Binding Tilt}"  HorizontalAlignment="Right" SmallChange="0.0174" LargeChange="0.0174" VerticalAlignment="Center"  Minimum="-3.14" Maximum="3.14">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="ValueChanged">
                                            <b:InvokeCommandAction Command="{Binding UpdateCameraTilt}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </Slider>
                                <TextBlock Grid.Row="2" Grid.Column="2" Width="{StaticResource ValueTextWidth}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}">
                                    <Run>
                                        <Run.Text>
                                            <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                <Binding Path="Value" ElementName="TiltSlider"/>
                                                <Binding Source="57.35"/>
                                            </MultiBinding>
                                        </Run.Text>
                                    </Run>
                                    <Run Text="°"/>
                                </TextBlock>

                                    <!-- CAMERA OFFSET -->
                                <TextBlock Text="{Binding Source='hae9d82aeg2efeg4754gb8b1g8e64ed7a3514', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="3" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                <!-- X axis -->
                                <TextBlock Text="{Binding Source='h57c7ff10g8af2g4e6ag8137gd2d9254b7b78', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="3" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource ValueTextStyle}"/>
                                    <Slider x:Name="CameraXSlider" Grid.Row="3" Grid.Column="1" Style="{StaticResource PhotoModeSliderCenterBarStyle}" Value="{Binding CameraOffsetX}" SmallChange="0.02" LargeChange="0.02" VerticalAlignment="Center" Minimum="-2" Maximum="2">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="ValueChanged">
                                            <b:InvokeCommandAction Command="{Binding UpdateCameraOffset}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </Slider>
                                <TextBlock Grid.Row="3" Grid.Column="2" Width="{StaticResource ValueTextWidth}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}">
                                    <Run>
                                        <Run.Text>
                                            <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                <Binding Path="Value" ElementName="CameraXSlider"/>
                                                <Binding Source="50"/>
                                            </MultiBinding>
                                        </Run.Text>
                                    </Run>
                                    <Run Text="%"/>
                                </TextBlock>
                                    <!-- Y axis -->
                                <TextBlock Text="{Binding Source='h93adf22agff23g4781gba07gc1e72eeda371', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="4" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource ValueTextStyle}"/>
                                <Slider x:Name="CameraYSlider" Grid.Row="4" Grid.Column="1" SmallChange="0.02" LargeChange="0.02" Style="{StaticResource PhotoModeSliderCenterBarStyle}"  Value="{Binding CameraOffsetY}" VerticalAlignment="Center" Minimum="-2" Maximum="2">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="ValueChanged">
                                            <b:InvokeCommandAction Command="{Binding UpdateCameraOffset}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </Slider>
                                <TextBlock Grid.Row="4" Grid.Column="2" Width="{StaticResource ValueTextWidth}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}">
                                    <Run>
                                        <Run.Text>
                                            <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                <Binding Path="Value" ElementName="CameraYSlider"/>
                                                <Binding Source="50"/>
                                            </MultiBinding>
                                        </Run.Text>
                                    </Run>
                                    <Run Text="%"/>
                                </TextBlock>
                                    <!-- Z axis -->
                                <TextBlock Text="{Binding Source='h646d5db9g5d75g4ec1gab2fg53e997e381b9', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="5" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource ValueTextStyle}"/>
                                <Slider x:Name="CameraZSlider" Grid.Row="5" Grid.Column="1" SmallChange="0.02" LargeChange="0.02" Style="{StaticResource PhotoModeSliderCenterBarStyle}"  Value="{Binding CameraOffsetZ}" VerticalAlignment="Center" Minimum="-2" Maximum="2">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="ValueChanged">
                                            <b:InvokeCommandAction Command="{Binding UpdateCameraOffset}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                </Slider>
                                <TextBlock Grid.Row="5" Grid.Column="2" Width="{StaticResource ValueTextWidth}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}">
                                    <Run>
                                        <Run.Text>
                                            <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                <Binding Path="Value" ElementName="CameraZSlider"/>
                                                <Binding Source="50"/>
                                            </MultiBinding>
                                        </Run.Text>
                                    </Run>
                                    <Run Text="%"/>
                                </TextBlock>

                                    <!-- CAMERA POSITION -->
                                <TextBlock Text="{Binding Source='h70cf89d9g4bd7g4c38g80ebgd94a93fc5d40', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="6" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" />
                                <!-- store -->
                                <ls:LSButton x:Name="SaveCameraTransform" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" Template="{StaticResource IconButtonTemplate}" Command="{Binding SaveCameraRecallTransform}">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Click">
                                            <b:ControlStoryboardAction ControlStoryboardOption="Play" Storyboard="{StaticResource StoreButtonFeedbackAnimation}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <ls:LSButton.Resources>
                                        <BitmapImage x:Key="ButtonNormal" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundDefault}}"/>
                                        <BitmapImage x:Key="ButtonHighlight" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundHighlight}}"/>
                                        <BitmapImage x:Key="ButtonPressed" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundPressed}}"/>
                                        <BitmapImage x:Key="ButtonDisabled" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundDisabled}}"/>

                                        <BitmapImage x:Key="IconNormal" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_store_d.png"/>
                                        <BitmapImage x:Key="IconHighlight" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_store_h.png"/>
                                        <BitmapImage x:Key="IconPressed" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_store_h.png"/>
                                        <BitmapImage x:Key="IconDisabled" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_store_d.png"/>

                                        <System:Double x:Key="IconWidth">40</System:Double>
                                        <System:Double x:Key="IconHeight">40</System:Double>
                                    </ls:LSButton.Resources>
                                </ls:LSButton>
                                <TextBlock Text="{Binding Source='h46434706g35c7g4f0eg85d3g5dad25920919', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="110,0,0,0" Style="{StaticResource LabelTextStyle}"/>
                                <!-- recall -->
                                <ls:LSButton x:Name="RecallCameraTransform" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left" Template="{StaticResource IconButtonTemplate}" Command="{Binding RecallCameraTransform}">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Click">
                                            <b:ControlStoryboardAction ControlStoryboardOption="Play" Storyboard="{StaticResource RecallButtonFeedbackAnimation}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <ls:LSButton.Resources>
                                        <BitmapImage x:Key="ButtonNormal" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundDefault}}"/>
                                        <BitmapImage x:Key="ButtonHighlight" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundHighlight}}"/>
                                        <BitmapImage x:Key="ButtonPressed" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundPressed}}"/>
                                        <BitmapImage x:Key="ButtonDisabled" UriSource="{Binding UriSource, Source={StaticResource TinyButtonBackgroundDisabled}}"/>

                                        <BitmapImage x:Key="IconNormal" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_reload_d.png"/>
                                        <BitmapImage x:Key="IconHighlight" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_reload_h.png"/>
                                        <BitmapImage x:Key="IconPressed" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_reload_h.png"/>
                                        <BitmapImage x:Key="IconDisabled" UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_reload_d.png"/>

                                        <System:Double x:Key="IconWidth">40</System:Double>
                                        <System:Double x:Key="IconHeight">40</System:Double>
                                    </ls:LSButton.Resources>
                                </ls:LSButton>
                                <TextBlock Text="{Binding Source='hf8e212eag19dcg4c0bg9a77g572ad4c69501', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="110,0,0,0" Style="{StaticResource LabelTextStyle}"/>

                                <ls:LSCheckBox x:Name="ReticleToggle" Style="{StaticResource PhotoModeTickBoxStyle}" IsChecked="{Binding ReticleVisibility}" HorizontalAlignment="Left" Grid.Row="8" Grid.Column="0">
                                    <TextBlock Text="{Binding Source='h2f49a389gaf52g46d2g8cc1g325d8f6612ae', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="10,0,0,0"/>
                                </ls:LSCheckBox>
                                <ls:LSCheckBox x:Name="CompositionGridToggle" Style="{StaticResource PhotoModeTickBoxStyle}" IsChecked="{Binding GridVisibility}" HorizontalAlignment="Left" Grid.Row="8" Grid.Column="1">
                                    <TextBlock Text="{Binding Source='h4ec3e76dga8abg48fbg9e7egff56ccda0c9e', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="10,0,0,0"/>
                                </ls:LSCheckBox>
                            </Grid>
                            </Grid>
                        </TabItem>

                        <!--===== LENS TAB =====-->
                        <TabItem x:Name="LensTab">
                            <TabItem.Header>
                                <Image Source="{StaticResource LensIconDefault}" Stretch="None"/>
                            </TabItem.Header>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <ls:LSButton Grid.Row="0" x:Name="RestoreLensButton" Style="{StaticResource RestoreButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={StaticResource BoolToVisibleConverter}}" ToolTipService.Placement="Right" ToolTipService.VerticalOffset="-36" ToolTipService.HorizontalOffset="20">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Click">
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="FieldOfView" Value="{Binding DefaultFieldOfView}"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="Exposure" Value="{Binding DefaultExposure}"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="DOFDistance" Value="{Binding DefaultDOFDistance}"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="DOFStrength" Value="{Binding DefaultDOFStrength}"/>
                                            <b:ChangePropertyAction TargetObject="{Binding .}" PropertyName="DepthOfField" Value="{Binding DefaultDOFEnabled}"/>
                                            <b:ChangePropertyAction TargetName="SelectedDOFTypeComboBox" PropertyName="SelectedIndex" Value="0"/>
                                            <b:InvokeCommandAction Command="{Binding UpdateFoV}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <ls:LSButton.ToolTip>
                                        <ls:LSTooltip Content="{Binding Source='h25d571f7g0b5fg4c8agb2f9g6b3aab5225ce',Converter={StaticResource TranslatedStringConverter}}"/>
                                    </ls:LSButton.ToolTip>
                                </ls:LSButton>
                                <TextBlock Grid.Row="0" Text="{Binding Source='h0543a4afgb815g46e2g96a8g247986435e20', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Top" HorizontalAlignment="Center" Style="{StaticResource TitleTextStyle}"/>

                                <Grid Grid.Row="1" Visibility="{Binding IsEnabled, RelativeSource={RelativeSource Self}, Converter={StaticResource BoolToVisibleConverter} }">
                                    <Grid.RowDefinitions>
                                        <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                        <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                        <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                        <RowDefinition MinHeight="{StaticResource RowMinHeight}" Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="380"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="{StaticResource ColumnWidth}"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- FIELD OF VIEW -->
                                    <TextBlock Text="{Binding Source='h840ea402gd31dg469dg98d4g29227e4faa24', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource LabelTextStyle}"/>
