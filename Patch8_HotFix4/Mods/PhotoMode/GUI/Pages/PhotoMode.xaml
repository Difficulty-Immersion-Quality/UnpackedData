                                                        <Slider x:Name="CharRotationSlider" Style="{StaticResource PhotoModeSliderCenterBarStyle}" Value="{Binding CharacterRotation}" SmallChange="0.0174" LargeChange="0.0174" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" Minimum="-3.14" Maximum="3.14">
