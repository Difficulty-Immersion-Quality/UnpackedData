                                                        <TextBlock Text="{Binding Source='h66cf3a33g1521g4ae1g9dacg9a3418162fb1', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left" Style="{StaticResource LabelTextStyle}" Margin="20,20,0,0"/>
