                                                            <Run>
                                                                <Run.Text>
                                                                    <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                                        <Binding Path="Value" ElementName="CharOffsetZSlider"/>
                                                                        <Binding Source="50"/>
                                                                    </MultiBinding>
