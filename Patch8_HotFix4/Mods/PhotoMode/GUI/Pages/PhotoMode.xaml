                                                        <b:ChangePropertyAction TargetName="StickerPanel" PropertyName="Visibility" Value="Collapsed"/>
                                                    </b:EventTrigger>
                                                </b:Interaction.Triggers>
                                            </ls:LSButton>
                                            <ListBox x:Name="StickerListbox" Grid.Row="1" ItemsSource="{Binding AvailableStickers, Mode=OneWay}" SelectedIndex="0" Margin="30,0" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <ls:LSGrid Columns="5" AutoIndex="True" CellWidth="200" CellHeight="200"/>
                                                    </ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="StickerRoot" Margin="30">
                                                            <Border.ToolTip>
                                                                <ls:LSTooltip Content="{Binding DataContext.DisplayName, ElementName=StickerRoot}"/>
                                                            </Border.ToolTip>
                                                            <Image x:Name="StickerImage" Stretch="Uniform">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource IconIdToSourceConverter}" >
                                                                        <Binding Source="Assets/Stickers/Preview/"/>
                                                                        <Binding Path="StickerImageName"/>
