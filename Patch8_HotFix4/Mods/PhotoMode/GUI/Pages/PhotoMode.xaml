                                                        <TextBlock Text="{Binding CharacterRotation, Converter={StaticResource MultiplierConverter}, ConverterParameter=57.33, StringFormat={}{0:F0}° }" Width="{StaticResource ValueTextWidth}" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}">
                                                            <Run>
                                                                <Run.Text>
                                                                    <MultiBinding Converter="{StaticResource MultiplierMultiConverter}" >
                                                                        <Binding Path="Value" ElementName="CharRotationSlider"/>
                                                                        <Binding Source="57.33"/>
