                <Control x:Name="PhotoModeNotificationControl" VerticalAlignment="Top" HorizontalAlignment="Center" Visibility="Collapsed" Opacity="0" Margin="0,200,0,0" IsHitTestVisible="False" Template="{StaticResource PhotoModeNotificationTemplate}"/>

                <Border x:Name="PhotoFlash" Background="White" Opacity="0" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False"/>
            </Grid>

            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding PhotoResult}" Value="Success">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInPhotoModeNotification}"/>
                        <BeginStoryboard Storyboard="{StaticResource PhotoModeFlashStoryboard}"/>
                    </DataTrigger.EnterActions>
                    <Setter TargetName="PhotoModeNotificationControl" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding PhotoResult}" Value="Failure">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInPhotoModeNotification}"/>
                    </DataTrigger.EnterActions>
                    <Setter TargetName="PhotoModeNotificationControl" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsSteamDeck}" Value="True">
                    <Setter TargetName="TakePhotoButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SteamDeckInstructions" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding PhotoResult}" Value="None">
                    <Setter TargetName="PhotoModeNotificationControl" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
        
                <DataTrigger Binding="{Binding PhotoPreviewOn}" Value="True">
                    <Setter TargetName="ReticleGrid" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CompositionGrid" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PhotoModePanelArea" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CloseBtn" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TakePhotoButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SteamDeckInstructions" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TogglePhotoPreviewButton" Property="Opacity" Value="0"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPlayer.SelectedCharacter.CharacterMode}" Value="InDialogue">
                    <Setter TargetName="CameraTab" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ActorTab" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="LensTab" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PhotoModePanel" Property="SelectedIndex" Value="3"/>
                </DataTrigger>
                
                <DataTrigger Binding="{Binding PhotoStatus}" Value="Prepared">
                    <Setter TargetName="ReticleGrid" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CompositionGrid" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PhotoModePanelArea" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CloseBtn" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TakePhotoButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PhotoModeNotificationControl" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TogglePhotoPreviewButton" Property="Opacity" Value="0"/>
                    <Setter TargetName="BlockInputWhileTakingPhoto" Property="IsEnabled" Value="True"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding PhotoStatus}" Value="Requested">
                    <Setter TargetName="ReticleGrid" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CompositionGrid" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PhotoModePanelArea" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="CloseBtn" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TakePhotoButton" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="PhotoModeNotificationControl" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TogglePhotoPreviewButton" Property="Opacity" Value="0"/>
                    <Setter TargetName="BlockInputWhileTakingPhoto" Property="IsEnabled" Value="True"/>
                </DataTrigger>

				<!--Disable all fields of DoF while DoF is disabled-->
				<DataTrigger Binding="{Binding DepthOfField}" Value="False">
					<Setter TargetName="DoFSettings" Property="IsEnabled" Value="False"/>
				</DataTrigger>

                <!--Depth of Field focus mode disabling elements that can't be changed-->
                <DataTrigger Binding="{Binding SelectedDOFFocusType}" Value="Manual">
                    <Setter TargetName="FocusActorComboBox" Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedDOFFocusType}" Value="Automatic">
                    <Setter TargetName="DOFDistance" Property="IsEnabled" Value="False"/>
                </DataTrigger>

                <!--Disable all fields that are not modifiable during a timeline-->
				<DataTrigger Binding="{Binding Mode}" Value ="Timeline">
					<!--Disable all the Camera Settings Tab-->
					<Setter TargetName="FocusedCharactersListBox" Property="IsEnabled" Value="False"/>
					<Setter TargetName="TrackCharacterToggle" Property="IsEnabled" Value="False"/>
					<Setter TargetName="TiltSlider" Property="IsEnabled" Value="False"/>
					<Setter TargetName="CameraXSlider" Property="IsEnabled" Value="False"/>
					<Setter TargetName="CameraYSlider" Property="IsEnabled" Value="False"/>
					<Setter TargetName="CameraZSlider" Property="IsEnabled" Value="False"/>
					<Setter TargetName="SaveCameraTransform" Property="IsEnabled" Value="False"/>
					<Setter TargetName="RecallCameraTransform" Property="IsEnabled" Value="False"/>
					<Setter TargetName="ReticleToggle" Property="IsEnabled" Value="False"/>
				    <Setter TargetName="CompositionGridToggle" Property="IsEnabled" Value="False"/>

					<!-- Disable Scene Settings Tab-->
					<Setter TargetName="PlayingVisibilityCheckbox" Property="IsEnabled" Value="False"/>
					<Setter TargetName="PartyVisibilityCheckbox" Property="IsEnabled" Value="False"/>
					<Setter TargetName="NPCVisibilityCheckbox" Property="IsEnabled" Value="False"/>
					<Setter TargetName="EnemyVisibilityCheckbox" Property="IsEnabled" Value="False"/>
				</DataTrigger>

                <DataTrigger Binding="{Binding CurrentStickers.Count, Converter={StaticResource LessThanConverter}, ConverterParameter={StaticResource StickerLimit}}" Value="False">
                    <Setter TargetName="OpenStickerPanel" Property="IsEnabled" Value="False" />
                    <Setter TargetName="AddStickerButton" Property="IsEnabled" Value="False" />
                </DataTrigger>

                <DataTrigger Binding="{Binding SelectedDOFFocusType}" Value="Manual">
                    <Setter TargetName="SelectedDOFTypeComboBox" Property="Text" Value="{Binding Source='hb2f11588g4f6fg45d7g9b62g16ad54be1d15', Converter={StaticResource TranslatedStringConverter}, Mode=OneWay}"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </ls:UIWidget.Template>

</ls:UIWidget>