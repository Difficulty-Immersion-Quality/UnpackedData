                                                        <Slider x:Name="StickerSizeSlider" Style="{StaticResource PhotoModeSliderLeftBarStyle}" Value="{Binding Size}" Minimum="0.1" Maximum="1" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" LargeChange="0.01"/>
