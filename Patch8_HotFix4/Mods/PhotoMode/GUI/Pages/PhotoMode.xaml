                                            <TextBlock Text="{Binding Source='hbb581a4ag924eg4c75gb899gc8393879db69', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                        </ls:LSCheckBox>
