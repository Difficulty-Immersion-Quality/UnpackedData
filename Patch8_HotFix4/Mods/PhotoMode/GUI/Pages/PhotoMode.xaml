                                        </ls:LSCheckBox>
										<ls:LSCheckBox x:Name="PartyVisibilityCheckbox" Style="{StaticResource PhotoModeTickBoxStyle}" Grid.Column="1" IsChecked="{Binding PartyVisibility}" Command="{Binding UpdatePartyVisibility}" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Source='h5d99de50g3440g44d3g8a93g7c4eb7333ca7', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                        </ls:LSCheckBox>
