                                                                                <b:Interaction.Behaviors>
                                                                                    <b:ConditionBehavior>
                                                                                        <b:ConditionalExpression>
                                                                                            <b:ComparisonCondition LeftOperand="{TemplateBinding IsSelected}" Operator="NotEqual" RightOperand="True"/>
                                                                                        </b:ConditionalExpression>
                                                                                    </b:ConditionBehavior>
                                                                                </b:Interaction.Behaviors>
                                                                                <ls:LSPlaySound Sound="UI_Shared_Panel_Select"/>
                                                                            </b:EventTrigger>
                                                                        </b:Interaction.Triggers>
                                                                        <Image x:Name="Bg" Source="{StaticResource StickerBackground}" Stretch="None"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
