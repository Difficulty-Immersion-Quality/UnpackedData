                                                                                <TextBlock Name="ComboBoxListLabel" Text="{Binding Name}" Foreground="{StaticResource LS_accent75TxtColor}" Background="Transparent" FontSize="{StaticResource ScaledMediumFontSize}" Padding="16,4" TextTrimming="CharacterEllipsis"/>
