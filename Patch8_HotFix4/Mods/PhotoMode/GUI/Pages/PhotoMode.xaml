                                                                <TextBlock Text="{Binding Source='hbc639ea5g7859g460fgb79bg7742537abc98', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="10,0,0,0"/>
                                                            </ls:LSCheckBox>
                                                        </StackPanel>
                                                    </Grid>
                                                </ls:LSNineSliceImage>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>

                                    <!-- STICKER SELECTION PANEL -->
                                    <ls:LSNineSliceImage x:Name="StickerPanel" Visibility="Collapsed" Style="{StaticResource StickerPanelBG}" VerticalAlignment="Stretch" HorizontalAlignment="Center" Grid.Row="0" Grid.RowSpan="3" Width="1200" Margin="-100,-80,-100,-100">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="120"/>
                                                <RowDefinition Height="966"/>
                                                <RowDefinition Height="160"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Source='h78cd4ca8ga3eag4cabgb8abga60c24f907e2', Converter={StaticResource TranslatedStringConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <ls:LSButton x:Name="StickerPanelCloseButton" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource SmallCloseButton}" Margin="0,0,30,0">
                                                <b:Interaction.Triggers>
