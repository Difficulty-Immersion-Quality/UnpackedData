                                                </DockPanel>

                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedEmoteCollection.EmoteList.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True">
