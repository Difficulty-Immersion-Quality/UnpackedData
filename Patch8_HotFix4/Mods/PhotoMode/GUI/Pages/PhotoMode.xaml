                                                        <Slider x:Name="CharOffsetYSlider" Style="{StaticResource PhotoModeSliderCenterBarStyle}" Value="{Binding CharacterOffsetY}" SmallChange="0.02" LargeChange="0.02" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"  Minimum="-2" Maximum="2">
                                                            <b:Interaction.Triggers>
