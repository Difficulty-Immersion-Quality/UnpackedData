                                                            <TextBlock Text="{Binding Source='ha62611f4g20adg42a0g92e0g360ec0cc2c46', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="12,0"/>
                                                        </ls:LSCheckBox>
