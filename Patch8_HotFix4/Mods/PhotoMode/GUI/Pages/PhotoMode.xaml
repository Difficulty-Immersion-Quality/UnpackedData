                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>
                                        </Slider>
                                        <TextBlock Width="{StaticResource ValueTextWidth}" Grid.Row="3" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}" Text="{Binding Value, ElementName=DOFDistance, Converter={StaticResource UnitConverter}, ConverterParameter='Distance N2 Short'}"/>

                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!--===== ACTORS TAB =====-->
                        <TabItem x:Name="ActorTab">
