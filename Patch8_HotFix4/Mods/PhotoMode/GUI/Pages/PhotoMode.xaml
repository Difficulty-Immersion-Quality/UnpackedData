                                        <TextBlock Text="{Binding Source='h4f7c8e05g99b1g4249g9589g9d493a8a6aeb', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                        <ls:LSComboBox x:Name="FocusActorComboBox"
