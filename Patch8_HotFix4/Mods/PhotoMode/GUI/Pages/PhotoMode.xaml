                                                            <TextBlock Text="{Binding Source='h38354ddfg9f5cg48bbg8edag6f09d3ea8c47', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="12,0"/>
                                                        </ls:LSCheckBox>
