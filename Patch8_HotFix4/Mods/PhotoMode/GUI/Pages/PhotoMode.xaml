                                                <b:EventTrigger EventName="SelectionChanged">
                                                    <b:InvokeCommandAction Command="{Binding UpdateDoF }"/>
                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>
                                        </ls:LSComboBox>
                                        <!-- strength -->
                                        <Path VerticalAlignment="Center" HorizontalAlignment="Left" Style="{StaticResource TreeNodeStyle}" Grid.Row="2" Grid.Column="0"/>
                                        <TextBlock Text="{Binding Source='h5f4b4474gec8fg4135g80abg4585450c6900', Converter={StaticResource TranslatedStringConverter}}" Grid.Row="2" Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                        <Slider x:Name="DOFStrength" Style="{StaticResource PhotoModeSliderLeftBarStyle}" Value="{Binding DOFStrength}" SmallChange="0.2" LargeChange="0.2" Minimum="1" Maximum="22" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" >
                                            <b:Interaction.Triggers>
                                                <b:EventTrigger EventName="ValueChanged">
                                                    <b:InvokeCommandAction Command="{Binding UpdateDoF }"/>
                                                </b:EventTrigger>
                                            </b:Interaction.Triggers>
