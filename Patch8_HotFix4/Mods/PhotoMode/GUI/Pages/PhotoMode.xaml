                                        <TextBlock Width="{StaticResource ValueTextWidth}" Grid.Row="2" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource ValueTextStyle}">
                                            <Run Text="f/"/>
                                            <Run Text="{Binding Value, ElementName=DOFStrength, StringFormat={}{0:N1}}"/>
                                        </TextBlock>
                                    
                                        <!-- distance -->
                                        <Path VerticalAlignment="Center" HorizontalAlignment="Left" Style="{StaticResource TreeNodeStyle}"  Grid.Row="3" Grid.Column="0"/>
                                        <TextBlock Text="{Binding Source='h97e57dd7g6836g4e7dga9feg6952efff414d', Converter={StaticResource TranslatedStringConverter}, Mode=OneWay}" Grid.Row="3" Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}"/>
                                        <Slider x:Name="DOFDistance" Style="{StaticResource PhotoModeSliderStyle}" Value="{Binding DOFDistance, StringFormat={}{0:N0}}" SmallChange="0.01" LargeChange="0.01" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Minimum="0" Maximum="30" >
