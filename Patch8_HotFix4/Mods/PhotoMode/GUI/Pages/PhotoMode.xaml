                                                                                <TextBlock Name="ComboBoxListLabel" Text="{Binding DisplayName}" Foreground="{StaticResource LS_accent75TxtColor}" Background="Transparent" FontSize="{StaticResource ScaledMediumFontSize}" Padding="16,4" TextTrimming="CharacterEllipsis"/>
