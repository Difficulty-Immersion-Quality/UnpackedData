                                                        <Slider x:Name="StickerOpacitySlider" Style="{StaticResource PhotoModeSliderLeftBarStyle}" Value="{Binding Opacity}" Minimum="0" Maximum="1" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" LargeChange="0.01"/>
