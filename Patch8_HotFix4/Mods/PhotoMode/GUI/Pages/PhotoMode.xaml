                                                        <Setter TargetName="PoseCollectionTag" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
													<DataTrigger Binding="{Binding SelectedFaceExpressionCollection.FaceExpressionList.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}" Value="True">
														<Setter TargetName="FaceExpressionVariantSelector" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="ExpressionCollectionTag" Property="Visibility" Value="Visible"/>
													</DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SelectedEmoteCollection.EmoteList.Count}" Value="1"/>
                                                            <Condition Binding="{Binding SelectedEmoteCollection.EmoteList[0], Converter={StaticResource TypeConverter}}" Value="ls.VMAnimation"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="AnimationTimingSelector" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="PlayAnimationButton" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="LoopAnimationButton" Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedEmote, Converter={StaticResource TypeConverter}}" Value="ls.VMAnimation">
                                                        <Setter TargetName="AnimationTimingSelector" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="PlayAnimationButton" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="LoopAnimationButton" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>

													<!--Disable all fields that are not modifiable during a timeline-->
                                                    <DataTrigger Binding="{Binding DataContext.Mode, ElementName=PhotoMode}" Value ="Timeline">
														<Setter TargetName="FaceExpressionVariantSelector" Property="IsEnabled" Value="False"/>
														<Setter TargetName="DummyLookAtCheckBox" Property="IsEnabled" Value="False"/>
														<Setter TargetName="Poses" Property="IsEnabled" Value="False"/>
														<Setter TargetName="VariantSelector" Property="IsEnabled" Value="False"/>
														<Setter TargetName="TranslateSettings" Property="IsEnabled" Value="False"/>
														<Setter TargetName="ShowCharacter" Property="IsEnabled" Value="False"/>
														<Setter TargetName="ShowBattleDamage" Property="IsEnabled" Value="False"/>
														<Setter TargetName="ShowHelmet" Property="IsEnabled" Value="False"/>
														<Setter TargetName="ShowWeapons" Property="IsEnabled" Value="False"/>
														<Setter TargetName="ShowInstrument" Property="IsEnabled" Value="False"/>
														<Setter TargetName="ShowCampClothes" Property="IsEnabled" Value="False"/>
													</DataTrigger>

                                                    <DataTrigger Binding="{Binding CharacterVisibility}" Value="False">
                                                        <Setter TargetName="ShowCharacterSettings" Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
