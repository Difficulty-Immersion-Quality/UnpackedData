                                                                    <b:ChangePropertyAction PropertyName="SelectedFaceExpression" TargetObject="{Binding }" Value="{Binding SelectedFaceExpressionCollection.FaceExpressionList[0]}" />
                                                                </b:DataTrigger>
                                                                <b:PropertyChangedTrigger Binding="{Binding SelectedFaceExpressionCollection}">
                                                                    <b:Interaction.Behaviors>
                                                                        <b:ConditionBehavior>
                                                                            <b:ConditionalExpression>
                                                                                <b:ComparisonCondition LeftOperand="{Binding SelectedFaceExpressionCollection.FaceExpressionList.Count}" Operator="NotEqual" RightOperand="0"/>
                                                                            </b:ConditionalExpression>
                                                                        </b:ConditionBehavior>
                                                                    </b:Interaction.Behaviors>
                                                                    <b:ChangePropertyAction PropertyName="SelectedFaceExpression" TargetObject="{Binding }" Value="{Binding SelectedFaceExpressionCollection.FaceExpressionList[0]}" />
                                                                </b:PropertyChangedTrigger>
                                                                <b:EventTrigger EventName="SelectionChanged">
                                                                    <b:InvokeCommandAction Command="{Binding DataContext.UpdateAnimationState, ElementName=PhotoMode }"/>
                                                                </b:EventTrigger>
                                                            </b:Interaction.Triggers>
                                                            <ls:LSComboBox.ItemContainerStyle>
                                                                <Style BasedOn="{StaticResource PhotoModeComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
                                                                    <Setter Property="ContentTemplate">
