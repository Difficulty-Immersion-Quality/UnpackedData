                                                            <TextBlock Text="{Binding Source='h1770a770gde53g4611g9d22g0b11144e785a', Converter={StaticResource TranslatedStringConverter}}" VerticalAlignment="Center" Style="{StaticResource LabelTextStyle}" Margin="12,0"/>
