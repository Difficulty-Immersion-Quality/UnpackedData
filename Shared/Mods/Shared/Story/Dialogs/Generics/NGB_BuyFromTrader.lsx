	<region id="editorData">
		<node id="editorData">
			<attribute id="HowToTrigger" type="LSString" value="Go to S_GOB_Festivities_Trader (goblin camp, across the central festivities area from the entrance to the king's hall), and pick up any of the items in his stall. The item will be added to his inventory (if you can buy it) and this dialogue will trigger. Same with the hag trader and cook in the Grove." />
			<attribute id="needLayout" type="bool" value="False" />
			<attribute id="nextNodeId" type="uint32" value="25" />
			<attribute id="synopsis" type="LSString" value="|A player picks up an item owned by an NPC that's tagged as TRADER, from within their shop's ownership trigger. If the shopkeeper notices this, they'll ask whether you want to buy it (through this dialogue) rather than trigger a steal crime. -- This dialogue can also be triggered for silenced players, so write the player responses in terms of nodding/indicating agreement rather than explicit talking.|" />
			<children>
				<node id="defaultAttitudes">
					<children>
						<node id="data">
							<attribute id="key" type="FixedString" value="0" />
							<attribute id="val" type="LSString" value="Neutral" />
